---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FaqSection from '../components/FaqSection.astro';
import SectionHeader from '../components/SectionHeader.astro';

const title = "Nosotros | REDEIL - 30 Años de Experiencia en Iluminación para Eventos";
const description = "REDEIL: más de 30 años en renta de iluminación profesional en CDMX. Conoce nuestra historia, misión y más de 3,000 eventos realizados en Ciudad de México.";
const canonical = "https://rentadeiluminacion.com/nosotros/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "Nosotros — REDEIL",
  "description": "REDEIL es la empresa líder en renta de iluminación profesional para eventos en CDMX con más de 30 años de experiencia.",
  "url": "https://rentadeiluminacion.com/nosotros/",
  "mainEntity": {
    "@type": "LocalBusiness",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com",
    "telephone": "+525530682988",
    "email": "hola@rentadeiluminacion.com",
    "foundingDate": "1994",
    "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" },
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ]
  }
});
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

  <Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Nosotros" }]} />
</Fragment>
<section class="hero hero-two-columns">
      <div class="hero-background" style="background-color: var(--color-secondary);"></div>
      <div class="container">
        <div class="hero-grid">
          <div class="hero-content">
            <h1 class="hero-title">Más de 30 Años Iluminando Momentos Inolvidables</h1>
            <p class="hero-subtitle">Líderes en renta de iluminación profesional para eventos en la Ciudad de México y zona metropolitana</p>
            <div class="hero-ctas">
              <a href="/contacto/" class="btn btn-primary btn-lg">Cotizar Ahora</a>
              <a href="https://wa.me/525530682988?text=Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20evento" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp btn-lg">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>
          <div class="hero-intro">
            <p>Desde <strong>1994</strong>, REDEIL ha iluminado eventos en toda la Ciudad de México y Estado de México. Con más de <strong>3,000 eventos realizados</strong>, incluyendo <strong>+800 bodas</strong> y <strong>+500 fiestas de XV años</strong>, somos el proveedor técnico en quien confían wedding planners, coordinadoras y productoras de la zona metropolitana. Trabajamos con equipo profesional de <strong>Martin Professional, Chauvet, Elation, JBL y QSC</strong>.</p>
            <p>Empezamos como empresa familiar en Benito Juárez y seguimos siendo la misma empresa de siempre: los mismos valores, el mismo cuidado por los detalles. Lo que cambió es el equipo — hoy contamos con las luminarias LED y los sistemas de audio más avanzados del mercado, los mismos que se usan en conciertos y producciones de televisión.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="stats-section-enhanced">
      <div class="container">
        <div class="stats-grid-enhanced">
          <div class="stat-card-enhanced">
            <span class="stat-number-enhanced">30+</span>
            <span class="stat-label-enhanced">Años de Experiencia</span>
          </div>
          <div class="stat-card-enhanced">
            <span class="stat-number-enhanced">3,000+</span>
            <span class="stat-label-enhanced">Eventos Realizados</span>
          </div>
          <div class="stat-card-enhanced">
            <span class="stat-number-enhanced">800+</span>
            <span class="stat-label-enhanced">Bodas Iluminadas</span>
          </div>
          <div class="stat-card-enhanced">
            <span class="stat-number-enhanced">CDMX + Edomex</span>
            <span class="stat-label-enhanced">Cobertura Total</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="section" style="background-color: var(--color-gray-100);">
      <div class="container">
        <div class="section-header">
          <h2>Nuestra Historia</h2>
          <p>Tres décadas de evolución e innovación en iluminación para eventos</p>
        </div>
        <div class="timeline">

          <div class="timeline-item">
            <div class="timeline-marker">
              <span class="timeline-year">1994</span>
            </div>
            <div class="timeline-content">
              <h3>Fundación</h3>
              <p>REDEIL nace como una empresa familiar dedicada a la renta de iluminación para eventos sociales en la Ciudad de México. Con un pequeño inventario de luminarias convencionales, comenzamos a iluminar bodas y celebraciones en las colonias Nápoles y Del Valle.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker">
              <span class="timeline-year">2000</span>
            </div>
            <div class="timeline-content">
              <h3>Expansión</h3>
              <p>Ampliamos nuestra cobertura al Estado de México y abrimos nuestra segunda sucursal en Polanco. Incorporamos equipos de sonido profesional y efectos especiales a nuestro catálogo, convirtiéndonos en un proveedor integral para eventos.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker">
              <span class="timeline-year">2010</span>
            </div>
            <div class="timeline-content">
              <h3>Era LED</h3>
              <p>Adoptamos la tecnología LED de última generación, renovando todo nuestro inventario con equipos de marcas líderes como Martin Professional, Chauvet y Elation. Esta transición nos permitió ofrecer mayor variedad de colores, menor consumo energético y efectos más espectaculares.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker">
              <span class="timeline-year">2020</span>
            </div>
            <div class="timeline-content">
              <h3>Presente</h3>
              <p>Con más de 3,000 eventos realizados — incluyendo +800 bodas y +500 fiestas de XV años — REDEIL sigue siendo la referencia en renta de iluminación para eventos en CDMX y Estado de México. Seguimos renovando el inventario con equipo de marcas como Martin Professional, Chauvet, Elation, JBL y QSC.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Misión, Visión, Propósito -->
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>Misión, Visión y Propósito</h2>
          <p>Los valores que nos guían en cada evento</p>
        </div>
        <div class="services-grid">

          <div class="service-card">
            <div class="service-card-content">
              <h3>Nuestra Misión</h3>
              <p>Brindar servicios de iluminación profesional de la más alta calidad para eventos, superando las expectativas de nuestros clientes a través de equipos de vanguardia, personal capacitado y un servicio integral que incluye transporte, instalación y operación.</p>
            </div>
          </div>

          <div class="service-card">
            <div class="service-card-content">
              <h3>Nuestra Visión</h3>
              <p>Ser la empresa líder y más reconocida en renta de iluminación para eventos en México, expandiendo nuestra presencia a nivel nacional mientras mantenemos los estándares de calidad y servicio personalizado que nos caracterizan.</p>
            </div>
          </div>

          <div class="service-card">
            <div class="service-card-content">
              <h3>Nuestro Propósito</h3>
              <p>Transformar espacios ordinarios en escenarios extraordinarios. Creemos que la iluminación tiene el poder de crear emociones, evocar sentimientos y hacer que cada evento sea un momento único e irrepetible para quienes lo viven.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Proceso de trabajo -->
    <section class="section" style="background-color: var(--color-gray-100);">
      <div class="container">
        <div class="section-header">
          <h2>Cómo Trabajamos</h2>
          <p>Del primer contacto al desmontaje final: así es nuestro proceso</p>
        </div>
        <div class="services-grid">
          <div class="service-card">
            <div class="service-card-content">
              <h3>1. Cotización</h3>
              <p>Nos compartes la fecha, el venue y el tipo de evento. Te respondemos con una propuesta en menos de 24 horas. Para proyectos grandes hacemos visita previa al venue sin costo adicional.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="service-card-content">
              <h3>2. Diseño</h3>
              <p>Con los detalles del venue, diseñamos el esquema de iluminación: dónde va cada luminaria, qué colores, qué efectos y cuándo se activa cada uno. Coordinamos con el wedding planner, DJ o coordinador del evento.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="service-card-content">
              <h3>3. Montaje</h3>
              <p>El equipo técnico llega al venue 4–6 horas antes del evento. Instalamos el equipo, hacemos las pruebas necesarias y coordinamos con el personal del salón para que todo esté listo antes de que llegue el primer invitado.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="service-card-content">
              <h3>4. Operación</h3>
              <p>Nuestros técnicos permanecen en el evento durante toda la celebración. Operan el seguidor, activan el humo bajo en el vals, lanzan el confeti en el brindis y manejan las cabezas móviles en la pista de baile.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="service-card-content">
              <h3>5. Desmontaje</h3>
              <p>Al terminar el evento, el equipo desmonta y retira todo el material. El venue queda exactamente como lo encontramos. No dejamos rastro — solo los recuerdos del evento.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="service-card-content">
              <h3>Un Solo Equipo, Todo el Evento</h3>
              <p>Cuando contratas iluminación y audio con REDEIL, un solo equipo técnico maneja todo. Sin coordinar a múltiples proveedores, sin malentendidos de tiempos. Un interlocutor, una cotización, un equipo.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Marcas -->
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>Equipo de Marcas Líderes</h2>
          <p>El mismo equipo que se usa en conciertos y producciones de televisión</p>
        </div>
        <div class="services-grid">
          <div class="service-card">
            <div class="service-card-content">
              <h3>Martin Professional</h3>
              <p>Marca de referencia mundial en iluminación de espectáculos. Sus cabezas móviles y efectos son los más usados en conciertos, festivales y bodas de primer nivel en todo el mundo.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="service-card-content">
              <h3>Chauvet Professional</h3>
              <p>Líder en iluminación LED para eventos. Sus par LED RGBW, wash y beam son confiables, eficientes y ofrecen colores precisos y saturados para cualquier tipo de evento.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="service-card-content">
              <h3>Elation Professional</h3>
              <p>Cabezas móviles, efectos y sistemas de control de alta gama. Elation es la marca favorita de los técnicos profesionales por su durabilidad y precisión en entornos exigentes.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="service-card-content">
              <h3>JBL Professional</h3>
              <p>Bocinas de referencia en el mundo del audio profesional. El sistema de sonido que eliges cuando el audio realmente importa — desde el vals hasta la hora loca.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="service-card-content">
              <h3>QSC Audio</h3>
              <p>Amplificadores y sistemas de procesamiento de audio de alta fidelidad. La potencia que garantiza que el sonido llegue con claridad a cada rincón del salón, sin distorsión.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="service-card-content">
              <h3>Shure</h3>
              <p>Micrófonos e inalámbricos de confianza para bodas, corporativos y XV años. Sus micrófonos de mano y de solapa son el estándar de la industria en captación de voz.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre REDEIL"
          subtitle="Lo que los clientes nos preguntan sobre nuestra empresa y servicios."
          paragraph1="Si tienes otra duda, escríbenos por WhatsApp o llámanos al 55 3068 2988."
          paragraph2="30 años de experiencia en CDMX nos hacen el proveedor de confianza para más de 3,000 eventos realizados."
        />
      </div>
      <FaqSection items={[
        { question: "¿Cuántos años de experiencia tiene REDEIL?", answer: "REDEIL fue fundada en 1994 — llevamos más de 30 años en el sector de renta de iluminación y audio para eventos en CDMX y Estado de México. Hemos realizado más de 3,000 eventos de todos los tipos: bodas, XV años, corporativos, conciertos y más." },
        { question: "¿Dónde están ubicados?", answer: "Operamos desde Ciudad de México con cobertura completa en toda la CDMX y el Estado de México. Atendemos las 16 alcaldías y los principales municipios del Edomex incluyendo Naucalpan, Huixquilucan, Tlalnepantla, Atizapán, Toluca y Metepec." },
        { question: "¿Cuánto tiempo tarda una cotización?", answer: "Si nos contactas por WhatsApp durante horario de atención (Lun–Dom 8:00–18:00), respondemos en minutos. Para proyectos grandes que requieren visita previa al venue, el proceso de cotización formal toma 24–48 horas." },
        { question: "¿Trabajan con wedding planners y productoras de eventos?", answer: "Sí. Una parte importante de nuestra clientela son wedding planners, coordinadoras de eventos y productoras que nos incluyen como proveedor técnico en sus proyectos. Tenemos tarifas especiales para colaboradores frecuentes." },
        { question: "¿Qué marcas de equipo utilizan?", answer: "Trabajamos con Martin Professional, Chauvet, Elation, JBL, QSC y Shure — las marcas líderes en iluminación y audio profesional. El equipo que usamos en eventos de boda o corporativo es el mismo que se usa en conciertos y producciones de televisión." },
        { question: "¿Tienen seguro de responsabilidad civil?", answer: "Sí. REDEIL cuenta con póliza de seguro de responsabilidad civil para la operación de equipos en eventos. Podemos proporcionar carta de cobertura cuando el venue lo requiere como requisito para operar en sus instalaciones." },
      ]} />
    </section>

    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Listo para trabajar con REDEIL?</h2>
          <p>30 años de experiencia y más de 3,000 eventos nos respaldan. Cuéntanos sobre tu evento y te cotizamos en minutos.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>
</BaseLayout>
