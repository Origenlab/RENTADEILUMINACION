---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import BlogSidebar from '../../../components/BlogSidebar.astro';
import Hero from '../../../components/Hero.astro';
import {
  blogArticles,
  buildCategories,
  getPopularArticles,
  getPageArticles,
  getTotalPages,
} from '../../../data/blog-articles';

export async function getStaticPaths() {
  const totalPages = getTotalPages();
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const { page: pageParam } = Astro.params;
const currentPage = Number(pageParam);
const totalPages = getTotalPages();

if (currentPage === 1) {
  return Astro.redirect('/blog/', 301);
}

if (currentPage < 1 || currentPage > totalPages || isNaN(currentPage)) {
  return Astro.redirect('/blog/', 301);
}

const pageArticles = getPageArticles(currentPage);
const categories = buildCategories();
const popularArticles = getPopularArticles();

const totalArticles = blogArticles.length;

const catMap = new Map<string, number>();
blogArticles.forEach(a => {
  catMap.set(a.category, (catMap.get(a.category) || 0) + 1);
});

const categoryOrder = ["Bodas", "XV Años", "Iluminación", "Sonido", "Audio", "DJ", "Guirnaldas", "Luces Neón", "Efectos", "Equipos", "Corporativo", "Comparativas", "Paquetes", "Temporadas", "Zonas", "Guía"];

const slugify = (s: string) =>
  s.toLowerCase()
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '')
    .replace(/\s+/g, '-');

const title = `Blog REDEIL — Página ${currentPage} de ${totalPages} | Iluminación CDMX`;
const description = `Más artículos sobre iluminación, sonido y efectos para eventos en CDMX. Página ${currentPage} de ${totalPages} del blog editorial REDEIL.`;
const canonical = `https://rentadeiluminacion.com/blog/pagina/${currentPage}/`;

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog REDEIL — Iluminación para Eventos CDMX",
  "description": description,
  "url": canonical,
  "publisher": {
    "@type": "Organization",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com"
  }
});

const readTime = (s: string) => Math.max(4, Math.min(9, Math.ceil(s.length / 35)));
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[
      { label: "Inicio", href: "/" },
      { label: "Blog", href: "/blog/" },
      { label: `Página ${currentPage}` }
    ]} />
  </Fragment>

  {/* ──── HERO ──── */}
  <Hero
    title={`Blog de Iluminación — Página ${currentPage}`}
    subtitle={`Más guías editoriales de nuestro equipo técnico. Página ${currentPage} de ${totalPages}.`}
    hideCtas={true}
    stats={[
      { value: `${totalArticles}+`, label: "Artículos publicados" },
      { value: `${currentPage}/${totalPages}`, label: "Página actual" },
      { value: "+30", label: "Años de experiencia" },
      { value: "CDMX", label: "Y zona metropolitana" }
    ]}
    introParagraph1='Continúa explorando nuestro archivo editorial: <strong>precios reales, comparativas técnicas y casos resueltos</strong> por nuestro equipo en CDMX y Zona Metropolitana.'
    introParagraph2='Cada artículo está escrito con base en montajes reales — sin tecnicismos innecesarios, con datos del campo y experiencia en cientos de bodas, XV años y eventos corporativos.'
  />

  {/* ──── PILLS DE CATEGORÍAS ──── */}
  <section class="blog-filters" aria-label="Filtrar por categoría">
    <div class="container">
      <div class="bf-pills">
        <a href="/blog/" class="bf-pill">
          Todos <span class="bf-pill__count">{totalArticles}</span>
        </a>
        {categoryOrder.filter(c => catMap.has(c)).map(cat => (
          <a href={`/blog/?cat=${slugify(cat)}`} class="bf-pill">
            {cat} <span class="bf-pill__count">{catMap.get(cat)}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ──── GRID + SIDEBAR ──── */}
  <section class="blog-main">
    <div class="container blog-main__layout">
      <div class="blog-main__content">
        <div class="blog-section-head">
          <h2 class="blog-section-head__title">Artículos en esta página</h2>
          <p class="blog-section-head__sub">Página {currentPage} de {totalPages} · {pageArticles.length} guías editoriales</p>
        </div>

        <div class="blog-grid">
          {pageArticles.map(article => (
            <article class="bc">
              <a href={`/blog/${article.slug}/`} class="bc__img-link">
                <div class="bc__img">
                  <img src={article.img} alt={article.title} loading="lazy" width="600" height="338" />
                  <span class="bc__cat">{article.category}</span>
                </div>
              </a>
              <div class="bc__body">
                <div class="bc__meta">
                  <span class="bc__read">{readTime(article.excerpt)} min</span>
                  <span class="bc__sep" aria-hidden="true">·</span>
                  <span class="bc__by">REDEIL</span>
                </div>
                <h3 class="bc__title">
                  <a href={`/blog/${article.slug}/`}>{article.title}</a>
                </h3>
                <p class="bc__desc">{article.excerpt}</p>
                <a href={`/blog/${article.slug}/`} class="bc__link">
                  Leer artículo
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>

        {/* Paginación */}
        <nav class="pagination" aria-label="Páginas del blog">
          {currentPage > 1 && (
            <a
              href={currentPage === 2 ? '/blog/' : `/blog/pagina/${currentPage - 1}/`}
              class="pagination__prev"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
              Anterior
            </a>
          )}

          <div class="pagination__pages">
            <a href="/blog/" class="pagination__page">1</a>
            {Array.from({ length: totalPages - 1 }, (_, i) => i + 2).map(p => (
              <a
                href={`/blog/pagina/${p}/`}
                class={`pagination__page${p === currentPage ? ' pagination__page--active' : ''}`}
                aria-current={p === currentPage ? 'page' : undefined}
              >{p}</a>
            ))}
          </div>

          {currentPage < totalPages && (
            <a href={`/blog/pagina/${currentPage + 1}/`} class="pagination__next">
              Siguiente
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          )}
        </nav>
      </div>

      <aside class="blog-main__sidebar">
        <BlogSidebar
          categories={categories}
          popularArticles={popularArticles}
        />
      </aside>
    </div>
  </section>

  {/* ──── CTA FINAL ──── */}
  <section class="blog-cta-final">
    <div class="container blog-cta-final__inner">
      <div class="blog-cta-final__badge">REDEIL · Producción integral</div>
      <h2>¿No encuentras la respuesta a tu evento?</h2>
      <p>Cuéntanos qué venue, cuántos invitados y qué fecha. Te respondemos con un plan técnico y un estimado real en menos de 1 hora.</p>
      <div class="blog-cta-final__btns">
        <a href="/contacto/" class="btn btn-primary btn-lg">Cotizar Gratis →</a>
        <a href="https://wa.me/5215530682988?text=Hola%20REDEIL%2C%20tengo%20una%20pregunta%20sobre%20iluminaci%C3%B3n." target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-lg">WhatsApp directo</a>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
