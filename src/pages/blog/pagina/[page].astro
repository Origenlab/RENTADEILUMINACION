---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import BlogSidebar from '../../../components/BlogSidebar.astro';
import {
  blogArticles,
  buildCategories,
  getPopularArticles,
  getPageArticles,
  getTotalPages,
  ARTICLES_PER_PAGE,
} from '../../../data/blog-articles';

export async function getStaticPaths() {
  const totalPages = getTotalPages();
  // Pages 2..N (page 1 is /blog/)
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const { page: pageParam } = Astro.params;
const currentPage = Number(pageParam);
const totalPages = getTotalPages();

// Redirect to /blog/ if page 1 is requested
if (currentPage === 1) {
  return Astro.redirect('/blog/', 301);
}

if (currentPage < 1 || currentPage > totalPages || isNaN(currentPage)) {
  return Astro.redirect('/blog/', 301);
}

const pageArticles = getPageArticles(currentPage);
const categories = buildCategories();
const popularArticles = getPopularArticles();

const catMap = new Map<string, number>();
blogArticles.forEach(a => {
  catMap.set(a.category, (catMap.get(a.category) || 0) + 1);
});

const categoryOrder = ["Bodas", "XV Años", "Guirnaldas", "Luces Neón", "Equipos", "Efectos", "Sonido", "Corporativo", "Guía", "Comparativas", "Paquetes", "Temporadas", "Zonas"];

const ctaBarItems = categories.map(cat => ({
  label: cat.name,
  href: `/blog/?cat=${cat.slug}`,
}));

const title = `Blog de Iluminación — Página ${currentPage} | REDEIL CDMX`;
const description = `Artículos de iluminación para eventos: guías, precios y consejos. Página ${currentPage} de ${totalPages}.`;
const canonical = `https://rentadeiluminacion.com/blog/pagina/${currentPage}/`;

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog de Iluminación para Eventos — REDEIL",
  "description": description,
  "url": canonical,
  "publisher": {
    "@type": "Organization",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com"
  }
});
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[
      { label: "Inicio", href: "/" },
      { label: "Blog", href: "/blog/" },
      { label: `Página ${currentPage}` }
    ]} />
  </Fragment>

  <Hero
    title="Blog de Iluminación para Eventos"
    subtitle="Guías prácticas, precios reales y consejos de nuestro equipo técnico con más de 30 años de experiencia."
    introParagraph1="En REDEIL compartimos más de 30 años de experiencia en iluminación para eventos. Cada artículo está escrito por nuestro equipo técnico con base en situaciones reales de bodas, XV años y corporativos en CDMX y Zona Metropolitana."
    introParagraph2="Encontrarás información concreta sobre precios, metros de guirnaldas, diferencias entre equipos, efectos especiales y todo lo que necesitas saber para tomar la mejor decisión para tu evento. Sin tecnicismos innecesarios, con datos reales."
  />

  <CtaBar
    headline="Explora por categoría"
    items={ctaBarItems}
  />

  {/* ──── PILLS DE CATEGORÍAS ──── */}
  <section class="blog-filters">
    <div class="container">
      <div class="bf-pills">
        <a href="/blog/" class="bf-pill">Todos</a>
        {categoryOrder.filter(c => catMap.has(c)).map(cat => (
          <a href={`/blog/`} class="bf-pill">{cat} <span class="bf-pill__count">{catMap.get(cat)}</span></a>
        ))}
      </div>
    </div>
  </section>

  {/* ──── GRID + SIDEBAR ──── */}
  <section class="blog-main">
    <div class="container blog-main__layout">
      <div class="blog-main__content">
        <div class="blog-grid">
          {pageArticles.map(article => (
            <article class="bc">
              <a href={`/blog/${article.slug}/`} class="bc__img-link">
                <div class="bc__img">
                  <img src={article.img} alt={article.title} loading="lazy" width="600" height="338" />
                  <span class="bc__cat">{article.category}</span>
                </div>
              </a>
              <div class="bc__body">
                <h2 class="bc__title">
                  <a href={`/blog/${article.slug}/`}>{article.title}</a>
                </h2>
                <p class="bc__desc">{article.excerpt}</p>
                <a href={`/blog/${article.slug}/`} class="bc__link">
                  Leer artículo <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>

        {/* ──── PAGINACIÓN ──── */}
        <nav class="pagination" aria-label="Páginas del blog">
          {currentPage > 1 && (
            <a
              href={currentPage === 2 ? '/blog/' : `/blog/pagina/${currentPage - 1}/`}
              class="pagination__prev"
            >« Anterior</a>
          )}

          <div class="pagination__pages">
            <a href="/blog/" class="pagination__page">1</a>
            {Array.from({ length: totalPages - 1 }, (_, i) => i + 2).map(p => (
              <a
                href={`/blog/pagina/${p}/`}
                class={`pagination__page${p === currentPage ? ' pagination__page--active' : ''}`}
                aria-current={p === currentPage ? 'page' : undefined}
              >{p}</a>
            ))}
          </div>

          {currentPage < totalPages && (
            <a href={`/blog/pagina/${currentPage + 1}/`} class="pagination__next">Siguiente »</a>
          )}
        </nav>
      </div>

      <aside class="blog-main__sidebar">
        <BlogSidebar
          categories={categories}
          popularArticles={popularArticles}
        />
      </aside>
    </div>
  </section>

  {/* ──── CTA FINAL ──── */}
  <section class="blog-cta-final">
    <div class="container blog-cta-final__inner">
      <h2>¿No encuentras lo que buscas?</h2>
      <p>Nuestro equipo técnico tiene la respuesta. Cotiza sin compromiso o pregúntanos directamente por WhatsApp.</p>
      <div class="blog-cta-final__btns">
        <a href="/contacto/" class="btn btn-primary btn-lg">Cotizar Gratis →</a>
        <a href="https://wa.me/5215530682988?text=Hola%20REDEIL%2C%20tengo%20una%20pregunta%20sobre%20iluminación." target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-lg">WhatsApp</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ──────────────────────────────────────────
     CATEGORY PILLS
     ────────────────────────────────────────── */
  .blog-filters {
    padding: 1.5rem 0;
    background: #fff;
    border-bottom: 1px solid #e9ecef;
    position: sticky;
    top: calc(36px + 70px);
    z-index: 50;
  }

  .bf-pills {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.25rem;
  }

  .bf-pills::-webkit-scrollbar {
    display: none;
  }

  .bf-pill {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 1rem;
    background: #f8f9fa;
    border: 1px solid #e9ecef;
    border-radius: 100px;
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 0.8125rem;
    font-weight: 500;
    color: #495057;
    text-decoration: none;
    white-space: nowrap;
  }

  .bf-pill:hover {
    border-color: var(--color-primary, #ff5722);
    color: var(--color-primary, #ff5722);
  }

  .bf-pill__count {
    font-size: 0.7rem;
    opacity: 0.7;
  }

  /* ──────────────────────────────────────────
     MAIN LAYOUT
     ────────────────────────────────────────── */
  .blog-main {
    padding: 3rem 0;
    background: #fff;
  }

  .blog-main__layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }

  .blog-main__sidebar {
    position: sticky;
    top: calc(36px + 70px + 60px + 1.5rem);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }

  /* ──────────────────────────────────────────
     BLOG CARDS
     ────────────────────────────────────────── */
  .bc {
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .bc__img-link {
    display: block;
    position: relative;
  }

  .bc__img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
  }

  .bc__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .bc__cat {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--color-primary, #ff5722);
    color: #fff;
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }

  .bc__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .bc__title {
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-secondary, #1a1a2e);
    margin: 0 0 0.625rem;
    line-height: 1.3;
  }

  .bc__title a {
    text-decoration: none;
    color: inherit;
  }

  .bc__title a:hover {
    color: var(--color-primary, #ff5722);
  }

  .bc__desc {
    font-size: 0.875rem;
    color: #6c757d;
    line-height: 1.65;
    flex: 1;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bc__link {
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-primary, #ff5722);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .bc__link:hover {
    color: #c44d00;
  }

  /* ──────────────────────────────────────────
     PAGINACIÓN
     ────────────────────────────────────────── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .pagination__prev,
  .pagination__next {
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary, #ff5722);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-primary, #ff5722);
    border-radius: 6px;
  }

  .pagination__prev:hover,
  .pagination__next:hover {
    background: var(--color-primary, #ff5722);
    color: #fff;
  }

  .pagination__pages {
    display: flex;
    gap: 0.35rem;
  }

  .pagination__page {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    border: 1px solid #dee2e6;
    border-radius: 6px;
    text-decoration: none;
    color: #495057;
  }

  .pagination__page--active {
    background: var(--color-primary, #ff5722);
    border-color: var(--color-primary, #ff5722);
    color: #fff;
  }

  .pagination__page:not(.pagination__page--active):hover {
    border-color: var(--color-primary, #ff5722);
    color: var(--color-primary, #ff5722);
  }

  /* ──────────────────────────────────────────
     CTA FINAL
     ────────────────────────────────────────── */
  .blog-cta-final {
    background: var(--color-primary, #ff5722);
    padding: 3.5rem 0;
  }

  .blog-cta-final__inner {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .blog-cta-final h2 {
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    color: #fff;
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin: 0 0 0.75rem;
  }

  .blog-cta-final p {
    color: rgba(255,255,255,0.9);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .blog-cta-final__btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .blog-cta-final .btn-primary {
    background: #fff;
    color: var(--color-primary, #ff5722);
    border-color: #fff;
    box-shadow: none;
  }

  .blog-cta-final .btn-primary:hover {
    background: #f0f0f0;
    color: #c44d00;
  }

  .blog-cta-final .btn-outline {
    background: transparent;
    color: #fff;
    border-color: rgba(255,255,255,0.5);
  }

  .blog-cta-final .btn-outline:hover {
    background: rgba(255,255,255,0.15);
    border-color: #fff;
    color: #fff;
  }

  /* ──────────────────────────────────────────
     RESPONSIVE
     ────────────────────────────────────────── */
  @media (max-width: 1200px) {
    .blog-main__layout {
      grid-template-columns: 1fr 280px;
      gap: 2rem;
    }

    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 960px) {
    .blog-main__layout {
      grid-template-columns: 1fr;
    }

    .blog-main__sidebar {
      position: static;
    }

    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }

    .blog-main {
      padding: 2rem 0;
    }

    .blog-cta-final {
      padding: 2.5rem 0;
    }
  }
</style>
