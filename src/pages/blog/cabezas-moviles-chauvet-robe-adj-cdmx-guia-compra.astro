    "mainEntityOfPage": { "@type": "WebPage", "@id": canonical }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Cuál es la diferencia entre Chauvet DJ y Chauvet Professional?", "acceptedAnswer": { "@type": "Answer", "text": "DJ: económico, 200-500W, ruido de motor audible, construcción plástica, durabilidad 2-3 años. Professional: 1,500-5,000W, silencioso, construcción de aluminio, durabilidad 10+ años en uso profesional. Precio DJ: $12,000-25,000 MXN. Professional: $45,000-80,000 MXN." } },
      { "@type": "Question", "name": "¿Robe vale la pena o es solo hype?", "acceptedAnswer": { "@type": "Answer", "text": "Robe no es hype. Es estándar en conciertos internacionales por durabilidad y versatilidad. Precio más alto que Chauvet Professional, pero menos downtime. Si tu cabeza se va a usar 200+ veces al año, Robe se paga sola. Para rental ocasional, Chauvet Professional es suficiente." } },
