const canonical = "https://rentadeiluminacion.com/blog/cabezas-moviles-chauvet-robe-adj-cdmx-guia-compra/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
