    <thead>
      <tr>
        <th style="border: 1px solid #ddd; padding: 12px; text-align: left;">Componente</th>
        <th style="border: 1px solid #ddd; padding: 12px; text-align: left;">Función</th>
        <th style="border: 1px solid #ddd; padding: 12px; text-align: left;">Presupuesto Típico</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td style="border: 1px solid #ddd; padding: 12px;"><strong>Fuente de Audio</strong></td>
        <td style="border: 1px solid #ddd; padding: 12px;">Spotify, Apple Music, micrófono para anuncios</td>
