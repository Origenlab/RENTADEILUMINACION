const description = "Comparativa real de controladores DJ Pioneer: DDJ-400 vs XDJ-RX3 vs CDJ-2000. Qué elegir según tu nivel, presupuesto y venue.";
const canonical = "https://rentadeiluminacion.com/blog/controladores-dj-pioneer-native-instruments-cdmx-guia/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Pioneer DDJ, XDJ o CDJ: Cuál Controlador DJ Necesitas en CDMX",
    "description": description,
    "author": { "@type": "Organization", "name": "REDEIL", "url": "https://rentadeiluminacion.com" },
    "publisher": { "@type": "Organization", "name": "REDEIL", "url": "https://rentadeiluminacion.com", "logo": { "@type": "ImageObject", "url": "https://rentadeiluminacion.com/img/logo-redeil.avif" } },
    "image": "https://rentadeiluminacion.com/img/directorio/directorio-equipo-dj-01.avif",
    "mainEntityOfPage": { "@type": "WebPage", "@id": canonical }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Debería empezar con DDJ-400 o invertir más en DDJ-1000?", "acceptedAnswer": { "@type": "Answer", "text": "DDJ-400 es bueno para aprender, pero en 6 meses puedes sentirlo pequeño. DDJ-1000 es mejor inversión a largo plazo. En CDMX, muchos DJs pasan de DDJ-400 a DDJ-1000 después de 8-12 meses." } },
      { "@type": "Question", "name": "¿Necesito XDJ-RX3 o es exceso para empezar?", "acceptedAnswer": { "@type": "Answer", "text": "XDJ-RX3 es todo-en-uno ($8,000-10,000 MXN). Para empezar, DDJ-400 + auriculares decentes ($3,500) es suficiente. XDJ cuando ya trabajas eventos regularmente." } },
