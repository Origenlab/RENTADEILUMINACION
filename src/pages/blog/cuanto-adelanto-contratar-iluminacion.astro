---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

const title = "¿Con Cuánta Anticipación Debo Contratar la Iluminación para mi Evento? | REDEIL";
const description = "Guía de anticipación para contratar iluminación profesional: bodas 3-6 meses, XV años 2-4 meses, corporativos 1-2 meses. Temporadas altas y tips de reserva.";
