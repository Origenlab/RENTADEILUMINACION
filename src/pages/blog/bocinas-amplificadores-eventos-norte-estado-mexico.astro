const canonical = "https://rentadeiluminacion.com/blog/bocinas-amplificadores-eventos-norte-estado-mexico/";
const schemaMarkup = JSON.stringify([
  { "@context": "https://schema.org", "@type": "Article", "headline": "Bocinas y Amplificadores para Eventos en el Norte del Estado de México: Potencia Real vs Marketing", "description": description, "author": { "@type": "Organization", "name": "REDEIL", "url": "https://rentadeiluminacion.com" }, "publisher": { "@type": "Organization", "name": "REDEIL", "url": "https://rentadeiluminacion.com", "logo": { "@type": "ImageObject", "url": "https://rentadeiluminacion.com/img/bocinas/bocinas-profesionales-evento-masivo.avif" } }, "image": "https://rentadeiluminacion.com/img/bocinas/bocinas-profesionales-evento-masivo.avif", "mainEntityOfPage": { "@type": "WebPage", "@id": canonical } },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [
    { "@type": "Question", "name": "¿Qué significa PMPO y por qué los fabricantes usan ese número?", "acceptedAnswer": { "@type": "Answer", "text": "PMPO = Pico Máximo de Potencia de Salida. Es potencia teórica en pulsos muy cortos, no realista. Fabricante coloca '5000W PMPO' en el anuncio para que parezca profesional, pero especificación real es '100W RMS'. Es marketing puro. Siempre ignora PMPO. Lee RMS en la especificación técnica." } },
    { "@type": "Question", "name": "¿Cuántos RMS reales necesito para evento de 100-150 personas?", "acceptedAnswer": { "@type": "Answer", "text": "100-150 personas en salón cerrado de 200-300m²: mínimo 200W RMS. En espacio abierto (jardín, calle): 300-400W RMS porque sonido se dispersa más. Presupuesta SIEMPRE para máximo esperado + 30%. Si calculas 200W, compra 250W." } },
