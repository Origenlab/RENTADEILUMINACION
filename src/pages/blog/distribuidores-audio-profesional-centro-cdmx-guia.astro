const description = "El técnico compra en tienda retail y paga $28,000. El director de producción compra con distribuidor y paga $21,000 por el mismo amplificador. Guía de dónde y cómo acceder a precios mayorista.";
const canonical = "https://rentadeiluminacion.com/blog/distribuidores-audio-profesional-centro-cdmx-guia/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Distribuidores de Audio en el Centro de CDMX: Acceso a Equipo de Alta Gama",
    "description": description,
    "author": { "@type": "Organization", "name": "REDEIL", "url": "https://rentadeiluminacion.com" },
    "publisher": { "@type": "Organization", "name": "REDEIL", "url": "https://rentadeiluminacion.com", "logo": { "@type": "ImageObject", "url": "https://rentadeiluminacion.com/img/logo-redeil.avif" } },
