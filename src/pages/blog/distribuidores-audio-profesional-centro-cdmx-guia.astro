  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Por qué el mismo amplificador cuesta $28,000 en retail y $21,000 en distribuidor?", "acceptedAnswer": { "@type": "Answer", "text": "Tienda retail: importa en pequeñas cantidades, paga impuestos altos, tiene costos de local y personal. Distribuidor: importa al por mayor, negocia directamente con fabricante, pasa ahorro al cliente profesional. Diferencia: 20-30% en precios." } },
      { "@type": "Question", "name": "¿Qué equipo venden los distribuidores que no encuentras en tiendas normales?", "acceptedAnswer": { "@type": "Answer", "text": "Amplificadores de potencia 3,000-8,000W (marca JBL, QSC, Yamaha), procesadores DSP profesionales, línea arrays, crossovers digitales, sistemas de monitoreo inalámbrico profesional, interfaces de audio de estudio. Marcas: QSC, JBL Pro, Shure, PreSonus, Behringer profesional." } },
