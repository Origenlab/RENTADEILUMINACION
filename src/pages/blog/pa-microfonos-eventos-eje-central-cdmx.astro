        <th>Ejemplo PA</th>
        <th>Precio MXN</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Salón pequeño (cerrado)</td>
        <td>30-50</td>
        <td>80-120</td>
        <td>60-80W RMS</td>
        <td>Behringer PMP500M</td>
        <td>$3,500</td>
      </tr>
      <tr>
        <td>Salón mediano (cerrado)</td>
        <td>80-150</td>
        <td>200-300</td>
