            <td style="padding: 10px; text-align:center; border: 1px solid #ddd;">Fijo</td>
            <td style="padding: 10px; text-align:center; border: 1px solid #ddd;">Pan y tilt motorizado</td>
          </tr>
          <tr style="background: #f9f9f9;">
            <td style="padding: 10px; border: 1px solid #ddd;">Tipo de luz</td>
