---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BlogCard from '../../components/BlogCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const title = "Blog de Iluminación para Eventos — Guías y Consejos | REDEIL";
const description = "Guías profesionales sobre iluminación para bodas, XV años y eventos en CDMX. Consejos de expertos con 30 años de experiencia. Aprende a elegir la luz perfecta.";
const canonical = "https://rentadeiluminacion.com/blog/";

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Agrupar por categoría
const categories = [...new Set(allPosts.map(p => p.data.category))];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[
      { label: "Inicio", href: "/" },
      { label: "Blog" }
    ]} />
  </Fragment>

  <!-- Hero -->
  <section class="hero hero-two-columns">
    <div class="hero-background" style="background-color: var(--color-secondary);"></div>
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <h1 class="hero-title">Blog de Iluminación para Eventos</h1>
          <p class="hero-subtitle">Guías profesionales, consejos expertos y tendencias en iluminación para bodas, XV años y eventos en CDMX.</p>
          <div class="hero-ctas">
            <a href="/servicios/iluminacion/" class="btn btn-primary btn-lg">Ver Servicios</a>
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotizar Gratis</a>
          </div>
        </div>
        <div class="hero-intro">
          <p>En <strong>REDEIL</strong> llevamos más de 30 años diseñando iluminación profesional para eventos en la Ciudad de México. En este blog compartimos todo lo que aprendemos en cada boda, XV años y evento corporativo — para que tú puedas tomar las mejores decisiones para tu celebración.</p>
          <p>Desde cómo elegir entre guirnaldas Edison y cascadas LED, hasta qué efectos especiales son los más impactantes para tu tipo de venue. Conocimiento práctico de quienes lo hacen de verdad.</p>
        </div>
      </div>
    </div>
  </section>

  {allPosts.length === 0 ? (
    <!-- Estado vacío -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="Próximamente"
          subtitle="Estamos preparando contenido de valor."
          paragraph1="Publicaremos guías, comparativas y consejos sobre iluminación profesional para eventos. Todo basado en nuestra experiencia real con más de 800 bodas en CDMX."
          paragraph2="Mientras tanto, revisa nuestros servicios o escríbenos por WhatsApp para asesoría personalizada."
        />
        <div style="text-align: center; padding: 2rem 0;">
          <a href="/servicios/iluminacion/" class="btn btn-primary btn-lg">Ver servicios de iluminación</a>
        </div>
      </div>
    </section>
  ) : (
    <>
      <!-- Todos los artículos -->
      <section class="services-section">
        <div class="container">
          <SectionHeader
            title="Artículos"
            subtitle="Guías prácticas para iluminar mejor tu evento."
            paragraph1="Cada artículo está escrito por nuestro equipo técnico con base en proyectos reales. Sin relleno — solo información útil y práctica."
            paragraph2="Encuentra el artículo que necesitas según el tipo de evento o servicio que buscas."
          />

          <!-- Filtros por categoría (solo visual) -->
          {categories.length > 1 && (
            <div class="blog-cats">
              {categories.map(cat => (
                <span class="blog-cat">{cat}</span>
              ))}
            </div>
          )}

          <!-- Grid de artículos -->
          <div class="blog-grid">
            {allPosts.map(post => (
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                image={post.data.image}
                imageAlt={post.data.imageAlt}
                category={post.data.category}
                slug={post.slug}
              />
            ))}
          </div>
        </div>
      </section>
    </>
  )}

  <!-- CTA Final -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Tienes un evento en puerta?</h2>
        <p>Cuéntanos la fecha, el venue y el tipo de celebración. Te armamos una propuesta de iluminación a tu medida.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.blog-cats {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 2.5rem;
}
.blog-cat {
  background: var(--color-gray-100, #f1f3f5);
  color: var(--color-secondary, #1C2B4A);
  font-family: var(--font-primary, 'Montserrat', sans-serif);
  font-size: 0.8rem;
  font-weight: 600;
  padding: 0.4rem 1rem;
  border-radius: 20px;
  border: 1px solid var(--color-gray-200, #e9ecef);
}
.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
@media (max-width: 1024px) {
  .blog-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .blog-grid { grid-template-columns: 1fr; }
}
</style>
