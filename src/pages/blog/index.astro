---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BlogSidebar from '../../components/BlogSidebar.astro';
import {
  blogArticles,
  buildCategories,
  getPopularArticles,
  getPageArticles,
  getTotalPages,
  ARTICLES_PER_PAGE,
} from '../../data/blog-articles';

const currentPage = 1;
const totalPages = getTotalPages();
const pageArticles = getPageArticles(currentPage);
const categories = buildCategories();
const popularArticles = getPopularArticles();

const catMap = new Map<string, number>();
blogArticles.forEach(a => {
  catMap.set(a.category, (catMap.get(a.category) || 0) + 1);
});

const categoryOrder = ["Audio", "DJ", "Iluminación", "Bodas", "XV Años", "Guirnaldas", "Luces Neón", "Equipos", "Efectos", "Sonido", "Corporativo", "Guía", "Comparativas", "Paquetes", "Temporadas", "Zonas"];

const ctaBarItems = categories.map(cat => ({
  label: cat.name,
  href: `/blog/?cat=${cat.slug}`,
}));

const title = 'Blog de Iluminación para Eventos CDMX | REDEIL';
const description = 'Guías de iluminación, sonido y efectos para bodas, XV años y eventos CDMX.';
const canonical = 'https://rentadeiluminacion.com/blog/';

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog de Iluminación para Eventos — REDEIL",
  "description": "Guías de iluminación, sonido y efectos para bodas, XV años y eventos CDMX.",
  "url": canonical,
  "publisher": {
    "@type": "Organization",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com"
  }
});
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[
      { label: "Inicio", href: "/" },
      { label: "Blog" }
    ]} />
  </Fragment>

  <Hero
    title="Blog de Iluminación para Eventos"
    subtitle="Guías prácticas, precios reales y consejos de nuestro equipo técnico con más de 30 años de experiencia."
    introParagraph1="En REDEIL compartimos más de 30 años de experiencia en iluminación para eventos. Cada artículo está escrito por nuestro equipo técnico con base en situaciones reales de bodas, XV años y corporativos en CDMX y Zona Metropolitana."
    introParagraph2="Encontrarás información concreta sobre precios, metros de guirnaldas, diferencias entre equipos, efectos especiales y todo lo que necesitas saber para tomar la mejor decisión para tu evento. Sin tecnicismos innecesarios, con datos reales."
  />


  {/* ──── PILLS DE CATEGORÍAS ──── */}
  <section class="blog-filters">
    <div class="container">
      <div class="bf-pills">
        <a href="/blog/" class="bf-pill">Todos</a>
        {categoryOrder.filter(c => catMap.has(c)).map(cat => (
          <a href={`/blog/`} class="bf-pill">{cat} <span class="bf-pill__count">{catMap.get(cat)}</span></a>
        ))}
      </div>
    </div>
  </section>

  {/* ──── GRID + SIDEBAR ──── */}
  <section class="blog-main">
    <div class="container blog-main__layout">
      <div class="blog-main__content">
        <div class="blog-grid">
          {pageArticles.map(article => (
            <article class="bc">
              <a href={`/blog/${article.slug}/`} class="bc__img-link">
                <div class="bc__img">
                  <img src={article.img} alt={article.title} loading="lazy" width="600" height="338" />
                  <span class="bc__cat">{article.category}</span>
                </div>
              </a>
              <div class="bc__body">
                <h2 class="bc__title">
                  <a href={`/blog/${article.slug}/`}>{article.title}</a>
                </h2>
                <p class="bc__desc">{article.excerpt}</p>
                <a href={`/blog/${article.slug}/`} class="bc__link">
                  Leer artículo <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>

        {/* ──── PAGINACIÓN ──── */}
        <nav class="pagination" aria-label="Páginas del blog">
          <div class="pagination__pages">
            <a href="/blog/" class="pagination__page pagination__page--active" aria-current="page">1</a>
            {Array.from({ length: totalPages - 1 }, (_, i) => i + 2).map(p => (
              <a
                href={`/blog/pagina/${p}/`}
                class="pagination__page"
              >{p}</a>
            ))}
          </div>

          {totalPages > 1 && (
            <a href={`/blog/pagina/2/`} class="pagination__next">Siguiente →</a>
          )}
        </nav>
      </div>

      <aside class="blog-main__sidebar">
        <BlogSidebar
          categories={categories}
          popularArticles={popularArticles}
        />
      </aside>
    </div>
  </section>

  {/* ──── CTA FINAL ──── */}
  <section class="blog-cta-final">
    <div class="container blog-cta-final__inner">
      <h2>¿No encuentras lo que buscas?</h2>
      <p>Nuestro equipo técnico tiene la respuesta. Cotiza sin compromiso o pregúntanos directamente por WhatsApp.</p>
      <div class="blog-cta-final__btns">
        <a href="/contacto/" class="btn btn-primary btn-lg">Cotizar Gratis →</a>
        <a href="https://wa.me/5215530682988?text=Hola%20REDEIL%2C%20tengo%20una%20pregunta%20sobre%20iluminación." target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-lg">WhatsApp</a>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
