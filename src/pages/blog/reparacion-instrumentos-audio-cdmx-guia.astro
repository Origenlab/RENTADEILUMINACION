<tr><td><strong>Reparación grieta</strong></td><td>$1,800-$3,500</td><td>2-6 semanas</td></tr>
<tr><td><strong>Cambio pastillas guitarra eléctrica</strong></td><td>$1,200-$2,000</td><td>3-5 días</td></tr>
<tr><td><strong>Servicio amplificador</strong></td><td>$1,500-$3,000</td><td>1-4 semanas</td></tr>
<tr><td><strong>Cambio transformador amplificador</strong></td><td>$2,500-$5,000</td><td>2-3 semanas</td></tr>
