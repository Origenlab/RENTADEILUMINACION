const canonical = "https://rentadeiluminacion.com/blog/iluminacion-eventos-benito-juarez/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Iluminación para Eventos en Benito Juárez — Del Valle, Narvarte y Colonia del Valle",
    "description": "Renta de luces profesionales para eventos en Benito Juárez: Del Valle, Narvarte, WTC y terrazas. Iluminación LED, guirnaldas y efectos. Cotiza hoy.",
    "author": { "@type": "Organization", "name": "REDEIL", "url": "https://rentadeiluminacion.com" },
    "publisher": { "@type": "Organization", "name": "REDEIL", "url": "https://rentadeiluminacion.com", "logo": { "@type": "ImageObject", "url": "https://rentadeiluminacion.com/img/logo-redeil.avif" } },
    "image": "https://rentadeiluminacion.com/img/city-color/iluminacion-fiesta-corporativa-azul.avif",
