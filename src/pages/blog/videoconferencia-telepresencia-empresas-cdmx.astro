      </tr>
      <tr>
        <td style="border: 1px solid #ddd; padding: 12px;"><strong>Audio</strong></td>
        <td style="border: 1px solid #ddd; padding: 12px;">Speaker laptop, con eco</td>
        <td style="border: 1px solid #ddd; padding: 12px;">Sistema profesional, echo cancellation</td>
      </tr>
      <tr>
        <td style="border: 1px solid #ddd; padding: 12px;"><strong>Ancho de banda</strong></td>
