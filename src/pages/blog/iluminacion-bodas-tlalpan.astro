---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

const title = "Renta de Iluminación para Bodas en Tlalpan — Haciendas y Jardines | REDEIL";
const description = "Iluminación profesional para bodas en Tlalpan CDMX. Guirnaldas, luces LED y efectos especiales para haciendas, jardines amplios y espacios en zona boscosa del Ajusco.";
const canonical = "https://rentadeiluminacion.com/blog/iluminacion-bodas-tlalpan/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Renta de Iluminación para Bodas en Tlalpan — Haciendas y Jardines",
    "description": "Iluminación profesional para bodas en Tlalpan CDMX. Guirnaldas, luces LED y efectos especiales para haciendas, jardines amplios y espacios en zona boscosa del Ajusco.",
