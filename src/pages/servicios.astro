---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Hero from '../components/Hero.astro';
import CtaBar from '../components/CtaBar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceCard from '../components/ServiceCard.astro';

const title = "Servicios de Iluminación, Sonido y Efectos | REDEIL CDMX";
const description = "Renta de iluminación, sonido profesional y efectos especiales para bodas, XV años y eventos en CDMX. 24 servicios con instalación incluida. Cotiza gratis.";
const canonical = "https://rentadeiluminacion.com/servicios/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Iluminación y Sonido Profesional para Eventos",
  "provider": {
    "@type": "LocalBusiness",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com",
    "telephone": "+525530682988",
    "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressCountry": "MX" }
  },
  "description": "Servicios profesionales de renta de iluminación, audio y efectos especiales para eventos en CDMX y Estado de México.",
  "areaServed": { "@type": "City", "name": "Ciudad de México" }
});

const iluminacion = [
  { title: "Guirnaldas Edison", image: "/img/guirnaldas/renta-guirnaldas-edison-terraza-recepcion-02-300w.avif", alt: "Guirnaldas con focos Edison para boda", description: "Focos tipo Edison con luz cálida vintage. Las más pedidas para bodas al aire libre, terrazas y jardines.", link: "/servicios/guirnaldas/" },
  { title: "Luces Neón y UV", image: "/img/luces-neon/renta-luces-neon-glow-party-celebracion-neon-300w.avif", alt: "Luces neón UV para fiesta glow", description: "Efectos fluorescentes y glow para fiestas temáticas, XV años y pistas de baile.", link: "/servicios/luces-neon/" },
  { title: "Luz Negra", image: "/img/luz-negra/luz-negra-fiesta-neon-300w.avif", alt: "Luz negra UV para fiesta", description: "Iluminación UV que hace brillar todo lo blanco y fluorescente. Ideal para fiestas neón.", link: "/servicios/luz-negra/" },
  { title: "Sky Tracker", image: "/img/sky-tracker/renta-skytracker-cielo-nocturno-potente-300w.avif", alt: "Sky tracker proyectando luz al cielo", description: "Haces de luz xenón de 7,000W visibles a kilómetros. Para inauguraciones y eventos espectaculares.", link: "/servicios/sky-tracker/" },
  { title: "Cabezas Móviles", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante-300w.avif", alt: "Cabezas móviles LED en boda", description: "Luces robóticas con movimiento programable vía DMX para shows de luces profesionales.", link: "/servicios/cabezas-moviles/" },
  { title: "Cascadas LED", image: "/img/cascadas-led/cascadas-led-arco-ceremonia-luces-moradas-400w.avif", alt: "Cascadas LED en ceremonia", description: "Cortinas de luces LED que caen como cascada. Fondo perfecto para mesa de novios.", link: "/servicios/cascadas-led/" },
  { title: "City Color", image: "/img/city-color/renta-luces-hacienda-boda-fuente-300w.avif", alt: "City Color iluminando hacienda", description: "Cañones de luz LED para bañar de color fachadas, escenarios y espacios grandes.", link: "/servicios/city-color/" },
  { title: "City Light", image: "/img/city-light/iluminacion-profesional-bodas-cdmx-400w.avif", alt: "City Light en salón de eventos", description: "Luminarias profesionales de luz potente y uniforme para salones y carpas.", link: "/servicios/city-light/" },
  { title: "Iluminación Arquitectónica", image: "/img/iluminacion-arquitectonica/boda-patio-hacienda-iluminacion-fachada-ambar-string-lights-baile-400w.avif", alt: "Uplighting en hacienda", description: "Uplighting profesional para transformar fachadas, columnas y jardines con color.", link: "/servicios/iluminacion-arquitectonica/" },
  { title: "Gobos", image: "/img/gobos/renta-gobo-monograma-pista-baile-300w.avif", alt: "Gobo con monograma en pista de baile", description: "Proyección de nombres, logos y diseños personalizados en paredes y pisos.", link: "/servicios/gobos/" },
  { title: "Seguidor", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Luz seguidor en primer baile", description: "Spotlight profesional para destacar al festejado en vals, brindis o entrada triunfal.", link: "/servicios/seguidor/" },
];

const sonido = [
  { title: "Audio para Eventos", image: "/img/bocinas/renta-bocinas-line-array-concierto-400w.avif", alt: "Bocinas line array JBL", description: "Bocinas JBL y QSC desde 50 hasta 2,000+ personas. Sonido cristalino y potente.", link: "/servicios/bocinas/" },
  { title: "DJ para Fiestas y Bodas", image: "/img/bocinas-djs/dj-para-eventos-cdmx-cabina-profesional-300w.avif", alt: "DJ profesional en cabina", description: "DJ con consola profesional y repertorio adaptado. Solo o con paquete de audio completo.", link: "/servicios/bocinas-djs/" },
  { title: "Bocinas para Bodas", image: "/img/bocinas-bodas/renta-bocinas-boda-primer-baile-novios-truss-300w.avif", alt: "Audio profesional para boda", description: "Audio dimensionado para ceremonia, coctel, vals y fiesta.", link: "/servicios/bocinas-bodas/" },
  { title: "Bocinas para XV Años", image: "/img/bocinas-xv/renta-bocinas-xv-anos-vals-padre-hija-dj-salon-300w.avif", alt: "Audio para XV años", description: "Vals con sonido cristalino, hora loca con potencia, DJ que sabe cuándo subir.", link: "/servicios/bocinas-xv/" },
  { title: "Bocinas para Fiestas", image: "/img/bocinas-fiestas/renta-bocinas-fiestas-eventos-profesionales-300w.avif", alt: "Bocinas para fiesta privada", description: "Audio profesional que se adapta al tamaño de tu fiesta.", link: "/servicios/bocinas-fiestas/" },
  { title: "Bocinas para Conferencias", image: "/img/bocinas-conferencias/renta-de-bocinas-para-conferencias-salon-ejecutivo-300w.avif", alt: "Audio para conferencia ejecutiva", description: "Audio cristalino para presentaciones. Micrófonos inalámbricos y mezcladoras profesionales.", link: "/servicios/bocinas-conferencias/" },
];

const efectos = [
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Humo bajo en vals de boda", description: "Nube mágica a nivel de piso para el vals. El efecto más solicitado en bodas y XV años.", link: "/servicios/humo-bajo/" },
  { title: "Máquina de Humo", image: "/img/humo-bajo/efecto-humo-bajo-baile-novios.avif", alt: "Humo escénico en pista de baile", description: "Humo escénico para crear atmósferas en pistas de baile y shows de luces.", link: "/servicios/maquina-humo/" },
  { title: "Confeti", image: "/img/confeti/confeti-dorado-boda-novios-fiesta.avif", alt: "Confeti dorado en boda", description: "Cañones de confeti dorado, plateado o multicolor para momentos especiales.", link: "/servicios/confeti/" },
  { title: "Burbujas", image: "/img/burbujas/burbujas-gigantes-fiesta-cumpleanos-ninos-400w.avif", alt: "Burbujas en fiesta infantil", description: "Máquinas de burbujas para fiestas infantiles y recepciones al aire libre.", link: "/servicios/burbujas/" },
  { title: "Bola Disco", image: "/img/bola-disco/bola-disco-dj-pista-baile-evento.avif", alt: "Bola disco en pista de baile", description: "Bola disco gigante con luces LED para pistas que invitan a bailar.", link: "/servicios/bola-disco/" },
  { title: "Pantalla Inflable", image: "/img/pantalla-inflable/alquiler-pantalla-inflable-aniversario-boda.avif", alt: "Pantalla inflable para cine al aire libre", description: "Cine al aire libre con pantalla gigante y proyector HD incluido.", link: "/servicios/pantalla-inflable/" },
  { title: "Podium", image: "/img/podiums/conferencia-corporativa-podium-acrilico-auditorio-luces-azules-300w.avif", alt: "Podium profesional en auditorio", description: "Tarimas y podiums para DJ, músicos o presentaciones corporativas.", link: "/servicios/podiums/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Servicios" }]} />
</Fragment>

    <Hero
      title="Servicios de Iluminación, Sonido y Efectos Especiales"
      subtitle="24 servicios profesionales con instalación incluida para tu evento en CDMX y Estado de México."
      introParagraph1='En <strong>REDEIL</strong> ofrecemos todo lo que necesitas para que tu evento se vea y se escuche increíble. Iluminación con equipo <strong>Martin Professional</strong>, <strong>Chauvet</strong> y <strong>Elation</strong>. Audio <strong>JBL</strong> y <strong>QSC</strong>. Efectos especiales que transforman cualquier celebración.'
      introParagraph2='Cada servicio incluye transporte, instalación profesional, operación durante el evento y desmontaje. Atendemos toda la CDMX y zona metropolitana. <strong>Cotiza sin compromiso</strong> — te armamos una propuesta a tu medida.'
    />

    <CtaBar
      headline="¿Qué necesitas para tu evento?"
      items={[
        { label: "Iluminación", href: "#iluminacion", icon: "iluminacion" },
        { label: "Sonido y DJ", href: "#sonido", icon: "sonido" },
        { label: "Efectos Especiales", href: "#efectos", icon: "efectos" },
        { label: "Cotiza Gratis", href: "https://wa.me/5530682988?text=Hola%20REDEIL,%20quiero%20cotizar%20para%20mi%20evento", icon: "cotizar" },
      ]}
    />

    <!-- ILUMINACIÓN -->
    <section class="services-section" id="iluminacion">
      <div class="container">
        <SectionHeader
          title="Iluminación Profesional"
          subtitle="11 servicios con equipo Martin Professional, Chauvet y Elation."
          paragraph1="Desde guirnaldas vintage para bodas íntimas hasta sky trackers que se ven a kilómetros. Cada equipo incluye instalación profesional y operación durante tu evento."
          paragraph2="Nuestros técnicos diseñan la iluminación a la medida de tu espacio — jardín, hacienda, salón o terraza. El resultado: un ambiente que tus invitados van a recordar."
        />
        <div class="services-grid">
          {iluminacion.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- SONIDO Y DJ -->
    <section class="services-section services-alt" id="sonido">
      <div class="container">
        <SectionHeader
          title="Sonido y DJ"
          subtitle="6 servicios de audio profesional JBL y QSC."
          paragraph1="No hay fiesta sin buen sonido. Sistemas dimensionados para tu espacio, desde reuniones de 50 personas hasta eventos de 2,000+."
          paragraph2="DJ con consola y repertorio adaptado, micrófonos inalámbricos, pantallas LED. Todo con técnico de audio incluido."
        />
        <div class="services-grid">
          {sonido.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- EFECTOS ESPECIALES -->
    <section class="services-section" id="efectos">
      <div class="container">
        <SectionHeader
          title="Efectos Especiales"
          subtitle="7 efectos que convierten un buen evento en uno inolvidable."
          paragraph1="Humo bajo para el vals, confeti para el brindis, burbujas para los niños — cada efecto tiene su momento perfecto."
          paragraph2="Nuestro equipo técnico opera cada efecto en el momento exacto. Tú solo disfrutas."
        />
        <div class="services-grid">
          {efectos.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

</BaseLayout>
