---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const title = "Servicios de Iluminación para Eventos | REDEIL CDMX";
const description = "Servicios de iluminación para bodas, XV años y eventos en CDMX. Guirnaldas, sky tracker, cabezas móviles. Instalación incluida.";
const canonical = "https://rentadeiluminacion.com/servicios/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Iluminación Profesional para Eventos",
  "provider": {
    "@type": "LocalBusiness",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com",
    "telephone": "+525530682988",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Ciudad de México",
      "addressCountry": "MX"
    }
  },
  "description": "Servicios profesionales de renta de iluminación para bodas, XV años, fiestas y eventos corporativos en CDMX y Estado de México.",
  "areaServed": {
    "@type": "City",
    "name": "Ciudad de México"
  },
  "serviceType": "Renta de Iluminación para Eventos"
});
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

  <Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Servicios" }]} />
</Fragment>
<section class="hero hero-two-columns">
      <div class="hero-background" style="background-color: var(--color-secondary);"></div>
      <div class="container">
        <div class="hero-grid">
          <div class="hero-content">
            <h1 class="hero-title">Servicios de Iluminación Profesional para Eventos</h1>
            <p class="hero-subtitle">Soluciones completas de iluminacion para bodas, XV años, fiestas y eventos corporativos en CDMX y Estado de México</p>
            <div class="hero-ctas">
              <a href="/contacto/" class="btn btn-primary btn-lg">Cotizar Ahora</a>
              <a href="https://wa.me/525530682988?text=Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20evento" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp btn-lg">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>
          <div class="hero-intro">
            <p>En <strong>REDEIL</strong> ofrecemos una amplia gama de servicios de iluminacion profesional para todo tipo de eventos. Desde elegantes guirnaldas LED para bodas románticas, hasta potentes sky trackers y cabezas móviles para fiestas y eventos corporativos. Nuestro equipo incluye marcas líderes como <strong>Martin Professional, Chauvet y Elation</strong>.</p>
            <p>Cada servicio incluye <strong>transporte, instalación profesional, operación durante el evento y desmontaje</strong>. Contamos con técnicos especializados que garantizan el funcionamiento perfecto de cada luminaria. Atendemos toda la CDMX y zona metropolitana: Polanco, Santa Fe, Coyoacán, Naucalpan, Huixquilucan, Tlalnepantla y más. <strong>Cotiza hoy sin compromiso</strong>.</p>
          </div>
        </div>
      </div>
    </section>

