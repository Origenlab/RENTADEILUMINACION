      { text: "Cabezas móviles", included: false },
      { text: "Sistema de audio", included: false },
    ],
    ctaLabel: "Cotizar Boda Íntima",
    ctaHref: "https://wa.me/525530682988?text=Hola,%20quiero%20cotizar%20el%20paquete%20Boda%20%C3%8Dntima",
  },
  {
    name: "Boda Estándar",
    badge: "Más pedido",
    highlight: true,
    price: "$12,000–$25,000",
    priceNote: "más IVA · 80–150 personas",
    description: "El paquete más completo para bodas en salón o hacienda. Iluminación de ambiente + pista de baile + efectos.",
    features: [
      { text: "Guirnaldas Edison (hasta 60 m)", included: true },
      { text: "City Color (6–8 piezas)", included: true },
      { text: "Cabezas móviles (4 piezas)", included: true },
