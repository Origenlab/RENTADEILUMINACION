---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import CtaBar from "../../components/CtaBar.astro";
import Gallery4x4 from "../../components/Gallery4x4.astro";
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Iluminación y Sonido para Bodas | REDEIL CDMX";
const description = "Renta de iluminación y sonido profesional para bodas en CDMX. REDEIL ofrece guirnaldas, city color, cabezas móviles, humo bajo, seguidor y bocinas para tu boda.";
const canonical = "https://rentadeiluminacion.com/eventos/bodas/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Iluminación y Sonido Profesional para Bodas",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressCountry": "MX" }
    },
    "description": "Servicio integral de iluminación y sonido profesional para bodas en Ciudad de México. Guirnaldas, city color, cabezas móviles, humo bajo, seguidor y bocinas.",
    "areaServed": { "@type": "City", "name": "Ciudad de México" },
    "serviceType": "Iluminación y Sonido para Bodas"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Cuánto tiempo antes debo reservar la iluminación para mi boda?", "acceptedAnswer": { "@type": "Answer", "text": "Recomendamos reservar con al menos 3 meses de anticipación, especialmente en temporada alta (noviembre–febrero). Los fines de semana se reservan rápido. Con fecha y venue confirmados, podemos hacer la visita previa y diseñar el esquema de iluminación personalizado." } },
      { "@type": "Question", "name": "¿Hacen visita previa al venue?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Para bodas hacemos visita previa al venue sin costo adicional. Esto nos permite diseñar el esquema de iluminación exacto, calcular el equipo necesario y coordinarnos con el salón sobre horarios de montaje. La visita se realiza de 4 a 6 semanas antes del evento." } },
      { "@type": "Question", "name": "¿Se coordina con el wedding planner y el DJ?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Trabajamos en coordinación con wedding planners, DJs, fotógrafos y decoradores. Les compartimos el schedule técnico y nos coordinamos para que cada efecto (humo bajo, confeti, seguidor) se active en el momento exacto que define la pareja." } },
      { "@type": "Question", "name": "¿Qué incluye el servicio de iluminación para boda?", "acceptedAnswer": { "@type": "Answer", "text": "El servicio incluye visita previa, diseño del esquema de iluminación, transporte del equipo, montaje (llega 4-6 horas antes), operación técnica durante toda la boda y desmontaje al finalizar. El equipo permanece hasta que termina el evento." } },
      { "@type": "Question", "name": "¿Pueden cubrir la ceremonia y la recepción?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Manejamos la iluminación y el audio para ambos momentos. Para la ceremonia usamos luz blanca cálida suave y seguidor para el vals. Para la recepción cambiamos a iluminación de ambiente y pista de baile con cabezas móviles y efectos especiales." } },
      { "@type": "Question", "name": "¿Tienen paquetes completos de iluminación + audio para bodas?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Armamos paquetes completos de iluminación + sonido + efectos especiales con precio especial. Es la forma más eficiente porque un solo equipo técnico coordina todo. Cuéntanos tu venue, fecha y número de invitados y te cotizamos el paquete completo." } }
    ]
  }
]);

const serviciosBoda = [
  { title: "Guirnaldas Edison", image: "/img/guirnaldas/renta-guirnaldas-edison-terraza-recepcion-02-300w.avif", alt: "Guirnaldas con focos Edison para boda al aire libre", description: "Focos tipo Edison con luz cálida vintage. Las más pedidas para jardines, terrazas y haciendas. Cableado IP65 certificado.", link: "/servicios/guirnaldas/" },
  { title: "Humo Bajo para el Vals", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Humo bajo creando nube mágica en primer vals de boda", description: "La nube mágica a nivel de piso para el primer vals. El efecto más solicitado en bodas. Activación a control remoto por nuestro técnico.", link: "/servicios/humo-bajo/" },
  { title: "Seguidor de Luz", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Seguidor de luz en primer baile de novios boda CDMX", description: "Spotlight que sigue a los novios en el vals, la entrada y los momentos más emotivos. Operado por un técnico dedicado.", link: "/servicios/seguidor/" },
  { title: "Cabezas Móviles", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante-300w.avif", alt: "Cabezas móviles LED en boda elegante CDMX", description: "Luces robóticas programables para la pista de baile. Show de luces que transforma el salón para la fiesta principal.", link: "/servicios/cabezas-moviles/" },
  { title: "City Color", image: "/img/city-color/renta-luces-hacienda-boda-fuente-300w.avif", alt: "City Color iluminando hacienda para boda", description: "Cañones LED de alto impacto para bañar de color fachadas y espacios grandes. Perfectos para exteriores de haciendas.", link: "/servicios/city-color/" },
  { title: "Audio para Boda", image: "/img/bocinas-bodas/renta-bocinas-boda-primer-baile-novios-truss-300w.avif", alt: "Sistema de audio profesional para boda", description: "Bocinas JBL con técnico de audio. Ceremonia con sonido cristalino para los votos y potencia para la pista de baile.", link: "/servicios/bocinas-bodas/" },
  { title: "Cascadas LED", image: "/img/cascadas-led/cascadas-led-arco-ceremonia-luces-moradas-400w.avif", alt: "Cascadas LED en arco de ceremonia de boda", description: "Cortinas de luces LED que caen en cascada. Fondo espectacular para el arco de ceremonia o la mesa de novios.", link: "/servicios/cascadas-led/" },
  { title: "Confeti para el Brindis", image: "/img/confeti/confeti-dorado-boda-novios-fiesta.avif", alt: "Cañón de confeti dorado en brindis de boda", description: "Cañones de confeti dorado para el brindis o la hora loca. El detalle que desata la celebración.", link: "/servicios/confeti/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[
      { label: "Inicio", href: "/" },
      { label: "Servicios", href: "/servicios/" },
      { label: "Bodas" }
    ]} />
  </Fragment>

  <Hero
    title="Iluminación y Sonido para Bodas en CDMX"
    subtitle="Todo lo que tu boda necesita en iluminación y audio profesional. Guirnaldas, humo bajo, cabezas móviles y bocinas. Instalación incluida."
    whatsappText="Hola,%20quiero%20cotizar%20iluminaci%C3%B3n%20y%20sonido%20para%20mi%20boda"
    introParagraph1='<strong>REDEIL</strong> es especialista en iluminación y sonido profesional para bodas en toda la Ciudad de México y Estado de México. Con más de 30 años iluminando bodas y más de 3,000 eventos realizados, conocemos cada momento de una boda que necesita iluminación especial: la ceremonia con luz cálida y seguidor para el vals, la recepción con guirnaldas Edison y uplighting de color, y la pista de baile con cabezas móviles y efectos especiales que hacen que nadie quiera irse.'
    introParagraph2='Ofrecemos un servicio integral que incluye guirnaldas de luces, city color, cabezas móviles, humo bajo, seguidor de luz, bocinas profesionales y cualquier efecto especial que imagines para tu boda. Nuestro equipo técnico trabaja en coordinación con wedding planners, decoradores y DJs para crear la atmósfera perfecta en cada momento de tu celebración. Cubrimos haciendas, jardines, salones y terrazas de CDMX y Estado de México.'
  />

  <CtaBar
    headline="¿Qué necesitas para tu boda?"
    items={[
      { label: "Guirnaldas", href: "/servicios/guirnaldas/", icon: "iluminacion" },
      { label: "Humo Bajo", href: "/servicios/humo-bajo/", icon: "efectos" },
      { label: "Audio para Boda", href: "/servicios/bocinas-bodas/", icon: "sonido" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <section class="services-section">
    <div class="container">
      <SectionHeader
        title="Tu boda merece iluminación y sonido de primer nivel"
        subtitle="Instalación profesional incluida. Coordinación con planner, DJ y fotógrafo."
        paragraph1="La iluminación es uno de los elementos que más impacto tiene en la atmósfera de una boda. Combinamos diferentes técnicas: guirnaldas Edison para calidez en jardines, city color para bañar fachadas, cabezas móviles para la pista de baile y seguidor de luz para destacar los momentos más emotivos. El resultado es una boda que luce espectacular en cada foto y cada video."
        paragraph2="Complementamos la iluminación con efectos especiales como humo bajo para el vals, confeti para el brindis y sonido profesional para que la música y los discursos lleguen con claridad a todos los invitados. Un solo proveedor integral para toda la producción técnica de tu boda."
      />
    </div>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <Gallery4x4 images={[
        { src: "/img/bodas/guirnaldas-edison-boda-hacienda-colonial.avif", alt: "Guirnaldas de focos Edison iluminando boda en hacienda colonial" },
        { src: "/img/bodas/iluminacion-completa-boda-hacienda-elegante.avif", alt: "Iluminación completa en boda elegante dentro de hacienda" },
        { src: "/img/bodas/salon-boda-iluminacion-edison-elegante.avif", alt: "Salón de boda con iluminación Edison elegante sobre mesas" },
        { src: "/img/bodas/boda-salon-colonial-guirnaldas-dj.avif", alt: "Boda en salón colonial con guirnaldas y cabina de DJ" },
        { src: "/img/bodas/guirnaldas-boda-jardin-mesa-imperial.avif", alt: "Guirnaldas sobre mesa imperial en boda de jardín" },
        { src: "/img/bodas/recepcion-boda-guirnaldas-hacienda-elegante.avif", alt: "Recepción de boda con guirnaldas en hacienda elegante" },
        { src: "/img/bodas/boda-hacienda-guirnaldas-city-color-dj.avif", alt: "Boda en hacienda con guirnaldas y city color junto a DJ" },
        { src: "/img/bodas/iluminacion-salon-fiesta-profesional.avif", alt: "Salón de fiesta de boda con iluminación profesional" },
        { src: "/img/galeria/seguidor-primer-baile-bodas.avif", alt: "Seguidor de luz en primer baile de novios boda CDMX" },
        { src: "/img/galeria/seguidor-entrada-novios-boda.avif", alt: "Spotlight siguiendo a novios en entrada de ceremonia" },
        { src: "/img/galeria/humo-bajo-01.avif", alt: "Humo bajo en vals de boda CDMX" },
        { src: "/img/galeria/humo-bajo-03.avif", alt: "Nube mágica de humo bajo en primer baile" },
        { src: "/img/galeria/boda-audio-01.avif", alt: "Sistema de audio profesional en boda salón" },
        { src: "/img/galeria/boda-audio-03.avif", alt: "Brindis con micrófono en boda hacienda" },
        { src: "/img/galeria/cascadas-led-01.avif", alt: "Cascadas LED en arco de ceremonia de boda" },
        { src: "/img/galeria/confeti-01.avif", alt: "Confeti dorado en brindis de boda CDMX" },
      ]} />
    </div>
  </section>

  <section class="services-section">
    <div class="container">
      <SectionHeader
        title="Servicios de REDEIL para tu Boda"
        subtitle="Iluminación, sonido y efectos especiales con un solo proveedor."
        paragraph1="Cada servicio se puede contratar por separado o en paquete. Cuando contratas todo con REDEIL, un solo equipo técnico coordina todo el evento — lo que significa mejor coordinación, un solo interlocutor y precio especial por paquete."
        paragraph2="¿No sabes cuáles servicios necesitas? Cuéntanos el venue, el número de invitados y el estilo de la boda. Te asesoramos sin costo."
      />
      <div class="services-grid">
        {serviciosBoda.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre Iluminación para Bodas"
        subtitle="Lo que las parejas nos preguntan antes de contratar."
        paragraph1="Si tu duda no está aquí, escríbenos por WhatsApp y te respondemos en minutos."
        paragraph2="Más de 30 años iluminando bodas en CDMX y Estado de México. Conocemos cada detalle."
      />
    </div>
    <FaqSection items={[
      { question: "¿Cuánto tiempo antes debo reservar la iluminación para mi boda?", answer: "Recomendamos reservar con al menos 3 meses de anticipación, especialmente en temporada alta (noviembre–febrero). Los fines de semana se reservan rápido. Con fecha y venue confirmados, podemos hacer la visita previa y diseñar el esquema de iluminación personalizado." },
      { question: "¿Hacen visita previa al venue?", answer: "Sí. Para bodas hacemos visita previa al venue sin costo adicional. Esto nos permite diseñar el esquema de iluminación exacto, calcular el equipo necesario y coordinarnos con el salón sobre horarios de montaje. La visita se realiza de 4 a 6 semanas antes del evento." },
      { question: "¿Se coordina con el wedding planner y el DJ?", answer: "Sí. Trabajamos en coordinación con wedding planners, DJs, fotógrafos y decoradores. Les compartimos el schedule técnico y nos coordinamos para que cada efecto (humo bajo, confeti, seguidor) se active en el momento exacto que define la pareja." },
      { question: "¿Qué incluye el servicio de iluminación para boda?", answer: "El servicio incluye visita previa, diseño del esquema de iluminación, transporte del equipo, montaje (llega 4-6 horas antes), operación técnica durante toda la boda y desmontaje al finalizar. El equipo permanece hasta que termina el evento." },
      { question: "¿Pueden cubrir la ceremonia y la recepción?", answer: "Sí. Manejamos la iluminación y el audio para ambos momentos. Para la ceremonia usamos luz blanca cálida suave y seguidor para el vals. Para la recepción cambiamos a iluminación de ambiente y pista de baile con cabezas móviles y efectos especiales." },
      { question: "¿Tienen paquetes completos de iluminación + audio para bodas?", answer: "Sí. Armamos paquetes completos de iluminación + sonido + efectos especiales con precio especial. Es la forma más eficiente porque un solo equipo técnico coordina todo. Cuéntanos tu venue, fecha y número de invitados y te cotizamos el paquete completo." },
    ]} />
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para que tu boda luzca como lo imaginaste?</h2>
        <p>Cuéntanos la fecha, el venue y el estilo que buscas. Te enviamos una propuesta personalizada en menos de 24 horas.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
