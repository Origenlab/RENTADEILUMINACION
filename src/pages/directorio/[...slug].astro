---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaBar from '../../components/CtaBar.astro';
import DirectoryCard from '../../components/DirectoryCard.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FaqSection from '../../components/FaqSection.astro';

export async function getStaticPaths() {
  const empresas = await getCollection('directorio', ({ data }) => data.activo !== false);
  return empresas.map((empresa) => ({
    params: { slug: empresa.slug },
    props: { empresa },
  }));
}

interface Props {
  empresa: CollectionEntry<'directorio'>;
}

const { empresa } = Astro.props;
const { Content } = await empresa.render();
const d = empresa.data;

// Fetch other companies of the same category
const todasLasEmpresas = await getCollection('directorio', ({ data }) => data.activo !== false);
const otrasEmpresas = todasLasEmpresas
  .filter(e => e.slug !== empresa.slug && e.data.categoria === d.categoria)
  .sort((a, b) => (b.data.resenas ?? 0) - (a.data.resenas ?? 0))
  .slice(0, 4);

const categoriaLabel: Record<string, string> = {
  audio: 'Audio Profesional',
  iluminacion: 'Iluminación',
  'audio-video': 'Audio & Video',
  dj: 'DJ',
  efectos: 'Efectos',
};

const zonaLabel: Record<string, string> = {
  cdmx: 'Ciudad de México',
  'estado-de-mexico': 'Estado de México',
};

const zonaShort: Record<string, string> = {
  cdmx: 'CDMX',
  'estado-de-mexico': 'Edomex',
};

const fullStars = Math.floor(d.rating ?? 0);
const hasHalf = (d.rating ?? 0) - fullStars >= 0.5;

// Hero description paragraphs (auto-generated from frontmatter)
const heroDesc1 = `${d.nombre} es una tienda de ${categoriaLabel[d.categoria] ?? d.categoria} ubicada en ${d.alcaldia_municipio}, ${zonaLabel[d.zona] ?? d.zona}. ${d.rating ? `Con ${d.rating} estrellas y ${d.resenas?.toLocaleString('es-MX')} reseñas verificadas en Google Maps, figura` : 'Figura'} como una de las opciones más reconocidas de la zona para quienes buscan equipo para eventos.`;

const heroDesc2 = d.servicios && d.servicios.length > 0
  ? `Su oferta incluye ${d.servicios.slice(0, 3).join(', ')} y otros productos especializados. ${d.horario ? `Horario de atención: ${d.horario}.` : 'Consulta horarios directamente con la tienda.'}`
  : `Especializada en equipo de ${categoriaLabel[d.categoria] ?? d.categoria} para profesionales y organizadores de eventos. ${d.horario ? `Atiende de ${d.horario}.` : ''}`;

// Google Maps URL
const mapsQuery = encodeURIComponent(`${d.nombre} ${d.direccion}`);
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;

// CtaBar items by category
const ctaBarItems: Record<string, Array<{ label: string; href: string; icon?: string }>> = {
  audio: [
    { label: 'Bocinas para Eventos', href: '/servicios/bocinas/', icon: 'sonido' },
    { label: 'Bocinas para Bodas', href: '/servicios/bocinas-bodas/', icon: 'sonido' },
    { label: 'DJ + Sonido', href: '/servicios/bocinas-djs/', icon: 'sonido' },
    { label: 'Cotizar Sonido', href: '/contacto/', icon: 'cotizar' },
  ],
  iluminacion: [
    { label: 'Iluminación para Bodas', href: '/eventos/bodas/', icon: 'iluminacion' },
    { label: 'Cabezas Móviles', href: '/servicios/cabezas-moviles/', icon: 'iluminacion' },
    { label: 'Efectos Especiales', href: '/servicios/efectos-especiales/', icon: 'efectos' },
    { label: 'Cotizar Evento', href: '/contacto/', icon: 'cotizar' },
  ],
  'audio-video': [
    { label: 'Bocinas Conferencias', href: '/servicios/bocinas-conferencias/', icon: 'sonido' },
    { label: 'Pantallas LED', href: '/servicios/pantallas-led/', icon: 'iluminacion' },
    { label: 'Iluminación', href: '/servicios/iluminacion/', icon: 'iluminacion' },
    { label: 'Cotizar Evento', href: '/contacto/', icon: 'cotizar' },
  ],
  dj: [
    { label: 'Bocinas DJ', href: '/servicios/bocinas-djs/', icon: 'sonido' },
    { label: 'Cabezas Móviles', href: '/servicios/cabezas-moviles/', icon: 'iluminacion' },
    { label: 'Efectos para DJ', href: '/servicios/efectos-especiales/', icon: 'efectos' },
    { label: 'Cotizar Show', href: '/contacto/', icon: 'cotizar' },
  ],
  efectos: [
    { label: 'Efectos Especiales', href: '/servicios/efectos-especiales/', icon: 'efectos' },
    { label: 'Láseres & Cabezas', href: '/servicios/cabezas-moviles/', icon: 'iluminacion' },
    { label: 'Máquina de Humo', href: '/servicios/maquina-humo/', icon: 'efectos' },
    { label: 'Cotizar Evento', href: '/contacto/', icon: 'cotizar' },
  ],
};
const ctaItems = ctaBarItems[d.categoria] ?? ctaBarItems.iluminacion;

// Servicios REDEIL relacionados
const serviciosRelacionados: Array<{ title: string; description: string; image: string; link: string; btnLabel: string }> =
  d.categoria === 'audio' || d.categoria === 'dj'
    ? [
        { title: 'Bocinas para Eventos', description: 'Renta de bocinas y sistemas de sonido profesional para bodas, XV años y eventos corporativos en CDMX.', image: '/img/servicios/bocinas.avif', link: '/servicios/bocinas/', btnLabel: 'Ver bocinas' },
        { title: 'DJ para Eventos', description: 'DJ profesional con equipo completo de sonido y mezcla para todo tipo de eventos en CDMX y Estado de México.', image: '/img/servicios/dj.avif', link: '/servicios/bocinas-djs/', btnLabel: 'Ver paquetes DJ' },
        { title: 'Cabezas Móviles', description: 'Renta de cabezas móviles para espectáculos de luz profesional en eventos y celebraciones.', image: '/img/servicios/cabezas-moviles.avif', link: '/servicios/cabezas-moviles/', btnLabel: 'Ver iluminación' },
      ]
    : d.categoria === 'audio-video'
    ? [
        { title: 'Bocinas para Conferencias', description: 'Sistema de audio profesional para conferencias, congresos y eventos corporativos en CDMX.', image: '/img/servicios/bocinas.avif', link: '/servicios/bocinas-conferencias/', btnLabel: 'Ver audio corporativo' },
        { title: 'Pantallas LED', description: 'Renta de pantallas LED de alta resolución para presentaciones y eventos corporativos.', image: '/img/servicios/pantallas-led.avif', link: '/servicios/pantallas-led/', btnLabel: 'Ver pantallas LED' },
        { title: 'Iluminación Corporativa', description: 'Iluminación profesional para eventos empresariales, congresos y lanzamientos de productos.', image: '/img/eventos/bodas.avif', link: '/servicios/iluminacion/', btnLabel: 'Ver iluminación' },
      ]
    : [
        { title: 'Iluminación para Bodas', description: 'Renta de equipo de iluminación completo para bodas en CDMX. Incluye instalación y operación.', image: '/img/eventos/bodas.avif', link: '/eventos/bodas/', btnLabel: 'Ver para bodas' },
        { title: 'Cabezas Móviles', description: 'Renta de cabezas móviles para espectáculos de luz profesional. Con instalación incluida.', image: '/img/servicios/cabezas-moviles.avif', link: '/servicios/cabezas-moviles/', btnLabel: 'Ver cabezas móviles' },
        { title: 'Efectos Especiales', description: 'Máquinas de humo, confeti, sparklers y más para crear momentos únicos en tu evento.', image: '/img/servicios/efectos.avif', link: '/servicios/efectos-especiales/', btnLabel: 'Ver efectos' },
      ];

// FAQs by category
const faqsByCategory: Record<string, Array<{ question: string; answer: string }>> = {
  audio: [
    { question: `¿Qué tipo de equipo de audio venden en ${d.nombre}?`, answer: `${d.nombre} se especializa en equipo de audio profesional para eventos: ${d.servicios?.slice(0, 3).join(', ') || 'bocinas, micrófonos y consolas'}. Puedes visitar su local en ${d.alcaldia_municipio} para revisar el inventario disponible o contactarles directamente por teléfono.` },
    { question: `¿${d.nombre} ofrece instalación además de venta?`, answer: `Muchas tiendas de audio en ${zonaLabel[d.zona] ?? d.zona} ofrecen servicios de instalación básicos además de la venta. Te recomendamos contactar directamente a ${d.nombre} para confirmar si cuentan con este servicio y cuál es su costo.` },
    { question: `¿Es mejor comprar o rentar equipo de audio para un evento?`, answer: `Depende de la frecuencia de uso. Si organizas más de 6–8 eventos por año, la compra puede convenir. Para eventos esporádicos como una boda o XV años, rentar es más eficiente: evitas la inversión inicial, el transporte y la logística. REDEIL ofrece renta de sistemas de sonido completos con instalación en CDMX y Estado de México.` },
    { question: `¿Cómo llego a ${d.nombre} en ${d.alcaldia_municipio}?`, answer: `${d.nombre} se ubica en ${d.direccion}. ${d.zona === 'cdmx' ? 'Al estar en la Ciudad de México, puedes llegar en Metro o Metrobús según la alcaldía.' : 'Consulta las rutas de transporte disponibles en la zona.'} Te recomendamos llamar antes de visitar para confirmar disponibilidad de lo que buscas.` },
  ],
  iluminacion: [
    { question: `¿Qué tipo de iluminación para eventos venden en ${d.nombre}?`, answer: `${d.nombre} maneja iluminación de diferentes tipos: ${d.servicios?.slice(0, 3).join(', ') || 'luminarias LED, focos de colores y efectos'}. Es recomendable visitar el local en ${d.alcaldia_municipio} o llamarles para verificar la disponibilidad de equipo específico.` },
    { question: `¿Puedo comprar equipo de iluminación profesional (DMX) para mi evento?`, answer: `Dependiendo de la especialización de ${d.nombre}, pueden tener equipo de control DMX, luminarias escénicas y accesorios profesionales. Para producciones de mayor escala, muchas empresas prefieren rentar equipo para un evento específico, lo cual resulta más económico que la compra.` },
    { question: `¿Cuánto cuesta armar un sistema de iluminación básico para una fiesta?`, answer: `Un sistema básico de iluminación para fiestas puede variar entre $3,000 y $15,000 MXN dependiendo del equipo seleccionado. Incluiría algunas luminarias LED de colores, controlador y accesorios básicos. Para bodas y eventos formales, la renta profesional suele ser más conveniente que la compra.` },
    { question: `¿Es mejor comprar o rentar iluminación para bodas y eventos en ${zonaShort[d.zona] ?? d.zona}?`, answer: `Para eventos únicos como bodas o XV años, la renta es casi siempre la mejor opción. Con REDEIL obtienes equipo profesional —cabezas móviles, láseres, efectos— con instalación y operación incluida. Sin preocuparte por almacenamiento, transporte ni mantenimiento. Contáctanos al 55 3068 2988 para cotizar.` },
  ],
  'audio-video': [
    { question: `¿${d.nombre} vende equipo para videoconferencia y presentaciones corporativas?`, answer: `${d.nombre} se especializa en ${d.servicios?.slice(0, 2).join(' y ') || 'sistemas de audio y video'}. Para proyectos corporativos, ofrecen asesoría técnica para seleccionar el equipo más adecuado según el espacio y las necesidades de comunicación de la empresa.` },
    { question: `¿Qué tipo de pantallas y proyectores manejan?`, answer: `La oferta de pantallas y proyectores varía según el inventario disponible. ${d.nombre} puede asesorarte sobre soluciones de visualización para salas de juntas, auditorios y espacios de presentación. Te recomendamos contactarles directamente para verificar modelos y precios actuales.` },
    { question: `¿Ofrecen instalación de sistemas audiovisuales?`, answer: `${d.nombre} ofrece servicios de instalación e integración de sistemas AV. Esto incluye la instalación física, configuración de software y pruebas de funcionamiento para garantizar que el sistema opere correctamente en tu espacio.` },
    { question: `¿Puedo rentar equipo audiovisual para un evento puntual?`, answer: `Para eventos donde no quieres invertir en la compra de equipo, la renta es la mejor opción. REDEIL ofrece renta de sistemas de sonido, pantallas LED y equipos de iluminación para eventos corporativos en CDMX y Estado de México. Contáctanos al 55 3068 2988.` },
  ],
  dj: [
    { question: `¿Qué marcas de equipo DJ maneja ${d.nombre}?`, answer: `${d.nombre} es la referencia en equipo para DJ en ${d.alcaldia_municipio}. Manejan controladores y equipo de marcas líderes como Pioneer DJ, Native Instruments y Rane, entre otras. Sus asesores tienen conocimiento real del sector y pueden orientarte según tu nivel y tipo de actuaciones.` },
    { question: `¿Puedo probar los controladores antes de comprar?`, answer: `En tiendas especializadas como ${d.nombre} suelen permitir probar el equipo antes de decidir. Es recomendable llamar con anticipación para verificar disponibilidad y si tienen el modelo específico que te interesa para una demostración.` },
    { question: `¿Qué equipo de iluminación necesita un DJ para sus eventos?`, answer: `Un DJ profesional necesita al menos algunas cabezas móviles, strobes y efectos LED para crear un buen show visual. Para eventos grandes, la opción más práctica es rentar el equipo de iluminación. REDEIL ofrece paquetes de iluminación completos para DJs con instalación incluida.` },
    { question: `¿Cómo llego a ${d.nombre} desde cualquier parte de CDMX?`, answer: `${d.nombre} se localiza en ${d.direccion}. ${d.zona === 'cdmx' ? 'La ubicación en el Centro Histórico tiene buena conexión de transporte: Metro Salto del Agua, Pino Suárez y varias líneas de Metrobús pasan cerca.' : 'Consulta las opciones de transporte disponibles en la zona para planear tu visita.'} Confirma horarios llamando al ${d.telefono || 'número disponible en Google Maps'}.` },
  ],
  efectos: [
    { question: `¿Qué tipo de efectos de luz venden en ${d.nombre}?`, answer: `${d.nombre} se especializa en efectos de luz y tecnología LED: ${d.servicios?.slice(0, 3).join(', ') || 'láseres, strobes y efectos LED'}. Su catálogo está orientado a quienes quieren crear ambientes visuales impactantes en eventos, clubs y espacios de entretenimiento.` },
    { question: `¿Los cañones láser son seguros para interiores?`, answer: `Los láseres para eventos deben clasificarse según su potencia y uso. Los láseres de clase 3B y 4 requieren operación por técnicos certificados y medidas de seguridad específicas. En ${d.nombre} pueden asesorarte sobre la clase adecuada para tu aplicación y las restricciones legales vigentes.` },
    { question: `¿Puedo sincronizar los efectos de luz con el sonido?`, answer: `La mayoría del equipo de efectos moderno tiene modo "sound-to-light" que sincroniza los efectos con el ritmo de la música automáticamente. Los sistemas más avanzados usan control DMX para programar secuencias precisas. En ${d.nombre} pueden explicarte las opciones disponibles en su catálogo.` },
    { question: `¿Es mejor comprar o rentar efectos especiales para un evento?`, answer: `Para eventos únicos, la renta es más conveniente: evitas la inversión y te aseguras de que el equipo esté operado correctamente. REDEIL renta cañones láser, máquinas de humo, confeti y efectos especiales para eventos en CDMX y Estado de México, con personal técnico incluido.` },
  ],
};
const faqItems = faqsByCategory[d.categoria] ?? faqsByCategory.iluminacion;

// LocalBusiness schema
const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": d.nombre,
  "description": `${d.nombre} — ${categoriaLabel[d.categoria] ?? d.categoria} en ${zonaLabel[d.zona] ?? d.zona}. ${d.alcaldia_municipio}.`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": d.direccion,
    "addressLocality": d.alcaldia_municipio,
    "addressRegion": d.zona === 'cdmx' ? 'CDMX' : 'Estado de México',
    "addressCountry": "MX",
  },
  ...(d.telefono ? { "telephone": d.telefono } : {}),
  ...(d.rating ? {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": d.rating,
      "reviewCount": d.resenas ?? 1,
      "bestRating": 5,
      "worstRating": 1,
    }
  } : {}),
  ...(d.horario ? { "openingHours": d.horario } : {}),
});
---

<BaseLayout
  title={`${d.nombre} — ${categoriaLabel[d.categoria] ?? d.categoria} en ${d.alcaldia_municipio} | Directorio REDEIL`}
  description={`${d.nombre} en ${d.alcaldia_municipio}. ${d.rating ? `⭐${d.rating} (${d.resenas} reseñas).` : ''} Equipo de ${categoriaLabel[d.categoria] ?? d.categoria} para eventos en ${zonaLabel[d.zona] ?? d.zona}.`}
  canonical={`https://rentadeiluminacion.com/directorio/${empresa.slug}/`}
  schemaMarkup={localBusinessSchema}
>
  <Breadcrumbs
    slot="breadcrumbs"
    items={[
      { label: 'Inicio', href: '/' },
      { label: 'Directorio', href: '/directorio/' },
      { label: zonaLabel[d.zona] ?? d.zona, href: `/directorio/${d.zona}/` },
      { label: d.nombre },
    ]}
  />

  <!-- ── Hero: 2 columnas ── -->
  <section class="ficha-hero">
    <div class="container">
      <div class="ficha-hero__grid">

        <!-- Col 1: datos empresa + CTAs -->
        <div class="ficha-hero__info">
          <div class="ficha-hero__badges">
            <span class="badge badge--cat">{categoriaLabel[d.categoria] ?? d.categoria}</span>
            <span class="badge badge--zona">{zonaShort[d.zona] ?? d.zona}</span>
          </div>

          <h1 class="ficha-hero__name">{d.nombre}</h1>

          {d.rating !== undefined && (
            <div class="ficha-rating">
              <span class="ficha-stars" aria-label={`${d.rating} de 5 estrellas`}>
                {Array.from({ length: 5 }, (_, i) => (
                  <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"
                    class={i < fullStars ? 'star star--full' : (i === fullStars && hasHalf ? 'star star--half' : 'star star--empty')}>
                    <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" fill="currentColor" stroke="currentColor" stroke-width="0.5"/>
                  </svg>
                ))}
              </span>
              <strong class="ficha-rating-val">{d.rating.toFixed(1)}</strong>
              {d.resenas !== undefined && (
                <span class="ficha-resenas">{d.resenas.toLocaleString('es-MX')} reseñas</span>
              )}
            </div>
          )}

          <p class="ficha-hero__addr">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {d.direccion}
          </p>

          <div class="ficha-hero__ctas">
            {d.telefono && (
              <a href={`tel:${d.telefono.replace(/\s/g, '')}`} class="ficha-hero__btn ficha-hero__btn--phone">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.13 12.72 19.79 19.79 0 012.06 4.11 2 2 0 014 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                {d.telefono}
              </a>
            )}
            <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="ficha-hero__btn ficha-hero__btn--maps">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Ver en Maps
            </a>
          </div>
        </div>

        <!-- Col 2: descripción de la empresa -->
        <div class="ficha-hero__desc">
          <p class="ficha-hero__desc-p">{heroDesc1}</p>
          <p class="ficha-hero__desc-p">{heroDesc2}</p>
          <div class="ficha-hero__redeil-hint">
            <span class="ficha-hero__hint-label">¿Prefieres rentar equipo?</span>
            <a href="https://wa.me/525530682988?text=Hola%20REDEIL%2C%20quiero%20cotizar%20iluminaci%C3%B3n%20para%20mi%20evento" target="_blank" rel="noopener noreferrer" class="ficha-hero__hint-link">
              REDEIL — 55 3068 2988 →
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── CtaBar: servicios REDEIL relacionados ── -->

  <!-- ── Contenido principal ── -->
  <div class="container ficha-body">
    <div class="ficha-layout">

      <!-- Columna principal -->
      <main class="ficha-main">

        <!-- Datos de la empresa -->
        <section class="ficha-datos">
          <h2 class="ficha-section-title">Datos de contacto</h2>
          <div class="ficha-datos__grid">
            <div class="ficha-datos__item">
              <div class="ficha-datos__icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <span class="ficha-datos__label">Dirección</span>
                <span class="ficha-datos__val">{d.direccion}</span>
              </div>
            </div>

            {d.telefono && (
              <div class="ficha-datos__item">
                <div class="ficha-datos__icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.13 12.72 19.79 19.79 0 012.06 4.11 2 2 0 014 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                </div>
                <div>
                  <span class="ficha-datos__label">Teléfono</span>
                  <a href={`tel:${d.telefono.replace(/\s/g, '')}`} class="ficha-datos__val ficha-datos__link">{d.telefono}</a>
                </div>
              </div>
            )}

            {d.horario && (
              <div class="ficha-datos__item">
                <div class="ficha-datos__icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div>
                  <span class="ficha-datos__label">Horario</span>
                  <span class="ficha-datos__val">{d.horario}</span>
                </div>
              </div>
            )}

            <div class="ficha-datos__item">
              <div class="ficha-datos__icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
              </div>
              <div>
                <span class="ficha-datos__label">Zona</span>
                <a href={`/directorio/${d.zona}/`} class="ficha-datos__val ficha-datos__link">{zonaLabel[d.zona] ?? d.zona}</a>
              </div>
            </div>

            {(d.facebook || d.instagram) && (
              <div class="ficha-datos__item">
                <div class="ficha-datos__icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                </div>
                <div>
                  <span class="ficha-datos__label">Redes sociales</span>
                  <span class="ficha-datos__val">
                    {d.facebook && <a href={d.facebook} target="_blank" rel="noopener noreferrer" class="ficha-datos__link">Facebook</a>}
                    {d.facebook && d.instagram && ' · '}
                    {d.instagram && <span>{d.instagram}</span>}
                  </span>
                </div>
              </div>
            )}
          </div>
        </section>

        <!-- Servicios que ofrece -->
        {d.servicios && d.servicios.length > 0 && (
          <section class="ficha-servicios">
            <h2 class="ficha-section-title">Servicios que ofrece {d.nombre}</h2>
            <ul class="ficha-servicios__list">
              {d.servicios.map(s => (
                <li class="ficha-servicios__item">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  {s}
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- Contenido descriptivo -->
        <section class="ficha-descripcion prose">
          <Content />
        </section>

        <!-- Mapa -->
        <section class="ficha-mapa">
          <h2 class="ficha-section-title">Cómo llegar a {d.nombre}</h2>
          <div class="ficha-mapa__embed">
            <iframe
              title={`Mapa de ${d.nombre}`}
              src={`https://maps.google.com/maps?q=${encodeURIComponent(d.nombre + ' ' + d.direccion)}&output=embed`}
              width="100%"
              height="340"
              style="border:0;"
              allowfullscreen={false}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
          <p class="ficha-mapa__addr">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {d.direccion}
          </p>
        </section>

      </main>

      <!-- Sidebar sticky -->
      <aside class="ficha-sidebar">
        <div class="ficha-sidebar__card">
          <h3 class="ficha-sidebar__title">Contacto rápido</h3>

          {d.telefono && (
            <a href={`tel:${d.telefono.replace(/\s/g, '')}`} class="ficha-sidebar__tel">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.13 12.72 19.79 19.79 0 012.06 4.11 2 2 0 014 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              {d.telefono}
            </a>
          )}
          <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="ficha-sidebar__maps">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Ver en Google Maps
          </a>
        </div>

        <!-- REDEIL CTA -->
        <div class="ficha-sidebar__cta">
          <p class="ficha-sidebar__cta-label">¿Prefieres rentar?</p>
          <h4 class="ficha-sidebar__cta-title">Renta de equipo con instalación incluida</h4>
          <p class="ficha-sidebar__cta-desc">REDEIL lleva, instala y opera el equipo en tu evento. Sin inversión inicial.</p>
          <a href="https://wa.me/525530682988?text=Hola%20REDEIL%2C%20quiero%20cotizar%20para%20mi%20evento" target="_blank" rel="noopener noreferrer" class="ficha-sidebar__wa-btn">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            55 3068 2988
          </a>
          <a href="/servicios/" class="ficha-sidebar__servicios-link">Ver todos los servicios →</a>
        </div>

        <!-- Zona link -->
        <div class="ficha-sidebar__zona">
          <p class="ficha-sidebar__zona-label">Más tiendas en {zonaLabel[d.zona] ?? d.zona}</p>
          <a href={`/directorio/${d.zona}/`} class="ficha-sidebar__zona-link">
            Ver directorio {zonaShort[d.zona] ?? d.zona} →
          </a>
        </div>
      </aside>

    </div>
  </div>

  <!-- ── Otras tiendas de la misma categoría ── -->
  {otrasEmpresas.length > 0 && (
    <section class="ficha-otras">
      <div class="container">
        <SectionHeader
          title={`Otras tiendas de ${categoriaLabel[d.categoria] ?? d.categoria}`}
          paragraph1={`Más proveedores de equipo de ${categoriaLabel[d.categoria] ?? d.categoria} en ${zonaLabel[d.zona] ?? d.zona} y zona metropolitana.`}
        />
        <div class="ficha-otras__grid">
          {otrasEmpresas.map(e => (
            <DirectoryCard
              nombre={e.data.nombre}
              categoria={e.data.categoria}
              zona={e.data.zona}
              alcaldia_municipio={e.data.alcaldia_municipio}
              telefono={e.data.telefono}
              rating={e.data.rating}
              resenas={e.data.resenas}
              slug={e.slug}
            />
          ))}
        </div>
        <div class="ficha-otras__ver-mas">
          <a href={`/directorio/${d.zona}/`} class="ficha-otras__btn">Ver todo el directorio {zonaShort[d.zona] ?? d.zona} →</a>
        </div>
      </div>
    </section>
  )}

  <!-- ── ¿Prefieres rentar? CTA con ServiceCards ── -->
  <section class="ficha-cta-rentar">
    <div class="container">
      <div class="ficha-cta-rentar__header">
        <h2 class="ficha-cta-rentar__title">¿Prefieres rentar equipo en lugar de comprarlo?</h2>
        <p class="ficha-cta-rentar__desc">REDEIL te lo lleva e instala. Renta de iluminación y audio profesional para eventos en CDMX y Estado de México. Sin inversión inicial, sin preocuparte por transporte ni montaje.</p>
        <div class="ficha-cta-rentar__btns">
          <a href="/contacto/" class="ficha-cta-rentar__btn ficha-cta-rentar__btn--primary">Cotizar mi evento</a>
          <a href="https://wa.me/525530682988?text=Hola%20REDEIL%2C%20quiero%20cotizar%20iluminaci%C3%B3n%20para%20mi%20evento" target="_blank" rel="noopener noreferrer" class="ficha-cta-rentar__btn ficha-cta-rentar__btn--wa">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
      <div class="ficha-cta-rentar__cards">
        {serviciosRelacionados.map(s => (
          <ServiceCard
            title={s.title}
            description={s.description}
            image={s.image}
            link={s.link}
            btnLabel={s.btnLabel}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="ficha-faq">
    <div class="container">
      <SectionHeader
        title={`Preguntas frecuentes sobre ${categoriaLabel[d.categoria] ?? 'equipo'} en ${d.alcaldia_municipio}`}
        paragraph1={`Resolvemos las dudas más comunes sobre comprar equipo de ${categoriaLabel[d.categoria] ?? 'audio e iluminación'} en ${zonaLabel[d.zona] ?? d.zona}.`}
      />
    </div>
    <FaqSection
      items={faqItems}
      waMessage={`Hola REDEIL, quiero saber más sobre equipo de ${categoriaLabel[d.categoria] ?? 'audio e iluminación'} para mi evento.`}
    />
  </section>

</BaseLayout>

