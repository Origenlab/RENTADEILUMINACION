---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ServiceCard from '../../components/ServiceCard.astro';

export async function getStaticPaths() {
  const empresas = await getCollection('directorio', ({ data }) => data.activo !== false);
  return empresas.map((empresa) => ({
    params: { slug: empresa.slug },
    props: { empresa },
  }));
}

interface Props {
  empresa: CollectionEntry<'directorio'>;
}

const { empresa } = Astro.props;
const { Content } = await empresa.render();
const d = empresa.data;

const categoriaLabel: Record<string, string> = {
  audio: 'Audio Profesional',
  iluminacion: 'Iluminación',
  'audio-video': 'Audio & Video',
  dj: 'DJ',
  efectos: 'Efectos',
};

const zonaLabel: Record<string, string> = {
  cdmx: 'Ciudad de México',
  'estado-de-mexico': 'Estado de México',
};

const fullStars = Math.floor(d.rating ?? 0);
const hasHalf = (d.rating ?? 0) - fullStars >= 0.5;

// LocalBusiness schema
const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": d.nombre,
  "description": `${d.nombre} — ${categoriaLabel[d.categoria] ?? d.categoria} en ${zonaLabel[d.zona] ?? d.zona}. ${d.alcaldia_municipio}.`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": d.direccion,
    "addressLocality": d.alcaldia_municipio,
    "addressRegion": d.zona === 'cdmx' ? 'CDMX' : 'Estado de México',
    "addressCountry": "MX",
  },
  ...(d.telefono ? { "telephone": d.telefono } : {}),
  ...(d.rating ? {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": d.rating,
      "reviewCount": d.resenas ?? 1,
      "bestRating": 5,
      "worstRating": 1,
    }
  } : {}),
  ...(d.horario ? { "openingHours": d.horario } : {}),
});

// Servicios REDEIL relacionados
const serviciosRelacionados = d.categoria === 'audio' || d.categoria === 'dj'
  ? [
      { title: 'Bocinas para Eventos', description: 'Renta de bocinas y sistemas de sonido profesional para bodas, XV años y eventos corporativos.', image: '/img/servicios/bocinas.avif', link: '/servicios/bocinas/', btnLabel: 'Ver bocinas' },
      { title: 'DJ para Eventos', description: 'DJ profesional con equipo completo de sonido y mezcla para todo tipo de eventos en CDMX.', image: '/img/servicios/dj.avif', link: '/servicios/bocinas-djs/', btnLabel: 'Ver paquetes DJ' },
      { title: 'Cabezas Móviles', description: 'Renta de cabezas móviles para espectáculos de luz profesional en eventos y conciertos.', image: '/img/servicios/cabezas-moviles.avif', link: '/servicios/cabezas-moviles/', btnLabel: 'Ver iluminación' },
    ]
  : [
      { title: 'Iluminación para Bodas', description: 'Renta de equipo de iluminación completo para bodas en CDMX. Incluye instalación y operación.', image: '/img/eventos/bodas.avif', link: '/eventos/bodas/', btnLabel: 'Ver para bodas' },
      { title: 'Cabezas Móviles', description: 'Renta de cabezas móviles para espectáculos de luz profesional en eventos y conciertos.', image: '/img/servicios/cabezas-moviles.avif', link: '/servicios/cabezas-moviles/', btnLabel: 'Ver cabezas móviles' },
      { title: 'Efectos Especiales', description: 'Máquinas de humo, confeti, sparklers y más para crear momentos únicos en tu evento.', image: '/img/servicios/efectos.avif', link: '/servicios/', btnLabel: 'Ver efectos' },
    ];
---

<BaseLayout
  title={`${d.nombre} — ${categoriaLabel[d.categoria] ?? d.categoria} en ${d.alcaldia_municipio} | Directorio REDEIL`}
  description={`${d.nombre} en ${d.alcaldia_municipio}. ${d.rating ? `⭐${d.rating} (${d.resenas} reseñas).` : ''} Equipo de ${categoriaLabel[d.categoria] ?? d.categoria} para eventos en ${zonaLabel[d.zona] ?? d.zona}.`}
  canonical={`https://rentadeiluminacion.com/directorio/${empresa.slug}/`}
  schemaMarkup={localBusinessSchema}
>
  <Breadcrumbs
    slot="breadcrumbs"
    items={[
      { label: 'Inicio', href: '/' },
      { label: 'Directorio', href: '/directorio/' },
      { label: d.nombre },
    ]}
  />

  <!-- Hero ficha -->
  <section class="ficha-hero">
    <div class="container">
      <div class="ficha-hero__grid">
        <div class="ficha-hero__content">
          <div class="ficha-hero__meta">
            <span class="ficha-badge">{categoriaLabel[d.categoria] ?? d.categoria}</span>
            <span class="ficha-zona">{zonaLabel[d.zona] ?? d.zona}</span>
          </div>
          <h1 class="ficha-hero__name">{d.nombre}</h1>

          {d.rating !== undefined && (
            <div class="ficha-rating">
              <span class="ficha-stars" aria-label={`${d.rating} de 5 estrellas`}>
                {Array.from({ length: 5 }, (_, i) => (
                  <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"
                    class={i < fullStars ? 'star star--full' : (i === fullStars && hasHalf ? 'star star--half' : 'star star--empty')}>
                    <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" fill="currentColor" stroke="currentColor" stroke-width="0.5"/>
                  </svg>
                ))}
              </span>
              <strong class="ficha-rating-val">{d.rating.toFixed(1)}</strong>
              {d.resenas !== undefined && (
                <span class="ficha-resenas">{d.resenas.toLocaleString('es-MX')} reseñas en Google Maps</span>
              )}
            </div>
          )}

          {d.alcaldia_municipio && (
            <p class="ficha-location">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {d.direccion}
            </p>
          )}
        </div>

        <!-- Contacto sidebar -->
        <aside class="ficha-contacto">
          <h2 class="ficha-contacto__title">Información de Contacto</h2>

          {d.telefono && (
            <div class="ficha-contacto__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.13 12.72 19.79 19.79 0 012.06 4.11 2 2 0 014 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              <div>
                <span class="ficha-contacto__label">Teléfono</span>
                <a href={`tel:${d.telefono.replace(/\s/g, '')}`} class="ficha-contacto__val ficha-contacto__link">{d.telefono}</a>
              </div>
            </div>
          )}

          {d.horario && (
            <div class="ficha-contacto__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div>
                <span class="ficha-contacto__label">Horario</span>
                <span class="ficha-contacto__val">{d.horario}</span>
              </div>
            </div>
          )}

          {d.facebook && (
            <div class="ficha-contacto__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              <div>
                <span class="ficha-contacto__label">Facebook</span>
                <a href={d.facebook} target="_blank" rel="noopener noreferrer" class="ficha-contacto__val ficha-contacto__link">Ver página</a>
              </div>
            </div>
          )}

          {d.instagram && (
            <div class="ficha-contacto__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              <div>
                <span class="ficha-contacto__label">Instagram</span>
                <span class="ficha-contacto__val">{d.instagram}</span>
              </div>
            </div>
          )}

          <div class="ficha-contacto__separator"></div>

          <div class="ficha-contacto__cta-label">¿Prefieres RENTAR?</div>
          <a href="https://wa.me/525530682988?text=Hola%20REDEIL%2C%20quiero%20cotizar%20iluminaci%C3%B3n%20para%20mi%20evento" class="ficha-contacto__wa-btn" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            REDEIL — 55 3068 2988
          </a>
          <a href="/servicios/" class="ficha-contacto__servicios-btn">Ver paquetes de renta →</a>
        </aside>
      </div>
    </div>
  </section>

  <!-- Cuerpo principal -->
  <div class="container ficha-body">
    <div class="ficha-main">

      <!-- Servicios que ofrece -->
      {d.servicios && d.servicios.length > 0 && (
        <section class="ficha-servicios">
          <h2 class="ficha-servicios__title">Servicios que ofrece {d.nombre}</h2>
          <ul class="ficha-servicios__list">
            {d.servicios.map(s => (
              <li class="ficha-servicios__item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {s}
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Contenido descriptivo -->
      <section class="ficha-descripcion prose">
        <Content />
      </section>

      <!-- Mapa -->
      <section class="ficha-mapa">
        <h2 class="ficha-mapa__title">Cómo llegar a {d.nombre}</h2>
        <div class="ficha-mapa__embed">
          <iframe
            title={`Mapa de ${d.nombre}`}
            src={`https://maps.google.com/maps?q=${encodeURIComponent(d.nombre + ' ' + d.direccion)}&output=embed`}
            width="100%"
            height="350"
            style="border:0;"
            allowfullscreen={false}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <p class="ficha-mapa__addr">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {d.direccion}
        </p>
      </section>
    </div>
  </div>

  <!-- CTA REDEIL -->
  <section class="ficha-cta">
    <div class="container">
      <div class="ficha-cta__box">
        <h2 class="ficha-cta__title">¿Prefieres rentar equipo en lugar de comprarlo?</h2>
        <p class="ficha-cta__desc">REDEIL te lo lleva e instala. Renta de iluminación profesional para eventos en CDMX y Estado de México. Sin inversión inicial, sin preocuparte por transporte ni montaje.</p>
        <div class="ficha-cta__actions">
          <a href="/contacto/" class="ficha-cta__btn ficha-cta__btn--primary">Cotizar mi evento</a>
          <a href="https://wa.me/525530682988?text=Hola%20REDEIL%2C%20vi%20el%20directorio%20y%20quiero%20cotizar%20iluminaci%C3%B3n%20para%20mi%20evento" class="ficha-cta__btn ficha-cta__btn--wa" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            55 3068 2988
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios REDEIL relacionados -->
  <section class="ficha-relacionados">
    <div class="container">
      <h2 class="ficha-relacionados__title">Servicios REDEIL para complementar tu evento</h2>
      <div class="ficha-relacionados__grid">
        {serviciosRelacionados.map(s => (
          <ServiceCard
            title={s.title}
            description={s.description}
            image={s.image}
            link={s.link}
            btnLabel={s.btnLabel}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero Ficha ── */
  .ficha-hero {
    background: var(--color-secondary, #1a1a2e);
    padding: 3rem 0;
  }

  .ficha-hero__grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }

  .ficha-hero__meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .ficha-badge {
    padding: 0.25rem 0.75rem;
    background: rgba(255,255,255,0.15);
    color: #fff;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .ficha-zona {
    padding: 0.25rem 0.75rem;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.7);
    border-radius: 20px;
    font-size: 0.75rem;
  }

  .ficha-hero__name {
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 2rem;
    font-weight: 800;
    color: #fff;
    margin: 0 0 1rem;
    line-height: 1.2;
  }

  .ficha-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .ficha-stars { display: flex; gap: 2px; }
  .star--full   { color: #F59E0B; }
  .star--half   { color: #F59E0B; opacity: 0.6; }
  .star--empty  { color: rgba(255,255,255,0.3); }

  .ficha-rating-val {
    font-size: 1.125rem;
    font-weight: 700;
    color: #fff;
  }

  .ficha-resenas {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
  }

  .ficha-location {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.75);
    margin: 0;
    line-height: 1.5;
  }

  .ficha-location svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: rgba(255,255,255,0.5);
  }

  /* ── Contacto sidebar ── */
  .ficha-contacto {
    background: #fff;
    border-radius: 12px;
    padding: 1.75rem;
    position: sticky;
    top: calc(var(--header-height, 70px) + 1rem);
  }

  .ficha-contacto__title {
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--c-text, #1C1917);
    margin: 0 0 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--c-border, #E7E0D8);
  }

  .ficha-contacto__item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .ficha-contacto__item svg {
    flex-shrink: 0;
    color: var(--color-primary, #2C5530);
    margin-top: 2px;
  }

  .ficha-contacto__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--c-text-muted, #78716C);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.125rem;
  }

  .ficha-contacto__val {
    display: block;
    font-size: 0.9375rem;
    color: var(--c-text, #1C1917);
    font-weight: 500;
  }

  .ficha-contacto__link {
    color: var(--color-primary, #2C5530);
    text-decoration: none;
  }

  .ficha-contacto__link:hover {
    text-decoration: underline;
  }

  .ficha-contacto__separator {
    border: 0;
    border-top: 1px solid var(--c-border, #E7E0D8);
    margin: 1.25rem 0;
  }

  .ficha-contacto__cta-label {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--c-text-muted, #78716C);
    margin-bottom: 0.625rem;
  }

  .ficha-contacto__wa-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.8rem 1rem;
    background: #25D366;
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 8px;
    margin-bottom: 0.5rem;
    font-family: var(--font-primary, 'Montserrat', sans-serif);
  }

  .ficha-contacto__servicios-btn {
    display: block;
    width: 100%;
    padding: 0.7rem 1rem;
    background: var(--c-bg-alt, #F7F4F0);
    color: var(--c-text, #1C1917);
    font-size: 0.875rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    border-radius: 8px;
    border: 1px solid var(--c-border, #E7E0D8);
  }

  /* ── Body ── */
  .ficha-body {
    padding: 3rem 0;
  }

  .ficha-main {
    max-width: 760px;
  }

  /* ── Servicios ── */
  .ficha-servicios {
    margin-bottom: 2.5rem;
  }

  .ficha-servicios__title {
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--c-text, #1C1917);
    margin: 0 0 1rem;
  }

  .ficha-servicios__list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
