---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Hero from '../components/Hero.astro';
import CtaBar from '../components/CtaBar.astro';
import ZoneCards from '../components/ZoneCards.astro';
import SectionHeader from '../components/SectionHeader.astro';

const title = "Zonas de Cobertura | Iluminación CDMX y Estado de México | REDEIL";
const description = "REDEIL cubre las 16 alcaldías de CDMX y 10+ municipios del Estado de México. Renta de iluminación profesional con instalación incluida en Polanco, Coyoacán, Naucalpan, Toluca y más.";
const canonical = "https://rentadeiluminacion.com/zonas-de-cobertura/";
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Zonas de Cobertura" }]} />
</Fragment>
    <Hero
      title="Zonas de Cobertura en CDMX y Estado de México"
      subtitle="Iluminación profesional en todas las alcaldías de la Ciudad de México y principales municipios del Estado de México."
      cotizarHref="/contacto/"
      whatsappText="Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20evento%20en%20CDMX"
      stats={[
        { value: "16", label: "Alcaldías CDMX" },
        { value: "25+", label: "Municipios Edomex" },
        { value: "30+", label: "Años de experiencia" },
      ]}
      introParagraph1='Con más de 30 años operando en la zona metropolitana, <strong>REDEIL</strong> garantiza cobertura completa en todas las alcaldías de CDMX y los principales municipios del Estado de México. Logística propia, sin subcontrataciones — el mismo equipo que cotiza es el que instala y opera.'
      introParagraph2='Cada servicio incluye <strong>transporte e instalación incluidos</strong> en la zona metropolitana. El equipo llega al venue 4–6 horas antes del evento para montaje y pruebas. ¿Tienes dudas sobre tu zona? Escríbenos y te confirmamos en minutos.'
    />


    <!-- Featured Zones -->
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>Zonas Destacadas</h2>
          <p>Nuestras zonas con mayor demanda de servicios de iluminación</p>
        </div>
        <div class="services-grid">

          <div class="service-card">
            <a href="/zonas/coyoacan/">
              <picture>
                <img src="/img/zonas/coyoacan-bodas-jardines.avif" alt="Renta de iluminación para bodas en Coyoacán CDMX" width="400" height="300" loading="lazy">
              </picture>
            </a>
            <div class="service-card-content">
              <h3>Coyoacán - Bodas</h3>
              <p>Iluminación romántica para bodas y XV años en las haciendas y jardines de Coyoacán, San Ángel y Tlalpan. 350+ eventos/año. Guirnaldas, gobos y cascadas LED.</p>
              <a href="/zonas/coyoacan/" class="btn btn-primary">Ver zona</a>
            </div>
          </div>

          <div class="service-card">
            <a href="/zonas/polanco/">
              <picture>
                <img src="/img/zonas/polanco-eventos-iluminacion.avif" alt="Renta de iluminación para eventos en Polanco CDMX" width="400" height="300" loading="lazy">
              </picture>
            </a>
            <div class="service-card-content">
              <h3>Polanco - Corporativo</h3>
              <p>Iluminación de lujo para eventos corporativos, lanzamientos y galas. 200+ eventos corporativos/año. Equipamiento premium en Polanco y Lomas.</p>
              <a href="/zonas/polanco/" class="btn btn-primary">Ver zona</a>
            </div>
          </div>

          <div class="service-card">
            <a href="/zonas/benito-juarez/">
              <picture>
                <img src="/img/zonas/condesa-roma-rooftops.avif" alt="Renta de iluminación para eventos en Benito Juárez CDMX" width="400" height="300" loading="lazy">
              </picture>
            </a>
            <div class="service-card-content">
              <h3>Benito Juárez - Accesible</h3>
              <p>Centro CDMX. Respuesta rápida en 30 minutos. Montaje en 2 horas. 400+ eventos/año. Presupuesto accesible desde $3,500.</p>
              <a href="/zonas/benito-juarez/" class="btn btn-primary">Ver zona</a>
            </div>
          </div>

          <div class="service-card">
            <a href="/zonas-de-cobertura/">
              <picture>
                <img src="/img/zonas/santa-fe-eventos-corporativos.avif" alt="Renta de iluminación para eventos corporativos en Santa Fe CDMX" width="400" height="300" loading="lazy">
              </picture>
            </a>
            <div class="service-card-content">
              <h3>Santa Fe - Corporativo</h3>
              <p>Soluciones de iluminación para eventos corporativos, convenciones y galas empresariales en la zona financiera de Santa Fe y sus centros de convenciones.</p>
              <a href="/contacto/" class="btn btn-primary">Cotizar</a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ZoneCards Component -->
    <section class="section">
      <div class="container">
        <SectionHeader
          title="Cobertura Completa CDMX y Estado de México"
          subtitle="Las 16 alcaldías de CDMX y los principales municipios del Edomex. Instalación incluida en toda la zona metropolitana."
          paragraph1="Operamos desde la Ciudad de México con logística propia. El equipo llega al venue 4–6 horas antes del evento, sin cargos adicionales por traslado en la zona metropolitana."
          paragraph2="¿Tu venue está fuera de la zona? Contáctanos de todas formas — atendemos eventos en todo el Estado de México y podemos cotizar traslado para otros estados."
        />
        <ZoneCards />
      </div>
    </section>

    <!-- Coverage Grid — 16 Alcaldías CDMX -->
    <section class="section coverage-section" style="background-color: var(--color-gray-100);">
      <div class="container">
        <div class="section-header">
          <h2>Las 16 Alcaldías de CDMX</h2>
          <p>Cubrimos toda la Ciudad de México — de Xochimilco a Gustavo A. Madero</p>
        </div>
        <div class="coverage-grid">

          <div class="coverage-column">
            <h3>Alcaldías Poniente y Centro</h3>
            <div class="coverage-lists">
              <ul class="coverage-list">
                <li>Miguel Hidalgo</li>
                <li>Cuauhtémoc</li>
                <li>Benito Juárez</li>
                <li>Álvaro Obregón</li>
              </ul>
            </div>
          </div>

          <div class="coverage-column">
            <h3>Alcaldías Sur</h3>
            <div class="coverage-lists">
              <ul class="coverage-list">
                <li>Coyoacán</li>
                <li>Tlalpan</li>
                <li>Xochimilco</li>
                <li>Milpa Alta</li>
                <li>Magdalena Contreras</li>
                <li>Tláhuac</li>
              </ul>
            </div>
          </div>

          <div class="coverage-column">
            <h3>Alcaldías Norte y Oriente</h3>
            <div class="coverage-lists">
              <ul class="coverage-list">
                <li>Azcapotzalco</li>
                <li>Gustavo A. Madero</li>
                <li>Venustiano Carranza</li>
                <li>Iztapalapa</li>
                <li>Iztacalco</li>
                <li>Cuajimalpa</li>
              </ul>
            </div>
          </div>

          <div class="coverage-column">
            <h3>Municipios Estado de México</h3>
            <div class="coverage-lists">
              <ul class="coverage-list">
                <li>Naucalpan</li>
                <li>Huixquilucan (Interlomas)</li>
                <li>Tlalnepantla</li>
                <li>Atizapán de Zaragoza</li>
                <li>Ecatepec</li>
                <li>Coacalco</li>
                <li>Cuautitlán Izcalli</li>
                <li>Tecámac</li>
                <li>Texcoco</li>
                <li>Toluca</li>
                <li>Metepec</li>
              </ul>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Tu evento está en CDMX o Estado de México?</h2>
          <p>Con más de 3,000 eventos realizados en la zona metropolitana, sabemos cómo llegar, cuándo llegar y cómo instalar en cualquier venue.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>
</BaseLayout>
