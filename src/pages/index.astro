---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';

const title = "Renta de Iluminación para Eventos en CDMX | REDEIL";
const description = "Renta de iluminación para bodas, XV años y eventos en CDMX. Guirnaldas, Sky Tracker, cabezas móviles. Instalación incluida.";
const canonical = "https://rentadeiluminacion.com/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "REDEIL - Renta de Iluminación Profesional",
    "alternateName": "REDEIL",
    "telephone": "+52-55-3068-2988",
    "email": "hola@rentadeiluminacion.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Río Amazonas 74B, Col. Renacimiento",
      "addressLocality": "Ciudad de México",
      "addressRegion": "CDMX",
      "postalCode": "06500",
      "addressCountry": "MX"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 19.4326,
      "longitude": -99.1332
    },
    "priceRange": "$$",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "reviewCount": "127"
    },
    "url": "https://rentadeiluminacion.com/",
    "image": "https://rentadeiluminacion.com/img/og/og-image-redeil.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "REDEIL - Renta de Iluminación",
    "url": "https://rentadeiluminacion.com/",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://rentadeiluminacion.com/?s={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cómo puedo cotizar la renta de iluminación para mi evento?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Puedes cotizar tu evento contactándonos por WhatsApp al 55 3068 2988, por correo a hola@rentadeiluminacion.com o a través de nuestro formulario de contacto. Cuéntanos la fecha, lugar y tipo de evento para enviarte una cotización personalizada sin compromiso."
        }
      },
      {
        "@type": "Question",
        "name": "¿La instalación está incluida en el servicio de renta?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí, todos nuestros servicios de renta de iluminación incluyen transporte, instalación profesional, operación durante el evento y desmontaje. Nuestro equipo técnico se encarga de todo para que tú solo disfrutes de tu evento."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cubren eventos en el Estado de México?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí, además de toda la Ciudad de México, cubrimos el Estado de México incluyendo Naucalpan, Huixquilucan, Interlomas, Tlalnepantla, Atizapán, Metepec, Toluca, Cuautitlán, Coacalco, Ecatepec, Tecámac y Texcoco."
        }
      }
    ]
  }
]);

const services = [
  {
    title: "Guirnaldas",
    image: "/img/guirnaldas/renta-guirnaldas-edison-terraza-recepcion-02-300w.avif",
    description: "Luces LED vintage perfectas para bodas, jardines y eventos al aire libre. Ambiente cálido y romántico.",
    link: "/renta-de-iluminacion/renta-de-guirnaldas.html"
  },
  {
    title: "Luces Neón",
    image: "/img/luces-neon/renta-luces-neon-glow-party-celebracion-neon-300w.avif",
    description: "Iluminacion neon, luz UV y efectos glow para fiestas espectaculares con colores vibrantes.",
    link: "/renta-de-iluminacion/renta-de-luces-neon.html"
  },
  {
    title: "Luz Negra",
    image: "/img/luz-negra/luz-negra-fiesta-neon-300w.avif",
    description: "Iluminación UV para fiestas temáticas, efectos fluorescentes y ambientes únicos.",
    link: "/renta-de-iluminacion/renta-de-luz-negra.html"
  },
  {
    title: "City Color",
    image: "/img/city-color/renta-luces-hacienda-boda-fuente-300w.avif",
    description: "Iluminación de alto impacto para fachadas, escenarios y grandes espacios con colores vibrantes.",
    link: "/renta-de-iluminacion/renta-de-city-color.html"
  },
  {
    title: "City Light",
    image: "/img/city-color/iluminacion-salon-boda-rosa-300w.avif",
    description: "Luminarias profesionales para iluminar espacios amplios con luz potente y uniforme.",
    link: "/renta-de-iluminacion/renta-de-city-light.html"
  },
  {
    title: "Sky Tracker",
    image: "/img/sky-tracker/renta-skytracker-cielo-nocturno-potente-300w.avif",
    description: "Potentes haces de luz que iluminan el cielo. Ideales para XV años, inauguraciones y eventos especiales.",
    link: "/renta-de-iluminacion/renta-de-sky-tracker.html"
  },
  {
    title: "Cabezas Móviles",
    image: "/img/cabezas-moviles/renta-cabezas-moviles-show-luces-beams-colores-300w.avif",
    description: "Luces robotizadas con movimiento y efectos dinámicos para shows y pistas de baile.",
    link: "/renta-de-iluminacion/renta-de-cabezas-moviles.html"
  },
  {
    title: "Cascadas LED",
    image: "/img/cascadas-led/renta-cascada-led-cortina-luces-mesa-novios-300w.avif",
    description: "Cortinas de luces que caen como cascada. Perfectas para fondos de mesa y decoración elegante.",
    link: "/renta-de-iluminacion/renta-de-cascadas-led.html"
  },
  {
    title: "Gobos",
    image: "/img/gobos/renta-gobo-proyeccion-logo-evento-corporativo-300w.avif",
    description: "Proyección de logos, nombres o diseños personalizados en paredes y pisos.",
    link: "/renta-de-iluminacion/renta-de-gobos.html"
  },
  {
    title: "Iluminación Arquitectónica",
    image: "/img/iluminacion-arquitectonica/renta-iluminacion-arquitectonica-hacienda-boda-300w.avif",
    description: "Iluminación para resaltar fachadas, columnas, árboles y elementos arquitectónicos.",
    link: "/renta-de-iluminacion/renta-de-iluminacion-arquitectonica.html"
  },
  {
    title: "Seguidor",
    image: "/img/seguidor/renta-seguidor-spotlight-vals-boda-300w.avif",
    description: "Luz de seguimiento profesional para destacar personas en escenario, vals y momentos especiales.",
    link: "/renta-de-iluminacion/renta-de-seguidor.html"
  }
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

  <!-- Breadcrumb -->
  <section class="breadcrumb-section">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item active" aria-current="page">Inicio</li>
        </ol>
      </nav>
    </div>
  </section>

  <main id="main-content">

    <!-- HERO -->
    <section class="hero hero-two-columns hero-home">
      <div class="hero-background" style="background-color: var(--color-secondary);"></div>
      <div class="container">
        <div class="hero-grid">
          <div class="hero-content">
            <h1 class="hero-title">Renta de Iluminación Profesional para Eventos en CDMX</h1>
            <p class="hero-subtitle">Transforma tu boda, XV años o evento corporativo con iluminacion que crea momentos inolvidables</p>
            <div class="hero-ctas">
              <a href="/contacto/" class="btn btn-primary">Cotiza tu Evento</a>
              <a href="https://wa.me/525530682988?text=Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20evento" class="btn btn-whatsapp" target="_blank" rel="noopener noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>
          <div class="hero-intro">
            <p><strong>REDEIL</strong> es la empresa líder en <strong>renta de iluminacion para eventos sociales</strong> en Ciudad de México y Estado de México. Ofrecemos soluciones completas de iluminacion profesional para <strong>bodas, XV años, fiestas, eventos corporativos</strong> y celebraciones especiales. Nuestro catálogo incluye guirnaldas LED, sky trackers, cabezas móviles, iluminacion arquitectonica, cascadas luminosas, luz neón, efectos especiales y mucho más, todo con equipo de marcas reconocidas como Martin Professional, Chauvet y Elation.</p>
            <p>Con más de <strong>30 años de experiencia</strong> y <strong>500 eventos realizados</strong> en la zona metropolitana, en REDEIL nos encargamos de todo: transporte, instalación profesional, operación durante tu evento y desmontaje. Atendemos Polanco, Santa Fe, Coyoacán, Condesa, Naucalpan, Huixquilucan, Tlalnepantla, Metepec y toda la CDMX. <strong>Cotiza sin compromiso</strong> y descubre por qué somos la opción preferida para iluminar los momentos más importantes de tu vida.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="services-section">
      <div class="container">
        <div class="section-header">
          <h2>Servicios de Iluminación</h2>
          <p class="section-subtitle">Soluciones profesionales para cada tipo de evento</p>
        </div>
        <div class="services-grid">
          {services.map((service) => (
            <ServiceCard
              title={service.title}
              image={service.image}
              description={service.description}
              link={service.link}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="why-us-section">
      <div class="container">
        <h2>¿Por Qué Elegir REDEIL?</h2>
        <div class="features-grid">
          <div class="feature-card">
            <h3>Instalación Incluida</h3>
            <p>Transporte, montaje profesional, operación durante tu evento y desmontaje. Nos encargamos de todo para que tú solo disfrutes.</p>
          </div>
          <div class="feature-card">
            <h3>Equipo Profesional</h3>
            <p>Trabajamos con marcas líderes como Martin Professional, Chauvet y Elation. Equipo de última generación siempre en óptimas condiciones.</p>
          </div>
          <div class="feature-card">
            <h3>+500 Eventos Realizados</h3>
            <p>Más de 30 años de experiencia iluminando bodas, XV años, eventos corporativos y celebraciones especiales en CDMX y Estado de México.</p>
          </div>
          <div class="feature-card">
            <h3>Cobertura Total</h3>
            <p>Atendemos toda la Ciudad de México y Estado de México: Polanco, Santa Fe, Coyoacán, Naucalpan, Huixquilucan, Metepec y más.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Coverage Zones -->
    <section class="coverage-section">
      <div class="container">
        <h2>Zonas de Cobertura</h2>
        <div class="coverage-grid">
          <div class="coverage-column">
            <h3>Ciudad de México</h3>
            <ul>
              <li>Polanco</li>
              <li>Santa Fe</li>
              <li>Coyoacán</li>
              <li>Condesa / Roma</li>
              <li>Pedregal</li>
              <li>Del Valle</li>
              <li>Nápoles</li>
              <li>Xochimilco</li>
              <li>Tlalpan</li>
              <li>Azcapotzalco</li>
            </ul>
          </div>
          <div class="coverage-column">
            <h3>Estado de México</h3>
            <ul>
              <li>Naucalpan</li>
              <li>Huixquilucan</li>
              <li>Interlomas</li>
              <li>Tlalnepantla</li>
              <li>Atizapán</li>
              <li>Metepec</li>
              <li>Toluca</li>
              <li>Cuautitlán</li>
              <li>Coacalco</li>
              <li>Ecatepec</li>
              <li>Tecámac</li>
              <li>Texcoco</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

  </main>

</BaseLayout>
