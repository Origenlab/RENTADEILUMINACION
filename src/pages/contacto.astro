                    <span>XV Años</span>
                  </button>
                  <button type="button" class="wizard-event-btn" data-value="Fiesta / Otro">
                    <span class="wizard-event-btn__icon">🎉</span>
                    <span>Fiesta / Otro</span>
                  </button>
                </div>
              </div>

              <!-- Paso 2: Servicios -->
              <div class="wizard-step" id="wizard-step-2" hidden>
                <h3 class="wizard-step__title">¿Qué necesitas para tu evento?</h3>
                <p class="wizard-step__hint">Puedes seleccionar varios</p>
                <div class="wizard-services">
                  <label class="wizard-service-option">
                    <input type="checkbox" value="Iluminación" name="servicio">
                    <span class="wizard-service-option__content">
                      <span class="wizard-service-option__icon">💡</span>
                      <span>Iluminación</span>
                    </span>
                  </label>
                  <label class="wizard-service-option">
                    <input type="checkbox" value="Sonido / DJ" name="servicio">
                    <span class="wizard-service-option__content">
                      <span class="wizard-service-option__icon">🔊</span>
                      <span>Sonido / DJ</span>
                    </span>
                  </label>
                  <label class="wizard-service-option">
                    <input type="checkbox" value="Efectos Especiales" name="servicio">
                    <span class="wizard-service-option__content">
                      <span class="wizard-service-option__icon">✨</span>
                      <span>Efectos Especiales</span>
                    </span>
                  </label>
                  <label class="wizard-service-option">
                    <input type="checkbox" value="Paquete Completo" name="servicio">
                    <span class="wizard-service-option__content">
                      <span class="wizard-service-option__icon">📦</span>
                      <span>Paquete Completo</span>
                    </span>
                  </label>
                </div>
                <div class="wizard-nav">
                  <button type="button" class="btn btn-outline" id="wizard-back-2">← Regresar</button>
                  <button type="button" class="btn btn-primary" id="wizard-next-2">Continuar →</button>
                </div>
              </div>

              <!-- Paso 3: WhatsApp -->
              <div class="wizard-step" id="wizard-step-3" hidden>
                <h3 class="wizard-step__title">¿Cuál es tu número de WhatsApp?</h3>
                <p class="wizard-step__hint">Te enviamos la cotización directamente ahí</p>
                <div class="wizard-phone-group">
                  <input type="tel" id="wizard-phone" name="telefono" placeholder="55 1234 5678" class="wizard-phone-input" inputmode="tel">
                </div>
                <div class="wizard-nav">
                  <button type="button" class="btn btn-outline" id="wizard-back-3">← Regresar</button>
                  <button type="button" class="btn btn-whatsapp btn-lg" id="wizard-submit" style="flex: 1;">
