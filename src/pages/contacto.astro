                <a href="https://wa.me/525530682988?text=Hola,%20quiero%20cotizar%20iluminaci%C3%B3n%20para%20mi%20evento" class="btn btn-whatsapp btn-lg" target="_blank" rel="noopener noreferrer">
                  Cotizar por WhatsApp →
                </a>
              </p>
            </noscript>
          </div>

          <!-- Contact Sidebar -->
          <div class="contact-sidebar">
            <div class="contact-info-card">
              <h3>Información de Contacto</h3>

              <div class="contact-info-item">
