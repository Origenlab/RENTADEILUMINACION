    color: #888;
    margin: 0;
  }
  .wizard-step__title {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: #1a1a2e;
  }
  .wizard-step__hint {
    font-size: 0.875rem;
    color: #888;
    margin-bottom: 1rem;
  }
  .wizard-event-types {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .wizard-event-btn {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 2px solid #e9ecef;
    border-radius: 12px;
    background: #fff;
    font-size: 1.1rem;
    font-weight: 600;
    color: #1a1a2e;
    cursor: pointer;
    text-align: left;
    transition: border-color 0.2s, background 0.2s;
    width: 100%;
  }
  .wizard-event-btn:hover,
  .wizard-event-btn.selected {
    border-color: #ff5722;
    background: #fff8f6;
  }
  .wizard-event-btn__icon {
    font-size: 1.75rem;
    line-height: 1;
  }
  .wizard-services {
