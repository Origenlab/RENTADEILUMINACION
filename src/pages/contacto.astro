                <svg viewBox="0 0 24 24" width="24" height="24" fill="var(--color-primary)"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                <div>
                  <strong>Correo Electrónico</strong>
                  <a href="mailto:hola@rentadeiluminacion.com">hola@rentadeiluminacion.com</a>
                </div>
              </div>

              <div class="contact-info-item">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="var(--color-primary)"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
                <div>
                  <strong>Horario de Atención</strong>
                  <span>Lunes a Domingo: 8:00 - 18:00</span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Branches -->
    <section class="section" style="background-color: var(--color-gray-100);">
