<style>
  /* ===== WIZARD FORM ===== */
  .wizard-progress {
    margin-bottom: 1.5rem;
  }
  .wizard-progress__bar {
    height: 6px;
    background: #e9ecef;
    border-radius: 99px;
    overflow: hidden;
    margin-bottom: 0.4rem;
  }
  .wizard-progress__fill {
    height: 100%;
    background: #ff5722;
    border-radius: 99px;
    transition: width 0.3s ease;
  }
  .wizard-progress__label {
