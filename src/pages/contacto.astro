              <span>Blvd. Manuel Ávila Camacho 5, Lomas de Sotelo, Piso 10, Torre B, C.P. 53390</span>
            </address>
          </div>

          <div class="footer-branch">
            <h5 class="footer-branch-title">Tlalnepantla</h5>
            <address class="footer-branch-address">
              <svg viewBox="0 0 24 24" width="16" height="16"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              <span>Emilio Carranza 17, Tlalnepantla Centro, C.P. 54000</span>
            </address>
          </div>

        </div>
