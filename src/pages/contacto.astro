  }
  .wizard-phone-group {
    margin-bottom: 1.25rem;
  }
  .wizard-phone-input {
    width: 100%;
    padding: 1rem;
    font-size: 1.1rem;
    border: 2px solid #e9ecef;
    border-radius: 12px;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }
  .wizard-phone-input:focus {
    border-color: #ff5722;
  }
