    text-decoration: none;
    transition: border-color 0.2s;
  }
  .btn-outline:hover {
    border-color: #aaa;
  }
</style>

<script is:inline>
  (function() {
    var selectedEvent = '';
    var currentStep = 1;

    function goToStep(step) {
      document.getElementById('wizard-step-1').hidden = step !== 1;
      document.getElementById('wizard-step-2').hidden = step !== 2;
      document.getElementById('wizard-step-3').hidden = step !== 3;
      currentStep = step;
      var fill = document.getElementById('wizard-progress-fill');
      var label = document.getElementById('wizard-step-label');
      var pct = step === 1 ? '33.33%' : step === 2 ? '66.66%' : '100%';
      fill.style.width = pct;
      label.textContent = 'Paso ' + step + ' de 3';
    }

    // Paso 1: seleccionar tipo de evento
    var eventBtns = document.querySelectorAll('.wizard-event-btn');
    eventBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        eventBtns.forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');
        selectedEvent = btn.getAttribute('data-value');
        setTimeout(function() { goToStep(2); }, 200);
      });
    });

    // Paso 2: continuar / regresar
    document.getElementById('wizard-back-2').addEventListener('click', function() { goToStep(1); });
    document.getElementById('wizard-next-2').addEventListener('click', function() {
      goToStep(3);
    });

    // Paso 3: regresar / enviar
    document.getElementById('wizard-back-3').addEventListener('click', function() { goToStep(2); });
    document.getElementById('wizard-submit').addEventListener('click', function() {
      var phone = document.getElementById('wizard-phone').value.trim();
      var checkedServices = [];
      document.querySelectorAll('input[name="servicio"]:checked').forEach(function(cb) {
        checkedServices.push(cb.value);
      });

      var text = 'Hola, quiero cotizar iluminación para mi evento.\n\n';
      if (selectedEvent) text += '*Tipo de evento:* ' + selectedEvent + '\n';
      if (checkedServices.length) text += '*Servicios:* ' + checkedServices.join(', ') + '\n';
      if (phone) text += '*Mi WhatsApp:* ' + phone + '\n';

      var url = 'https://wa.me/525530682988?text=' + encodeURIComponent(text);
      window.open(url, '_blank');
    });
  })();
</script>

</BaseLayout>
