  }
  .wizard-service-option input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .wizard-service-option__content {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 2px solid #e9ecef;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a2e;
    transition: border-color 0.2s, background 0.2s;
