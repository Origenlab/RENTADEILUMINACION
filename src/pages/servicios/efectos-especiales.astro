---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Efectos Especiales para Eventos CDMX | REDEIL";
const description = "Humo bajo, confeti, burbujas, bola disco y más para tu boda o fiesta. Operación profesional incluida. 7 efectos disponibles. Cotiza por WhatsApp.";
const canonical = "https://rentadeiluminacion.com/servicios/efectos-especiales/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Efectos Especiales para Eventos",
  "provider": { "@type": "LocalBusiness", "name": "REDEIL", "url": "https://rentadeiluminacion.com", "telephone": "+525530682988" },
  "description": "Servicio profesional de efectos especiales para bodas, XV años y eventos en CDMX. Humo bajo, confeti, burbujas y más.",
  "areaServed": { "@type": "City", "name": "Ciudad de México" }
});

const servicios = [
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Humo bajo creando nube a nivel de piso en vals de boda", description: "La nube mágica a nivel de piso para el vals. Equipos JEM ZR33 y Antari ICE-101 con fluido farmacéutico certificado. El efecto más solicitado en bodas.", link: "/servicios/humo-bajo/" },
  { title: "Máquina de Humo", image: "/img/humo-bajo/efecto-humo-bajo-baile-novios.avif", alt: "Humo escénico en pista de baile", description: "Humo atmosférico Antari Z-1500 para crear neblina en pistas de baile. El show de luces se multiplica con humo.", link: "/servicios/maquina-humo/" },
  { title: "Confeti", image: "/img/confeti/confeti-dorado-boda-novios-fiesta.avif", alt: "Cañón de confeti dorado en celebración de boda", description: "Cañones de CO₂ que lanzan confeti dorado, plateado o multicolor a 10 metros de altura. El momento más fotografiado.", link: "/servicios/confeti/" },
  { title: "Confeti para Bodas", image: "/img/confeti/confeti-dorado-boda-novios-fiesta.avif", alt: "Confeti y pétalos para salida de iglesia", description: "Confeti biodegradable y pétalos para la salida de iglesia y el vals. Coordinado con el fotógrafo para el timing perfecto.", link: "/servicios/confeti-papelitos/" },
  { title: "Máquina CO₂", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Cañones de CO2 para entrada de novios", description: "Columnas de vapor frío que se disparan a control remoto. No activan alarmas, no dejan residuo. Desde $3,500 + IVA.", link: "/servicios/co2/" },
  { title: "Bengalas Frías", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Sparklers bengalas frías para boda", description: "Chispas de titanio sin calor, sin humo. Columnas de 1-3m aprobadas para interiores. Sparkular y Showven.", link: "/servicios/sparklers/" },
  { title: "Burbujas", image: "/img/burbujas/burbujas-gigantes-fiesta-cumpleanos-ninos-400w.avif", alt: "Máquina de burbujas en fiesta infantil", description: "Lluvia continua de burbujas y burbujas gigantes. Encanta a los niños, es fotogénico en bodas, funciona en todos los eventos.", link: "/servicios/burbujas/" },
  { title: "Bola Disco", image: "/img/bola-disco/bola-disco-dj-pista-baile-evento.avif", alt: "Bola disco gigante en pista de baile", description: "Bola de espejos de 30cm a 1.2m con motor y focos PAR. Destellos que llenan la pista — atemporal y siempre efectiva.", link: "/servicios/bola-disco/" },
  { title: "Robot LED", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante-300w.avif", alt: "Robot LED automatizado para pista de baile", description: "Robots de luz con movimiento motorizado que reaccionan a la música automáticamente. Show de luces sin operador.", link: "/servicios/robot-led/" },
  { title: "Pantalla Inflable", image: "/img/pantalla-inflable/alquiler-pantalla-inflable-aniversario-boda.avif", alt: "Pantalla inflable para cine al aire libre", description: "Pantalla de 3 a 10+ metros con proyector HD y audio. Cine al aire libre en 15 minutos. Bodas, fiestas y corporativos.", link: "/servicios/pantalla-inflable/" },
  { title: "Podium de Acrílico", image: "/img/podiums/conferencia-corporativa-podium-acrilico-auditorio-luces-azules-300w.avif", alt: "Podium profesional en auditorio corporativo", description: "Atriles de acrílico cristalino 10mm para conferencias, bodas y congresos. Iluminación LED base opcional.", link: "/servicios/podiums/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Servicios", href: "/servicios/" }, { label: "Efectos Especiales" }]} />
</Fragment>

    <Hero
      title="Efectos Especiales para Eventos en CDMX"
      subtitle="11 efectos con operador incluido. Lo que la gente recuerda de un evento no es la comida — es el momento que los puso de pie."
      introParagraph1='Humo bajo <strong>JEM ZR33</strong> y <strong>Antari ICE-101</strong> para el vals. Cañones de CO₂ para la entrada. Bengalas frías <strong>Sparkular</strong> que no activan alarmas. Confeti biodegradable que se barre en 10 minutos. Burbujas, bola disco, robot LED, pantalla inflable. En <strong>REDEIL</strong> operamos 11 efectos distintos y los coordinamos con el DJ y el fotógrafo para que cada disparo suceda en el segundo exacto. Si el fotógrafo no estaba listo, el confeti se desperdició.'
      introParagraph2='El operador llega con el equipo, instala, hace pruebas antes de que lleguen los invitados y activa cada efecto a control remoto durante el evento. Importante: no todos los efectos funcionan en todos los espacios. El humo bajo necesita piso frío para mantenerse abajo. Las burbujas dependen del viento. La pantalla inflable necesita oscuridad. Te decimos qué funciona en tu venue antes de cotizar.'
    />

    <CtaBar
      headline="¿Qué efecto quieres para tu evento?"
      items={[
        { label: "Humo Bajo", href: "/servicios/humo-bajo/", icon: "efectos" },
        { label: "Confeti", href: "/servicios/confeti/", icon: "efectos" },
        { label: "Burbujas", href: "/servicios/burbujas/", icon: "efectos" },
        { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
      ]}
    />

    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="Catálogo de Efectos Especiales"
          subtitle="11 efectos — cada uno con su momento en el protocolo del evento."
          paragraph1="El humo bajo va en el vals, no antes. El confeti se dispara en el brindis o en la salida, no en los dos porque pierde impacto. Las bengalas frías funcionan mejor como recibimiento. Las burbujas son para la sesión de fotos o la entrada de los niños. Cada efecto tiene un momento y el operador lo activa en coordinación con el DJ."
          paragraph2="La mayoría de las bodas llevan 2 o 3 efectos. No tiene sentido contratar los 11. Te ayudamos a elegir los que realmente hacen diferencia en tu tipo de evento y en tu venue."
        />
        <div class="services-grid">
          {servicios.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre Efectos Especiales"
          subtitle="Lo que nos preguntan por WhatsApp antes de apartar fecha."
          paragraph1="Si tu duda no está aquí, mándanos mensaje y te contestamos en minutos."
          paragraph2=""
        />
      </div>
      <FaqSection items={[
        { question: "¿El humo bajo activa las alarmas contra incendio?", answer: "Depende del tipo de detector. Los detectores iónicos (los más viejos) sí se activan con cualquier tipo de humo. Los fotoeléctricos y de temperatura no. En salones de eventos normalmente son fotoeléctricos y no hay problema, pero siempre coordinamos con el venue antes del evento para confirmar. Si el salón tiene detectores iónicos, los desactivamos en coordinación con el encargado del venue." },
        { question: "¿Puedo usar varios efectos en el mismo evento?", answer: "Sí, de hecho es lo más común. Una boda típica lleva humo bajo para el vals y confeti o bengalas frías para la entrada. No recomendamos más de 3 efectos porque saturan — el impacto se diluye cuando todo pasa al mismo tiempo. Mejor pocos y bien coordinados." },
        { question: "¿Las bengalas frías son seguras en salón cerrado?", answer: "Sí. Son chispas de titanio a temperatura ambiente — puedes poner la mano encima sin quemarte. No generan humo, no activan alarmas y no dejan residuo. Las usamos en hoteles como Marquis Reforma y Hyatt Regency sin restricción. Es el único tipo de chispa aprobado para interiores." },
        { question: "¿El confeti ensucia mucho? ¿Quién limpia?", answer: "El confeti biodegradable se barre en 10 minutos en interior. En exterior se disuelve con agua en 24-72 horas. Hacemos una limpieza básica al desmontar. La mayoría de los venues no ponen problema con el confeti biodegradable porque ya lo conocen." },
        { question: "¿Qué efecto recomiendan si solo puedo contratar uno?", answer: "Para bodas, humo bajo. Es el efecto con más impacto visual en las fotos del vals y el que más recuerdan los invitados. Para XV años, bengalas frías en la entrada de la quinceañera. Para fiestas, una bola disco — simple pero efectivo toda la noche." },
        { question: "¿Necesito planta de luz para los efectos?", answer: "La mayoría de los efectos consumen poco — un cañón de confeti o la máquina de burbujas no necesitan más que un contacto normal. El humo bajo con máquina JEM ZR33 sí necesita circuito dedicado de 20A. Si tu venue es un jardín sin instalación eléctrica, llevamos planta de luz." },
      ]} />
    </section>

    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Quieres efectos para tu evento?</h2>
          <p>Mándanos por WhatsApp la fecha, el venue y qué momentos quieres resaltar. Te decimos qué efectos funcionan y cuánto cuesta.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
