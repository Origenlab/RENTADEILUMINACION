---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import PricingCards from '../../components/PricingCards.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Máquina de Burbujas para Eventos CDMX | REDEIL";
const description = "Máquinas de burbujas profesionales para bodas, XV años, fiestas infantiles y eventos en CDMX. Burbujas gigantes o lluvia continua. Desde $1,800 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/burbujas/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Máquina de Burbujas para Eventos",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Servicio profesional de renta de máquinas de burbujas para bodas, XV años, fiestas infantiles y eventos en CDMX. Burbujas continuas o gigantes.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Renta de Máquina de Burbujas",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿La máquina de burbujas moja el piso?", "acceptedAnswer": { "@type": "Answer", "text": "Las burbujas dejan una capa muy ligera de jabón en el piso al reventarse, especialmente si el volumen es alto. En pistas de baile, recomendamos tener personal que revise el área periódicamente. El fluido profesional que usamos es mínimamente resbaladizo comparado con soluciones caseras." }},
      { "@type": "Question", "name": "¿Cuánto tiempo produce burbujas una carga de fluido?", "acceptedAnswer": { "@type": "Answer", "text": "Un litro de fluido concentrado produce burbujas continuas durante 60-90 minutos en uso normal. Para eventos de 4-6 horas llevamos fluido adicional para recargas." }},
      { "@type": "Question", "name": "¿Sirve para la entrada de la quinceañera o los novios?", "acceptedAnswer": { "@type": "Answer", "text": "Sí — es uno de los usos más populares. La entrada de la quinceañera o los novios entre una lluvia de burbujas es una imagen espectacular para las fotos y el video. El operador activa la máquina exactamente cuando la persona hace su entrada." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Niebla baja en boda en jardín", description: "Burbujas + niebla baja = entrada de los novios como en una película. El combo más mágico para bodas.", link: "/servicios/humo-bajo/" },
  { title: "Confeti y Papelitos", image: "/img/maquina-de-papelitos/confeti-dorado-primer-baile-novios-romantico-400w.avif", alt: "Confeti dorado en primer baile de novios", description: "Burbujas durante la ceremonia + confeti en el brindis. Dos momentos visuales que la gente no olvida.", link: "/servicios/confeti/" },
  { title: "Luces Neón y UV", image: "/img/luces-neon/renta-luces-neon-glow-party-celebracion-neon-300w.avif", alt: "Luces neón UV en fiesta", description: "Las burbujas con iluminación UV se vuelven fluorescentes — el efecto más sorprendente para glow parties.", link: "/servicios/luces-neon/" },
  { title: "Sky Tracker", image: "/img/sky-tracker/renta-skytracker-cielo-nocturno-potente-300w.avif", alt: "Sky tracker con haz al cielo", description: "Para eventos al aire libre: burbujas + sky tracker crean un momento visual único e irrepetible.", link: "/servicios/sky-tracker/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Burbujas" }
  ]} />
</Fragment>

    <Hero
      title="Renta de Máquina de Burbujas para Fiestas y Eventos en CDMX"
      subtitle="Lluvia continua de burbujas para entradas, vals, pistas de baile y fiestas infantiles. Fluido profesional. Desde $1,800 + IVA."
      introParagraph1='Hay que ser honestos: las burbujas dependen del viento. En interiores o en jardines protegidos, la lluvia de burbujas dura flotando 10-15 segundos y se ve tal como en las fotos. Con viento fuerte, las burbujas se dispersan rápido y el efecto dura menos. Dicho eso, cuando las condiciones son buenas, la entrada de los novios entre burbujas o la sorpresa en una fiesta infantil genera reacciones genuinas que ningún otro efecto logra. En <strong>REDEIL</strong> usamos máquinas de producción continua que generan entre 500 y 2,000 burbujas por minuto.'
      introParagraph2='Usamos fluido profesional concentrado que produce burbujas más resistentes que las de jabón casero — flotan más, revientan menos rápido y generan un efecto más denso. Algo que la gente no pregunta pero debería: el piso se pone resbaloso si las burbujas caen en superficie lisa (mármol, porcelanato). Para pistas de baile con uso intensivo, recomendamos que el personal del venue revise la zona. Con luz UV, las burbujas se vuelven fluorescentes, que es el efecto que funciona para glow parties y XV años temáticos.'
    />


    <!-- Galería -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="¿Cómo se ven las burbujas en un evento real?"
          subtitle="Un efecto que queda bien en cualquier tipo de evento y en cualquier foto."
          paragraph1="La clave con burbujas es el timing. Si las activas 5 segundos antes de que los novios entren, el fotógrafo captura la lluvia en su punto máximo. Si las activas tarde, los novios ya pasaron y las burbujas caen atrás sin contexto. El operador se coordina con el fotógrafo y el MC para activar en el momento exacto."
          paragraph2="En fiestas infantiles es más simple: activas y los niños hacen el resto. Las burbujas gigantes de 30-50cm generan más reacción que las pequeñas pero producen menos cantidad."
        />
        <Gallery4x4 images={[
          { src: "/img/burbujas/maquina-burbujas-boda-entrada-novios.avif", alt: "Máquina de burbujas en entrada de novios a boda" },
          { src: "/img/burbujas/maquina-burbujas-profesional-boda-jardin.avif", alt: "Máquina de burbujas profesional en jardín de boda" },
          { src: "/img/burbujas/maquina-burbujas-vals-quinceanos-pista.avif", alt: "Burbujas en vals de quinceañera en pista" },
          { src: "/img/burbujas/renta-burbujas-evento-xv-anos-salon.avif", alt: "Renta de burbujas para evento de XV años en salón" },
          { src: "/img/burbujas/burbujas-gigantes-fiesta-cumpleanos-ninos.avif", alt: "Burbujas gigantes en fiesta de cumpleaños de niños" },
          { src: "/img/burbujas/burbujas-gigantes-show-infantil-animacion.avif", alt: "Show infantil con burbujas gigantes y animación" },
          { src: "/img/burbujas/maquina-burbujas-fiesta-jardin-terraza.avif", alt: "Máquina de burbujas en fiesta de jardín y terraza" },
          { src: "/img/burbujas/maquina-burbujas-boda-romantica-exterior.avif", alt: "Burbujas en boda romántica en exterior" },
          { src: "/img/burbujas/burbujas-fiesta-tematica-magica-luces.avif", alt: "Burbujas en fiesta temática mágica con luces" },
          { src: "/img/burbujas/renta-maquina-burbujas-fiesta-infantil.avif", alt: "Máquina de burbujas para fiesta infantil" },
          { src: "/img/burbujas/renta-burbujas-baby-shower-decoracion.avif", alt: "Burbujas en decoración de baby shower" },
          { src: "/img/burbujas/renta-burbujas-evento-corporativo-lanzamiento.avif", alt: "Burbujas en lanzamiento de evento corporativo" },
          { src: "/img/burbujas/burbujas-fiesta-pool-party-alberca.avif", alt: "Burbujas en fiesta pool party junto a alberca" },
          { src: "/img/burbujas/renta-burbujas-festival-kermesse-feria.avif", alt: "Máquina de burbujas en festival y kermesse" },
          { src: "/img/burbujas/maquina-burbujas-despedida-soltera-diversion.avif", alt: "Burbujas en despedida de soltera divertida" },
          { src: "/img/burbujas/burbujas-efecto-especial-fotografia-video.avif", alt: "Efecto especial de burbujas para fotografía y video" },
        ]} />
      </div>
    </section>

    <!-- Paquetes -->
    <section class="services-section services-alt" id="paquetes">
      <div class="container">
        <SectionHeader
          title="¿Cuánto cuesta rentar máquina de burbujas en CDMX?"
          subtitle="Para un momento específico o para toda la fiesta. Operador incluido."
          paragraph1="Cada paquete incluye la máquina, fluido profesional, operador técnico y traslado. El operador coordina el momento exacto de activación con el DJ o maestro de ceremonias."
          paragraph2="¿Quieres burbujas gigantes con UV para glow party? ¿O lluvia continua para la pista de baile de toda la noche? Cotiza tu combinación ideal."
        />
        <PricingCards packages={[
          {
            name: "Momento Estelar",
            price: "$1,800",
            priceNote: "+ IVA",
            description: "Burbujas para un momento específico: entrada, vals, brindis. El efecto perfecto para la foto que todos quieren.",
            features: [
              { text: "1 máquina de burbujas profesional", included: true },
              { text: "Fluido profesional (1 hora)", included: true },
              { text: "Operador técnico incluido", included: true },
              { text: "Traslado + montaje + desmontaje", included: true },
              { text: "Coordinación con DJ/fotógrafo", included: true },
              { text: "Ideal para: entrada, vals, momentos especiales", included: true },
              { text: "Uso toda la noche", included: false },
              { text: "Burbujas gigantes UV", included: false },
            ],
            ctaLabel: "Cotizar momento estelar",
            ctaHref: "/servicios/burbujas/paquete-fiesta-infantil/",
          },
          {
            name: "Fiesta Completa",
            price: "$3,200",
            priceNote: "+ IVA",
            badge: "Más popular",
            highlight: true,
            description: "Burbujas disponibles toda la noche para múltiples momentos. El operador activa en los picos del evento.",
            features: [
              { text: "1 máquina de burbujas de alta producción", included: true },
              { text: "Fluido ilimitado (toda la noche)", included: true },
              { text: "Operador técnico 4-6 horas", included: true },
              { text: "Traslado + montaje + desmontaje", included: true },
              { text: "Activaciones múltiples a demanda", included: true },
              { text: "Ideal para: bodas, XV años, fiestas", included: true },
              { text: "Coordinación completa con DJ/MC", included: true },
              { text: "Burbujas gigantes UV", included: false },
            ],
            ctaLabel: "Cotizar fiesta completa",
            ctaHref: "/servicios/burbujas/paquete-boda-entrada/",
          },
          {
            name: "Show Infantil",
            price: "$4,500",
            priceNote: "+ IVA",
            description: "Burbujas gigantes + lluvia continua para el show más memorable. Ideal para eventos infantiles y cumpleaños.",
            features: [
              { text: "1 máquina de lluvia + 1 de burbujas gigantes", included: true },
              { text: "Fluido ilimitado", included: true },
              { text: "Operador técnico incluido", included: true },
              { text: "Traslado + montaje + desmontaje", included: true },
              { text: "Burbujas de 30-50cm de diámetro", included: true },
              { text: "Ideal para: cumpleaños infantiles, colegios", included: true },
              { text: "Coordinación con animador del evento", included: true },
              { text: "Show de burbujas de 20 minutos", included: true },
            ],
            ctaLabel: "Cotizar show infantil",
            ctaHref: "/servicios/burbujas/paquete-burbujas-gigantes/",
          },
          {
            name: "Glow Party UV",
            price: "$6,500",
            priceNote: "+ IVA",
            description: "Burbujas + luz UV + fluido fluorescente. Las burbujas se iluminan en colores neón bajo la luz negra.",
            features: [
              { text: "2 máquinas de burbujas profesionales", included: true },
              { text: "Fluido fluorescente UV especial", included: true },
              { text: "4 barras UV LED para iluminar las burbujas", included: true },
              { text: "Fluido ilimitado toda la noche", included: true },
              { text: "Operadores técnicos incluidos", included: true },
              { text: "Traslado + montaje + desmontaje", included: true },
              { text: "Ideal para: glow parties, XV años neón", included: true },
              { text: "Coordinación con DJ y luces", included: true },
            ],
            ctaLabel: "Cotizar glow party",
            ctaHref: "/servicios/burbujas/paquete-produccion/",
          },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas frecuentes sobre burbujas para eventos"
          subtitle="Todo lo que necesitas saber antes de contratar."
          paragraph1="Si tienes otra duda, escríbenos por WhatsApp y te respondemos en minutos."
          paragraph2="Te asesoramos sobre qué tipo de máquina y fluido es mejor para tu tipo de evento."
        />
      </div>
      <FaqSection items={[
        { question: "¿El piso se pone resbaloso?", answer: "Sí, algo. El fluido profesional deja menos residuo que el jabón casero, pero en superficies lisas (mármol, porcelanato) se nota. Para pistas de baile con uso intensivo, el personal del venue debería revisar cada cierto rato. En pool parties donde la gente anda descalza, más cuidado todavía." },
        { question: "¿Funciona con viento?", answer: "Funciona pero diferente. Con poco viento las burbujas flotan 10-15 segundos y el efecto es denso. Con viento fuerte se dispersan rápido y algunas revientan antes de subir. Para la foto de la entrada de los novios, los mejores resultados son con poco o nada de viento." },
        { question: "¿Cuántas burbujas produce?", answer: "Las máquinas de lluvia producen entre 500 y 2,000 por minuto. Las de burbujas gigantes, 5-20 grandes por minuto. Para la entrada de los novios usamos lluvia al máximo para efecto denso. Para fiesta infantil, las gigantes generan más reacción." },
        { question: "¿Es seguro para niños pequeños?", answer: "El fluido es no tóxico y está formulado para entretenimiento infantil. Si un niño toca una burbuja o se la mete a la boca, no pasa nada. Lo que sí evitamos es que toquen el fluido concentrado directo — que está en el tanque de la máquina, no en las burbujas." },
        { question: "¿Se ven en fotos?", answer: "Se ven bien cuando hay iluminación de fondo. La luz rebota en cada burbuja y genera puntos de luz. Los fotógrafos de bodas saben capturarlas. Con luz UV, las burbujas fluorescentes quedan en otro nivel — pero necesitas oscuridad para que funcione." },
        { question: "¿Puedo pedir burbujas solo para un momento?", answer: "Sí. El paquete Momento Estelar cubre una activación específica: entrada de los novios, brindis, vals. El operador llega, monta, activa en el momento exacto coordinado con el fotógrafo, y desmonta." },
      ]} />
    </section>

    <!-- Servicios relacionados -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="¿Qué otros servicios combinan con burbujas?"
          subtitle="Los novios entran entre nubes en el piso y burbujas en el aire."
          paragraph1="La combinación que más montamos en bodas: humo bajo pegado al suelo + lluvia de burbujas desde arriba. El fotógrafo queda loco con ese encuadre. Para XV años, el combo es burbujas + UV — las burbujas fluorescentes en la oscuridad generan reacciones genuinas."
          paragraph2="Cuando el cliente ya tiene humo bajo o luces neón con nosotros, el operador de burbujas coordina directo con el resto del equipo."
        />
        <div class="services-grid">
          {serviciosRelacionados.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Lista la lluvia de burbujas para tu evento?</h2>
          <p>Cuéntanos qué tipo de evento es, cuántas personas esperan y qué momento quieres que sea especial. Te cotizamos en minutos.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
