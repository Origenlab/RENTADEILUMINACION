---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import PricingCards from '../../components/PricingCards.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Bocinas para Fiestas en CDMX | Sonido Profesional | REDEIL";
const description = "Bocinas y sonido profesional para fiestas en CDMX. Cumpleaños, graduaciones, posadas, garden parties. Desde $3,500. Instalación incluida. Cotiza gratis.";
const canonical = "https://rentadeiluminacion.com/servicios/bocinas-fiestas/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Bocinas para Fiestas",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Servicio de renta de bocinas y sonido profesional para fiestas en Ciudad de México. Audio para cumpleaños, graduaciones, posadas, baby showers y garden parties.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Renta de Bocinas para Fiestas",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Puedo rentar solo las bocinas sin DJ?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Muchos clientes rentan solo el equipo de audio con técnico. Conectamos tu playlist de Spotify o tu laptop. El técnico se encarga de que todo suene bien durante toda la fiesta." }},
      { "@type": "Question", "name": "¿Las bocinas tienen Bluetooth?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, nuestros equipos portátiles tienen conexión Bluetooth y auxiliar. Para fiestas más grandes usamos conexión directa por cable para mejor calidad y estabilidad de audio." }},
      { "@type": "Question", "name": "¿Incluyen karaoke?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, podemos incluir sistema de karaoke con micrófono inalámbrico y pantalla con letras. Es perfecto para fiestas de cumpleaños y posadas. Solo menciónalo al cotizar." }},
      { "@type": "Question", "name": "¿Cuánto tiempo antes llegan a montar?", "acceptedAnswer": { "@type": "Answer", "text": "Llegamos entre 2 y 3 horas antes del evento para montar y probar el sonido. Para eventos grandes, llegamos con más anticipación. Nos coordinamos contigo para los horarios." }},
      { "@type": "Question", "name": "¿Trabajan en fines de semana y días festivos?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, trabajamos todos los días del año incluyendo fines de semana y días festivos. La mayoría de nuestras fiestas son en sábado, así que es nuestro día más activo." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "DJ para Eventos", image: "/img/bocinas-djs/dj-para-eventos-cdmx-cabina-profesional.avif", alt: "DJ profesional en cabina para eventos en CDMX", description: "DJ profesional con cabina completa para fiestas y eventos. Música en vivo que mantiene la pista llena.", link: "/servicios/bocinas-djs/" },
  { title: "Bocinas para Bodas", image: "/img/bocinas-bodas/renta-bocinas-boda-primer-baile-novios-romantico.avif", alt: "Sonido profesional para primer baile de novios", description: "Audio especializado para bodas. Ceremonia, vals, brindis y fiesta con sonido impecable.", link: "/servicios/bocinas-bodas/" },
  { title: "Bocinas para XV Años", image: "/img/bocinas-xv/renta-bocinas-xv-anos-vals-padre-hija-dj-salon.avif", alt: "Bocinas para vals de XV años en salón", description: "Sonido profesional para XV años. Vals, sorpresas, brindis y fiesta con audio de calidad.", link: "/servicios/bocinas-xv/" },
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Efecto de humo bajo en piso para fiesta", description: "Efecto de nubes en el piso para momentos especiales. Combínalo con tu fiesta para un toque mágico.", link: "/servicios/humo-bajo/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Sonido", href: "/servicios/sonido/" },
    { label: "Bocinas para Fiestas" }
  ]} />
</Fragment>

    <Hero
      title="Renta de Bocinas para Fiestas en CDMX"
      subtitle="Sonido profesional para cumpleaños, despedidas, garden parties y todo tipo de celebraciones. Desde $3,500. Instalación incluida."
      introParagraph1='La buena música hace que cualquier fiesta sea memorable. En <strong>REDEIL</strong> ofrecemos sonido profesional para todo tipo de fiestas en CDMX — cumpleaños, graduaciones, posadas, baby showers, garden parties. Equipos de audio potente y claro que mantienen la pista de baile llena toda la noche.'
      introParagraph2='Desde bocinas portátiles con Bluetooth hasta montajes completos con DJ, subwoofers y mezcladora. Paquetes con y sin operador técnico. Transporte, montaje y desmontaje incluido en todos los paquetes. Trabajamos en casas, jardines, terrazas, salones y cualquier espacio en la CDMX y Edo. Méx.'
    />

    <CtaBar
      headline="¿Qué tipo de fiesta estás organizando?"
      items={[
        { label: "Fiestas", href: "/servicios/bocinas-fiestas/", icon: "sonido" },
        { label: "DJ Eventos", href: "/servicios/bocinas-djs/", icon: "sonido" },
        { label: "XV Años", href: "/servicios/bocinas-xv/", icon: "sonido" },
        { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
      ]}
    />

    <!-- Galería de sonido para fiestas -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="Sonido Profesional para Todo Tipo de Fiestas"
          subtitle="Montajes reales en fiestas y celebraciones en CDMX."
          paragraph1="La música es el alma de cualquier fiesta. Un buen sistema de sonido hace la diferencia entre una celebración memorable y una que pasa desapercibida. Equipos profesionales que garantizan potencia, claridad y la energía que tu fiesta necesita."
          paragraph2="Montamos en casas, jardines, terrazas, salones, rooftops y cualquier espacio. Nuestro equipo llega con anticipación para instalar y probar el sonido — todo listo antes de que lleguen tus invitados."
        />
        <Gallery4x4 images={[
          { src: "/img/bocinas-fiestas/renta-bocinas-fiestas-eventos-profesionales.avif", alt: "Bocinas profesionales montadas para fiesta" },
          { src: "/img/bocinas-fiestas/bocinas-profesionales-fiestas-noche.avif", alt: "Sonido profesional en fiesta nocturna con luces" },
          { src: "/img/bocinas-fiestas/alquiler-altavoces-fiestas-piscina.avif", alt: "Altavoces en fiesta junto a piscina al aire libre" },
          { src: "/img/bocinas-fiestas/equipo-sonido-eventos-elegantes.avif", alt: "Equipo de sonido para celebración elegante" },
          { src: "/img/bocinas-fiestas/renta-bocinas-baby-shower.avif", alt: "Bocinas para baby shower con decoración festiva" },
          { src: "/img/bocinas-fiestas/sistema-audio-graduaciones-eventos.avif", alt: "Audio profesional para fiesta de graduación" },
          { src: "/img/bocinas-fiestas/bocinas-amplificadas-fiestas-jardines.avif", alt: "Bocinas amplificadas en fiesta de jardín" },
          { src: "/img/bocinas-fiestas/equipo-audio-cumpleanos-reuniones.avif", alt: "Audio para cumpleaños y reuniones" },
          { src: "/img/bocinas-fiestas/equipo-bocinas-fiestas-salon.avif", alt: "Bocinas instaladas en salón de fiestas" },
          { src: "/img/bocinas-fiestas/bocinas-fiestas-ano-nuevo-celebracion.avif", alt: "Sonido para celebración de año nuevo" },
          { src: "/img/bocinas-fiestas/renta-audio-profesional-eventos-sociales.avif", alt: "Audio profesional para evento social" },
          { src: "/img/bocinas-fiestas/equipo-audio-celebraciones-especiales.avif", alt: "Equipo de audio para celebración especial" },
          { src: "/img/bocinas-fiestas/alquiler-audio-fiestas-disco.avif", alt: "Audio para fiesta tipo disco" },
          { src: "/img/bocinas-fiestas/bocinas-grandes-eventos-masivos.avif", alt: "Bocinas para evento masivo" },
          { src: "/img/bocinas-fiestas/bocinas-potentes-eventos-empresariales.avif", alt: "Bocinas potentes para evento empresarial" },
          { src: "/img/bocinas-fiestas/renta-equipo-dj-fiestas-electronicas.avif", alt: "Equipo DJ para fiesta electrónica" },
        ]} />
      </div>
    </section>

    <!-- Paquetes -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Paquetes de Sonido para Fiestas"
          subtitle="3 opciones según el tamaño de tu fiesta. Instalación incluida en todos."
          paragraph1="Cada paquete incluye transporte, montaje profesional, operación durante el evento y desmontaje. Sin costos ocultos — el precio es todo incluido."
          paragraph2="¿Tu fiesta necesita algo diferente? Armamos paquetes a la medida. Cotiza por WhatsApp y te hacemos una propuesta personalizada en menos de 24 horas."
        />
        <PricingCards packages={[
          {
            name: "Fiesta Pequeña",
            price: "$3,500",
            priceNote: "+IVA",
            description: "Perfecto para reuniones íntimas y celebraciones de hasta 50 personas.",
            features: [
              { text: "Hasta 50 personas", included: true },
              { text: "2 bocinas amplificadas portátiles", included: true },
              { text: "Conexión Bluetooth + auxiliar", included: true },
              { text: "Micrófono inalámbrico para karaoke", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Ideal para: cumpleaños, baby shower, reunión", included: true },
              { text: "DJ profesional", included: false },
              { text: "Subwoofer", included: false },
            ],
            ctaLabel: "Cotizar Fiesta Pequeña",
            ctaHref: "/contacto/",
          },
          {
            name: "Fiesta Mediana",
            price: "$7,500",
            priceNote: "+IVA",
            badge: "Más popular",
            highlight: true,
            description: "El más pedido para graduaciones, posadas y garden parties de 50 a 150 personas.",
            features: [
              { text: "50-150 personas", included: true },
              { text: "2 bocinas JBL PRX + subwoofer 15\"", included: true },
              { text: "2 micrófonos inalámbricos", included: true },
              { text: "Mezcladora digital", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Ideal para: graduaciones, posadas, garden party", included: true },
              { text: "Técnico de audio presente", included: true },
              { text: "DJ profesional", included: false },
            ],
            ctaLabel: "Cotizar Fiesta Mediana",
            ctaHref: "/contacto/",
          },
          {
            name: "Fiesta Grande",
            price: "$14,000",
            priceNote: "+IVA",
            description: "Producción completa para fiestas grandes y eventos masivos de 150+ personas.",
            features: [
              { text: "150+ personas", included: true },
              { text: "4 bocinas QSC + 2 subwoofers 18\"", included: true },
              { text: "3 micrófonos inalámbricos", included: true },
              { text: "Mezcladora digital + DJ profesional", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Ideal para: fiestas grandes, eventos masivos", included: true },
              { text: "Luces básicas de pista incluidas", included: true },
              { text: "Técnico de audio dedicado", included: true },
            ],
            ctaLabel: "Cotizar Fiesta Grande",
            ctaHref: "/contacto/",
          },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre Bocinas para Fiestas"
          subtitle="Lo que todos preguntan antes de cotizar."
          paragraph1="Si tienes otra duda sobre la renta de bocinas para fiestas, escríbenos por WhatsApp y te respondemos en minutos."
          paragraph2="Cada fiesta es diferente — por eso hacemos propuestas a la medida según el número de invitados y el tipo de espacio."
        />
      </div>
      <FaqSection items={[
        { question: "¿Puedo rentar solo las bocinas sin DJ?", answer: "Sí. Muchos clientes rentan solo el equipo de audio con técnico. Conectamos tu playlist de Spotify o tu laptop. El técnico se encarga de que todo suene bien durante toda la fiesta." },
        { question: "¿Las bocinas tienen Bluetooth?", answer: "Sí, nuestros equipos portátiles tienen conexión Bluetooth y auxiliar. Para fiestas más grandes usamos conexión directa por cable para mejor calidad y estabilidad de audio." },
        { question: "¿Incluyen karaoke?", answer: "Sí, podemos incluir sistema de karaoke con micrófono inalámbrico y pantalla con letras. Es perfecto para fiestas de cumpleaños y posadas. Solo menciónalo al cotizar." },
        { question: "¿Cuánto tiempo antes llegan a montar?", answer: "Llegamos entre 2 y 3 horas antes del evento para montar y probar el sonido. Para eventos grandes, llegamos con más anticipación. Nos coordinamos contigo para los horarios." },
        { question: "¿Trabajan en fines de semana y días festivos?", answer: "Sí, trabajamos todos los días del año incluyendo fines de semana y días festivos. La mayoría de nuestras fiestas son en sábado, así que es nuestro día más activo." },
      ]} />
    </section>

    <!-- Servicios relacionados -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Combina con Otros Servicios"
          subtitle="Tu fiesta se ve y suena mejor cuando complementas."
          paragraph1="La mayoría de nuestros clientes combinan el sonido con iluminación y efectos especiales para crear una experiencia completa. El resultado: una fiesta que se ve y se siente de otro nivel."
          paragraph2="Armamos paquetes personalizados con precio especial cuando combinas servicios. Cuéntanos tu evento y te hacemos una propuesta integral."
        />
        <div class="services-grid">
          {serviciosRelacionados.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Listo para que tu fiesta suene increíble?</h2>
          <p>Cuéntanos qué tipo de fiesta estás organizando, cuántos invitados esperas y el lugar. Te armamos una propuesta con el equipo ideal y el precio exacto.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
