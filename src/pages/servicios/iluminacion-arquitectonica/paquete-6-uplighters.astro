---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "6 Uplighters para Fachada de Hacienda CDMX | REDEIL";
const description = "Uplighting inalámbrico para fachada frontal o arco de ceremonia. Sin cables. Instalación incluida en CDMX. $3,500 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/iluminacion-arquitectonica/paquete-6-uplighters/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Paquete 6 Uplighters — Fachada de Hacienda y Arco de Ceremonia",
    "description": "6 reflectores LED uplighting inalámbricos para iluminar la fachada frontal de hacienda o el arco de ceremonia. Sin cables. Batería de hasta 12 horas. Transporte e instalación incluidos en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/iluminacion-arquitectonica/paquete-6-uplighters/",
      "priceCurrency": "MXN",
      "price": "3500",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "53",
      "reviewCount": "53"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Isabel Castillo" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Contratamos 6 uplighters para iluminar la fachada de la Hacienda La Laborcilla en Tláhuac. El arco de cantera en violeta fue el backdrop perfecto para las fotos de entrada. Sin ningún cable visible — quedó impecable. REDEIL llegó con mucha anticipación y fue muy profesional."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Tomás Espinoza" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Para el arco de nuestra ceremonia en el Jardín Botánico Culhuacán usamos 6 uplighters en rosa pálido. La primera impresión de los invitados al llegar fue exactamente lo que queríamos. Sin cables, sin complicaciones. El precio es justo."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Renata Flores" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Boda en la Hacienda Peñafiel en Tepotzotlán. Los 6 reflectores en la fachada principal en color ámbar dorado transformaron completamente la entrada. Los invitados llegaban impresionados. Servicio de primera desde la cotización hasta el desmontaje."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/iluminacion-arquitectonica/iluminacion-arcos-coloniales-columnas-piedra-luz-calida-boda.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Para qué sirven 6 uplighters en una boda?", "acceptedAnswer": { "@type": "Answer", "text": "6 uplighters son perfectos para iluminar la fachada frontal de una hacienda, el arco de ceremonia o la entrada del venue. Crean la primera impresión visual del evento — los invitados llegan y ya saben que algo especial les espera adentro." }},
      { "@type": "Question", "name": "¿Los uplighters son inalámbricos?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Usamos uplighters LED Chauvet Freedom Par y ADJ Element con batería recargable de hasta 12 horas. No hay cables en el piso — se colocan directamente al pie de columnas, arcos y fachadas sin necesidad de instalación eléctrica." }},
      { "@type": "Question", "name": "¿Puedo elegir el color del uplighting?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, cada reflector produce cualquier color RGBW. El color se fija antes del evento según tu paleta de boda — ámbar para haciendas rústicas, rosa para bodas románticas, violeta para un toque dramático o blanco cálido para elegancia clásica." }},
      { "@type": "Question", "name": "¿6 uplighters son suficientes para la fachada de una hacienda?", "acceptedAnswer": { "@type": "Answer", "text": "Para la fachada frontal principal de una hacienda mediana o el arco de ceremonia, sí. Si la fachada tiene más de 15 metros de ancho o quieres cubrir también el jardín y árboles laterales, el paquete de 12 uplighters es la opción correcta." }},
      { "@type": "Question", "name": "¿El precio de $3,500 incluye instalación?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Los $3,500 + IVA incluyen transporte de los 6 reflectores, instalación y posicionamiento en el venue, operación durante el evento y retiro al finalizar. Sin costos adicionales por viáticos en CDMX y zona metropolitana." }},
      { "@type": "Question", "name": "¿Se puede combinar con guirnaldas o PAR LED?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, es la combinación más popular. Uplighters en la fachada y arcos de la hacienda + guirnaldas Edison dentro y en el techo del jardín = una transformación completa del venue. También combina perfectamente con PAR LED dentro del salón para cubrir el venue de afuera hacia adentro." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "12 Uplighters — Fachada + Jardín", image: "/img/iluminacion-arquitectonica/iluminacion-arbol-centenario-verde-jardin-boda-luces-decorativas.avif", alt: "12 uplighters para fachada y jardín de hacienda", description: "El más popular para bodas en hacienda. Fachada completa más jardín y árboles. $6,000 + IVA.", link: "/servicios/iluminacion-arquitectonica/paquete-12-uplighters/" },
  { title: "20 Uplighters — Hacienda con DMX", image: "/img/iluminacion-arquitectonica/iluminacion-arcada-hacienda-plantas-luz-ambar-evento-social.avif", alt: "20 uplighters para hacienda completa con DMX", description: "Hacienda completa con 4 zonas DMX independientes y cambios de color en vivo. $9,500 + IVA.", link: "/servicios/iluminacion-arquitectonica/paquete-20-uplighters/" },
  { title: "Guirnaldas Edison", image: "/img/guirnaldas/renta-guirnaldas-edison-terraza-recepcion-02-300w.avif", alt: "Guirnaldas Edison para interior de hacienda", description: "Uplighters en la fachada + guirnaldas dentro. La combinación perfecta para haciendas.", link: "/servicios/guirnaldas/" },
  { title: "City Color", image: "/img/city-color/iluminacion-ceremonia-boda-hacienda-300w.avif", alt: "City Color para fachadas de hacienda", description: "Uplighters para los detalles arquitectónicos + city color para las fachadas grandes.", link: "/servicios/city-color/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Iluminación", href: "/servicios/iluminacion/" },
    { label: "Iluminación Arquitectónica", href: "/servicios/iluminacion-arquitectonica/" },
    { label: "Paquete 6 Uplighters" }
  ]} />
</Fragment>

  <Hero
    title="Paquete 6 Uplighters — Fachada y Arco de Ceremonia"
    subtitle="Desde $3,500 + IVA. 6 reflectores LED inalámbricos. Sin cables. La primera impresión de tu boda."
    introParagraph1='Los primeros metros de cualquier boda son los más fotografiados — la llegada de los invitados, la entrada del cortejo, la primera vista del venue. El paquete de 6 uplighters está diseñado exactamente para ese momento: iluminar la <strong>fachada frontal de la hacienda</strong> o el <strong>arco de ceremonia</strong> con el color de tu boda, sin cables visibles, sin instalación eléctrica invasiva.'
    introParagraph2='Los 6 reflectores Chauvet Freedom Par se colocan al pie de las columnas, el arco o la fachada principal y proyectan la luz hacia arriba — la cantera se vuelve violeta, el arco floral se baña en rosa, los muros blancos cobran el color de tu paleta. Con batería de hasta 12 horas, operan durante todo el evento sin necesidad de cables de corriente. Transporte, instalación y desmontaje incluidos en toda la <strong>CDMX y Estado de México</strong>.'
  />


  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Paquete Básico"
      price="$3,500"
      priceNote="+ IVA · Sin cables · Instalación incluida"
      features={[
        { text: "6 uplighters LED RGBW inalámbricos" },
        { text: "Batería hasta 12 horas por unidad" },
        { text: "Sin cables en el piso" },
        { text: "1 zona: fachada frontal o arco" },
        { text: "Color fijo personalizado" },
        { text: "Transporte ida y vuelta" },
        { text: "Instalación y desmontaje incluidos" },
        { text: "Ideal: primera impresión del venue" },
        { text: "Cobertura CDMX y Edomex" },
        { text: "Compatible con cualquier estilo de venue" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete de 6 uplighters para fachada de hacienda o arco de ceremonia."
      packages={[
        { label: "6 Uplighters", price: "$3,500", href: "/servicios/iluminacion-arquitectonica/paquete-6-uplighters/", active: true },
        { label: "12 Uplighters", price: "$6,000", href: "/servicios/iluminacion-arquitectonica/paquete-12-uplighters/" },
        { label: "20 Uplighters", price: "$9,500", href: "/servicios/iluminacion-arquitectonica/paquete-20-uplighters/" },
        { label: "Producción 30+", price: "$14,000", href: "/servicios/iluminacion-arquitectonica/paquete-produccion/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="¿Qué puedes iluminar con 6 uplighters?"
          subtitle="Una zona de impacto: la primera imagen de tu evento."
          paragraph1="6 reflectores colocados estratégicamente al pie de las estructuras crean un foco de luz dramático que transforma la arquitectura. No necesitas cubrir toda la hacienda para crear un momento fotogénico — una fachada bien iluminada es suficiente."
          paragraph2="La clave está en la colocación: el ángulo del haz, la distancia a la estructura y la posición relativa entre reflectores determina la calidad del resultado. Nuestro equipo sabe exactamente dónde poner cada uno."
        />
        <FeatureGrid features={[
          { title: "Fachada Frontal de Hacienda", description: "La entrada principal bañada en el color de tu boda. La foto más compartida del evento." },
          { title: "Arco de Ceremonia", description: "El marco de tu momento más importante. Luz ascendente que lo enmarca perfectamente." },
          { title: "Arcos de Cantera", description: "La textura de la piedra iluminada desde abajo — dramática, profunda, espectacular." },
          { title: "Columnas de la Entrada", description: "Columnas coloniales iluminadas que crean un pasillo de color hacia el interior." },
          { title: "Portal Principal", description: "El portal que anuncia el evento desde que los invitados doblan la esquina." },
          { title: "Árbol de Ceremonia", description: "Un árbol centenario iluminado en verde o malva como backdrop de la ceremonia." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Sin cables: la gran ventaja del uplighting inalámbrico"
          subtitle="Se colocan donde se necesitan — sin restricciones de instalación eléctrica."
          paragraph1="Los cables son el enemigo del uplighting bien fotografiado. En las fotos de bodas, un cable cruzando el piso frente a un arco iluminado arruina completamente el resultado. Nuestros uplighters inalámbricos no tienen este problema."
          paragraph2="Se colocan con discreción al pie de las estructuras, sin cables visibles desde ningún ángulo. El resultado en foto y en video es tan limpio como la arquitectura misma."
        />
        <FeatureGrid features={[
          { title: "Batería 12 Horas", description: "Duran desde la llegada de los primeros invitados hasta el último baile." },
          { title: "Control Inalámbrico", description: "El color y la intensidad se ajustan a distancia sin tocar el equipo." },
          { title: "Posicionamiento Libre", description: "Piso de cantera, jardín, escalones — van exactamente donde deben ir." },
          { title: "Sin Daños al Venue", description: "No se perfora, no se fija con tornillos. El venue queda exactamente igual." },
          { title: "Resistencia al Exterior", description: "Clasificación IP65. Funcionan bajo llovizna y humedad nocturna." },
          { title: "Carga Rápida", description: "Se cargan entre eventos. Siempre llegan con batería completa." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="⭐⭐⭐⭐⭐ 5 estrellas en 53 reseñas verificadas."
          paragraph1="Bodas en haciendas de CDMX y Estado de México con el paquete de 6 uplighters."
          paragraph2="Pregunta por referencias de venues similares cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Isabel Castillo", event: "Boda — Hacienda La Laborcilla, Tláhuac", rating: 5, text: "El arco de cantera en violeta fue el backdrop perfecto para las fotos de entrada. Sin ningún cable visible — quedó impecable. Muy profesionales." },
          { name: "Tomás Espinoza", event: "Boda — Jardín Botánico Culhuacán", rating: 5, text: "El arco de ceremonia en rosa pálido fue exactamente lo que queríamos. Sin cables, sin complicaciones. La primera impresión de los invitados fue perfecta." },
          { name: "Renata Flores", event: "Boda — Hacienda Peñafiel, Tepotzotlán", rating: 5, text: "Los 6 reflectores en la fachada principal en ámbar dorado transformaron completamente la entrada. Los invitados llegaban impresionados. Servicio impecable." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Fachadas y arcos iluminados con 6 uplighters"
        subtitle="La primera impresión de la boda — fotografiada desde que los invitados llegan."
        paragraph1="Estas fotos son de eventos reales con nuestro paquete de 6 uplighters en haciendas y venues de CDMX y Estado de México. La transformación que logra un reflector bien colocado sobre una fachada de cantera no tiene comparación."
        paragraph2="¿Quieres ver cómo quedaría en tu venue? Mándanos fotos de la fachada o el arco por WhatsApp y te mostramos el resultado esperado."
      />
      <Gallery4x4 images={[
        { src: "/img/iluminacion-arquitectonica/iluminacion-arcos-coloniales-columnas-piedra-luz-calida-boda.avif", alt: "Arcos coloniales con uplighting de luz cálida para boda" },
        { src: "/img/iluminacion-arquitectonica/iluminacion-arquitectonica-arcos-coloniales-luz-violeta-fachada.avif", alt: "Fachada con arcos coloniales iluminados en violeta" },
        { src: "/img/iluminacion-arquitectonica/iluminacion-arcada-hacienda-plantas-luz-ambar-evento-social.avif", alt: "Arcada de hacienda con uplighting ámbar para evento" },
        { src: "/img/iluminacion-arquitectonica/boda-patio-hacienda-iluminacion-fachada-ambar-string-lights-baile.avif", alt: "Patio de hacienda con fachada iluminada en ámbar" },
        { src: "/img/iluminacion-arquitectonica/iluminacion-arbol-majestuoso-uplighting-verde-hacienda-colonial.avif", alt: "Árbol majestuoso con uplighting verde en hacienda colonial" },
        { src: "/img/iluminacion-arquitectonica/iluminacion-arbol-centenario-verde-jardin-boda-luces-decorativas.avif", alt: "Árbol centenario iluminado en verde para boda en jardín" },
        { src: "/img/iluminacion-arquitectonica/iluminacion-arboles-morados-boda-exterior-mesas-velas-romantico.avif", alt: "Árboles iluminados en morado para boda exterior romántica" },
        { src: "/img/iluminacion-arquitectonica/iluminacion-boda-fachada-rosa-luces-colgantes-arboles-mesas.avif", alt: "Fachada de hacienda iluminada en rosa con árboles y mesas" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete 6 Uplighters"
        subtitle="Todo lo que necesitas saber sobre uplighting para fachada y arco de ceremonia."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp al 55 3068 2988. Respondemos en minutos."
        paragraph2="Cuéntanos el tipo de fachada o arco — te decimos exactamente cómo quedaría con 6 uplighters."
      />
    </div>
    <FaqSection items={[
      { question: "¿Para qué sirven 6 uplighters en una boda?", answer: "6 uplighters son perfectos para iluminar la fachada frontal de una hacienda, el arco de ceremonia o la entrada del venue. Crean la primera impresión visual del evento — los invitados llegan y ya saben que algo especial les espera adentro." },
      { question: "¿Los uplighters son inalámbricos?", answer: "Sí. Usamos uplighters LED Chauvet Freedom Par con batería recargable de hasta 12 horas. No hay cables en el piso — se colocan directamente al pie de columnas, arcos y fachadas sin necesidad de instalación eléctrica." },
      { question: "¿Puedo elegir el color del uplighting?", answer: "Sí, cada reflector produce cualquier color RGBW. El color se fija antes del evento según tu paleta de boda — ámbar para haciendas rústicas, rosa para bodas románticas, violeta para un toque dramático o blanco cálido para elegancia clásica." },
      { question: "¿6 uplighters son suficientes para la fachada de una hacienda?", answer: "Para la fachada frontal principal de una hacienda mediana o el arco de ceremonia, sí. Si la fachada tiene más de 15 metros de ancho o quieres cubrir también el jardín y árboles laterales, el paquete de 12 uplighters ($6,000) es la opción correcta." },
      { question: "¿El precio de $3,500 incluye instalación?", answer: "Sí. Los $3,500 + IVA incluyen transporte de los 6 reflectores, instalación y posicionamiento en el venue, operación durante el evento y retiro al finalizar. Sin costos adicionales por viáticos en CDMX y zona metropolitana." },
      { question: "¿Se puede combinar con guirnaldas o PAR LED?", answer: "Sí, es la combinación más popular. Uplighters en la fachada y arcos + guirnaldas Edison dentro y en el techo del jardín = transformación completa del venue. También combina con PAR LED dentro del salón para cobertura de afuera hacia adentro." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes y Servicios"
        subtitle="¿Quieres cubrir más zonas de la hacienda o combinar servicios?"
        paragraph1="Si tu hacienda tiene jardín, árboles y múltiples áreas para iluminar, el paquete de 12 o 20 uplighters te da la cobertura completa. Y combinado con guirnaldas, el venue queda totalmente transformado."
        paragraph2="Propuestas integrales con precio especial cuando combinas 2 o más servicios."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para iluminar la fachada de tu hacienda?</h2>
        <p>Mándanos fotos de la fachada o el arco por WhatsApp con la fecha de tu evento. Te confirmamos disponibilidad y te enviamos el presupuesto en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Reservar — Cotiza Gratis</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
