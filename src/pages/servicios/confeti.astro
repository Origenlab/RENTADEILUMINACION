---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import GallerySection from "../../components/GallerySection.astro";
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const title = "Máquina de Confeti para Eventos | REDEIL CDMX";
const description = "Renta de máquina de confeti para bodas y eventos en CDMX. Lluvia de confeti profesional para celebraciones inolvidables. Servicio completo por REDEIL.";
const canonical = "https://rentadeiluminacion.com/servicios/confeti/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Máquina de Confeti para Eventos",
  "provider": {
    "@type": "LocalBusiness",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com",
    "telephone": "+525530682988",
    "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressCountry": "MX" }
  },
  "description": "Servicio de renta de máquinas de confeti para bodas, fiestas y eventos en la Ciudad de México. Lluvia de confeti profesional para momentos especiales.",
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "serviceType": "Renta de Máquina de Confeti"
});
---
<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Servicios", href: "/servicios/" }, { label: "Confeti" }]} />
</Fragment>
<Hero
      title="Máquina de Confeti para Eventos en CDMX"
      subtitle="Lluvia de confeti que convierte cada momento en una celebración espectacular"
      introParagraph1="En REDEIL ofrecemos renta de máquinas de confeti para bodas, fiestas y eventos en la Ciudad de México. Nuestros equipos profesionales lanzan confeti de forma controlada y espectacular, creando el clímax perfecto para los momentos más importantes de tu celebración."
      introParagraph2="Con experiencia en bodas, eventos corporativos, lanzamientos y fiestas privadas, nuestro equipo se encarga de coordinar las descargas de confeti en los instantes precisos para generar el mayor impacto visual y emocional en tus invitados."
    />
    <section class="service-detail">
      <SectionHeader
          title="El toque final que corona tu celebración"
          subtitle="Instalación profesional incluida en CDMX y Edomex."
          paragraph1="Una lluvia de confeti en el momento justo puede transformar un instante memorable en un recuerdo imborrable. Ya sea durante el brindis de los novios, el conteo de Año Nuevo o la revelación de un producto, el confeti aporta espectacularidad y emoción a cualquier evento."
          paragraph2="En REDEIL trabajamos con máquinas de confeti profesionales que permiten controlar la dirección, altura y densidad de la descarga. Utilizamos confeti de distintos colores y materiales que se adaptan a la temática de cada evento, incluyendo opciones metálicas doradas y plateadas ideales para bodas."
        />
        <p>Nuestro servicio en CDMX incluye el equipo, la operación técnica y el confeti necesario para tu evento. Coordinamos las descargas con tu DJ, maestro de ceremonias o coordinador para asegurar que el efecto ocurra en el momento perfecto.</p>
      </div>
    </section>
    <GallerySection title="Galería de Confeti" subtitle="Momentos de celebración con lluvia de confeti profesional">
      <figure class="gallery-item">
        <img src="/img/confeti/maquina-confeti-boda-novios-celebracion.avif" alt="Máquina de confeti lanzando papel durante celebración de boda con los novios" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/confeti/confeti-dorado-boda-novios-fiesta.avif" alt="Confeti dorado cayendo sobre los novios durante la fiesta de boda" width="800" height="533" loading="lazy">
      </figure>
    </GallerySection>
</BaseLayout>
