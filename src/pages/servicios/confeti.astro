---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import PricingCards from '../../components/PricingCards.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Máquina de Confeti para Eventos CDMX | REDEIL";
const description = "Explosiones de confeti y lluvia de papelitos para bodas, XV años, gender reveal y festivales en CDMX. Confeti biodegradable disponible. Desde $2,000 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/confeti/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Máquina de Confeti para Eventos",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Servicio profesional de renta de máquinas de confeti y papelitos para bodas, XV años, gender reveal y eventos masivos en CDMX. Confeti biodegradable disponible.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Renta de Máquina de Confeti",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Cuánto alcance tiene la explosión de confeti?", "acceptedAnswer": { "@type": "Answer", "text": "Las máquinas de confeti profesionales de CO₂ pueden disparar una nube de confeti hasta 8-10 metros de altura y 5-6 metros de radio. Para pistas de baile de hasta 200m², con 2-3 máquinas bien posicionadas se cubre toda el área." }},
      { "@type": "Question", "name": "¿Tienen confeti biodegradable?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Contamos con confeti de papel biodegradable especialmente para eventos al aire libre — jardines, haciendas y espacios exteriores donde la limpieza puede ser difícil. El confeti de papel se disuelve con agua y no daña el entorno." }},
      { "@type": "Question", "name": "¿El confeti se puede usar en exteriores?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Las máquinas de confeti de CO₂ funcionan perfectamente en exteriores. Con viento, la nube se dispersa más ampliamente — el efecto visual puede ser incluso más espectacular. Para exteriores recomendamos confeti biodegradable." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Niebla baja en boda en jardín", description: "Confeti en el primer baile + niebla baja para el vals. Dos efectos visuales que crean el momento más fotografiado.", link: "/servicios/humo-bajo/" },
  { title: "Seguidor de Luz", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Seguidor de luz en vals de novios", description: "Spotlight + lluvia de confeti = la foto de portada de revista. El efecto más cinematográfico para bodas.", link: "/servicios/seguidor/" },
  { title: "Cabezas Móviles", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante-300w.avif", alt: "Cabezas móviles con beams en boda", description: "Show de luces + explosión de confeti en el drop musical. La combinación que hace gritar a todos.", link: "/servicios/cabezas-moviles/" },
  { title: "Bola Disco", image: "/img/bola-disco/bola-disco-dj-pista-baile-evento.avif", alt: "Bola disco en pista de baile", description: "Los destellos de la bola disco + confeti cayendo = imagen de discoteca de lujo. Para fiestas retro o elegantes.", link: "/servicios/bola-disco/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Confeti y Papelitos" }
  ]} />
</Fragment>

    <Hero
      title="Renta de Máquina de Confeti y Papelitos en CDMX"
      subtitle="Explosiones de confeti de CO₂ para bodas, XV años, gender reveal y conciertos. Biodegradable disponible. Desde $2,000 + IVA."
      introParagraph1='Hay dos tipos de confeti para eventos, y la diferencia importa. Los cañones manuales de tienda de fiesta disparan a 2-3 metros y se acaban en un solo tiro. Las máquinas profesionales de CO₂ que usamos en <strong>REDEIL</strong> disparan nubes de confeti hasta 8-10 metros de altura con un radio de 5-6 metros. Puedes recargarlas y disparar varias veces en la misma noche. La explosión es más densa, más alta y se ve en las fotos de lejos.'
      introParagraph2='Tenemos confeti en <strong>dorado, blanco, rosa, azul, multicolor</strong> y en formas: corazones, estrellas, círculos. Para bodas en jardín o hacienda, el confeti <strong>biodegradable</strong> de papel es obligatorio en muchos venues porque se disuelve con agua en 24-72 horas sin dañar plantas. El confeti metálico (Mylar) se ve mejor en fotos pero es más difícil de limpiar y algunos salones cobran extra por usarlo. Te decimos cuál conviene según tu venue. El operador coordina el disparo exacto con tu fotógrafo y el DJ.'
    />

    <CtaBar
      headline="¿Para qué momento quieres la explosión?"
      items={[
        { label: "Vals de Boda", href: "#paquetes", icon: "efectos" },
        { label: "Gender Reveal", href: "#paquetes", icon: "efectos" },
        { label: "Más efectos", href: "/servicios/efectos-especiales/", icon: "efectos" },
        { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
      ]}
    />

    <!-- Galería -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="Confeti en bodas, XV años y gender reveals reales"
          subtitle="El momento exacto importa más que la cantidad de confeti."
          paragraph1="El operador no dispara cuando quiere. Se coordina con el fotógrafo para que la cámara esté lista, con el DJ para que coincida con el pico de la canción, y con el MC para que los novios estén en posición. Si el confeti sale 3 segundos antes o después, la foto no funciona."
          paragraph2="En gender reveals, el timing es todavía más crítico: la pareja abre la caja o el cañón dispara, y la reacción de sorpresa dura un segundo. El fotógrafo necesita estar listo en ese segundo exacto."
        />
        <Gallery4x4 images={[
          { src: "/img/maquina-de-papelitos/confeti-dorado-primer-baile-novios-romantico.avif", alt: "Confeti dorado en primer baile de novios romántico" },
          { src: "/img/maquina-de-papelitos/maquina-confeti-primer-baile-boda-salon-elegante.avif", alt: "Máquina de confeti en primer baile en salón elegante" },
          { src: "/img/maquina-de-papelitos/explosion-confeti-blanco-boda-pista-baile.avif", alt: "Explosión de confeti blanco en pista de baile de boda" },
          { src: "/img/maquina-de-papelitos/confeti-dorado-xv-anos-vals-quinceañera.avif", alt: "Confeti dorado en vals de quinceañera" },
          { src: "/img/maquina-de-papelitos/maquina-confeti-xv-anos-baile-padre-quinceañera.avif", alt: "Máquina de confeti en baile de padre con quinceañera" },
          { src: "/img/maquina-de-papelitos/lluvia-confeti-corazones-xv-anos-vestido-rosa.avif", alt: "Lluvia de confeti corazones en XV años con vestido rosa" },
          { src: "/img/maquina-de-papelitos/confeti-rosa-boda-jardin-atardecer-novios.avif", alt: "Confeti rosa en boda de jardín al atardecer" },
          { src: "/img/maquina-de-papelitos/explosion-confeti-rosa-revelacion-sexo-bebe-nina.avif", alt: "Explosión de confeti rosa en gender reveal de niña" },
          { src: "/img/maquina-de-papelitos/explosion-confeti-azul-revelacion-sexo-bebe-nino.avif", alt: "Confeti azul en gender reveal de niño" },
          { src: "/img/maquina-de-papelitos/maquina-confeti-concierto-fiesta-neon-colores.avif", alt: "Máquina de confeti en concierto con fiesta neón de colores" },
          { src: "/img/maquina-de-papelitos/explosion-confeti-concierto-multitud-luces.avif", alt: "Explosión de confeti en concierto con multitud y luces" },
          { src: "/img/maquina-de-papelitos/confeti-discoteca-laser-verde-bola-espejos.avif", alt: "Confeti en discoteca con láser verde y bola de espejos" },
          { src: "/img/maquina-de-papelitos/maquina-confeti-baile-padre-novia-recepcion.avif", alt: "Confeti en baile de padre e hija en recepción de boda" },
          { src: "/img/maquina-de-papelitos/lluvia-papelitos-boda-elegante-candelabros.avif", alt: "Lluvia de papelitos en boda elegante con candelabros" },
          { src: "/img/maquina-de-papelitos/confeti-salida-iglesia-boda-novios-felices.avif", alt: "Confeti en salida de iglesia de boda novios felices" },
          { src: "/img/maquina-de-papelitos/lluvia-confeti-boda-candelier-chispas-frias.avif", alt: "Lluvia de confeti con chispas frías y candelier en boda" },
        ]} />
      </div>
    </section>

    <!-- Paquetes -->
    <section class="services-section services-alt" id="paquetes">
      <div class="container">
        <SectionHeader
          title="Paquetes de Confeti y Papelitos"
          subtitle="Desde un disparo único hasta cobertura completa del evento. Operador incluido."
          paragraph1="Cada paquete incluye las máquinas de CO₂, el confeti en el color que elijas, operador técnico y traslado. El operador coordina el disparo con el fotógrafo, el DJ y el maestro de ceremonias para el timing perfecto."
          paragraph2="¿Necesitas colores específicos o confeti en forma especial? Consultanos — tenemos amplio catálogo de formas y colores."
        />
        <PricingCards packages={[
          {
            name: "Disparo Único",
            price: "$2,000",
            priceNote: "+ IVA",
            description: "Una explosión de confeti perfectamente cronometrada para el momento más especial del evento.",
            features: [
              { text: "1 máquina de confeti CO₂ profesional", included: true },
              { text: "1 carga de confeti a tu elección de color", included: true },
              { text: "Operador técnico incluido", included: true },
              { text: "Traslado + montaje + desmontaje", included: true },
              { text: "Coordinación con fotógrafo/DJ", included: true },
              { text: "Ideal para: vals, gender reveal, momentos únicos", included: true },
              { text: "Disparos adicionales", included: false },
              { text: "Múltiples colores", included: false },
            ],
            ctaLabel: "Cotizar disparo único",
            ctaHref: "/servicios/confeti/paquete-2-canones/",
          },
          {
            name: "Moments Pack — 3 Disparos",
            price: "$4,000",
            priceNote: "+ IVA",
            badge: "Más popular",
            highlight: true,
            description: "3 explosiones para los 3 momentos estelares del evento. Vals, brindis y hora loca — cada uno con su propio confeti.",
            features: [
              { text: "2 máquinas de confeti CO₂", included: true },
              { text: "3 cargas de confeti (colores diferentes)", included: true },
              { text: "Operador técnico incluido", included: true },
              { text: "Traslado + montaje + desmontaje", included: true },
              { text: "Coordinación completa con DJ/MC", included: true },
              { text: "Ideal para: bodas, XV años completos", included: true },
              { text: "Timing personalizado por momento", included: true },
              { text: "Confeti biodegradable opcional", included: true },
            ],
            ctaLabel: "Cotizar 3 momentos",
            ctaHref: "/servicios/confeti/paquete-4-canones/",
          },
          {
            name: "Show Completo",
            price: "$6,500",
            priceNote: "+ IVA",
            description: "Máquinas de confeti disponibles toda la noche para múltiples activaciones en los picos del evento.",
            features: [
              { text: "3 máquinas de confeti CO₂ profesionales", included: true },
              { text: "Recarga ilimitada de confeti", included: true },
              { text: "Operador técnico toda la noche", included: true },
              { text: "Múltiples colores disponibles", included: true },
              { text: "Coordinación con DJ en tiempo real", included: true },
              { text: "Ideal para: galas, corporativos, XV años VIP", included: true },
              { text: "Confeti biodegradable para exterior", included: true },
              { text: "Cobertura de toda la pista de baile", included: true },
            ],
            ctaLabel: "Cotizar show completo",
            ctaHref: "/servicios/confeti/paquete-confeti-biodegradable/",
          },
          {
            name: "Producción Masiva",
            price: "$12,000",
            priceNote: "+ IVA",
            description: "Para conciertos, festivales y eventos de gran escala. Cañones de confeti de largo alcance para cubrir a cientos de personas.",
            features: [
              { text: "6+ cañones de confeti profesionales", included: true },
              { text: "Confeti de largo alcance (hasta 15m)", included: true },
              { text: "Confeti dorado, plateado y multicolor", included: true },
              { text: "Equipo técnico completo", included: true },
              { text: "Sincronización con producción del evento", included: true },
              { text: "Recarga ilimitada durante el show", included: true },
              { text: "Ideal para: conciertos, festivales, TV", included: true },
              { text: "Visita previa de producción", included: true },
            ],
            ctaLabel: "Cotizar producción masiva",
            ctaHref: "/servicios/confeti/paquete-produccion/",
          },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre Confeti y Papelitos"
          subtitle="Todo lo que necesitas saber antes de contratar."
          paragraph1="Si tienes otra duda, escríbenos por WhatsApp y te respondemos en minutos."
          paragraph2="Tenemos confeti en todos los colores, tamaños y materiales — te asesoramos para elegir el ideal."
        />
      </div>
      <FaqSection items={[
        { question: "¿El confeti deja residuo difícil de limpiar?", answer: "Depende del tipo. El confeti metálico (Mylar) es el más bonito pero el más difícil de recoger — se adhiere a telas y alfombras. El confeti de papel es más fácil de barrer. El biodegradable se disuelve con agua. Para venues que cobran limpieza extra por confeti metálico, recomendamos el de papel o biodegradable. Siempre consultamos con el venue antes." },
        { question: "¿Tienen confeti biodegradable para jardines?", answer: "Sí. Contamos con confeti de papel biodegradable en colores, corazones y formas especiales. Se disuelve con agua en 24-72 horas sin afectar plantas ni jardines. Es la opción preferida para bodas en haciendas y jardines exteriores." },
        { question: "¿En qué colores tienen confeti?", answer: "Dorado, plateado, blanco, rosa, azul, verde, rojo, multicolor y en formas: corazones, estrellas, círculos, mariposas y confeti rectangular estándar. Para gender reveals tenemos rosa y azul específicamente. Si necesitas un color especial, consúltanos con anticipación." },
        { question: "¿Cuánto alcance tiene la máquina?", answer: "Las máquinas profesionales de CO₂ disparan confeti hasta 8-10 metros de altura y 5-6 metros de radio horizontal. Para cubrir una pista de baile de 200m², usamos 2-3 máquinas posicionadas estratégicamente en los extremos." },
        { question: "¿Se puede usar en el exterior de la iglesia?", answer: "Sí — es uno de los usos más populares. La salida de los novios de la iglesia entre una lluvia de confeti es una imagen clásica. Usamos confeti de papel biodegradable para no dejar residuo en la banqueta. El operador se posiciona en el exterior y dispara cuando los novios cruzan la puerta." },
        { question: "¿Los cañones de CO₂ son seguros?", answer: "Sí. Las máquinas profesionales de confeti CO₂ son equipo de entretenimiento certificado — el gas CO₂ se libera en cantidades mínimas y se disipa instantáneamente en el aire sin riesgo para los invitados. Son las mismas máquinas que se usan en conciertos de estadio." },
      ]} />
    </section>

    <!-- Servicios relacionados -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Lo que más se combina con confeti"
          subtitle="Confeti + seguidor de luz = la foto que los novios enmarcan."
          paragraph1="Confeti dorado cayendo mientras el spotlight del seguidor ilumina a los novios. Esa combinación produce la foto que más se comparte de cualquier boda. También funciona bien con cabezas móviles en modo beam, porque los haces de luz iluminan cada papelito en el aire."
          paragraph2="Precio especial cuando combinas confeti con otros servicios."
        />
        <div class="services-grid">
          {serviciosRelacionados.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Listo para el momento más fotografiado de tu evento?</h2>
          <p>Cuéntanos para qué momento quieres el confeti y qué color va mejor con tu decoración. Te cotizamos en minutos.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
