---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Show Estándar 8 Cabezas Móviles para Bodas CDMX | REDEIL";
const description = "8 cabezas Beam+Spot+Wash con operador DMX para bodas completas y XV años en CDMX. Truss o totems. Desde $10,000 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/cabezas-moviles/paquete-show-estandar/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Show Estándar — 8 Cabezas Móviles",
    "description": "Show de luces con 8 cabezas móviles LED Beam+Spot+Wash para bodas completas y XV años en CDMX. Incluye truss o totems, operador DMX profesional, transporte, montaje y desmontaje.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/cabezas-moviles/paquete-show-estandar/",
      "priceCurrency": "MXN",
      "price": "10000",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "67",
      "reviewCount": "67"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Valentina Cruz" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Contratamos el Show Estándar para nuestra boda en una hacienda de Tlalpan. Las 8 cabezas móviles cubrieron perfectamente tanto la pista como el salón de cena. La combinación de beams, spot y wash es impresionante — cada momento del evento tuvo su propio ambiente de luces."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Elena Morales" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Lo usamos para los XV años de mi hija en un salón de Santa Fe. El show de luces fue lo que más elogios recibió de los invitados. El operador programó secuencias específicas para la vals, la sorpresa y la fiesta — todo perfectamente coordinado con el DJ."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Roberto Jiménez" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Nuestra boda en un hotel de Polanco con 180 invitados. Las 8 cabezas en truss cubrieron todo el salón — desde los beams que cruzaban el techo hasta el wash que cambiaba el color de las paredes. REDEIL es profesional en todo sentido."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/cabezas-moviles/renta-cabezas-moviles-show-profesional-truss-beams.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿8 cabezas móviles son suficientes para una boda de 150 invitados?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. 8 cabezas móviles Beam+Spot+Wash son perfectas para bodas de 100-200 invitados. El Spot agrega proyección de patrones y gobos, el Beam crea efectos aéreos y el Wash ambienta el salón completo. Para eventos de más de 200 invitados o producción profesional, considera el Show Premium de 12 cabezas." }},
      { "@type": "Question", "name": "¿Puedo elegir entre truss y totems?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El Show Estándar incluye ambas opciones según las características de tu venue. El truss crea un montaje aéreo más profesional e impactante. Los totems son ideales cuando el techo no permite instalación aérea. Evaluamos tu espacio y te recomendamos la mejor opción." }},
      { "@type": "Question", "name": "¿Las cabezas Spot proyectan gobos personalizados?", "acceptedAnswer": { "@type": "Answer", "text": "Las cabezas Spot del Show Estándar incluyen gobos estándar (espirales, puntos, figuras geométricas). Para proyectar tu nombre o monograma personalizado, tenemos el servicio de gobos personalizados como complemento. Pregúntanos al cotizar." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Show Básico — 4 Cabezas", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante.avif", alt: "4 cabezas móviles para boda íntima", description: "Beam+Wash en totems para bodas íntimas y pistas pequeñas. $6,000 + IVA.", link: "/servicios/cabezas-moviles/paquete-show-basico/" },
  { title: "Show Premium — 12 Cabezas", image: "/img/cabezas-moviles/renta-cabezas-moviles-gala-corporativa-salon-rosa.avif", alt: "12 cabezas móviles en truss para gala premium", description: "Truss aéreo para galas corporativas y producciones grandes. $16,000 + IVA.", link: "/servicios/cabezas-moviles/paquete-show-premium/" },
  { title: "Sky Tracker", image: "/img/sky-tracker/renta-skytracker-cielo-nocturno-potente-300w.avif", alt: "Sky tracker en el cielo nocturno", description: "Combina sky tracker exterior con el show de cabezas móviles interior.", link: "/servicios/sky-tracker/" },
  { title: "City Color", image: "/img/city-color/iluminacion-ceremonia-boda-hacienda-300w.avif", alt: "City color iluminando ceremonia en hacienda", description: "Wash de color en paredes y fachada como complemento al show en pista.", link: "/servicios/city-color/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Iluminación", href: "/servicios/iluminacion/" },
    { label: "Cabezas Móviles", href: "/servicios/cabezas-moviles/" },
    { label: "Show Estándar" }
  ]} />
</Fragment>

  <Hero
    title="Show Estándar — 8 Cabezas Móviles para Bodas y XV Años"
    subtitle="Desde $10,000 + IVA. Beam + Spot + Wash. Truss o totems. El más pedido."
    introParagraph1='El Show Estándar de 8 cabezas móviles es el paquete más solicitado para bodas completas y XV años en CDMX. Con 8 luminarias robóticas que combinan los tres tipos — Beam para efectos aéreos, Spot para proyección de patrones y gobos, Wash para ambientar el salón con color — tienes una producción de luces que cubre tanto la pista de baile como el espacio general del evento para 150 o más invitados.'
    introParagraph2='A diferencia del Show Básico, aquí incorporamos las cabezas Spot que proyectan figuras geométricas, espirales y patrones en piso y paredes, agregando una dimensión visual completamente diferente. El montaje puede ser en truss aéreo para el efecto más profesional, o en totems si el venue no permite instalación colgante. Operador DMX con consola profesional incluido, programación de cues por momentos clave y coordinación con tu DJ o banda en vivo. Cobertura CDMX y Estado de México.'
  />

  <CtaBar
    headline="¿Necesitas más o menos cabezas móviles?"
    items={[
      { label: "Show Básico — $6,000", href: "/servicios/cabezas-moviles/paquete-show-basico/", icon: "iluminacion" },
      { label: "Show Premium — $16,000", href: "/servicios/cabezas-moviles/paquete-show-premium/", icon: "iluminacion" },
      { label: "Producción — $28,000", href: "/servicios/cabezas-moviles/paquete-produccion/", icon: "iluminacion" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <!-- Contenido principal + Sidebar sticky -->
  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Show Estándar"
      price="$10,000"
      priceNote="+ IVA · El más popular"
      badge="Más popular"
      features={[
        { text: "8 cabezas móviles LED" },
        { text: "Tipo Beam + Spot + Wash" },
        { text: "Truss aéreo o totems" },
        { text: "Cableado DMX certificado" },
        { text: "Operador profesional incluido" },
        { text: "Programación de cues completa" },
        { text: "Gobos estándar incluidos" },
        { text: "Sincronización con DJ" },
        { text: "Transporte, montaje y desmontaje" },
        { text: "Cobertura CDMX y Edomex" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el Show Estándar de 8 cabezas móviles para mi evento."
      packages={[
        { label: "Show Básico — 4", price: "$6,000", href: "/servicios/cabezas-moviles/paquete-show-basico/" },
        { label: "Show Estándar — 8", price: "$10,000", href: "/servicios/cabezas-moviles/paquete-show-estandar/", active: true },
        { label: "Show Premium — 12", price: "$16,000", href: "/servicios/cabezas-moviles/paquete-show-premium/" },
        { label: "Producción — 20+", price: "$28,000", href: "/servicios/cabezas-moviles/paquete-produccion/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="El show completo para bodas y XV años"
          subtitle="8 cabezas Beam+Spot+Wash cubren pista y salón completo."
          paragraph1="Este paquete está diseñado para eventos donde quieres un show de luces que se vea en toda la foto — no solo en la pista. Las 8 cabezas distribuidas estratégicamente en truss o totems crean efecto en el techo, las paredes y el piso simultáneamente."
          paragraph2="El truss aéreo eleva el impacto visual: las cabezas cuelgan sobre la pista y los beams bajan hacia la pista de baile, el mismo efecto que ves en conciertos profesionales."
        />
        <FeatureGrid features={[
          { title: "Bodas 150+ Invitados", description: "Cobertura completa de pista y salón. El show de luces que esperan tus invitados." },
          { title: "XV Años", description: "El evento favorito para cabezas móviles en CDMX. Beams rosas y azules que todos recuerdan." },
          { title: "Haciendas y Salones", description: "Adaptamos el montaje a la arquitectura — columnas, vigas y techos altos." },
          { title: "Truss Aéreo Profesional", description: "Efecto de concierto. Los beams cuelgan sobre la pista y apuntan hacia abajo." },
          { title: "Totems como Alternativa", description: "Para venues donde el truss no cabe. Mismo show, diferente ángulo." },
          { title: "Sincronización con Banda", description: "Coordinamos con bandas en vivo para cues en canciones específicas." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Beam + Spot + Wash: el trío profesional"
          subtitle="Cada tipo de cabeza cumple un rol diferente en el show."
          paragraph1="El Beam crea los haces aéreos que cruzan el salón — el efecto más espectacular cuando hay algo de humo. El Spot proyecta patrones y gobos en piso y paredes con bordes definidos. El Wash baña grandes áreas con color cambiante."
          paragraph2="Cuando los tres trabajan juntos y los controla un operador profesional, el resultado es una producción de luces que parece de una categoría completamente diferente."
        />
        <FeatureGrid features={[
          { title: "Beam — Efectos Aéreos", description: "Haces concentrados que cruzan el salón. Se ven mejor con algo de humo escénico." },
          { title: "Spot — Patrones y Gobos", description: "Proyecta figuras, espirales y diseños geométricos en piso y paredes." },
          { title: "Wash — Color Ambiente", description: "Baña el salón completo con colores que cambian según el momento." },
          { title: "3 Tipos Simultáneos", description: "Los tres efectos al mismo tiempo crean una profundidad visual imposible con un solo tipo." },
          { title: "Gobos Estándar Incluidos", description: "Espirales, puntos, figuras geométricas y abstractas — sin costo adicional." },
          { title: "Coreografía Personalizada", description: "Programación específica para vals, sorpresa, hora loca y cierre del evento." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="⭐⭐⭐⭐⭐ 5 estrellas en 67 reseñas."
          paragraph1="El Show Estándar es el más contratado — y el que más reseñas recibe. Estos son tres eventos reales."
          paragraph2="Pregunta por referencias de eventos similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Valentina Cruz", event: "Boda en hacienda — Tlalpan", rating: 5, text: "Las 8 cabezas cubrieron perfectamente la pista y el salón de cena. La combinación de beams, spot y wash es impresionante — cada momento del evento tuvo su propio ambiente de luces." },
          { name: "Elena Morales", event: "XV años en salón — Santa Fe", rating: 5, text: "El show de luces fue lo que más elogios recibió. El operador programó secuencias específicas para el vals, la sorpresa y la fiesta — todo perfectamente coordinado con el DJ." },
          { name: "Roberto Jiménez", event: "Boda en hotel — Polanco", rating: 5, text: "180 invitados en un hotel de Polanco. Las 8 cabezas en truss cubrieron todo el salón — los beams cruzaban el techo y el wash cambiaba el color de las paredes. Muy profesionales." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <!-- Galería -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Show Estándar en eventos reales"
        subtitle="8 cabezas móviles en bodas, XV años y eventos de 150+ invitados."
        paragraph1="Cada foto es de un montaje real con el paquete Show Estándar. Haciendas, salones de hotel, venues modernos — 8 cabezas en truss o totems crean un show que se ve en toda la celebración."
        paragraph2="¿Tu venue se parece a alguno de estos? Mándanos fotos por WhatsApp y te decimos cómo quedarían las cabezas móviles."
      />
      <Gallery4x4 images={[
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-show-luces-beams-colores.avif", alt: "Show de luces con 8 cabezas beams de colores" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-fiesta-xv-beams-rosa-azul.avif", alt: "XV años con 8 cabezas móviles beams rosa y azul" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-show-profesional-truss-beams.avif", alt: "Montaje profesional en truss con 8 cabezas móviles" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-xv-anos-pista-baile-rosa.avif", alt: "Pista de baile de XV años con cabezas móviles rosa" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-boda-salon-iluminacion-completa.avif", alt: "Salón de boda con iluminación completa de 8 cabezas" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-evento-beams-cruzados-fiesta.avif", alt: "Beams cruzados de 8 cabezas en fiesta nocturna" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-fiesta-graduacion-luces-colores.avif", alt: "Fiesta de graduación con show de luces coloridas" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-evento-social-iluminacion-dinamica.avif", alt: "Evento social con iluminación dinámica de cabezas móviles" },
      ]} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Show Estándar"
        subtitle="Todo lo que necesitas saber antes de reservar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
        paragraph2="Cada espacio es diferente — te asesoramos gratis sobre la mejor configuración para tu venue."
      />
    </div>
    <FaqSection items={[
      { question: "¿8 cabezas son suficientes para una boda de 150-200 invitados?", answer: "Sí. 8 cabezas móviles Beam+Spot+Wash son la configuración estándar para bodas de 100-200 invitados en salones medianos a grandes. El Beam cubre efectos aéreos, el Spot proyecta patrones y el Wash ambienta el salón completo. Para más de 200 invitados o producción premium, considera el Show de 12 Cabezas." },
      { question: "¿En qué se diferencia del Show Básico de 4 cabezas?", answer: "El Show Estándar agrega 4 cabezas más y suma el tipo Spot — que proyecta patrones y gobos en piso y paredes. Con 8 cabezas cubres pista y salón completo, no solo la pista de baile. Además, puedes elegir montaje en truss aéreo para un efecto más profesional." },
      { question: "¿Puedo pedir truss aéreo en vez de totems?", answer: "Sí. El Show Estándar incluye la opción de truss o totems según las características de tu venue. El truss aéreo requiere puntos de anclaje en el techo — nuestro equipo evalúa el espacio en la visita previa. Si el techo no permite instalación, los totems dan el mismo show desde un ángulo diferente." },
      { question: "¿Las cabezas Spot pueden proyectar mi nombre?", answer: "Las cabezas Spot del Show Estándar incluyen gobos estándar (figuras, espirales, patrones). Para proyectar tu nombre o monograma personalizado necesitas el servicio de gobos personalizados — pregúntanos al cotizar y te hacemos precio especial." },
      { question: "¿Pueden coordinarse con una banda en vivo?", answer: "Sí. Nuestro operador se reúne antes del evento con el coordinador musical para definir los cues exactos. Con banda en vivo, se programa por canciones específicas — el vals, los brindis, la hora loca. El resultado es un show sincronizado que amplifica el impacto de cada momento." },
      { question: "¿Qué pasa si hay lluvia el día de mi evento?", answer: "Los venues cerrados no tienen problema. Para eventos al aire libre o jardines, evaluamos la configuración con anticipación. Contamos con equipo con mayor protección para exteriores en casos específicos — coméntalo al cotizar." },
    ]} />
  </section>

  <!-- Otros paquetes -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes y Servicios"
        subtitle="¿Necesitas menos, más o quieres combinar con otro servicio?"
        paragraph1="Si tu evento es más íntimo, el Show Básico de 4 cabezas cubre la pista perfectamente. Si es una gala o producción grande, el Show Premium lleva el espectáculo al siguiente nivel."
        paragraph2="También puedes combinar con sky tracker exterior y city color para una producción visual completa."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para reservar el Show Estándar de cabezas móviles?</h2>
        <p>Cuéntanos la fecha, el venue y la cantidad de invitados. Te confirmamos disponibilidad y te enviamos el presupuesto en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Reservar — Cotiza Gratis</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
