---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Show Básico 4 Cabezas Móviles para Bodas CDMX | REDEIL";
const description = "Show de luces con 4 cabezas móviles LED Beam+Wash para pista de baile en bodas y fiestas CDMX. Operador DMX incluido. Desde $6,000 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/cabezas-moviles/paquete-show-basico/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Show Básico — 4 Cabezas Móviles",
    "description": "Show de luces con 4 cabezas móviles LED Beam+Wash para pista de baile en bodas íntimas y fiestas privadas en CDMX. Incluye totems portátiles, operador DMX, transporte, montaje y desmontaje.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/cabezas-moviles/paquete-show-basico/",
      "priceCurrency": "MXN",
      "price": "6000",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "44",
      "reviewCount": "44"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Sofía Ramírez" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Contratamos el show básico para nuestra boda en un jardín de Coyoacán. Las 4 cabezas móviles transformaron la pista de baile — los beams blancos durante el vals se veían increíbles. El operador llegó temprano y todo estuvo listo antes de que llegaran los invitados."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Diego Herrera" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Renté las cabezas móviles para una fiesta privada en Polanco. El equipo fue muy puntual y el show de luces superó todas mis expectativas. Para una pista de baile pequeña, las 4 cabezas son más que suficientes. Totalmente recomendado."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Patricia Vega" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Usé el paquete básico para el cumpleaños de mis 50 años en la Condesa. Las cabezas móviles le dieron un ambiente de club a la terraza. El operador fue excelente — coordinó las luces perfectamente con el DJ."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿4 cabezas móviles son suficientes para mi pista de baile?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. 4 cabezas móviles cubren perfectamente una pista de baile de hasta 100m². Para bodas íntimas de hasta 80 invitados, este paquete crea un show de luces completo con beams y wash. Si tu evento tiene más invitados o varias zonas, te recomendamos el Show Estándar de 8 cabezas." }},
      { "@type": "Question", "name": "¿Los totems portátiles se pueden instalar en cualquier venue?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Los totems son estructuras autoportantes que no requieren fijación al techo ni paredes. Se instalan en minutos y funcionan en jardines, salones, terrazas y venues con techos bajos donde el truss aéreo no es viable." }},
      { "@type": "Question", "name": "¿El operador DMX está incluido en el precio?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Los $6,000 + IVA incluyen todo: 4 cabezas móviles LED, totems, cableado DMX, operador profesional con consola, programación de secuencias y desmontaje al finalizar. Sin costos adicionales." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Show Estándar — 8 Cabezas", image: "/img/cabezas-moviles/renta-cabezas-moviles-show-profesional-truss-beams.avif", alt: "8 cabezas móviles en truss para boda estándar", description: "Beam+Spot+Wash para bodas 150+ invitados y XV años. Truss o totems. $10,000 + IVA.", link: "/servicios/cabezas-moviles/paquete-show-estandar/" },
  { title: "Show Premium — 12 Cabezas", image: "/img/cabezas-moviles/renta-cabezas-moviles-gala-corporativa-salon-rosa.avif", alt: "12 cabezas móviles para gala corporativa premium", description: "Truss aéreo profesional para galas y producciones grandes. $16,000 + IVA.", link: "/servicios/cabezas-moviles/paquete-show-premium/" },
  { title: "Gobos Personalizados", image: "/img/gobos/renta-gobo-monograma-pista-baile-300w.avif", alt: "Gobo proyectando monograma en pista de baile", description: "Complementa las cabezas móviles con tu monograma proyectado en la pista de baile.", link: "/servicios/gobos/" },
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Efecto nubes en piso para boda en jardín", description: "Los beams se ven espectaculares cortando el humo bajo. La combinación más solicitada.", link: "/servicios/humo-bajo/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Iluminación", href: "/servicios/iluminacion/" },
    { label: "Cabezas Móviles", href: "/servicios/cabezas-moviles/" },
    { label: "Show Básico" }
  ]} />
</Fragment>

  <Hero
    title="Show Básico — 4 Cabezas Móviles para Pista de Baile"
    subtitle="Desde $6,000 + IVA. Beam + Wash en totems portátiles. Operador DMX incluido."
    introParagraph1='El Show Básico de 4 cabezas móviles es la opción ideal para bodas íntimas, fiestas privadas y celebraciones donde la pista de baile es el centro de la noche. Cuatro luminarias robóticas LED montadas en totems portátiles que proyectan beams concentrados y wash de colores — suficiente para transformar cualquier pista de hasta 100m² en un escenario profesional. Sin necesidad de truss ni instalación compleja en el techo.'
    introParagraph2='Incluye todo lo necesario: las 4 cabezas móviles LED tipo Beam+Wash, totems autoportantes que se instalan en minutos, cableado DMX certificado, operador profesional con consola y programación personalizada de secuencias. El operador llega antes del evento para programar los cues según tus momentos clave — vals, brindis, hora loca — y los controla en vivo sincronizando con tu DJ. Servicio completo en toda la CDMX y Estado de México.'
  />


  <!-- Contenido principal + Sidebar sticky -->
  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Show Básico"
      price="$6,000"
      priceNote="+ IVA · Operador incluido"
      features={[
        { text: "4 cabezas móviles LED" },
        { text: "Tipo Beam + Wash" },
        { text: "Totems portátiles autoportantes" },
        { text: "Cableado DMX certificado" },
        { text: "Operador profesional incluido" },
        { text: "Programación por momentos clave" },
        { text: "Transporte ida y vuelta" },
        { text: "Montaje y desmontaje" },
        { text: "Pista de baile hasta 100m²" },
        { text: "Cobertura CDMX y Edomex" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el Show Básico de 4 cabezas móviles para mi evento."
      packages={[
        { label: "Show Básico — 4", price: "$6,000", href: "/servicios/cabezas-moviles/paquete-show-basico/", active: true },
        { label: "Show Estándar — 8", price: "$10,000", href: "/servicios/cabezas-moviles/paquete-show-estandar/" },
        { label: "Show Premium — 12", price: "$16,000", href: "/servicios/cabezas-moviles/paquete-show-premium/" },
        { label: "Producción — 20+", price: "$28,000", href: "/servicios/cabezas-moviles/paquete-produccion/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="Perfecto para estos eventos"
          subtitle="4 cabezas móviles cubren pistas de baile de hasta 100m²."
          paragraph1="Este paquete está diseñado para eventos íntimos donde quieres un show de luces profesional sin la complejidad ni el costo de una producción grande. Los totems portátiles permiten instalar en cualquier venue sin depender del techo."
          paragraph2="Nuestro operador diseña la posición óptima de los totems según la forma de tu pista para maximizar el efecto de los beams."
        />
        <FeatureGrid features={[
          { title: "Bodas Íntimas", description: "Hasta 80 invitados. Show completo en la pista de baile con beams y wash de colores." },
          { title: "Fiestas Privadas", description: "Departamentos, rooftops y salones pequeños. Los totems no requieren fijación al techo." },
          { title: "Cumpleaños de Adultos", description: "Ambiente de club para celebraciones íntimas en terrazas y jardines privados." },
          { title: "Venues con Techo Bajo", description: "Donde el truss no cabe, los totems son la solución. Instalación en 30 minutos." },
          { title: "Eventos al Aire Libre", description: "Jardines y terrazas. Los equipos operan sin problemas en exteriores bajo techo." },
          { title: "Bodas en Jardín", description: "Ideal para ceremonias íntimas. Los beams blancos durante el vals son icónicos." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Beam + Wash: dos efectos en uno"
          subtitle="Los dos tipos de luz que más se usan en bodas y fiestas privadas."
          paragraph1="Las cabezas Beam proyectan haces concentrados y delgados — el efecto de rayos cruzándose en el salón que ves en conciertos. Las cabezas Wash bañan la pista de colores suaves y cambiantes. La combinación de ambas crea un show completo."
          paragraph2="En el vals, usamos beams blancos suaves. En la hora loca, colores explosivos y movimientos rápidos. Tu operador adapta el show a cada momento del evento."
        />
        <FeatureGrid features={[
          { title: "Beam — Haces Aéreos", description: "Rayos concentrados que cruzan el salón. El efecto más impactante para la pista." },
          { title: "Wash — Color Ambiente", description: "Baño de color que envuelve la pista. Cambia el ambiente de cálido a festivo." },
          { title: "Totems Autoportantes", description: "No necesitan techo ni estructura del venue. Se posicionan estratégicamente." },
          { title: "Control DMX en Vivo", description: "El operador controla cada movimiento en tiempo real desde su consola." },
          { title: "Programación Personalizada", description: "Cues específicos para vals, brindis, entrada de novios y hora loca." },
          { title: "Sincronización con DJ", description: "Las luces siguen el ritmo y la energía de cada canción del evento." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="El operador hace la diferencia"
          subtitle="Llegamos 2 horas antes. Programamos. Controlamos en vivo."
          paragraph1="Un show de luces sin operador es solo iluminación estática. Con un operador profesional, las luces cuentan la historia de tu evento — cada momento tiene su ambiente."
          paragraph2="Nuestro operador se coordina con tu DJ o MC para saber los tiempos exactos. El resultado es un show donde las luces y la música funcionan como uno solo."
        />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="⭐⭐⭐⭐⭐ 5 estrellas en 44 reseñas."
          paragraph1="Cada reseña es de un cliente real que contrató el Show Básico de cabezas móviles."
          paragraph2="Pregunta por referencias de eventos similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Sofía Ramírez", event: "Boda en jardín íntima — Coyoacán", rating: 5, text: "Las 4 cabezas móviles transformaron la pista de baile — los beams blancos durante el vals se veían increíbles. El operador llegó temprano y todo estuvo listo antes de que llegaran los invitados." },
          { name: "Diego Herrera", event: "Fiesta privada — Polanco", rating: 5, text: "El show de luces superó todas mis expectativas. Para una pista de baile pequeña, las 4 cabezas son más que suficientes. El equipo fue muy puntual y profesional." },
          { name: "Patricia Vega", event: "Cumpleaños de adultos — Condesa", rating: 5, text: "Las cabezas móviles le dieron un ambiente de club a la terraza. El operador fue excelente — coordinó las luces perfectamente con el DJ durante toda la noche." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <!-- Galería -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Show Básico en eventos reales"
        subtitle="4 cabezas móviles en pistas de baile, bodas íntimas y fiestas privadas."
        paragraph1="Cada foto es de un montaje real con el paquete Show Básico. Bodas en jardín, fiestas en rooftop, cumpleaños en terraza — 4 cabezas son suficientes para crear una pista de baile profesional."
        paragraph2="¿Tu venue se parece a alguno de estos? Mándanos fotos por WhatsApp y te decimos cómo quedarían las cabezas móviles."
      />
      <Gallery4x4 images={[
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante.avif", alt: "4 cabezas móviles con beams blancos en boda elegante" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-boda-pista-baile-azul-rosa.avif", alt: "Pista de baile iluminada con cabezas móviles azul y rosa" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-boda-baile-novios-iluminacion.avif", alt: "Baile de novios con iluminación de cabezas móviles" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-boda-romantica-beams-suaves.avif", alt: "Boda romántica con beams suaves en pista íntima" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-fiesta-beams-humo-pista.avif", alt: "Fiesta privada con beams cortando el humo en pista" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-fiesta-privada-beams-azul.avif", alt: "Fiesta privada con cabezas móviles beams azul" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-operador-consola-dmx-boda.avif", alt: "Operador DMX controlando show de luces en boda" },
        { src: "/img/cabezas-moviles/renta-cabezas-moviles-pista-baile-gobos-espiral.avif", alt: "Pista de baile con gobos espiral de cabezas móviles" },
      ]} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Show Básico"
        subtitle="Todo lo que necesitas saber antes de reservar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
        paragraph2="Cada espacio es diferente — te asesoramos gratis sobre si 4 cabezas son suficientes para tu venue."
      />
    </div>
    <FaqSection items={[
      { question: "¿4 cabezas móviles son suficientes para mi pista de baile?", answer: "Sí. 4 cabezas móviles cubren perfectamente una pista de baile de hasta 100m². Para bodas íntimas de hasta 80 invitados, este paquete crea un show de luces completo con beams y wash. Si tu evento tiene más invitados o varias zonas de iluminación, te recomendamos el Show Estándar de 8 cabezas ($10,000 + IVA)." },
      { question: "¿El precio de $6,000 incluye el operador?", answer: "Sí. Los $6,000 + IVA incluyen todo: las 4 cabezas móviles LED, los totems, el cableado DMX, el operador profesional con consola, la programación de secuencias y el desmontaje al finalizar. Sin costos ocultos ni adicionales." },
      { question: "¿Los totems se pueden instalar en jardines y terrazas?", answer: "Sí. Los totems son estructuras autoportantes que no requieren fijación al techo, paredes ni estructuras del venue. Se instalan en cualquier superficie plana — jardines, terrazas, patios y salones. Ideales para venues donde el truss aéreo no es viable." },
      { question: "¿Qué diferencia hay entre Beam y Wash?", answer: "Beam proyecta haces concentrados y delgados que cruzan el salón — el efecto de rayos que ves en conciertos. Wash baña la pista con colores suaves y uniformes que cambian el ambiente. Las 4 cabezas del Show Básico incluyen ambos tipos para que tengas los dos efectos." },
      { question: "¿Se puede agregar humo escénico al paquete?", answer: "Sí, y es la combinación más pedida. Los beams se hacen visibles al cortar el humo — el efecto es espectacular. Cotiza el humo bajo o humo escénico por separado y te hacemos precio especial al combinar con el Show Básico." },
      { question: "¿Con cuánta anticipación debo reservar?", answer: "Idealmente 2-3 semanas antes. En temporada alta (noviembre-enero y mayo-junio) las fechas se llenan rápido. Entre antes reserves, mejor — así garantizamos disponibilidad para tu fecha." },
    ]} />
  </section>

  <!-- Otros paquetes -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes y Servicios"
        subtitle="¿Necesitas más cabezas móviles o complementar el show?"
        paragraph1="Si tu evento es más grande o quieres una producción más completa, tenemos paquetes hasta 20+ cabezas. Y si quieres maximizar el efecto, combinamos con gobos personalizados y humo bajo."
        paragraph2="Armamos propuestas integrales con precio especial cuando combinas servicios."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para reservar el Show Básico de cabezas móviles?</h2>
        <p>Mándanos la fecha, el venue y el tamaño de la pista de baile. Te confirmamos disponibilidad y te enviamos el presupuesto completo en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Reservar — Cotiza Gratis</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
