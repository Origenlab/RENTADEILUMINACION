---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import GallerySection from "../../components/GallerySection.astro";
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const title = "Renta de Seguidor de Luz para Eventos | REDEIL CDMX";
const description = "Renta de seguidor de luz (follow spot) para bodas, XV años y eventos en CDMX. REDEIL destaca momentos clave con iluminación profesional operada por técnicos expertos.";
const canonical = "https://rentadeiluminacion.com/servicios/seguidor/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Seguidor de Luz para Eventos",
  "provider": {
    "@type": "LocalBusiness",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com",
    "telephone": "+525530682988",
    "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressCountry": "MX" }
  },
  "description": "Servicio profesional de renta de seguidor de luz (follow spot) para bodas, XV años, conciertos y eventos en Ciudad de México. Operación por técnicos expertos.",
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "serviceType": "Renta de Seguidor de Luz"
});
---
<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Servicios", href: "/servicios/" }, { label: "Seguidor" }]} />
</Fragment>
<Hero
      title="Seguidor de Luz para Eventos en CDMX"
      subtitle="Destaca los momentos más importantes con un haz de luz profesional"
      introParagraph1="REDEIL ofrece el servicio de renta de seguidor de luz (follow spot) para eventos en toda la Ciudad de México. El seguidor permite iluminar de manera precisa a personas o elementos clave durante momentos especiales como el primer baile, el vals, brindis, discursos y presentaciones en escenario."
      introParagraph2="Cada seguidor es operado por un técnico profesional de REDEIL que coordina los movimientos de luz con el desarrollo del evento. Trabajamos en bodas, XV años, conciertos, obras de teatro, eventos corporativos y cualquier celebración que requiera destacar protagonistas con iluminación dirigida."
    />
    <section class="service-detail">
      <SectionHeader
          title="Seguidor profesional: el protagonismo que tus momentos merecen"
          subtitle="Instalación profesional incluida en CDMX y Edomex."
          paragraph1="El seguidor de luz es un equipo de iluminación profesional que proyecta un haz concentrado y direccionable, permitiendo seguir en tiempo real a una persona o un punto focal durante el evento. Es el recurso ideal para dar protagonismo al primer baile de los novios, al vals de XV años, a un orador en escenario o al artista en un concierto."
          paragraph2="En REDEIL operamos seguidores profesionales con control preciso de intensidad, apertura del haz y temperatura de color. Nuestros técnicos tienen experiencia en todo tipo de eventos y saben anticipar los movimientos para que la iluminación acompañe de forma fluida cada momento sin distracciones."
        />
        <p>El servicio incluye traslado del equipo, montaje en la posición óptima del venue, operación técnica durante todo el evento y desmontaje. Nos coordinamos con DJs, wedding planners y organizadores para que cada entrada de luz sea precisa y oportuna.</p>
      </div>
    </section>
    <GallerySection title="Galería de Seguidor de Luz" subtitle="Momentos destacados con iluminación dirigida en eventos reales">
      <figure class="gallery-item">
        <img src="/img/seguidor/luz-seguidor-brindis-boda-evento-corporativo.avif" alt="Seguidor de luz iluminando brindis durante boda y evento corporativo" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/seguidor/seguidor-boda-primer-baile-novios-candil-invitados.avif" alt="Primer baile de novios iluminado con seguidor bajo candil con invitados alrededor" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/seguidor/seguidor-iluminacion-evento-boda-pasillo-flores.avif" alt="Seguidor iluminando pasillo de boda decorado con flores" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/seguidor/luz-seguidor-quinceañera-vals-chambelan-vestido-rosa.avif" alt="Quinceañera bailando vals con chambelán iluminada por seguidor con vestido rosa" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/seguidor/luz-seguidor-teatro-actor-escenario-monologo.avif" alt="Actor en escenario iluminado por seguidor durante monólogo de teatro" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/seguidor/seguidor-boda-corte-pastel-novios-iluminacion.avif" alt="Novios cortando pastel de boda iluminados por seguidor profesional" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/seguidor/seguidor-concierto-cantante-microfono-escenario.avif" alt="Cantante en concierto iluminado por seguidor mientras canta al micrófono en escenario" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/seguidor/seguidor-escenario-auditorio-geles-multicolor.avif" alt="Escenario de auditorio iluminado con seguidor y geles de colores multicolor" width="800" height="533" loading="lazy">
      </figure>
    </GallerySection>
</BaseLayout>
