---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Cascadas LED Producción — Decoración Total Evento CDMX | REDEIL";
const description = "8+ cortinas LED para decoración total de venue. Paredes, divisiones y backdrop. Producción completa en CDMX. $15,000 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/cascadas-led/paquete-produccion/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Cascadas LED Producción — Decoración Total de Venue",
    "description": "8 o más cortinas de cascada LED para decoración total del venue. Cubre paredes completas, divisiones entre zonas y backdrops simultáneos con control DMX completo. Visita previa al venue incluida. Ideal para bodas de lujo, eventos corporativos masivos y festivales de XV años en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/cascadas-led/paquete-produccion/",
      "priceCurrency": "MXN",
      "price": "15000",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "22",
      "reviewCount": "22"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Eduardo Ramírez" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Evento corporativo de 400 personas en un centro de convenciones. Instalamos 10 cortinas LED en tres zonas diferentes del venue. El efecto al entrar al salón era de producción total — como un show de lujo. El equipo de REDEIL hizo la visita previa para medir todo y la instalación fue impecable. Los asistentes no paraban de tomar fotos."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Lorena Jiménez" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Festival de XV años con 500 invitados. Usamos 8 cortinas para decorar toda la hacienda — la entrada, el jardín de ceremonia, el salón de recepción y el área de baile. Cada zona tenía su color temático y el control DMX sincronizaba los cambios en toda la instalación. Fue una producción impresionante."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Carlos Villanueva" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Boda de lujo en salón privado de Lomas de Chapultepec. 9 cortinas LED en todas las paredes del salón. La novia quería que el salón 'brillara por completo' y eso fue exactamente lo que logramos. El resultado fue un salón completamente transformado — paredes de luz en todos los ángulos. Sin duda el mejor servicio que hemos contratado."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/cascadas-led/renta-cascadas-led-instalacion-backdrop-evento.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Cuántas cortinas incluye el paquete de producción?", "acceptedAnswer": { "@type": "Answer", "text": "El paquete de producción incluye 8 cortinas de cascada LED como base, con posibilidad de agregar más según las dimensiones del venue. El precio de $15,000 + IVA es punto de partida — el presupuesto final se define después de la visita previa al venue que realizamos sin costo." }},
      { "@type": "Question", "name": "¿Qué incluye la visita previa al venue?", "acceptedAnswer": { "@type": "Answer", "text": "Un técnico de REDEIL visita el venue para medir los espacios, identificar las zonas de montaje, revisar la infraestructura eléctrica y diseñar la distribución óptima de las cortinas. Con base en esta visita, preparamos el diseño final y el presupuesto definitivo sin costos sorpresa." }},
      { "@type": "Question", "name": "¿Para cuántos invitados es este paquete?", "acceptedAnswer": { "@type": "Answer", "text": "El paquete de producción está pensado para eventos de 200 invitados en adelante, con venues que requieren iluminar múltiples zonas simultáneamente: entrada, zona de ceremonia, salón de recepción y área de baile. Para eventos más pequeños, el paquete de 4 cortinas ($9,000 + IVA) es la elección correcta." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "1 Cortina — Mesa de Novios", image: "/img/cascadas-led/cascadas-led-cortina-luz-mesa-novios.avif", alt: "1 cortina LED para mesa de novios", description: "Backdrop para la mesa de novios o photo booth. La opción más compacta. $3,000 + IVA.", link: "/servicios/cascadas-led/paquete-1-cortina/" },
  { title: "2 Cortinas — Backdrop Boda", image: "/img/cascadas-led/cascadas-led-backdrop-boda-espectacular.avif", alt: "Backdrop de 6m con 2 cortinas LED para boda", description: "Backdrop completo de 6m. El más popular para bodas. $5,500 + IVA.", link: "/servicios/cascadas-led/paquete-2-cortinas/" },
  { title: "4 Cortinas — Salón Completo", image: "/img/cascadas-led/cascadas-led-iluminacion-completa-boda.avif", alt: "4 cortinas LED para salón completo", description: "12 metros con control DMX. Haciendas y salones grandes. $9,000 + IVA.", link: "/servicios/cascadas-led/paquete-4-cortinas/" },
  { title: "Iluminación Arquitectónica", image: "/img/iluminacion-arquitectonica/iluminacion-arquitectonica-arcos-coloniales-luz-violeta-fachada-300w.avif", alt: "Uplighting en fachada de hacienda colonial", description: "Cascadas LED adentro + uplighting arquitectónico afuera. La producción total completa.", link: "/servicios/iluminacion-arquitectonica/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Iluminación", href: "/servicios/iluminacion/" },
    { label: "Cascadas LED", href: "/servicios/cascadas-led/" },
    { label: "Producción — Decoración Total" }
  ]} />
</Fragment>

  <Hero
    title="Cascadas LED Producción — Decoración Total del Venue"
    subtitle="Desde $15,000 + IVA. 8+ cortinas LED con control DMX completo. Múltiples zonas. Visita previa incluida."
    introParagraph1='Cuando el objetivo es transformar el venue completo — no solo un punto focal — el paquete de producción es la solución. Con <strong>8 o más cortinas de cascada LED</strong> distribuidas en múltiples zonas del espacio, creamos un ambiente de iluminación total: paredes de luz en la entrada, backdrop brillante en la zona de recepción, cortinas como divisores de ambientes y cascadas en el área de baile. El efecto cuando un invitado entra al venue es de producción de alto presupuesto.'
    introParagraph2='Este paquete incluye visita previa al venue por parte de nuestro equipo técnico — medimos, diseñamos la distribución y preparamos el plan de instalación antes del evento. El control DMX completo permite sincronizar cambios de color y efectos en todas las zonas simultáneamente. Ideal para <strong>bodas de lujo</strong>, eventos corporativos de más de 200 personas y festivales de XV años donde la producción visual es la protagonista. Precio desde $15,000 + IVA según el número de cortinas y la complejidad del montaje.'
  />

  <CtaBar
    headline="¿Quieres menos cobertura?"
    items={[
      { label: "1 Cortina — $3,000", href: "/servicios/cascadas-led/paquete-1-cortina/", icon: "iluminacion" },
      { label: "2 Cortinas — $5,500", href: "/servicios/cascadas-led/paquete-2-cortinas/", icon: "iluminacion" },
      { label: "4 Cortinas — $9,000", href: "/servicios/cascadas-led/paquete-4-cortinas/", icon: "iluminacion" },
      { label: "Cotiza Producción", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Producción — Premium"
      price="$15,000"
      priceNote="+ IVA · desde (precio final según venue)"
      features={[
        { text: "8+ cortinas LED de 3×3 metros" },
        { text: "Múltiples zonas iluminadas" },
        { text: "Control DMX completo sincronizado" },
        { text: "Efectos programados en todas las zonas" },
        { text: "Equipo técnico completo" },
        { text: "Visita previa al venue incluida" },
        { text: "Diseño de distribución personalizado" },
        { text: "Transporte y logística completa" },
        { text: "Instalación y desmontaje profesional" },
        { text: "Cobertura CDMX y Edomex" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete de producción con 8+ cortinas LED para mi evento."
      packages={[
        { label: "1 cortina", price: "$3,000", href: "/servicios/cascadas-led/paquete-1-cortina/" },
        { label: "2 cortinas", price: "$5,500", href: "/servicios/cascadas-led/paquete-2-cortinas/" },
        { label: "4 cortinas", price: "$9,000", href: "/servicios/cascadas-led/paquete-4-cortinas/" },
        { label: "Producción", price: "$15,000", href: "/servicios/cascadas-led/paquete-produccion/", active: true },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="Decoración total: múltiples zonas, un solo look"
          subtitle="8+ cortinas distribuidas en todo el venue para un efecto envolvente."
          paragraph1="La diferencia entre el paquete de producción y los otros no es solo cantidad — es concepto. En lugar de tener iluminación en un punto específico, el objetivo es que el venue entero esté envuelto en luz brillante. Los invitados experimentan el efecto desde que entran hasta que salen."
          paragraph2="Con 8 o más cortinas, es posible cubrir la entrada del venue, dividir zonas con cortinas de luz, crear múltiples backdrops en diferentes áreas y poner cascadas en el área de baile para amplificar el efecto visual durante la música. Todo sincronizado con un sistema DMX central."
        />
        <FeatureGrid features={[
          { title: "Entrada del Venue", description: "Cortinas en la entrada crean el primer impacto visual. Los invitados entran a través de una cortina de luz." },
          { title: "Salón de Recepción Completo", description: "Todas las paredes del salón cubiertas. El efecto envolvente transforma el espacio de piso a techo." },
          { title: "Divisores de Zonas", description: "Cortinas como separadores visuales entre la zona de cena, el área lounge y la pista de baile." },
          { title: "Área de Baile", description: "Cortinas detrás de la pista dan profundidad al espacio y amplifican el efecto visual de la iluminación." },
          { title: "Zona de Ceremonia", description: "Arco y laterales de ceremonia iluminados. El momento más fotografiado con backdrop de producción." },
          { title: "Foto y Video Profesional", description: "La iluminación total del venue facilita el trabajo del fotógrafo y videógrafo en todos los ángulos." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Visita previa: nada se improvisa"
          subtitle="Un técnico de REDEIL va al venue antes del evento para diseñar todo."
          paragraph1="Para eventos de producción, la visita previa no es opcional — es obligatoria. Nuestro técnico visita el venue para medir los espacios exactos, identificar las zonas de anclaje, revisar la capacidad eléctrica disponible y diseñar la distribución óptima de las cortinas."
          paragraph2="Con base en la visita, preparamos el diseño final con el número exacto de cortinas necesarias, la configuración del sistema DMX y el plan de instalación. Así el presupuesto definitivo no tiene sorpresas y el día del evento todo está listo según el plan acordado."
        />
        <FeatureGrid features={[
          { title: "Medición Exacta del Venue", description: "Sin estimaciones. Medimos cada metro de pared, columna y espacio disponible." },
          { title: "Diseño de Distribución", description: "Plano de la distribución de cada cortina, cada estructura y cada punto de conexión eléctrica." },
          { title: "Revisión Eléctrica", description: "Verificamos que la capacidad eléctrica del venue soporte la instalación completa sin riesgos." },
          { title: "Presupuesto Sin Sorpresas", description: "El precio final se fija antes del evento — no hay cargos adicionales el día de la instalación." },
          { title: "Coordinación con el Venue", description: "Coordinamos directamente con el coordinador del salón para los horarios de montaje." },
          { title: "Plan de Contingencia", description: "Equipo de respaldo para cada componente crítico. Si algo falla, tenemos el reemplazo listo." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Eventos que vivieron la producción completa"
          subtitle="⭐⭐⭐⭐⭐ 5 estrellas en 22 reseñas de producción."
          paragraph1="El paquete de producción es el elegido para eventos donde la iluminación es parte del espectáculo — no solo decoración."
          paragraph2="Pregunta por el portafolio de eventos masivos cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Eduardo Ramírez", event: "Evento Corporativo Masivo — 400 personas", rating: 5, text: "Instalamos 10 cortinas LED en tres zonas del centro de convenciones. El efecto al entrar al salón era de producción total. El equipo hizo la visita previa para medir todo y la instalación fue impecable. Los asistentes no paraban de tomar fotos." },
          { name: "Lorena Jiménez", event: "Festival XV Años — 500 invitados", rating: 5, text: "8 cortinas para decorar toda la hacienda — la entrada, el jardín de ceremonia, el salón y el área de baile. Cada zona con su color y el DMX sincronizando todo. Fue una producción impresionante." },
          { name: "Carlos Villanueva", event: "Boda de Lujo — Lomas de Chapultepec", rating: 5, text: "9 cortinas LED en todas las paredes del salón. La novia quería que el salón brillara por completo y eso fue exactamente lo que logramos. Sin duda el mejor servicio que hemos contratado." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Producción total en eventos reales"
        subtitle="8+ cortinas en bodas de lujo, corporativos y festivales de XV años."
        paragraph1="Estas imágenes muestran el nivel de producción que se logra cuando el venue completo está iluminado con cascadas LED. La diferencia con un solo backdrop es la inmersión total — el ambiente envuelve a los invitados desde todos los ángulos."
        paragraph2="¿Quieres ver trabajos similares al tuyo? Mándanos el tipo de evento y el venue por WhatsApp y te compartimos referencias específicas."
      />
      <Gallery4x4 images={[
        { src: "/img/cascadas-led/renta-cascadas-led-instalacion-backdrop-evento.avif", alt: "Instalación de producción con 8+ cortinas LED en evento" },
        { src: "/img/cascadas-led/cascadas-led-instalacion-equipo-profesional.avif", alt: "Equipo profesional instalando producción de cascadas LED" },
        { src: "/img/cascadas-led/renta-luces-led-cascada-salon-eventos.avif", alt: "Salón de eventos con decoración total de cascadas LED" },
        { src: "/img/cascadas-led/cascadas-led-carpa-exterior-iluminacion.avif", alt: "Carpa exterior con producción de cascadas LED" },
        { src: "/img/cascadas-led/cascadas-led-iluminacion-completa-boda.avif", alt: "Boda con iluminación completa de cascadas LED producción" },
        { src: "/img/cascadas-led/renta-luces-led-cascada-ambiente-magico.avif", alt: "Ambiente mágico creado por producción de cascadas LED" },
        { src: "/img/cascadas-led/luces-para-bodas-cascada-instalacion-salon.avif", alt: "Instalación de producción de cascadas en salón de bodas" },
        { src: "/img/cascadas-led/renta-luces-led-cortina-brillante-evento.avif", alt: "Cortinas brillantes LED en producción completa de evento" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete de Producción"
        subtitle="Todo sobre el proceso, la visita previa y el presupuesto final."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
        paragraph2="Para eventos menores de 200 invitados o venues más compactos, el paquete de 4 cortinas ($9,000 + IVA) puede ser más adecuado."
      />
    </div>
    <FaqSection items={[
      { question: "¿Cuántas cortinas incluye el paquete de producción?", answer: "El paquete incluye 8 cortinas de cascada LED como base. Dependiendo de las dimensiones del venue y las zonas a cubrir, el número puede aumentar. El precio de $15,000 + IVA es punto de partida — el presupuesto definitivo se fija después de la visita previa al venue que realizamos sin costo." },
      { question: "¿Qué incluye la visita previa al venue?", answer: "Un técnico de REDEIL visita el venue para medir los espacios, identificar zonas de montaje, revisar la infraestructura eléctrica y diseñar la distribución óptima de las cortinas. Con base en esta visita, preparamos el plan de instalación y el presupuesto definitivo sin costos sorpresa." },
      { question: "¿Para cuántos invitados es este paquete?", answer: "Está pensado para eventos de 200 invitados en adelante, donde se requiere iluminar múltiples zonas simultáneamente. Para eventos más pequeños, el paquete de 4 cortinas con DMX ($9,000 + IVA) es la elección correcta." },
      { question: "¿El control DMX puede sincronizar todas las zonas simultáneamente?", answer: "Sí. El sistema DMX completo del paquete de producción permite controlar todas las cortinas desde un solo punto. El operador técnico puede cambiar el color y los efectos en todas las zonas al mismo tiempo o por zonas independientes — lo que la programación del evento requiera." },
      { question: "¿Con cuánta anticipación debo reservar para un evento de producción?", answer: "Para eventos de producción recomendamos reservar con al menos 4-6 semanas de anticipación. La visita previa al venue necesita coordinarse con tiempo, y la logística de 8+ cortinas requiere más preparación que los paquetes estándar." },
      { question: "¿El precio es fijo o puede cambiar después de la visita previa?", answer: "El precio de $15,000 + IVA es el punto de partida. El precio definitivo se establece después de la visita previa, cuando conocemos exactamente el número de cortinas necesarias y la complejidad del montaje. Ese precio final es el que aplica — sin cargos adicionales el día del evento." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes de Cascadas LED"
        subtitle="¿El paquete de producción es más de lo que necesitas?"
        paragraph1="Si tu evento es más pequeño o tu presupuesto requiere ajuste, los paquetes de 1, 2 y 4 cortinas ofrecen un impacto visual excelente a un costo más accesible. El paquete de 4 cortinas con DMX es el favorito para bodas y XV años grandes."
        paragraph2="También combinamos cascadas LED con iluminación arquitectónica para producción total del venue — adentro y afuera."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Tu evento merece una producción total de luz?</h2>
        <p>Cuéntanos el venue, el número de invitados y la fecha. Agendamos la visita previa sin costo y te presentamos el diseño completo.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Agendar Visita — Sin Costo</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
