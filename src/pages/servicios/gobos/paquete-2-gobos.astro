---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "2 Gobos para Bodas — Pista y Entrada en CDMX | REDEIL";
const description = "Proyección doble: nombres en pista de baile + monograma en entrada o pared. Bodas completas en CDMX. $4,500 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/gobos/paquete-2-gobos/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "2 Gobos para Bodas — Pista y Entrada — REDEIL",
    "description": "Proyección doble: nombres en pista de baile + monograma en entrada o pared. Dos proyectores profesionales, fabricación de 2 gobos metálicos personalizados, transporte, montaje y desmontaje para bodas en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/gobos/paquete-2-gobos/",
      "priceCurrency": "MXN",
      "price": "4500",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "89",
      "reviewCount": "89"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Daniela Morales" },
        "datePublished": "2026-02-08",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Nuestra boda fue en una hacienda para 200 personas y los 2 gobos quedaron perfectos. Uno con nuestros nombres en la pista para el vals y otro con el monograma en la pared de la entrada. Todos los invitados se tomaron fotos con los dos. El servicio fue impecable de principio a fin."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Mariana Espinoza" },
        "datePublished": "2025-12-14",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Para los XV años de mi hija en una gala de salón los gobos fueron el detalle más comentado de la noche. El diseño con sus iniciales en la pista y la proyección en la pared de entrada crearon un ambiente de lujo. REDEIL es muy profesional."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Jorge Vázquez" },
        "datePublished": "2025-11-30",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Usamos el paquete de 2 gobos para nuestra boda en el hotel Santa Fe. La coordinación fue excelente — instalaron las 2 proyecciones en menos de 2 horas y todo quedó perfectamente alineado. Vale completamente el precio."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/gobos/gobo-proyeccion-monograma-boda-elegante.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Qué incluye el paquete de 2 gobos?", "acceptedAnswer": { "@type": "Answer", "text": "El paquete incluye fabricación de 2 gobos metálicos personalizados, 2 proyectores profesionales de 575W, transporte, montaje, enfoque y posicionamiento de ambas proyecciones, operación durante el evento y desmontaje. Los 2 gobos son tuyos al finalizar." }},
      { "@type": "Question", "name": "¿Puedo proyectar diseños diferentes en cada gobo?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Cada gobo se fabrica por separado con su propio diseño. Lo más común es nombres de novios en la pista y monograma o fecha en la entrada, pero puedes elegir cualquier combinación." }},
      { "@type": "Question", "name": "¿Por qué 2 gobos es el paquete más popular?", "acceptedAnswer": { "@type": "Answer", "text": "Porque cubre los dos momentos más fotografiados de una boda: la entrada al salón y la pista de baile durante el vals. Con 2 proyecciones simultáneas activas toda la noche, la personalización está presente en los dos puntos donde más se concentran los invitados." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "1 Gobo — Solo Pista", image: "/img/gobos/renta-gobo-monograma-pista-baile-400w.avif", alt: "1 gobo para pista de baile en boda íntima", description: "Proyección de nombres o iniciales en pista de baile. Ideal para bodas íntimas. $2,500 + IVA.", link: "/servicios/gobos/paquete-1-gobo/" },
  { title: "4 Gobos Full Color", image: "/img/gobos/gobo-personalizado-proyectar-logo-empresa-400w.avif", alt: "4 gobos full color para bodas premium", description: "2 metálicos + 2 de vidrio full color. Logos, fotos y diseños complejos a color. $7,500 + IVA.", link: "/servicios/gobos/paquete-4-gobos/" },
  { title: "Producción — 6+ Gobos", image: "/img/gobos/gobos-eventos-proyectar-marca-personalizada-400w.avif", alt: "Producción completa con 6 o más gobos", description: "Branding completo del venue. Logos a color, patrones y múltiples proyecciones. $12,000 + IVA.", link: "/servicios/gobos/paquete-produccion/" },
  { title: "Seguidor de Luz", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Seguidor de luz para primer baile en boda", description: "El monograma en la pista + spotlight siguiendo a los novios durante el vals. El momento más cinematográfico.", link: "/servicios/seguidor/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Iluminación", href: "/servicios/iluminacion/" },
    { label: "Gobos", href: "/servicios/gobos/" },
    { label: "2 Gobos — Pista y Entrada" }
  ]} />
</Fragment>

  <Hero
    title="2 Gobos — Pista de Baile y Entrada para Bodas Completas"
    subtitle="Desde $4,500 + IVA. El paquete más pedido para bodas en CDMX. Proyección doble simultánea."
    introParagraph1='Dos proyecciones activas durante toda la noche: los nombres de los novios en la pista de baile y el monograma en la entrada o pared principal del salón. Este es el paquete más pedido de <strong>REDEIL</strong> porque cubre los dos momentos más fotografiados de cualquier boda — la entrada al salón y el vals. Mientras los invitados llegan, ven el monograma iluminado en la pared. Cuando los novios bailan, la pista los enmarca con sus nombres.'
    introParagraph2='El paquete de <strong>2 gobos metálicos a $4,500 + IVA</strong> incluye la fabricación de ambos diseños, 2 proyectores profesionales posicionados independientemente, transporte, montaje completo y desmontaje. Cada proyección se ajusta en tamaño y posición según las características del venue. Trabajamos en haciendas, hoteles, salones de gala y jardines. Las dos plantillas metálicas son tuyas después del evento — un recuerdo doble de tu boda.'
  />

  <CtaBar
    headline="¿Necesitas más proyecciones?"
    items={[
      { label: "1 Gobo — $2,500", href: "/servicios/gobos/paquete-1-gobo/", icon: "iluminacion" },
      { label: "4 Gobos Full Color — $7,500", href: "/servicios/gobos/paquete-4-gobos/", icon: "iluminacion" },
      { label: "Producción — $12,000", href: "/servicios/gobos/paquete-produccion/", icon: "iluminacion" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="2 Gobos Metálicos"
      price="$4,500"
      priceNote="+ IVA · Más popular"
      badge="Más popular"
      features={[
        { text: "2 gobos metálicos personalizados" },
        { text: "2 proyectores profesionales 575W" },
        { text: "Fabricación de 2 diseños distintos" },
        { text: "Transporte ida y vuelta" },
        { text: "Montaje y enfoque de 2 proyecciones" },
        { text: "Operación durante todo el evento" },
        { text: "Desmontaje al finalizar" },
        { text: "Ambos gobos son tuyos" },
        { text: "Pista + entrada/pared simultáneas" },
        { text: "Cobertura CDMX y Edomex" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete de 2 gobos para mi boda."
      packages={[
        { label: "1 Gobo", price: "$2,500", href: "/servicios/gobos/paquete-1-gobo/" },
        { label: "2 Gobos", price: "$4,500", href: "/servicios/gobos/paquete-2-gobos/", active: true },
        { label: "4 Gobos", price: "$7,500", href: "/servicios/gobos/paquete-4-gobos/" },
        { label: "Producción", price: "$12,000", href: "/servicios/gobos/paquete-produccion/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="2 proyecciones, 2 momentos clave"
          subtitle="Entrada y pista: los dos puntos donde se concentran todas las miradas."
          paragraph1="La entrada al salón es el primer momento de impacto — los invitados llegan y ven el monograma de los novios iluminado en la pared. La pista de baile es el segundo gran momento — durante el vals, los nombres enmarcan a los novios. Con 2 gobos tienes ambos cubiertos durante toda la noche."
          paragraph2="Cada proyector se posiciona de forma independiente para lograr el ángulo y tamaño óptimo en cada superficie. No es una sola proyección desdoblada — son 2 equipos separados con 2 diseños distintos activos simultáneamente."
        />
        <FeatureGrid features={[
          { title: "Pista de Baile", description: "Los nombres de los novios iluminados durante el vals y toda la recepción. El centro de todas las fotos." },
          { title: "Entrada del Salón", description: "El monograma en la pared principal cuando los invitados llegan. Primer impacto visual perfecto." },
          { title: "Pared de Acento", description: "Si no hay entrada formal, el segundo gobo puede ir en la pared detrás de la mesa de novios." },
          { title: "Bodas en Hacienda", description: "Proyección en patio para el vals + gobo en la fachada o pared colonial para la entrada." },
          { title: "Salones de Gala", description: "2 proyecciones independientes en áreas separadas del mismo salón." },
          { title: "XV Años", description: "Iniciales de la festejada en pista + nombre completo o fecha en la entrada. Elegante y consistente." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="2 diseños, 2 gobos fabricados"
          subtitle="Cada plantilla se fabrica por separado. Puedes tener diseños distintos."
          paragraph1="El paquete incluye la fabricación de 2 gobos metálicos independientes. Lo más común es usar los mismos nombres en ambos, pero con tipografía o composición diferente — uno en estilo script para la pista y uno más formal para la entrada."
          paragraph2="Si quieres el mismo diseño en ambos, también. O nombres en uno y fecha + monograma en el otro. Tú decides — nosotros lo fabricamos y lo proyectamos exactamente como lo apruebas."
        />
        <FeatureGrid features={[
          { title: "Diseños Distintos", description: "Cada gobo puede tener composición, tipografía y elementos diferentes entre sí." },
          { title: "Mismo Diseño x2", description: "Si prefieres consistencia visual, fabricamos 2 copias del mismo diseño." },
          { title: "Arte Incluido", description: "Si no tienes diseño, nuestro equipo crea ambas artes sin costo adicional." },
          { title: "Aprobación Previa", description: "Te enviamos la prueba digital de cada gobo para aprobación antes de fabricar." },
          { title: "5-7 días de fabricación", description: "Tiempo de producción desde que apruebas los 2 artes finales." },
          { title: "Ambos gobos son tuyos", description: "Te los entregamos al finalizar el evento. Dos recuerdos físicos únicos." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="⭐⭐⭐⭐⭐ 5 estrellas en 89 reseñas."
          paragraph1="El paquete de 2 gobos es el más reservado — y el más comentado por los invitados."
          paragraph2="Pregunta por referencias de bodas similares a la tuya cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Daniela Morales", event: "Boda en hacienda — 200 personas", rating: 5, text: "Los 2 gobos quedaron perfectos. El vals con los nombres en la pista y el monograma en la entrada — todos los invitados se tomaron fotos con los dos. Servicio impecable de principio a fin." },
          { name: "Mariana Espinoza", event: "XV años gala — Satélite", rating: 5, text: "El detalle más comentado de la noche. Las iniciales en la pista y la proyección en la entrada crearon un ambiente de lujo. REDEIL es muy profesional y puntual." },
          { name: "Jorge Vázquez", event: "Boda en hotel — Santa Fe", rating: 5, text: "Instalaron las 2 proyecciones en menos de 2 horas y todo quedó perfectamente alineado. La coordinación fue excelente. Vale completamente el precio." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Así se ven 2 gobos en una boda"
        subtitle="Proyecciones simultáneas en pista de baile y entrada."
        paragraph1="Cada foto es de un evento real con nuestro paquete de 2 gobos. Haciendas, hoteles, salones de gala y jardines — adaptamos las 2 proyecciones a la arquitectura de tu venue."
        paragraph2="¿Tienes fotos de tu salón? Mándanoslas por WhatsApp y te mostramos dónde irían las 2 proyecciones."
      />
      <Gallery4x4 images={[
        { src: "/img/gobos/gobo-proyeccion-monograma-boda-elegante.avif", alt: "Monograma proyectado en boda elegante" },
        { src: "/img/gobos/renta-gobo-monograma-pista-baile.avif", alt: "Gobo de monograma en pista de baile para boda" },
        { src: "/img/gobos/renta-proyeccion-gobos-monograma-boda.avif", alt: "Proyección de monograma con gobos en boda en CDMX" },
        { src: "/img/gobos/alquiler-proyeccion-gobos-boda-elegante.avif", alt: "Alquiler de proyección de gobos para boda elegante" },
        { src: "/img/gobos/gobos-luz-proyectar-monograma-boda.avif", alt: "Luz de gobo proyectando monograma en boda" },
        { src: "/img/gobos/proyeccion-gobo-personalizado-evento-social.avif", alt: "Proyección de gobo personalizado en evento social" },
        { src: "/img/gobos/renta-gobos-personalizados-logo-evento.avif", alt: "Gobos personalizados para evento en CDMX" },
        { src: "/img/gobos/renta-gobos-proyeccion-logotipo-evento.avif", alt: "Proyección de logotipo con gobos en evento" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete 2 Gobos"
        subtitle="Todo lo que necesitas saber sobre la proyección doble."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
        paragraph2="Podemos coordinar el montaje con tu fotógrafo para que esté listo desde la primera toma."
      />
    </div>
    <FaqSection items={[
      { question: "¿Qué incluye el paquete de 2 gobos a $4,500?", answer: "Incluye fabricación de 2 gobos metálicos personalizados con tus diseños, 2 proyectores profesionales ETC Source Four de 575W, transporte al venue, montaje y enfoque de ambas proyecciones, operación durante el evento y desmontaje. Los 2 gobos metálicos son tuyos al finalizar." },
      { question: "¿Las 2 proyecciones funcionan al mismo tiempo?", answer: "Sí, las 2 proyecciones están activas simultáneamente durante todo el evento — desde que llegan los primeros invitados hasta que termina la fiesta. No son turnos ni alternativas, son 2 equipos independientes funcionando a la vez." },
      { question: "¿Puedo usar diseños diferentes en cada gobo?", answer: "Sí. Cada gobo se fabrica por separado. Lo más común es nombres de novios en la pista y monograma o fecha en la entrada, pero puedes elegir cualquier combinación — incluso diseños completamente distintos si lo prefieres." },
      { question: "¿Cómo se posicionan los 2 proyectores?", answer: "Nuestro técnico visita el venue previamente (o revisamos fotos del espacio) para definir el mejor ángulo de proyección para cada área. Los proyectores se montan en trípodes o se fijan en estructuras del venue para el ángulo óptimo." },
      { question: "¿2 gobos son suficientes para una boda grande?", answer: "Para la mayoría de las bodas de hasta 200 personas con 2 áreas principales, sí. Si tu venue tiene más áreas (cocktail, cena y baile en espacios separados, por ejemplo) o quieres gobos de color, el paquete de 4 gobos a $7,500 + IVA es la opción indicada." },
      { question: "¿Con cuánto tiempo debo reservar?", answer: "Idealmente 3 semanas antes para garantizar fecha y tiempo de fabricación de los 2 gobos. En temporada alta las fechas se reservan rápido — a veces con 2 meses de anticipación para fechas de diciembre y junio." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes y Servicios"
        subtitle="¿Necesitas más proyecciones o combinar con otro servicio?"
        paragraph1="Si tu evento requiere más puntos de proyección o gobos de color, tenemos paquetes de 4 y 6+ gobos. Y para una producción de iluminación completa, combinamos gobos con seguidor, cascadas LED y cabezas móviles."
        paragraph2="Armamos propuestas integrales con precio especial cuando combinas servicios."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para personalizar tu boda con 2 proyecciones?</h2>
        <p>Mándanos los nombres, la fecha y las fotos del venue por WhatsApp. Te decimos exactamente dónde irían los gobos y te enviamos el presupuesto en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Reservar — Cotiza Gratis</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
