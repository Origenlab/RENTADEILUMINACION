            priceNote: "+ IVA",
            badge: "Más popular",
            highlight: true,
            description: "El tamaño más solicitado para bodas y XV años. Pantalla imponente para 50-150 invitados.",
            features: [
              { text: "Pantalla inflable de 5 metros", included: true },
              { text: "Proyector HD 5,000 lumens", included: true },
              { text: "Sistema de audio profesional", included: true },
              { text: "Operador técnico incluido", included: true },
              { text: "Traslado + montaje + desmontaje", included: true },
              { text: "Ideal para: bodas, XV años, fiestas grandes", included: true },
              { text: "Capacidad: 50-150 personas", included: true },
              { text: "Conexión HDMI + inalámbrica", included: true },
            ],
            ctaLabel: "Cotizar pantalla 5 metros",
            ctaHref: "/servicios/pantalla-inflable/paquete-5metros/",
          },
          {
            name: "Pantalla 8 Metros",
            price: "$9,500",
            priceNote: "+ IVA",
            description: "Para eventos corporativos y reuniones empresariales. Proyector de 10,000 lumens para imagen nítida.",
