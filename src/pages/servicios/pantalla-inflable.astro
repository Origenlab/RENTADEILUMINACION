---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import GallerySection from "../../components/GallerySection.astro";
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const title = "Renta de Pantalla Inflable para Eventos | REDEIL CDMX";
const description = "Renta de pantalla inflable para eventos en CDMX. Cine al aire libre, bodas y fiestas con pantalla gigante inflable. Montaje profesional por REDEIL.";
const canonical = "https://rentadeiluminacion.com/servicios/pantalla-inflable/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Pantalla Inflable para Eventos",
  "provider": {
    "@type": "LocalBusiness",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com",
    "telephone": "+525530682988",
    "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressCountry": "MX" }
  },
  "description": "Servicio de renta de pantallas inflables para cine al aire libre, bodas, fiestas y eventos en la Ciudad de México. Incluye proyector y sistema de audio.",
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "serviceType": "Renta de Pantalla Inflable"
});
---
<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Servicios", href: "/servicios/" }, { label: "Pantalla Inflable" }]} />
</Fragment>
<Hero
      title="Renta de Pantalla Inflable para Eventos en CDMX"
      subtitle="Cine al aire libre y proyecciones gigantes para eventos inolvidables"
      introParagraph1="En REDEIL ponemos a tu disposición el servicio de renta de pantallas inflables para eventos en la Ciudad de México y zona metropolitana. Nuestras pantallas gigantes son ideales para funciones de cine al aire libre, proyecciones de video en bodas, fiestas temáticas y eventos corporativos."
      introParagraph2="Ofrecemos un servicio integral que incluye el montaje de la pantalla inflable, proyector de alta luminosidad y sistema de audio. Nuestro equipo técnico se encarga de todo para que tú y tus invitados disfruten de una experiencia audiovisual de primer nivel."
    />
    <section class="service-detail">
      <div class="container">
        <h2>Pantalla gigante inflable para todo tipo de eventos</h2>
        <p>Las pantallas inflables han revolucionado la forma de disfrutar el entretenimiento visual en eventos al aire libre. Su gran tamaño permite que todos los asistentes disfruten del contenido con comodidad, ya sea una película, un video de bodas, presentaciones corporativas o transmisiones deportivas en vivo.</p>
        <p>En REDEIL contamos con pantallas inflables de gran formato que se instalan en minutos y ofrecen una superficie de proyección uniforme y sin arrugas. Son perfectas para jardines, terrazas, azoteas, estacionamientos y cualquier espacio abierto donde se quiera crear una experiencia de cine bajo las estrellas.</p>
        <p>Nuestro servicio de renta de pantalla inflable en CDMX es muy solicitado para bodas donde se proyectan videos de los novios, fiestas de cumpleaños con películas temáticas, eventos corporativos con presentaciones y noches de cine comunitario. Nos adaptamos a las necesidades específicas de tu evento para garantizar una experiencia memorable.</p>
      </div>
    </section>
    <GallerySection title="Galería de Pantalla Inflable" subtitle="Proyecciones y cine al aire libre en eventos reales">
      <figure class="gallery-item">
        <img src="/img/pantalla-inflable/pantalla-inflable-videojuegos-evento-gaming.avif" alt="Pantalla inflable utilizada para proyección de videojuegos en evento gaming" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/pantalla-inflable/pantalla-gigante-cine-inflable-feria.avif" alt="Pantalla gigante inflable montada en feria para función de cine al aire libre" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/pantalla-inflable/renta-pantalla-inflable-fiesta-navidad.avif" alt="Pantalla inflable rentada para fiesta navideña con proyección de películas" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/pantalla-inflable/pantalla-cine-inflable-evento-familiar.avif" alt="Pantalla de cine inflable en evento familiar al aire libre con público sentado" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/pantalla-inflable/alquiler-pantalla-inflable-boda-hacienda.avif" alt="Pantalla inflable instalada en hacienda para proyección de video de boda" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/pantalla-inflable/pantalla-inflable-cine-noche-romantica.avif" alt="Pantalla inflable para noche de cine romántica al aire libre" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/pantalla-inflable/renta-pantalla-cine-inflable-terraza-roof.avif" alt="Pantalla de cine inflable montada en terraza rooftop para evento nocturno" width="800" height="533" loading="lazy">
      </figure>
    </GallerySection>
</BaseLayout>
