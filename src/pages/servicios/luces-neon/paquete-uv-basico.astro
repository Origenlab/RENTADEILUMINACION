---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Paquete UV Básico — Luz Negra para Fiestas CDMX | REDEIL";
const description = "Kit de 4-6 barras UV LED para pista de baile en XV años y fiestas. Cobertura hasta 80m². Certificación DMX. Instalación profesional incluida. CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/luces-neon/paquete-uv-basico/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org", "@type": "Product",
    "name": "Paquete UV Básico — Luces Ultravioleta para Pista de Baile",
    "description": "Kit de 4-6 barras UV LED profesionales para transformar la pista de baile con efecto blacklight. Cobertura hasta 80m². Para XV años y fiestas.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "image": "https://rentadeiluminacion.com/img/luces-neon/renta-luces-neon-glow-party-invitados-baile-300w.avif",
    "offers": { "@type": "Offer", "url": canonical, "priceCurrency": "MXN", "price": "4500", "priceValidUntil": "2027-12-31", "availability": "https://schema.org/InStock" },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5", "bestRating": "5", "ratingCount": "38", "reviewCount": "38" },
    "review": [
      { "@type": "Review", "author": { "@type": "Person", "name": "Sofía Ramírez" }, "datePublished": "2026-02-10", "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "Las barras UV transformaron la pista de baile de los XV de mi hija. Todas las chambelanas con ropa blanca brillaban increíble. Las fotos quedaron espectaculares." },
      { "@type": "Review", "author": { "@type": "Person", "name": "Marco Torres" }, "datePublished": "2026-01-25", "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "Rentamos el paquete UV para un cumpleaños en mi terraza. El efecto blacklight hizo que la fiesta se sintiera como un club. Montaje rápido y profesional." },
      { "@type": "Review", "author": { "@type": "Person", "name": "Laura Vega" }, "datePublished": "2025-12-18", "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "Perfecto para la fiesta de graduación de mi hijo. Los chavos se divirtieron muchísimo con las luces UV. El precio es accesible y el servicio completo." }
    ]
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [
    { "@type": "Question", "name": "¿4-6 barras UV son suficientes para mi pista?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. 4-6 barras UV LED cubren pistas de hasta 80m² con efecto blacklight uniforme. Para eventos más grandes, el paquete Glow Party incluye 8-12 barras." }},
    { "@type": "Question", "name": "¿Las luces UV son seguras?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Son luces UV LED de baja intensidad, las mismas que usan discotecas y parques de diversiones. Seguras para piel y ojos." }}
  ]}
]);

const otrosPaquetes = [
  { title: "Glow Party — $8,000", image: "/img/luces-neon/renta-luces-neon-glow-party-celebracion-neon-300w.avif", alt: "Glow party completa", description: "UV + 100 accesorios fluorescentes + pintura neón. El más pedido para XV años.", link: "/servicios/luces-neon/paquete-glow-party/" },
  { title: "Neón Premium — $12,000", image: "/img/luces-neon/letrero-neon-better-together-boda.avif", alt: "Neón premium con letreros", description: "UV completo + 2 letreros LED neón personalizados + body paint.", link: "/servicios/luces-neon/paquete-neon-premium/" },
  { title: "Producción — $18,000", image: "/img/luces-neon/letrero-neon-celebracion-cdmx.avif", alt: "Producción neón completa", description: "Producción temática completa. UV + letreros + DJ + lásers + humo.", link: "/servicios/luces-neon/paquete-produccion-neon/" },
  { title: "Bola Disco", image: "/img/bola-disco/bola-disco-dj-pista-baile-evento.avif", alt: "Bola disco complemento UV", description: "Combina bola disco con UV para una pista de baile épica.", link: "/servicios/bola-disco/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Iluminación", href: "/servicios/iluminacion/" }, { label: "Luces Neón", href: "/servicios/luces-neon/" }, { label: "UV Básico" }]} />
</Fragment>

    <Hero title="Paquete UV Básico — Luces Ultravioleta para la Pista de Baile" subtitle="$4,500 + IVA. 4-6 barras UV LED. Cobertura hasta 80m². Instalación profesional incluida."
      introParagraph1='El paquete UV Básico es la forma más accesible de transformar tu pista de baile en una experiencia blacklight. Con 4 a 6 barras UV LED profesionales con control DMX, todo lo blanco y fluorescente brilla en la oscuridad — camisas, zapatos, dientes, decoración. El efecto es inmediato y espectacular.'
      introParagraph2='Ideal para XV años donde las chambelanas llevan vestidos blancos, cumpleaños con temática neón, graduaciones y fiestas privadas que quieren un toque diferente sin invertir en una producción completa. Incluye transporte, montaje y desmontaje en toda la CDMX y Estado de México.'
    />


    <section class="services-section">
      <ContentWithSidebar sidebarTitle="UV Básico" price="$4,500" priceNote="+ IVA · Pista de baile" features={[
        { text: "4-6 barras UV LED profesionales" }, { text: "Cobertura hasta 80m²" }, { text: "Control DMX" }, { text: "Transporte + montaje + desmontaje" }, { text: "Operación durante el evento" }, { text: "Efecto blacklight completo" }, { text: "Ideal para pistas de baile" }, { text: "Seguro para piel y ojos" }, { text: "Cobertura CDMX y Edomex" },
      ]} waMessage="Hola REDEIL, quiero cotizar el paquete UV Básico para mi fiesta." packages={[
        { label: "UV Básico", price: "$4,500", href: "/servicios/luces-neon/paquete-uv-basico/", active: true },
        { label: "Glow Party", price: "$8,000", href: "/servicios/luces-neon/paquete-glow-party/" },
        { label: "Neón Premium", price: "$12,000", href: "/servicios/luces-neon/paquete-neon-premium/" },
        { label: "Producción", price: "$18,000", href: "/servicios/luces-neon/paquete-produccion-neon/" },
      ]}>
        <div class="container">
          <SectionHeader title="Perfecto para estos momentos" subtitle="La pista de baile es donde todo pasa." paragraph1="El efecto UV convierte cualquier pista oscura en un espectáculo visual. Todo lo blanco brilla, los colores neón cobran vida, y la energía de la fiesta sube instantáneamente." paragraph2="No necesitas una producción completa para impresionar — 4-6 barras UV bien colocadas hacen toda la diferencia." />
          <FeatureGrid features={[
            { title: "XV Años", description: "Chambelanas con vestidos blancos que brillan. El vals con efecto blacklight. Las fotos más compartidas de la fiesta." },
            { title: "Cumpleaños", description: "Transforma tu fiesta en un mini club. Tus invitados con camisas blancas parecen estrellas bajo UV." },
            { title: "Graduaciones", description: "Celebra con estilo. La pista de baile con UV hace que todos quieran quedarse bailando." },
            { title: "Fiestas privadas", description: "En casa, terraza o salón. El efecto funciona en cualquier espacio oscuro de hasta 80m²." },
            { title: "After party", description: "Para la segunda fase de tu evento. Cuando bajan las luces principales, prende las UV." },
            { title: "Fiestas temáticas", description: "Base perfecta para temas neón, space, disco retro, halloween fluorescente." },
          ]} columns={2} />
        </div>
        <div class="container" style="margin-top: 3rem;">
          <SectionHeader title="Lo que dicen nuestros clientes" subtitle="⭐⭐⭐⭐⭐ 38 reseñas verificadas." paragraph1="Fiestas y XV años que usaron el paquete UV Básico." paragraph2="El efecto blacklight siempre sorprende — incluso cuando ya lo esperan." />
          <TestimonialCards testimonials={[
            { name: "Sofía Ramírez", event: "XV años — Tlalnepantla", rating: 5, text: "Las barras UV transformaron la pista. Todas las chambelanas con ropa blanca brillaban increíble. Las fotos quedaron espectaculares." },
            { name: "Marco Torres", event: "Cumpleaños — Condesa", rating: 5, text: "El efecto blacklight hizo que mi fiesta en terraza se sintiera como un club. Montaje rápido y profesional." },
            { name: "Laura Vega", event: "Graduación — Naucalpan", rating: 5, text: "Los chavos se divirtieron muchísimo con las luces UV. El precio es accesible y el servicio completo." },
          ]} />
        </div>
      </ContentWithSidebar>
    </section>

    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader title="El efecto UV en acción" subtitle="Fotos reales de fiestas con nuestro paquete UV." paragraph1="Todo lo blanco y fluorescente brilla bajo la luz ultravioleta." paragraph2="¿Tu fiesta se parece? Mándanos detalles por WhatsApp." />
        <Gallery4x4 images={[
          { src: "/img/luces-neon/renta-luces-neon-glow-party-invitados-baile-300w.avif", alt: "Invitados bailando bajo luces UV" },
          { src: "/img/luces-neon/renta-luces-neon-fiesta-uv-maquillaje-neon-300w.avif", alt: "Maquillaje neón brillando bajo UV" },
          { src: "/img/luces-neon/renta-luces-neon-glow-party-celebracion-neon-300w.avif", alt: "Celebración con efecto blacklight" },
          { src: "/img/luces-neon/luces-neon-decoracion-fiestas.avif", alt: "Decoración fluorescente en fiesta UV" },
          { src: "/img/luces-neon/luces-neon-infantiles-fiestas.avif", alt: "Fiesta con luces neón UV" },
          { src: "/img/luces-neon/luces-neon-para-bodas.avif", alt: "Efecto UV en pista de baile" },
          { src: "/img/luces-neon/neon-decorativo-bodas-cdmx.avif", alt: "Iluminación UV decorativa" },
          { src: "/img/luces-neon/luces-neon-mesa-novios.avif", alt: "Efecto blacklight en evento" },
        ]} />
      </div>
    </section>

    <section class="faq-section">
      <div class="container">
        <SectionHeader title="Preguntas sobre UV Básico" subtitle="Todo lo que necesitas saber." paragraph1="Escríbenos por WhatsApp si tienes otra duda." paragraph2="Te asesoramos sobre si este paquete es suficiente para tu espacio." />
      </div>
      <FaqSection items={[
        { question: "¿4-6 barras UV son suficientes para mi pista de baile?", answer: "Sí. Cubren pistas de hasta 80m² con efecto blacklight uniforme. Nuestro equipo las distribuye estratégicamente para maximizar la cobertura. Si tu pista es más grande, el paquete Glow Party incluye 8-12 barras." },
        { question: "¿Las luces UV son seguras?", answer: "Sí. Son UV LED de baja intensidad — las mismas que usan discotecas y parques de diversiones. Seguras para piel y ojos. No son lámparas UV industriales." },
        { question: "¿Qué ropa debo recomendar a mis invitados?", answer: "Todo lo blanco brilla bajo UV — camisas, vestidos, tenis. También brillan los colores neón y fluorescentes. Puedes incluir en tu invitación 'dress code: blanco o neón' para maximizar el efecto." },
        { question: "¿Funciona de día?", answer: "Las luces UV necesitan oscuridad para el efecto completo. Funcionan perfecto en salones cerrados sin ventanas o en eventos nocturnos al aire libre después del atardecer." },
        { question: "¿Puedo agregar accesorios fluorescentes?", answer: "El paquete UV Básico no incluye accesorios. Si quieres pulseras, collares y pintura neón, el paquete Glow Party ($8,000 + IVA) los incluye. También puedes comprar los tuyos y nosotros ponemos las luces." },
      ]} />
    </section>

    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader title="Otros Paquetes y Complementos" subtitle="¿Necesitas más efecto? Compara opciones." paragraph1="Cada paquete sube en intensidad y accesorios." paragraph2="Combina UV con bola disco para una pista épica." />
        <div class="services-grid">{otrosPaquetes.map((s) => (<ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />))}</div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container"><div class="cta-content">
        <h2>¿Listo para prender la pista con UV?</h2>
        <p>Cuéntanos la fecha, el lugar y cuántas personas esperas. Te confirmamos disponibilidad en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza tu Fiesta UV</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div></div>
    </section>
</BaseLayout>
