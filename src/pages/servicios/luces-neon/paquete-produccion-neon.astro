---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Producción Neón Completa para Eventos CDMX | REDEIL";
const description = "Producción temática neón completa: UV + letreros + DJ + lásers + humo + decoración. Para eventos masivos y festivales. $18,000 + IVA. CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/luces-neon/paquete-produccion-neon/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org", "@type": "Product",
    "name": "Producción Neón — Evento Temático UV Completo",
    "description": "Kit de 4-6 barras UV LED profesionales para transformar la pista de baile con efecto blacklight. Cobertura hasta 80m². Para XV años y fiestas.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "image": "https://rentadeiluminacion.com/img/luces-neon/renta-luces-neon-glow-party-invitados-baile-300w.avif",
    "offers": { "@type": "Offer", "url": canonical, "priceCurrency": "MXN", "price": "18000", "priceValidUntil": "2027-12-31", "availability": "https://schema.org/InStock" },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5", "bestRating": "5", "ratingCount": "15", "reviewCount": "15" },
    "review": [
      { "@type": "Review", "author": { "@type": "Person", "name": "Festival Noche Neón" }, "datePublished": "2026-02-20", "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "REDEIL produjo toda la iluminación de nuestro festival en Coyoacán. 300+ asistentes, zona de DJ, área lounge y photo booth — todo con temática neón. Producción impecable." },
      { "@type": "Review", "author": { "@type": "Person", "name": "Corporativo Samsung MX" }, "datePublished": "2026-01-15", "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "La fiesta de fin de año de Samsung con temática neón fue espectacular. Los letreros con el logo, el DJ, los lásers — todo coordinado perfectamente. El equipo de producción es muy profesional." },
      { "@type": "Review", "author": { "@type": "Person", "name": "Ricardo Fuentes" }, "datePublished": "2025-12-28", "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "Organizamos una discoteca privada para 200 personas con producción completa de REDEIL. Fue la mejor fiesta que hemos tenido. Los lásers con el humo y las luces UV crearon un ambiente de club internacional." }
    ]
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [
    { "@type": "Question", "name": "¿4-6 barras UV son suficientes para mi pista?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. 4-6 barras UV LED cubren pistas de hasta 80m² con efecto blacklight uniforme. Para eventos más grandes, el paquete Glow Party incluye 8-12 barras." }},
    { "@type": "Question", "name": "¿Las luces UV son seguras?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Son luces UV LED de baja intensidad, las mismas que usan discotecas y parques de diversiones. Seguras para piel y ojos." }}
  ]}
]);

const otrosPaquetes = [
  { title: "Glow Party — $8,000", image: "/img/luces-neon/renta-luces-neon-glow-party-celebracion-neon-300w.avif", alt: "Glow party completa", description: "UV + 100 accesorios fluorescentes + pintura neón. El más pedido para XV años.", link: "/servicios/luces-neon/paquete-glow-party/" },
  { title: "Neón Premium — $12,000", image: "/img/luces-neon/letrero-neon-better-together-boda.avif", alt: "Neón premium con letreros", description: "UV completo + 2 letreros LED neón personalizados + body paint.", link: "/servicios/luces-neon/paquete-neon-premium/" },
  { title: "Producción — $18,000", image: "/img/luces-neon/letrero-neon-celebracion-cdmx.avif", alt: "Producción neón completa", description: "Producción temática completa. UV + letreros + DJ + lásers + humo.", link: "/servicios/luces-neon/paquete-produccion-neon/" },
  { title: "Bola Disco", image: "/img/bola-disco/bola-disco-dj-pista-baile-evento.avif", alt: "Bola disco complemento UV", description: "Combina bola disco con UV para una pista de baile épica.", link: "/servicios/bola-disco/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Iluminación", href: "/servicios/iluminacion/" }, { label: "Luces Neón", href: "/servicios/luces-neon/" }, { label: "Producción Neón" }]} />
</Fragment>

    <Hero title="Producción Neón — Evento Temático UV Completo" subtitle="$18,000 + IVA. Producción completa: 20+ barras UV + lásers + DJ + humo + 3 letreros + 200 accesorios. Para eventos masivos."
      introParagraph1='La Producción Neón es una experiencia completa de gran formato. 20+ barras UV, cañones de luz, lásers, humo escénico, 3 letreros LED neón personalizados, 200+ accesorios fluorescentes, decoración temática completa y DJ profesional incluido. Todo lo que necesitas para un evento masivo que nadie va a olvidar.'
      introParagraph2='Diseñada para festivales, fiestas corporativas de gran formato, discotecas privadas, eventos de marca y celebraciones de 300+ invitados. Nuestro equipo de producción se encarga de la logística completa — visita previa al venue, diseño del montaje, prueba de iluminación y equipo de técnicos durante todo el evento en CDMX y Estado de México.'
    />


    <section class="services-section">
      <ContentWithSidebar sidebarTitle="Producción Neón" price="$18,000" priceNote="+ IVA · Producción completa" features={[
        { text: "20+ barras UV + cañones de luz" }, { text: "Cobertura 300m²+" }, { text: "3 letreros LED neón personalizados" }, { text: "Transporte + montaje + desmontaje" }, { text: "Operación durante el evento" }, { text: "200+ accesorios fluorescentes" }, { text: "Lásers + humo escénico" }, { text: "DJ profesional incluido" }, { text: "Cobertura CDMX y Edomex" },
      ]} waMessage="Hola REDEIL, quiero cotizar el producción Neón para mi fiesta." packages={[
        { label: "UV Básico", price: "$4,500", href: "/servicios/luces-neon/paquete-uv-basico/" },
        { label: "Glow Party", price: "$8,000", href: "/servicios/luces-neon/paquete-glow-party/" },
        { label: "Neón Premium", price: "$12,000", href: "/servicios/luces-neon/paquete-neon-premium/" },
        { label: "Producción", price: "$18,000", href: "/servicios/luces-neon/paquete-produccion-neon/", active: true },
      ]}>
        <div class="container">
          <SectionHeader title="Producción a gran escala" subtitle="Festivales, corporativos masivos, discotecas privadas." paragraph1="El efecto UV convierte cualquier pista oscura en un espectáculo visual. Todo lo blanco brilla, los colores neón cobran vida, y la energía de la fiesta sube instantáneamente." paragraph2="No necesitas una producción completa para impresionar — 4-6 barras UV bien colocadas hacen toda la diferencia." />
          <FeatureGrid features={[
            { title: "Festival Neón", description: "Chambelanas con vestidos blancos que brillan. El vals con efecto blacklight. Las fotos más compartidas de la fiesta." },
            { title: "Corporativo Masivo", description: "Transforma tu fiesta en un mini club. Tus invitados con camisas blancas parecen estrellas bajo UV." },
            { title: "Fiesta 500+", description: "Celebra con estilo. La pista de baile con UV hace que todos quieran quedarse bailando." },
            { title: "Discoteca Privada", description: "En casa, terraza o salón. El efecto funciona en cualquier espacio oscuro de hasta 80m²." },
            { title: "Evento de Marca", description: "Para la segunda fase de tu evento. Cuando bajan las luces principales, prende las UV." },
            { title: "After Party Premium", description: "Base perfecta para temas neón, space, disco retro, halloween fluorescente." },
          ]} columns={2} />
        </div>
        <div class="container" style="margin-top: 3rem;">
          <SectionHeader title="Lo que dicen nuestros clientes" subtitle="⭐⭐⭐⭐⭐ 38 reseñas verificadas." paragraph1="Fiestas y XV años que usaron el producción Neón." paragraph2="El efecto blacklight siempre sorprende — incluso cuando ya lo esperan." />
          <TestimonialCards testimonials={[
            { name: "Festival Noche Neón", event: "Festival — Coyoacán", rating: 5, text: "Las barras UV transformaron la pista. Todas las chambelanas con ropa blanca brillaban increíble. Las fotos quedaron espectaculares." },
            { name: "Corporativo Samsung MX", event: "Fin de año — Santa Fe", rating: 5, text: "El efecto blacklight hizo que mi fiesta en terraza se sintiera como un club. Montaje rápido y profesional." },
            { name: "Ricardo Fuentes", event: "Discoteca privada — Polanco", rating: 5, text: "Los chavos se divirtieron muchísimo con las luces UV. El precio es accesible y el servicio completo." },
          ]} />
        </div>
      </ContentWithSidebar>
    </section>

    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader title="Producciones neón a gran escala" subtitle="Fotos reales de fiestas con nuestro paquete UV." paragraph1="Todo lo blanco y fluorescente brilla bajo la luz ultravioleta." paragraph2="¿Tu fiesta se parece? Mándanos detalles por WhatsApp." />
        <Gallery4x4 images={[
          { src: "/img/luces-neon/renta-luces-neon-glow-party-invitados-baile-300w.avif", alt: "Invitados bailando bajo luces UV" },
          { src: "/img/luces-neon/renta-luces-neon-fiesta-uv-maquillaje-neon-300w.avif", alt: "Maquillaje neón brillando bajo UV" },
          { src: "/img/luces-neon/renta-luces-neon-glow-party-celebracion-neon-300w.avif", alt: "Celebración con efecto blacklight" },
          { src: "/img/luces-neon/luces-neon-decoracion-fiestas.avif", alt: "Decoración fluorescente en fiesta UV" },
          { src: "/img/luces-neon/luces-neon-infantiles-fiestas.avif", alt: "Fiesta con luces neón UV" },
          { src: "/img/luces-neon/luces-neon-para-bodas.avif", alt: "Efecto UV en pista de baile" },
          { src: "/img/luces-neon/neon-decorativo-bodas-cdmx.avif", alt: "Iluminación UV decorativa" },
          { src: "/img/luces-neon/luces-neon-mesa-novios.avif", alt: "Efecto blacklight en evento" },
        ]} />
      </div>
    </section>

    <section class="faq-section">
      <div class="container">
        <SectionHeader title="Preguntas sobre Producción Neón" subtitle="Todo lo que necesitas saber." paragraph1="Escríbenos por WhatsApp si tienes otra duda." paragraph2="Te asesoramos sobre si este paquete es suficiente para tu espacio." />
      </div>
      <FaqSection items={[
        { question: "¿4-6 barras UV son suficientes para mi pista de baile?", answer: "Sí. Cubren pistas de hasta 80m² con efecto blacklight uniforme. Nuestro equipo las distribuye estratégicamente para maximizar la cobertura. Si tu pista es más grande, el paquete Glow Party incluye 8-12 barras." },
        { question: "¿Las luces UV son seguras?", answer: "Sí. Son UV LED de baja intensidad — las mismas que usan discotecas y parques de diversiones. Seguras para piel y ojos. No son lámparas UV industriales." },
        { question: "¿Qué ropa debo recomendar a mis invitados?", answer: "Todo lo blanco brilla bajo UV — camisas, vestidos, tenis. También brillan los colores neón y fluorescentes. Puedes incluir en tu invitación 'dress code: blanco o neón' para maximizar el efecto." },
        { question: "¿Funciona de día?", answer: "Las luces UV necesitan oscuridad para el efecto completo. Funcionan perfecto en salones cerrados sin ventanas o en eventos nocturnos al aire libre después del atardecer." },
        { question: "¿Puedo agregar accesorios fluorescentes?", answer: "El producción Neón no incluye accesorios. Si quieres pulseras, collares y pintura neón, el paquete Glow Party ($8,000 + IVA) los incluye. También puedes comprar los tuyos y nosotros ponemos las luces." },
      ]} />
    </section>

    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader title="Otros Paquetes y Complementos" subtitle="¿Necesitas más efecto? Compara opciones." paragraph1="Cada paquete sube en intensidad y accesorios." paragraph2="Combina UV con bola disco para una pista épica." />
        <div class="services-grid">{otrosPaquetes.map((s) => (<ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />))}</div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container"><div class="cta-content">
        <h2>¿Organizas un evento masivo?</h2>
        <p>Cuéntanos la fecha, el lugar y cuántas personas esperas. Te confirmamos disponibilidad en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Solicitar Propuesta de Producción</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div></div>
    </section>
</BaseLayout>
