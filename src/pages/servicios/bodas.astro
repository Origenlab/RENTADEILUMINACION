---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import GallerySection from "../../components/GallerySection.astro";

const title = "Iluminación para Bodas en CDMX | REDEIL";
const description = "Renta de iluminación profesional para bodas en CDMX. Guirnaldas, cabezas móviles, city color, gobos y más. Paquetes completos de luz para tu boda. REDEIL.";
const canonical = "https://rentadeiluminacion.com/servicios/bodas/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Iluminación Profesional para Bodas",
  "provider": {
    "@type": "LocalBusiness",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com",
    "telephone": "+525530682988",
    "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressCountry": "MX" }
  },
  "description": "Servicio integral de iluminación profesional para bodas en Ciudad de México. Guirnaldas, cabezas móviles, city color, gobos y diseño de iluminación personalizado.",
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "serviceType": "Iluminación para Bodas"
});
---
<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <nav class="breadcrumb-section" aria-label="Breadcrumb">
    <div class="container">
      <div class="breadcrumb"><ol><li><a href="/">Inicio</a></li><li><a href="/servicios/">Servicios</a></li><li>Iluminación para Bodas</li></ol></div>
    </div>
  </nav>
  <main id="main-content">
    <Hero
      title="Iluminación Profesional para Bodas en CDMX"
      subtitle="Diseño de luz que transforma tu boda en una experiencia mágica e inolvidable"
      introParagraph1="En REDEIL somos especialistas en iluminación para bodas en la Ciudad de México. Combinamos guirnaldas edison, cabezas móviles, city color, gobos personalizados y luces arquitectónicas para crear ambientes únicos que reflejan la personalidad de cada pareja y el estilo de su celebración."
      introParagraph2="Ofrecemos paquetes completos de iluminación que cubren desde la ceremonia hasta la fiesta. Nuestro equipo de diseño lumínico visita el venue previamente para planificar cada detalle, asegurando que la luz realce la decoración, el espacio y cada momento especial de tu boda."
    />
    <section class="service-detail">
      <div class="container">
        <h2>Iluminación que hace única cada boda</h2>
        <p>La iluminación es uno de los elementos más transformadores en una boda. Las guirnaldas edison crean ese ambiente cálido y romántico en jardines y haciendas. Las cabezas móviles añaden dinamismo durante la fiesta y el primer baile. El city color permite bañar paredes y fachadas con el color temático de tu boda. Y los gobos personalizados proyectan monogramas e iniciales de los novios.</p>
        <p>En REDEIL diseñamos la iluminación de tu boda considerando cada momento: luz suave y cálida para la ceremonia, ambientación elegante para la cena, iluminación dinámica para el primer baile y efectos de alto impacto para la fiesta. Cada transición es operada en vivo por nuestros técnicos para crear una experiencia visual fluida.</p>
        <p>Cubrimos bodas en haciendas, jardines, salones, terrazas, rooftops, playas y cualquier venue en la CDMX y zona metropolitana. Contamos con equipo de respaldo y generadores de energía para venues sin conexión eléctrica.</p>
      </div>
    </section>
    <GallerySection title="Galería de Iluminación para Bodas" subtitle="Montajes de luz en bodas reales en la Ciudad de México">
      <figure class="gallery-item">
        <img src="/img/bodas/boda-hacienda-guirnaldas-cabezas-moviles.avif" alt="Boda en hacienda con guirnaldas edison y cabezas móviles creando ambiente mágico" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bodas/boda-elegante-guirnaldas-iluminacion-dj.avif" alt="Boda elegante con guirnaldas decorativas e iluminación profesional de DJ" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bodas/recepcion-boda-guirnaldas-edison-hacienda.avif" alt="Recepción de boda en hacienda iluminada con guirnaldas edison vintage" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bodas/iluminacion-completa-boda-hacienda-elegante.avif" alt="Iluminación completa profesional en boda elegante en hacienda colonial" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bodas/guirnaldas-led-boda-jardin-noche.avif" alt="Guirnaldas LED iluminando jardín durante boda nocturna romántica" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bodas/salon-boda-guirnaldas-edison-city-color.avif" alt="Salón de boda con guirnaldas edison y city color en tonos elegantes" width="800" height="533" loading="lazy">
      </figure>
    </GallerySection>
  </main>
</BaseLayout>
