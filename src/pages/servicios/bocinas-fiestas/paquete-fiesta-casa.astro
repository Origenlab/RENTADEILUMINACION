---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Renta de Bocinas para Fiesta en Casa CDMX — $3,000 + IVA | REDEIL";
const description = "2 bocinas JBL EON615 + subwoofer + Bluetooth para fiestas en casa de 20-60 personas. Audio que no molesta a vecinos. CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/bocinas-fiestas/paquete-fiesta-casa/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Bocinas para Fiesta en Casa — 2 JBL EON615 + Subwoofer",
    "description": "Paquete de 2 bocinas JBL EON615 con subwoofer JBL y conexión Bluetooth/AUX para fiestas en casa de 20 a 60 personas. Incluye micrófono Shure inalámbrico, técnico de audio, transporte, montaje y desmontaje en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/bocinas-fiestas/paquete-fiesta-casa/",
      "priceCurrency": "MXN",
      "price": "3000",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "56",
      "reviewCount": "56"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Lucía Martínez" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Las bocinas JBL EON se escucharon perfectas en el patio. El técnico ajustó el volumen para no molestar vecinos y aún así la música se sentía en el pecho."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Raúl Ortiz" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Para un depa, el sonido fue increíble. El sub le dio cuerpo a la música sin que los vecinos de abajo se quejaran. Conectamos Spotify por Bluetooth y listo."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Elena García" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Audio perfecto para la comida familiar en el jardín. Pusimos nuestra playlist por Bluetooth y el técnico ajustó la ecualización. Nada de distorsión."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/bocinas-fiestas/bocinas-amplificadas-fiestas-jardines.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Las bocinas JBL EON615 son suficientes para una fiesta en casa?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Las 2 JBL EON615 con subwoofer cubren perfectamente espacios de 20 a 60 personas — patios, terrazas, jardines pequeños y departamentos. El técnico ecualiza al espacio para que suene fuerte sin distorsión." }},
      { "@type": "Question", "name": "¿Van a molestar a los vecinos?", "acceptedAnswer": { "@type": "Answer", "text": "El técnico ajusta el volumen y la ecualización para que la música se sienta dentro de tu espacio sin rebotar hacia afuera. El subwoofer compacto da cuerpo al audio sin exceder en bajos que traspasen paredes." }},
      { "@type": "Question", "name": "¿Puedo conectar mi celular por Bluetooth?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El sistema acepta conexión Bluetooth directa desde tu celular, tablet o laptop. También puedes conectar por cable AUX o USB. Tu playlist de Spotify, Apple Music o YouTube Music suena directo." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Bocinas para Fiesta en Salón — $5,500", image: "/img/bocinas-fiestas/bocinas-eventos-cocktail-recepcion.avif", alt: "Bocinas para fiesta en salón de eventos", description: "4 bocinas JBL PRX + 2 subs + 2 micrófonos. Para salones de 80-200 personas. El más popular.", link: "/servicios/bocinas-fiestas/paquete-fiesta-salon/" },
  { title: "Audio para Fiesta en Jardín — $7,500", image: "/img/bocinas-fiestas/bocinas-amplificadas-fiestas-jardines.avif", alt: "Bocinas para fiesta al aire libre en jardín", description: "4 JBL PRX825 + 4 subs para jardines y haciendas. Cubre 100-300 personas al aire libre.", link: "/servicios/bocinas-fiestas/paquete-fiesta-jardin/" },
  { title: "DJ para Fiestas", image: "/img/bocinas-djs/dj-para-fiestas-ambiente-festivo.avif", alt: "DJ profesional para fiestas en CDMX", description: "¿Necesitas DJ además de bocinas? Complementa tu paquete con un DJ profesional que arma la fiesta.", link: "/servicios/bocinas-djs/" },
  { title: "Bola Disco", image: "/img/bola-disco/renta-bola-disco-para-fiestas-cdmx.avif", alt: "Bola disco para fiestas en casa", description: "Bocinas + bola disco = la fiesta completa. Destellos retro que transforman cualquier espacio.", link: "/servicios/bola-disco/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Sonido y DJ", href: "/servicios/sonido/" },
    { label: "Bocinas para Fiestas", href: "/servicios/bocinas-fiestas/" },
    { label: "Paquete Fiesta en Casa" }
  ]} />
</Fragment>

  <Hero
    title="Bocinas para Fiesta en Casa — 2 JBL EON615 + Subwoofer"
    subtitle="Desde $3,000 + IVA. Audio profesional para fiestas en casa, departamento, patio y terraza. 20-60 personas. CDMX."
    introParagraph1='La diferencia entre tu bocina Bluetooth de casa y un par de <strong>JBL EON615</strong> con subwoofer es la diferencia entre "se oye la música" y "se siente la fiesta". El paquete Fiesta en Casa está diseñado para espacios pequeños — patios, terrazas, departamentos y jardines donde necesitas audio que suene profesional sin que los vecinos llamen a la patrulla.'
    introParagraph2='Incluye 2 bocinas <strong>JBL EON615</strong>, un subwoofer que le da cuerpo a la música sin excederse en potencia, conexión Bluetooth para tu playlist de Spotify o Apple Music, y un técnico que monta, ecualiza al espacio y ajusta el volumen según el momento de la noche — suave para la comida, más fuerte para el baile. Sin sobredimensionar, sin cables cruzando la sala. Fiestas en casas, departamentos, terrazas y jardines en toda la <strong>CDMX</strong>.'
  />

  <CtaBar
    headline="¿Necesitas más potencia?"
    items={[
      { label: "Fiesta Salón — $5,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-salon/", icon: "sonido" },
      { label: "Fiesta Jardín — $7,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-jardin/", icon: "sonido" },
      { label: "Fiesta Masiva — $14,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-masiva/", icon: "sonido" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Fiesta en Casa"
      price="$3,000"
      priceNote="+ IVA · Técnico incluido"
      features={[
        { text: "2 bocinas JBL EON615" },
        { text: "1 subwoofer JBL compacto" },
        { text: "Conexión Bluetooth + AUX + USB" },
        { text: "1 micrófono Shure inalámbrico" },
        { text: "Volumen controlado para vecinos" },
        { text: "Ecualización al espacio" },
        { text: "Técnico de audio incluido" },
        { text: "Transporte + montaje + desmontaje" },
        { text: "Ideal: fiestas 20-60 personas" },
        { text: "Setup compacto para espacios reducidos" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete Fiesta en Casa — bocinas JBL EON615 + subwoofer para mi fiesta."
      packages={[
        { label: "Fiesta Casa", price: "$3,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-casa/", active: true },
        { label: "Fiesta Salón", price: "$5,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-salon/" },
        { label: "Fiesta Jardín", price: "$7,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-jardin/" },
        { label: "Fiesta Masiva", price: "$14,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-masiva/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="Para qué tipo de fiesta funciona este paquete"
          subtitle="Audio profesional que cabe en tu sala, patio o terraza."
          paragraph1="Las JBL EON615 son bocinas activas de 15 pulgadas que llenan espacios pequeños y medianos con audio limpio. Con el subwoofer, la música tiene cuerpo — sientes los bajos en el pecho sin que el volumen se salga de control."
          paragraph2="El técnico ajusta la ecualización según tu espacio: más agudos en exteriores, más control de graves en departamentos. Y durante la noche, sube o baja según el momento — cena, brindis, baile."
        />
        <FeatureGrid features={[
          { title: "Cumpleaños en Casa", description: "Tu sala o patio se convierte en venue. Las EON615 llenan el espacio y el Bluetooth te deja poner tu playlist desde el celular." },
          { title: "Posada Navideña en Patio", description: "Audio para villancicos en la cena y reguetón para el baile. El técnico maneja los niveles para cada momento de la noche." },
          { title: "Reunión Familiar en Jardín", description: "Música ambiental durante la comida, volumen para el baile después. El sub le da ese punch que tu bocina portátil no puede." },
          { title: "Pool Party en Terraza", description: "Setup compacto que no estorba alrededor de la alberca. Conexión Bluetooth para que cualquiera ponga su canción." },
          { title: "Aniversario en Departamento", description: "El equipo suena fuerte adentro sin que retumbe hacia los vecinos. El técnico ecualiza para que los bajos no traspasen pisos." },
          { title: "Baby Shower con Música", description: "Volumen suave para el evento, micrófono inalámbrico para los juegos y las dedicatorias. Todo controlado." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Qué hace diferente a este paquete"
          subtitle="Diseñado para espacios pequeños donde el sonido importa."
          paragraph1="No se trata de poner la bocina más grande. Se trata de poner el equipo correcto para tu espacio y que suene como si estuvieras en un venue profesional."
          paragraph2="El técnico de audio es la diferencia real: ecualiza, controla volumen y resuelve cualquier tema acústico de tu espacio."
        />
        <FeatureGrid features={[
          { title: "Bluetooth Directo desde Tu Celular", description: "Conecta Spotify, Apple Music o YouTube Music directo. Sin cables, sin complicaciones. Tu playlist suena en calidad profesional." },
          { title: "Subwoofer Compacto Sin Exceso", description: "El sub JBL le da cuerpo a la música — sientes los bajos pero no retumban las paredes. Diseñado para espacios residenciales." },
          { title: "Control de Volumen para Vecinos", description: "El técnico ecualiza para que la música se concentre en tu espacio. Suena fuerte adentro, moderado hacia afuera." },
          { title: "Sin Cables Cruzando Tu Sala", description: "Montaje limpio con cables ocultos. Nada cruzando pasillos ni estorbando la circulación de tus invitados." },
          { title: "Micrófono para Brindis o Karaoke", description: "Micrófono Shure inalámbrico incluido. Perfecto para el brindis, las mañanitas o una sesión de karaoke improvisada." },
          { title: "Setup en 30 Minutos", description: "Llegamos, montamos y probamos en media hora. Todo listo antes de que llegue tu primer invitado." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen quienes nos contrataron"
          subtitle="4.9 estrellas en 56 reseñas."
          paragraph1="Cada reseña es de un cliente real que contrató el paquete Fiesta en Casa."
          paragraph2="Pregunta por referencias de eventos similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Lucía Martínez", event: "Posada en Casa — Coyoacán, 45 invitados", rating: 5, text: "Las bocinas JBL EON se escucharon perfectas en el patio. El técnico ajustó el volumen para no molestar vecinos y aún así la música se sentía en el pecho." },
          { name: "Raúl Ortiz", event: "Cumpleaños en Departamento — Polanco, 35 invitados", rating: 5, text: "Para un depa, el sonido fue increíble. El sub le dio cuerpo a la música sin que los vecinos de abajo se quejaran. Conectamos Spotify por Bluetooth y listo." },
          { name: "Elena García", event: "Reunión Familiar en Jardín — Tlalpan, 55 invitados", rating: 5, text: "Audio perfecto para la comida familiar en el jardín. Pusimos nuestra playlist por Bluetooth y el técnico ajustó la ecualización. Nada de distorsión." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Bocinas para fiestas en casa — montajes reales"
        subtitle="Fiestas en patios, terrazas, departamentos y jardines en CDMX."
        paragraph1="Cada foto es de un montaje real con nuestras bocinas JBL. Espacios pequeños donde el audio profesional hizo la diferencia entre una reunión y una fiesta."
        paragraph2="¿Tienes fotos de tu espacio? Mándanoslas por WhatsApp y te confirmamos que este paquete es el ideal."
      />
      <Gallery4x4 images={[
        { src: "/img/bocinas-fiestas/bocinas-amplificadas-fiestas-jardines.avif", alt: "Bocinas amplificadas para fiestas en jardines" },
        { src: "/img/bocinas-fiestas/bocinas-karaoke-fiestas-familiares.avif", alt: "Bocinas para karaoke en fiestas familiares" },
        { src: "/img/bocinas-fiestas/bocinas-inalambricas-fiestas-casa.avif", alt: "Bocinas inalámbricas para fiestas en casa" },
        { src: "/img/bocinas-fiestas/equipo-audio-cumpleanos-reuniones.avif", alt: "Equipo de audio para cumpleaños y reuniones" },
        { src: "/img/bocinas-fiestas/alquiler-bocinas-fiestas-navidad.avif", alt: "Alquiler de bocinas para fiestas de Navidad" },
        { src: "/img/bocinas-fiestas/alquiler-altavoces-fiestas-piscina.avif", alt: "Alquiler de altavoces para fiestas en piscina" },
        { src: "/img/bocinas-fiestas/bocinas-fiestas-ano-nuevo-celebracion.avif", alt: "Bocinas para fiestas de Año Nuevo" },
        { src: "/img/bocinas-fiestas/equipo-audio-celebraciones-especiales.avif", alt: "Equipo de audio para celebraciones especiales" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete Fiesta en Casa"
        subtitle="Todo lo que necesitas saber antes de reservar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
        paragraph2="Si tu fiesta es en salón o jardín grande, tenemos paquetes con más potencia."
      />
    </div>
    <FaqSection items={[
      { question: "¿Las bocinas JBL EON615 son suficientes para una fiesta en casa?", answer: "Sí. Las 2 JBL EON615 con subwoofer cubren perfectamente espacios de 20 a 60 personas — patios, terrazas, jardines pequeños y departamentos. El técnico ecualiza al espacio para que suene fuerte sin distorsión." },
      { question: "¿Van a molestar a los vecinos?", answer: "El técnico ajusta el volumen y la ecualización para que la música se sienta dentro de tu espacio sin rebotar hacia afuera. El subwoofer compacto da cuerpo al audio sin exceder en bajos que traspasen paredes." },
      { question: "¿Puedo conectar mi celular por Bluetooth?", answer: "Sí. El sistema acepta conexión Bluetooth directa desde tu celular, tablet o laptop. También puedes conectar por cable AUX o USB. Tu playlist de Spotify, Apple Music o YouTube Music suena directo." },
      { question: "¿El técnico se queda toda la fiesta?", answer: "Sí. El técnico monta el equipo, ecualiza según tu espacio y se queda durante todo el evento para ajustar volumen, resolver cualquier tema técnico y desmontar al final. No te deja solo con el equipo." },
      { question: "¿Qué necesito tener en mi casa para el montaje?", answer: "Solo una conexión eléctrica cerca del área de la fiesta. El equipo es compacto y no requiere instalación especial. El técnico llega con todo — bocinas, cables, tripié, subwoofer y micrófono. En 30 minutos está listo." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes y Servicios"
        subtitle="¿Necesitas más potencia o complementar tu fiesta?"
        paragraph1="Si tu evento es más grande o quieres agregar DJ, bola disco u otros efectos, tenemos paquetes que se combinan con precio especial."
        paragraph2="Cuéntanos tu evento y armamos la propuesta ideal para tu espacio y presupuesto."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Lista la música para tu fiesta?</h2>
        <p>Mándanos la fecha, el número de invitados y fotos de tu espacio. Te confirmamos disponibilidad y te cotizamos en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza Gratis por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
