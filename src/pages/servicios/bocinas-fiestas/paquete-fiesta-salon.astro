---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Bocinas para Fiesta en Salón CDMX — $5,500 + IVA | REDEIL";
const description = "4 bocinas JBL PRX + 2 subs + 2 micrófonos Shure para fiestas en salón de 80-200 personas. Graduaciones, posadas. CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/bocinas-fiestas/paquete-fiesta-salon/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Bocinas para Fiesta en Salón — 4 JBL PRX + 2 Subwoofers",
    "description": "Paquete de 4 bocinas JBL PRX con 2 subwoofers, 2 micrófonos Shure inalámbricos y mezcladora para fiestas en salón de 80 a 200 personas. Incluye técnico de audio, transporte, montaje y desmontaje en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/bocinas-fiestas/paquete-fiesta-salon/",
      "priceCurrency": "MXN",
      "price": "5500",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "68",
      "reviewCount": "68"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Martha Peña" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Las 4 bocinas JBL PRX cubrieron todo el salón del hotel. Los discursos de los directivos se escucharon claros y cuando arrancó la fiesta, los subs sacudieron la pista."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "José Luis Barrera" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Salón grande, 200 personas y cero puntos muertos. La música se escuchaba igual en la pista que en las mesas del fondo. El técnico ajustó el sonido para que los brindis se oyeran perfecto."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Guadalupe Torres" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Fiesta de aniversario en salón. El equipo sonó profesional toda la noche. Conectamos nuestra playlist por Bluetooth y el técnico se encargó de que todo sonara impecable."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/bocinas-fiestas/bocinas-eventos-cocktail-recepcion.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿4 bocinas JBL PRX cubren un salón de 200 personas?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Las 4 JBL PRX se posicionan estratégicamente en el salón para eliminar puntos muertos. Con los 2 subwoofers, el audio llega con la misma fuerza a la pista de baile y a las mesas del fondo." }},
      { "@type": "Question", "name": "¿Los micrófonos Shure sirven para discursos y brindis?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Los 2 micrófonos Shure inalámbricos incluidos son profesionales — captan la voz con claridad sin distorsión ni feedback. El técnico ajusta la ganancia para que los discursos se escuchen en todo el salón." }},
      { "@type": "Question", "name": "¿Puedo usar mi playlist y también micrófono al mismo tiempo?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. La mezcladora incluida permite reproducir música por Bluetooth y usar los micrófonos simultáneamente. El técnico balancea los niveles para que la voz se escuche sobre la música." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Bocinas para Fiesta en Casa — $3,000", image: "/img/bocinas-fiestas/bocinas-inalambricas-fiestas-casa.avif", alt: "Bocinas para fiesta en casa", description: "2 JBL EON615 + sub para fiestas íntimas de 20-60 personas. Ideal para patios y departamentos.", link: "/servicios/bocinas-fiestas/paquete-fiesta-casa/" },
  { title: "Audio para Fiesta en Jardín — $7,500", image: "/img/bocinas-fiestas/bocinas-amplificadas-fiestas-jardines.avif", alt: "Bocinas para fiesta al aire libre en jardín", description: "4 JBL PRX825 + 4 subs para jardines y haciendas. Planta de luz opcional. 100-300 personas.", link: "/servicios/bocinas-fiestas/paquete-fiesta-jardin/" },
  { title: "Confeti para Fiestas", image: "/img/maquina-de-papelitos/confeti-dorado-primer-baile-novios-romantico.avif", alt: "Confeti para fiestas y celebraciones", description: "Cañones de confeti para el momento cumbre de tu fiesta. Graduaciones, XV años, bodas.", link: "/servicios/confeti/" },
  { title: "Máquina de Humo", image: "/img/humo/maquina-humo-profesional-boda-pista-baile.avif", alt: "Máquina de humo para fiestas en salón", description: "Humo + bocinas + luces = la fiesta completa. Efecto de antro en tu salón de eventos.", link: "/servicios/maquina-humo/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Sonido y DJ", href: "/servicios/sonido/" },
    { label: "Bocinas para Fiestas", href: "/servicios/bocinas-fiestas/" },
    { label: "Paquete Fiesta en Salón" }
  ]} />
</Fragment>

  <Hero
    title="Bocinas para Fiesta en Salón — 4 JBL PRX + 2 Subs"
    subtitle="Desde $5,500 + IVA. Audio que cubre cada rincón del salón. 80-200 personas. Graduaciones, XV años, aniversarios. CDMX."
    introParagraph1='Un salón de eventos tiene un problema acústico que tu DJ con 2 bocinas no va a resolver: <strong>puntos muertos</strong>. Las mesas del fondo no escuchan la música igual que la pista, los discursos se pierden en el eco y cuando sube el volumen para compensar, la primera fila se queda sorda. Con 4 <strong>bocinas JBL PRX</strong> posicionadas estratégicamente, 2 subwoofers y una mezcladora profesional, el audio es uniforme en todo el salón — la pista, las mesas y el rincón del fondo.'
    introParagraph2='Incluye 2 <strong>micrófonos Shure inalámbricos</strong> para discursos, brindis y mañanitas que se escuchan con claridad profesional. El técnico de audio se queda toda la noche para manejar los niveles — música ambiental para la cena, micrófonos abiertos para los discursos, volumen de fiesta para el baile. Sin feedback, sin distorsión, sin que nadie tenga que gritar para que lo escuchen. Graduaciones, XV años, posadas, aniversarios y fiestas corporativas en salones de toda la <strong>CDMX</strong>.'
  />

  <CtaBar
    headline="Compara paquetes de bocinas"
    items={[
      { label: "Fiesta Casa — $3,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-casa/", icon: "sonido" },
      { label: "Fiesta Jardín — $7,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-jardin/", icon: "sonido" },
      { label: "Fiesta Masiva — $14,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-masiva/", icon: "sonido" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Fiesta en Salón"
      price="$5,500"
      priceNote="+ IVA · Más popular"
      features={[
        { text: "4 bocinas JBL PRX activas" },
        { text: "2 subwoofers JBL profesionales" },
        { text: "2 micrófonos Shure inalámbricos" },
        { text: "Mezcladora profesional" },
        { text: "Conexión Bluetooth + AUX + USB" },
        { text: "Cobertura uniforme sin puntos muertos" },
        { text: "Técnico de audio toda la noche" },
        { text: "Transporte + montaje + desmontaje" },
        { text: "Ideal: salones 80-200 personas" },
        { text: "Cables ocultos, montaje limpio" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete Fiesta en Salón — 4 bocinas JBL PRX + 2 subs para mi evento."
      packages={[
        { label: "Fiesta Casa", price: "$3,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-casa/" },
        { label: "Fiesta Salón", price: "$5,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-salon/", active: true },
        { label: "Fiesta Jardín", price: "$7,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-jardin/" },
        { label: "Fiesta Masiva", price: "$14,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-masiva/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="Eventos ideales para este paquete"
          subtitle="Audio profesional para salones de eventos de 80 a 200 personas."
          paragraph1="Las 4 JBL PRX se distribuyen en el salón para que el audio sea parejo en todos los rincones. Los 2 subs se colocan cerca de la pista para que los bajos se sientan donde importa — en el baile."
          paragraph2="Los 2 micrófonos Shure permiten discursos simultáneos, mañanitas con la familia o karaoke para los invitados. El técnico balancea todo en tiempo real."
        />
        <FeatureGrid features={[
          { title: "Graduación en Hotel o Salón", description: "Discursos de directivos que se escuchan claros, música para la fiesta que sacude la pista. Los micrófonos Shure no fallan en ceremonias formales." },
          { title: "XV Años en Salón de Eventos", description: "Vals, brindis, mañanitas y la fiesta. El técnico maneja cada momento con el volumen y la ecualización correcta para el salón." },
          { title: "Posada Empresarial en Salón", description: "Música ambiental para la cena, micrófono para los discursos del jefe, volumen de fiesta para la rifa y el baile. Todo controlado." },
          { title: "Aniversario en Salón", description: "Audio elegante para la cena, micrófono para las dedicatorias y música que llena la pista cuando llega el momento de bailar." },
          { title: "Boda Civil en Salón", description: "Ceremonia con micrófono para los votos, música ambiental para el banquete y audio de fiesta para el baile. Un solo equipo para todo." },
          { title: "Cumpleaños en Salón Rentado", description: "¿El salón no tiene equipo de sonido propio? Las 4 JBL PRX convierten cualquier salón vacío en un venue con audio profesional." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Por qué 4 bocinas y no 2"
          subtitle="La diferencia entre 'se oye' y 'se oye parejo en todo el salón'."
          paragraph1="Con 2 bocinas en un salón grande, las mesas del fondo quedan en silencio relativo. El sonido se dispersa en el espacio y pierde fuerza. Con 4 JBL PRX posicionadas en puntos estratégicos, el audio llega uniforme a cada rincón."
          paragraph2="Los 2 subwoofers agregan los bajos que hacen que la música se sienta — no solo se oiga. Posicionados cerca de la pista, concentran la energía donde más se necesita."
        />
        <FeatureGrid features={[
          { title: "Cero Puntos Muertos", description: "4 bocinas distribuidas estratégicamente = cobertura pareja. Las mesas del fondo escuchan la misma calidad que la pista de baile." },
          { title: "2 Micrófonos Profesionales Shure", description: "Inalámbricos, con anti-feedback y ganancia ajustable. Para discursos, brindis, mañanitas o karaoke. Sin chiflidos." },
          { title: "Mezcladora con Bluetooth", description: "La mezcladora profesional permite reproducir música, usar micrófonos y conectar fuentes simultáneas. Todo balanceado por el técnico." },
          { title: "Técnico Toda la Noche", description: "No te deja el equipo y se va. Se queda para ajustar niveles en cada momento: cena, ceremonia, discursos, baile." },
          { title: "2 Subwoofers para la Pista", description: "Bajos que se sienten en el cuerpo sin distorsionar la música. Posicionados donde el impacto importa — la pista de baile." },
          { title: "Montaje Invisible", description: "Cables canalizados, bocinas en tripiés discretos o montadas en puntos del salón. El equipo no compite con tu decoración." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen quienes nos contrataron"
          subtitle="4.9 estrellas en 68 reseñas."
          paragraph1="Cada reseña es de un cliente real que contrató el paquete Fiesta en Salón."
          paragraph2="Pregunta por referencias de eventos similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Martha Peña", event: "Graduación Anáhuac — Hotel Camino Real, 180 invitados", rating: 5, text: "Las 4 bocinas JBL PRX cubrieron todo el salón del hotel. Los discursos de los directivos se escucharon claros y cuando arrancó la fiesta, los subs sacudieron la pista." },
          { name: "José Luis Barrera", event: "XV Años — Salón Montecarlo, Nezahualcóyotl, 200 invitados", rating: 5, text: "Salón grande, 200 personas y cero puntos muertos. La música se escuchaba igual en la pista que en las mesas del fondo. El técnico ajustó el sonido para que los brindis se oyeran perfecto." },
          { name: "Guadalupe Torres", event: "Aniversario — Salón Los Arcos, Tlalnepantla, 150 invitados", rating: 5, text: "Fiesta de aniversario en salón. El equipo sonó profesional toda la noche. Conectamos nuestra playlist por Bluetooth y el técnico se encargó de que todo sonara impecable." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Audio en salones de eventos — montajes reales"
        subtitle="Graduaciones, XV años, aniversarios y posadas en salones de CDMX."
        paragraph1="Cada foto es de un montaje real con nuestro equipo JBL PRX en salones de eventos. Cobertura completa sin puntos muertos, micrófonos para discursos y bajos que sacuden la pista."
        paragraph2="¿Ya tienes salón reservado? Mándanos fotos y te decimos exactamente cómo posicionamos las bocinas."
      />
      <Gallery4x4 images={[
        { src: "/img/bocinas-fiestas/bocinas-eventos-cocktail-recepcion.avif", alt: "Bocinas para eventos de cocktail y recepción" },
        { src: "/img/bocinas-fiestas/bocinas-profesionales-fiestas-noche.avif", alt: "Bocinas profesionales para fiestas de noche" },
        { src: "/img/bocinas-fiestas/bocinas-grandes-eventos-masivos.avif", alt: "Bocinas para eventos grandes en salón" },
        { src: "/img/bocinas-fiestas/alquiler-sonido-aniversarios-celebraciones.avif", alt: "Alquiler de sonido para aniversarios" },
        { src: "/img/bocinas-fiestas/equipo-audio-celebraciones-especiales.avif", alt: "Equipo de audio para celebraciones especiales en salón" },
        { src: "/img/bocinas-fiestas/alquiler-altavoces-eventos-terraza.avif", alt: "Alquiler de altavoces para eventos en terraza" },
        { src: "/img/bocinas-fiestas/bocinas-eventos-neon-glow.avif", alt: "Bocinas para eventos neon y glow party" },
        { src: "/img/bocinas-fiestas/alquiler-bocinas-fiestas-navidad.avif", alt: "Alquiler de bocinas para posadas navideñas" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete Fiesta en Salón"
        subtitle="Todo lo que necesitas saber antes de reservar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
        paragraph2="Si tu evento es al aire libre o para más de 200 personas, revisa nuestros paquetes Jardín o Masivo."
      />
    </div>
    <FaqSection items={[
      { question: "¿4 bocinas JBL PRX cubren un salón de 200 personas?", answer: "Sí. Las 4 JBL PRX se posicionan estratégicamente en el salón para eliminar puntos muertos. Con los 2 subwoofers, el audio llega con la misma fuerza a la pista de baile y a las mesas del fondo." },
      { question: "¿Los micrófonos sirven para discursos y brindis?", answer: "Sí. Los 2 micrófonos Shure inalámbricos son profesionales — captan la voz con claridad sin distorsión ni feedback. El técnico ajusta la ganancia para que los discursos se escuchen en todo el salón." },
      { question: "¿Puedo usar playlist y micrófono al mismo tiempo?", answer: "Sí. La mezcladora incluida permite reproducir música por Bluetooth y usar los micrófonos simultáneamente. El técnico balancea los niveles para que la voz se escuche sobre la música sin cortarla." },
      { question: "¿El salón necesita tener tomas de corriente especiales?", answer: "No. El equipo funciona con corriente estándar doméstica (110V). Solo necesitamos acceso a 2 tomas de corriente cercanas al área de montaje. Si el salón tiene limitaciones de electricidad, lo evaluamos previamente." },
      { question: "¿Cuánto tiempo tardan en montar?", answer: "Entre 45 minutos y 1 hora. Llegamos con tiempo suficiente para posicionar las 4 bocinas, los 2 subs, cablear la mezcladora y hacer pruebas de sonido antes de que lleguen los invitados." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes y Servicios"
        subtitle="¿Necesitas menos potencia, más cobertura o efectos especiales?"
        paragraph1="Si tu evento es más íntimo, el paquete Casa cubre de 20 a 60 personas. Si es al aire libre, el paquete Jardín compensa la dispersión del sonido. Y si quieres la fiesta completa, agrega confeti o máquina de humo."
        paragraph2="Armamos combos con descuento. Cuéntanos qué necesitas."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo el audio para tu fiesta en salón?</h2>
        <p>Mándanos la fecha, el nombre del salón y el número de invitados. Te cotizamos en minutos y te explicamos cómo posicionamos las bocinas.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza Gratis por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
