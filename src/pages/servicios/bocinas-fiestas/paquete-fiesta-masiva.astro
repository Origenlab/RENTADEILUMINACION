---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Audio para Eventos Masivos y Conciertos Privados CDMX — $14,000 + IVA | REDEIL";
const description = "Line array QSC KLA12 + delays + monitors + planta de luz para eventos de 400+ personas. Producción completa. CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/bocinas-fiestas/paquete-fiesta-masiva/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Audio para Eventos Masivos — Line Array QSC KLA12 + Delays + Monitors",
    "description": "Sistema de line array QSC KLA12 con delays, monitors de escenario y planta de luz incluida para eventos masivos de 400+ personas. Producción completa con técnico FOH. Transporte, montaje y desmontaje en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/bocinas-fiestas/paquete-fiesta-masiva/",
      "priceCurrency": "MXN",
      "price": "14000",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "42",
      "reviewCount": "42"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Ricardo Núñez" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "El line array QSC KLA12 cubrió 600 personas en un estacionamiento industrial. Los delays mantuvieron la sincronización perfecta. Producción de concierto real."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Beatriz Salinas" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Contratamos audio para un concierto privado con banda en vivo. Los monitors de escenario permitieron que los músicos tocaran cómodos y el FOH mezcló impecable."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Gerardo Castillo" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Graduación universitaria al aire libre. El sistema de delays mantuvo el audio sincronizado en todo el espacio. Los discursos se escucharon claros a 450 personas."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/bocinas-fiestas/bocinas-grandes-eventos-masivos.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Qué es un line array y por qué lo necesito para 400+ personas?", "acceptedAnswer": { "@type": "Answer", "text": "Un line array es un sistema de bocinas apiladas verticalmente que proyecta el sonido en un patrón controlado. A diferencia de bocinas convencionales, el line array mantiene la presión sonora a distancia — la persona en la fila 50 escucha con la misma claridad que la de la fila 1. Para 400+ personas, es la única forma de garantizar cobertura uniforme." }},
      { "@type": "Question", "name": "¿Qué son los delays y para qué sirven?", "acceptedAnswer": { "@type": "Answer", "text": "Los delays son bocinas secundarias posicionadas a mitad del espacio que reciben la señal con un retraso calculado en milisegundos. Esto sincroniza el sonido para que las personas del fondo escuchen el audio al mismo tiempo que las del frente — sin eco ni desfase. Son indispensables en espacios de más de 40 metros de profundidad." }},
      { "@type": "Question", "name": "¿Incluye planta de luz?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El paquete Fiesta Masiva incluye planta de luz porque eventos de 400+ personas generalmente se realizan en espacios exteriores o industriales donde la instalación eléctrica no soporta el consumo del equipo. La planta garantiza voltaje estable toda la noche." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Audio para Fiesta en Jardín — $7,500", image: "/img/bocinas-fiestas/bocinas-amplificadas-fiestas-jardines.avif", alt: "Bocinas para fiesta al aire libre en jardín", description: "4 JBL PRX825 + 4 subs para jardines y haciendas. 100-300 personas. Planta de luz opcional.", link: "/servicios/bocinas-fiestas/paquete-fiesta-jardin/" },
  { title: "Bocinas para Fiesta en Salón — $5,500", image: "/img/bocinas-fiestas/bocinas-eventos-cocktail-recepcion.avif", alt: "Bocinas para fiesta en salón de eventos", description: "4 JBL PRX + 2 subs + 2 micrófonos. Para salones de 80-200 personas. El más popular.", link: "/servicios/bocinas-fiestas/paquete-fiesta-salon/" },
  { title: "Cabezas Móviles", image: "/img/cabezas-moviles/renta-cabezas-moviles-para-eventos-cdmx.avif", alt: "Cabezas móviles para eventos masivos", description: "Line array + cabezas móviles = producción de concierto. Iluminación inteligente que sigue al artista.", link: "/servicios/cabezas-moviles/" },
  { title: "Confeti para Eventos Masivos", image: "/img/maquina-de-papelitos/confeti-para-bodas-xv-anos-cdmx.avif", alt: "Confeti para eventos masivos y conciertos", description: "Cañones de confeti para el momento cumbre. El cierre visual que todo evento masivo necesita.", link: "/servicios/confeti/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Sonido y DJ", href: "/servicios/sonido/" },
    { label: "Bocinas para Fiestas", href: "/servicios/bocinas-fiestas/" },
    { label: "Paquete Fiesta Masiva" }
  ]} />
</Fragment>

  <Hero
    title="Audio para Eventos Masivos — Line Array QSC KLA12"
    subtitle="Desde $14,000 + IVA. Line array + delays + monitors + planta de luz. Conciertos privados, graduaciones masivas, festivales. 400+ personas. CDMX."
    introParagraph1='Cuando el evento supera las 400 personas, las bocinas convencionales no alcanzan. Necesitas un <strong>line array</strong> — un sistema de cajas acústicas apiladas que proyecta el sonido en un patrón controlado y mantiene la presión sonora a distancia. El <strong>QSC KLA12</strong> es un line array compacto de grado profesional que cubre desde conciertos privados hasta graduaciones universitarias al aire libre. La persona en la última fila escucha con la misma claridad que la de la primera.'
    introParagraph2='Este paquete incluye <strong>delays</strong> posicionados a mitad del espacio para sincronizar el audio en profundidad, <strong>monitors de escenario</strong> para que los artistas o ponentes se escuchen a sí mismos, <strong>planta de luz incluida</strong> porque eventos de este tamaño generalmente superan la capacidad eléctrica del venue, y un ingeniero de audio <strong>FOH</strong> (Front of House) que mezcla en vivo toda la noche. Esto no es rentar bocinas — es contratar una producción de audio completa para tu evento masivo en <strong>CDMX</strong>.'
  />

  <CtaBar
    headline="¿Tu evento es más pequeño?"
    items={[
      { label: "Fiesta Casa — $3,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-casa/", icon: "sonido" },
      { label: "Fiesta Salón — $5,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-salon/", icon: "sonido" },
      { label: "Fiesta Jardín — $7,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-jardin/", icon: "sonido" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Fiesta Masiva"
      price="$14,000"
      priceNote="+ IVA · Planta de luz incluida"
      features={[
        { text: "Line array QSC KLA12" },
        { text: "Subwoofers QSC KS212C" },
        { text: "Delays para sincronización" },
        { text: "Monitors de escenario" },
        { text: "Planta de luz incluida" },
        { text: "Mezcladora digital profesional" },
        { text: "Micrófonos Shure inalámbricos" },
        { text: "Ingeniero de audio FOH" },
        { text: "Ideal: eventos 400+ personas" },
        { text: "Transporte + montaje + desmontaje" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete Fiesta Masiva — line array QSC KLA12 para mi evento de 400+ personas."
      packages={[
        { label: "Fiesta Casa", price: "$3,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-casa/" },
        { label: "Fiesta Salón", price: "$5,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-salon/" },
        { label: "Fiesta Jardín", price: "$7,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-jardin/" },
        { label: "Fiesta Masiva", price: "$14,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-masiva/", active: true },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="Eventos que necesitan producción de audio"
          subtitle="Para cuando 'rentar unas bocinas' ya no es suficiente."
          paragraph1="Un evento de 400+ personas requiere ingeniería de audio real. Posicionamiento de line array, cálculo de delays, monitors para el escenario y un ingeniero FOH que mezcle en vivo. Esto no es conectar un Bluetooth y darle play."
          paragraph2="El QSC KLA12 es un line array compacto que proyecta sonido controlado — llega lejos sin distorsionar y mantiene la inteligibilidad de la voz en discursos y la potencia de la música en el baile."
        />
        <FeatureGrid features={[
          { title: "Concierto Privado con Banda en Vivo", description: "Monitors para que los músicos se escuchen, line array para el público y un FOH que mezcla cada instrumento. Audio de festival en tu evento privado." },
          { title: "Graduación Masiva al Aire Libre", description: "450+ graduados. Discursos que se escuchan claros a 80 metros de distancia gracias a los delays. Sin eco, sin desfase, sin gritar al micrófono." },
          { title: "Festival Corporativo o Activación de Marca", description: "Evento en estacionamiento, explanada o parque. El line array proyecta a distancia y los subs llenan de energía el espacio abierto." },
          { title: "Evento Privado en Terreno o Explanada", description: "Cumpleaños masivo, boda de 500 invitados o evento social en un espacio sin infraestructura. Planta de luz + line array = evento completo." },
          { title: "Rally o Convención Empresarial", description: "Ponentes con micrófono que se escuchan en todo el espacio. Música de transición. Video con audio sincronizado. Todo desde la mezcladora digital." },
          { title: "Fiesta de Fin de Año Masiva", description: "La cuenta regresiva que se escucha a 600 personas, los bajos que hacen vibrar el piso y el audio perfecto para arrancar el año." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que incluye la producción de audio"
          subtitle="Cada componente tiene una función específica en eventos masivos."
          paragraph1="Esto no es un paquete de bocinas — es un sistema de producción de audio diseñado para que 400+ personas escuchen con la misma calidad. Cada elemento resuelve un problema acústico específico de los eventos masivos."
          paragraph2="El ingeniero FOH es quien hace que todo funcione: posiciona, calibra, ecualiza y mezcla en vivo durante todo el evento."
        />
        <FeatureGrid features={[
          { title: "Line Array QSC KLA12", description: "Cajas acústicas apiladas que proyectan sonido en un patrón controlado. La persona en la fila 50 escucha igual que la de la fila 1. Sin distorsión a volumen alto." },
          { title: "Delays para Espacios Profundos", description: "Bocinas secundarias a mitad del espacio con retraso calculado en milisegundos. Sincronizan el audio para que no haya eco ni desfase en las filas del fondo." },
          { title: "Monitors de Escenario", description: "Bocinas apuntando hacia el artista o ponente para que se escuche a sí mismo. Sin monitors, los músicos pierden el tempo y los ponentes no saben si el micrófono funciona." },
          { title: "Subwoofers QSC KS212C", description: "Los bajos que hacen vibrar el pecho. Posicionados al frente del escenario para que la energía de la música se sienta físicamente en la audiencia." },
          { title: "Planta de Luz Incluida", description: "Eventos masivos superan la capacidad eléctrica de cualquier venue. La planta garantiza voltaje estable para el line array, subs, delays y monitors durante toda la noche." },
          { title: "Ingeniero FOH en Vivo", description: "El cerebro de la operación. Mezcla en tiempo real, ajusta niveles, compensa el viento en exteriores y garantiza que cada momento del evento suene perfecto." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen quienes nos contrataron"
          subtitle="4.9 estrellas en 42 reseñas."
          paragraph1="Cada reseña es de un cliente real que contrató el paquete Fiesta Masiva."
          paragraph2="Pregunta por referencias de eventos similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Ricardo Núñez", event: "Evento Empresa — Parque Industrial Tlalnepantla, 600 personas", rating: 5, text: "El line array QSC KLA12 cubrió 600 personas en un estacionamiento industrial. Los delays mantuvieron la sincronización perfecta. Producción de concierto real." },
          { name: "Beatriz Salinas", event: "Concierto Privado — Explanada Pedregal, 500 personas", rating: 5, text: "Contratamos audio para un concierto privado con banda en vivo. Los monitors de escenario permitieron que los músicos tocaran cómodos y el FOH mezcló impecable." },
          { name: "Gerardo Castillo", event: "Graduación Masiva — Zona Externa, 450 personas", rating: 5, text: "Graduación universitaria al aire libre. El sistema de delays mantuvo el audio sincronizado en todo el espacio. Los discursos se escucharon claros a 450 personas." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Producción de audio masiva — montajes reales"
        subtitle="Conciertos privados, graduaciones y festivales corporativos en CDMX."
        paragraph1="Cada foto es de un montaje real con nuestro sistema de line array QSC KLA12. Eventos de 400 a 600+ personas donde el audio profesional fue la columna vertebral de la producción."
        paragraph2="¿Tienes un evento masivo? Mándanos los detalles — espacio, número de personas y tipo de evento — y te armamos la propuesta de producción."
      />
      <Gallery4x4 images={[
        { src: "/img/bocinas-fiestas/bocinas-grandes-eventos-masivos.avif", alt: "Bocinas para eventos masivos y conciertos" },
        { src: "/img/bocinas-fiestas/bocinas-profesionales-fiestas-noche.avif", alt: "Bocinas profesionales para fiestas de noche" },
        { src: "/img/bocinas-fiestas/bocinas-eventos-neon-glow.avif", alt: "Audio para eventos de producción con luces" },
        { src: "/img/bocinas-fiestas/alquiler-parlantes-fiestas-roof-top.avif", alt: "Audio para eventos masivos en rooftop" },
        { src: "/img/bocinas-fiestas/equipo-audio-cumpleanos-reuniones.avif", alt: "Equipo de audio para eventos grandes" },
        { src: "/img/bocinas-fiestas/alquiler-bocinas-eventos-rusticos.avif", alt: "Audio profesional para eventos en exteriores" },
        { src: "/img/bocinas-fiestas/bocinas-eventos-cocktail-recepcion.avif", alt: "Audio para eventos de producción y recepción" },
        { src: "/img/bocinas-fiestas/alquiler-bocinas-fiestas-navidad.avif", alt: "Audio para eventos masivos de fin de año" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete Fiesta Masiva"
        subtitle="Todo lo que necesitas saber antes de reservar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
        paragraph2="Cada evento masivo es único — cotizamos según tu espacio, número de personas y tipo de producción."
      />
    </div>
    <FaqSection items={[
      { question: "¿Qué es un line array y por qué lo necesito para 400+ personas?", answer: "Un line array es un sistema de bocinas apiladas verticalmente que proyecta el sonido en un patrón controlado. A diferencia de bocinas convencionales, el line array mantiene la presión sonora a distancia — la persona en la fila 50 escucha con la misma claridad que la de la fila 1. Para 400+ personas, es la única forma de garantizar cobertura uniforme." },
      { question: "¿Qué son los delays y para qué sirven?", answer: "Los delays son bocinas secundarias posicionadas a mitad del espacio que reciben la señal con un retraso calculado en milisegundos. Esto sincroniza el sonido para que las personas del fondo escuchen el audio al mismo tiempo que las del frente — sin eco ni desfase. Son indispensables en espacios de más de 40 metros de profundidad." },
      { question: "¿El paquete incluye planta de luz?", answer: "Sí. El paquete Fiesta Masiva incluye planta de luz porque eventos de 400+ personas generalmente se realizan en espacios exteriores o industriales donde la instalación eléctrica no soporta el consumo del equipo. La planta garantiza voltaje estable toda la noche." },
      { question: "¿Funciona para conciertos con banda en vivo?", answer: "Sí. El paquete incluye monitors de escenario para que los músicos se escuchen a sí mismos y una mezcladora digital donde el ingeniero FOH mezcla cada canal — voz, guitarra, bajo, batería — en tiempo real. Es producción de concierto completa." },
      { question: "¿Cuánto tarda el montaje de un line array?", answer: "Entre 3 y 4 horas dependiendo del espacio. El line array requiere rigging (montaje en altura), cableado de delays, posicionamiento de subs y monitors, y calibración acústica del sistema completo. Llegamos con el tiempo necesario para que todo esté perfecto antes del evento." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes y Servicios"
        subtitle="¿Tu evento es más pequeño o necesitas producción visual?"
        paragraph1="Si tu evento es de 100-300 personas en jardín, el paquete Jardín es suficiente. Si es en salón cerrado, el paquete Salón cubre 80-200 personas. Y si quieres producción visual además de audio, las cabezas móviles y el confeti completan la experiencia."
        paragraph2="Armamos producciones integrales de audio + iluminación. Cuéntanos tu visión."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Tienes un evento masivo en puerta?</h2>
        <p>Mándanos los detalles — espacio, número de personas, tipo de evento y si hay banda en vivo. Te armamos la propuesta de producción de audio completa.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza Gratis por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
