---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Audio para Fiesta al Aire Libre CDMX — $7,500 + IVA | REDEIL";
const description = "4 bocinas JBL PRX825 + 4 subs para fiestas en jardín de 100-300 personas. Técnico + planta de luz opcional. CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/bocinas-fiestas/paquete-fiesta-jardin/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Audio para Fiesta al Aire Libre — 4 JBL PRX825 + 4 Subwoofers",
    "description": "Paquete de 4 bocinas JBL PRX825 con 4 subwoofers para fiestas al aire libre en jardines y haciendas de 100 a 300 personas. Incluye planta de luz opcional, técnico de audio, transporte, montaje y desmontaje en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/bocinas-fiestas/paquete-fiesta-jardin/",
      "priceCurrency": "MXN",
      "price": "7500",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "54",
      "reviewCount": "54"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Silvia Ramos" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "El audio al aire libre fue espectacular. Las JBL PRX825 con 4 subs compensaron perfectamente la dispersión del jardín. Se escuchaba igual cerca y lejos de las bocinas."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Manuel Herrera" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "El técnico trajo planta de luz porque la hacienda tenía poca corriente. Las bocinas sonaron toda la noche sin interrupciones. Profesionalismo total."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Verónica Luna" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Posada corporativa al aire libre con 180 personas. El equipo cubrió todo el jardín. La música ambiental para la cena fue perfecta y la fiesta posterior sonó increíble."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/bocinas-fiestas/bocinas-amplificadas-fiestas-jardines.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿El sonido al aire libre pierde potencia?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, al aire libre el sonido se dispersa porque no hay paredes que lo reflejen. Por eso este paquete incluye 4 bocinas JBL PRX825 y 4 subwoofers — el doble de subs que el paquete salón — para compensar esa dispersión y mantener el audio potente en todo el jardín." }},
      { "@type": "Question", "name": "¿Qué pasa si el jardín no tiene suficiente corriente eléctrica?", "acceptedAnswer": { "@type": "Answer", "text": "Ofrecemos planta de luz como accesorio opcional. Muchas haciendas y jardines tienen instalación eléctrica limitada. La planta garantiza que el equipo funcione toda la noche sin interrupciones ni bajones de voltaje." }},
      { "@type": "Question", "name": "¿El equipo resiste la intemperie?", "acceptedAnswer": { "@type": "Answer", "text": "Las bocinas JBL PRX825 son robustas y funcionan en exteriores sin problema. Si hay pronóstico de lluvia, protegemos el equipo con lonas y canalizamos los cables para evitar riesgos. El técnico monitorea las condiciones durante todo el evento." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Bocinas para Fiesta en Salón — $5,500", image: "/img/bocinas-fiestas/bocinas-eventos-cocktail-recepcion.avif", alt: "Bocinas para fiesta en salón de eventos", description: "4 JBL PRX + 2 subs + 2 micrófonos. Para salones de 80-200 personas. El más popular.", link: "/servicios/bocinas-fiestas/paquete-fiesta-salon/" },
  { title: "Audio para Eventos Masivos — $14,000", image: "/img/bocinas-fiestas/bocinas-grandes-eventos-masivos.avif", alt: "Audio para eventos masivos y conciertos", description: "Line array QSC KLA12 + delays + monitors. Para 400+ personas. Producción completa.", link: "/servicios/bocinas-fiestas/paquete-fiesta-masiva/" },
  { title: "Guirnaldas Edison", image: "/img/guirnaldas/guirnaldas-edison-hacienda-boda.avif", alt: "Guirnaldas Edison para jardines y bodas", description: "Bocinas + guirnaldas Edison = jardín de revista. El complemento visual perfecto para tu fiesta al aire libre.", link: "/servicios/guirnaldas/" },
  { title: "DJ para Fiestas", image: "/img/bocinas-djs/dj-para-fiestas-ambiente-festivo.avif", alt: "DJ profesional para fiestas al aire libre", description: "¿Necesitas DJ además del equipo de audio? Un DJ que arma la fiesta mientras el técnico maneja el sonido.", link: "/servicios/bocinas-djs/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Sonido y DJ", href: "/servicios/sonido/" },
    { label: "Bocinas para Fiestas", href: "/servicios/bocinas-fiestas/" },
    { label: "Paquete Fiesta en Jardín" }
  ]} />
</Fragment>

  <Hero
    title="Audio para Fiesta al Aire Libre — 4 JBL PRX825 + 4 Subs"
    subtitle="Desde $7,500 + IVA. Sonido que vence al viento y la dispersión. Jardines, haciendas, terrazas. 100-300 personas. CDMX."
    introParagraph1='Al aire libre, el sonido se va. No hay paredes que lo reflejen, el viento se lo lleva y los espacios abiertos absorben la potencia. Por eso una fiesta en jardín necesita el doble de equipo que una fiesta en salón. Este paquete trae 4 <strong>bocinas JBL PRX825</strong> — la versión reforzada para exteriores — y 4 subwoofers que compensan la dispersión natural del sonido al aire libre. El resultado: audio que se escucha igual a 5 metros que a 50 metros de las bocinas.'
    introParagraph2='Incluye 2 <strong>micrófonos Shure inalámbricos</strong>, mezcladora profesional y un técnico de audio que se queda toda la noche. Si el jardín o la hacienda tiene instalación eléctrica limitada, ofrecemos <strong>planta de luz opcional</strong> para garantizar que el equipo no se apague a media fiesta. Bodas en jardín, cumpleaños en hacienda, posadas al aire libre, fiestas de empresa en terraza — cubrimos jardines y espacios exteriores en toda la <strong>CDMX</strong> y Estado de México.'
  />

  <CtaBar
    headline="Compara paquetes de bocinas"
    items={[
      { label: "Fiesta Casa — $3,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-casa/", icon: "sonido" },
      { label: "Fiesta Salón — $5,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-salon/", icon: "sonido" },
      { label: "Fiesta Masiva — $14,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-masiva/", icon: "sonido" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Fiesta en Jardín"
      price="$7,500"
      priceNote="+ IVA · Planta de luz opcional"
      features={[
        { text: "4 bocinas JBL PRX825 para exteriores" },
        { text: "4 subwoofers JBL profesionales" },
        { text: "2 micrófonos Shure inalámbricos" },
        { text: "Mezcladora profesional" },
        { text: "Conexión Bluetooth + AUX + USB" },
        { text: "Planta de luz opcional" },
        { text: "Técnico de audio toda la noche" },
        { text: "Transporte + montaje + desmontaje" },
        { text: "Ideal: jardines 100-300 personas" },
        { text: "Cables protegidos para exteriores" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete Fiesta en Jardín — 4 bocinas JBL PRX825 + 4 subs para mi evento al aire libre."
      packages={[
        { label: "Fiesta Casa", price: "$3,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-casa/" },
        { label: "Fiesta Salón", price: "$5,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-salon/" },
        { label: "Fiesta Jardín", price: "$7,500", href: "/servicios/bocinas-fiestas/paquete-fiesta-jardin/", active: true },
        { label: "Fiesta Masiva", price: "$14,000", href: "/servicios/bocinas-fiestas/paquete-fiesta-masiva/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="Eventos ideales para este paquete"
          subtitle="Audio diseñado para vencer la dispersión del aire libre."
          paragraph1="Al aire libre, necesitas más potencia, más puntos de audio y más bajos para compensar lo que el viento y el espacio abierto se llevan. Las 4 JBL PRX825 se posicionan para crear un campo de sonido uniforme en todo el jardín."
          paragraph2="La planta de luz opcional resuelve el problema más común de las haciendas y jardines: instalación eléctrica insuficiente. Sin bajones de voltaje, sin apagones a media fiesta."
        />
        <FeatureGrid features={[
          { title: "Boda en Jardín o Hacienda", description: "Ceremonia con audio para los votos, coctel con música ambiental y fiesta con bajos que hacen temblar el pasto. Todo con el mismo equipo." },
          { title: "Cumpleaños en Jardín Grande", description: "200+ invitados en un jardín abierto. Las 4 PRX825 cubren todo el espacio — la mesa de regalos, la pista y las mesas del fondo." },
          { title: "Posada al Aire Libre", description: "Posada de empresa o familiar en jardín. Villancicos, rifa con micrófono y fiesta que se escucha hasta la entrada sin molestar al vecindario." },
          { title: "Fiesta en Terraza Rooftop", description: "Terrazas amplias donde el sonido se va al cielo. Las PRX825 direccionan el audio hacia abajo para mantener la potencia donde están los invitados." },
          { title: "Evento Corporativo en Hacienda", description: "Haciendas con poca corriente eléctrica y espacios enormes. Planta de luz + 4 bocinas + 4 subs = problema resuelto." },
          { title: "Fiesta de Fin de Año al Aire Libre", description: "Cuenta regresiva con micrófono, música para la cena y audio de fiesta para arrancar el año bailando. El técnico maneja la noche completa." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Cómo resolvemos el audio al aire libre"
          subtitle="El reto más grande del sonido en exteriores: que se escuche parejo."
          paragraph1="En un jardín, el sonido no rebota — se va. El viento lo desvía, el pasto lo absorbe y la distancia lo debilita. Por eso duplicamos los subwoofers respecto al paquete salón y usamos las PRX825 que tienen más proyección que las PRX estándar."
          paragraph2="El técnico posiciona cada bocina según la geometría de tu jardín. No es ponerlas al frente y subir el volumen — es crear un campo de sonido que cubra todo el espacio."
        />
        <FeatureGrid features={[
          { title: "4 Subs Compensan la Dispersión", description: "Al aire libre, los bajos se pierden primero. Con 4 subwoofers distribuidos, la música mantiene cuerpo y energía en todo el jardín." },
          { title: "PRX825 — Proyección Reforzada", description: "Las JBL PRX825 tienen más alcance que las PRX estándar. Diseñadas para proyectar sonido a distancia en espacios abiertos." },
          { title: "Planta de Luz Opcional", description: "Haciendas y jardines con corriente limitada no son problema. La planta garantiza voltaje estable para todo el equipo durante toda la noche." },
          { title: "Cables Protegidos para Exteriores", description: "Todos los cables van canalizados y protegidos con cubrecables para evitar tropezones y proteger la instalación de la humedad del jardín." },
          { title: "Posicionamiento Estratégico", description: "El técnico evalúa tu jardín y posiciona las bocinas para que el sonido cubra mesas, pista y áreas de coctel sin puntos muertos." },
          { title: "Técnico Monitorea Condiciones", description: "Viento, humedad, cambio de clima — el técnico ajusta el audio en tiempo real según las condiciones del evento." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen quienes nos contrataron"
          subtitle="4.9 estrellas en 54 reseñas."
          paragraph1="Cada reseña es de un cliente real que contrató el paquete Fiesta en Jardín."
          paragraph2="Pregunta por referencias de eventos similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Silvia Ramos", event: "Fiesta en Jardín — Xochimilco, 200 invitados", rating: 5, text: "El audio al aire libre fue espectacular. Las JBL PRX825 con 4 subs compensaron perfectamente la dispersión del jardín. Se escuchaba igual cerca y lejos de las bocinas." },
          { name: "Manuel Herrera", event: "Cumpleaños en Hacienda — Tlalpan, 250 invitados", rating: 5, text: "El técnico trajo planta de luz porque la hacienda tenía poca corriente. Las bocinas sonaron toda la noche sin interrupciones. Profesionalismo total." },
          { name: "Verónica Luna", event: "Posada Corporativa al Aire Libre — San Ángel, 180 invitados", rating: 5, text: "Posada corporativa al aire libre con 180 personas. El equipo cubrió todo el jardín. La música ambiental para la cena fue perfecta y la fiesta posterior sonó increíble." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Audio al aire libre — montajes reales en jardines"
        subtitle="Bodas, cumpleaños y eventos corporativos en jardines de CDMX."
        paragraph1="Cada foto es de un montaje real con nuestro equipo JBL PRX825 en jardines, haciendas y terrazas. Audio que vence la dispersión del aire libre y se escucha parejo en todo el espacio."
        paragraph2="¿Ya tienes el jardín reservado? Mándanos fotos y te explicamos cómo posicionamos las bocinas."
      />
      <Gallery4x4 images={[
        { src: "/img/bocinas-fiestas/bocinas-amplificadas-fiestas-jardines.avif", alt: "Bocinas amplificadas para fiestas en jardines" },
        { src: "/img/bocinas-fiestas/alquiler-parlantes-fiestas-roof-top.avif", alt: "Alquiler de parlantes para fiestas en rooftop" },
        { src: "/img/bocinas-fiestas/alquiler-altavoces-eventos-terraza.avif", alt: "Alquiler de altavoces para eventos en terraza" },
        { src: "/img/bocinas-fiestas/alquiler-bocinas-eventos-rusticos.avif", alt: "Alquiler de bocinas para eventos rústicos en jardín" },
        { src: "/img/bocinas-fiestas/alquiler-altavoces-fiestas-piscina.avif", alt: "Alquiler de altavoces para fiestas en piscina" },
        { src: "/img/bocinas-fiestas/bocinas-fiestas-ano-nuevo-celebracion.avif", alt: "Bocinas para fiesta de Año Nuevo al aire libre" },
        { src: "/img/bocinas-fiestas/alquiler-sonido-aniversarios-celebraciones.avif", alt: "Alquiler de sonido para aniversarios al aire libre" },
        { src: "/img/bocinas-fiestas/equipo-audio-celebraciones-especiales.avif", alt: "Equipo de audio para celebraciones al aire libre" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete Fiesta en Jardín"
        subtitle="Todo lo que necesitas saber antes de reservar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
        paragraph2="Si tu evento es para más de 300 personas, el paquete Fiesta Masiva incluye line array y delays."
      />
    </div>
    <FaqSection items={[
      { question: "¿El sonido al aire libre pierde potencia?", answer: "Sí, al aire libre el sonido se dispersa porque no hay paredes que lo reflejen. Por eso este paquete incluye 4 bocinas JBL PRX825 y 4 subwoofers — el doble de subs que el paquete salón — para compensar esa dispersión y mantener el audio potente en todo el jardín." },
      { question: "¿Qué pasa si el jardín no tiene suficiente corriente eléctrica?", answer: "Ofrecemos planta de luz como accesorio opcional. Muchas haciendas y jardines tienen instalación eléctrica limitada. La planta garantiza que el equipo funcione toda la noche sin interrupciones ni bajones de voltaje." },
      { question: "¿El equipo resiste lluvia o humedad?", answer: "Las bocinas JBL PRX825 son robustas y funcionan en exteriores sin problema. Si hay pronóstico de lluvia, protegemos el equipo con lonas y canalizamos los cables para evitar riesgos. El técnico monitorea las condiciones durante todo el evento." },
      { question: "¿Cómo posicionan las bocinas en un jardín?", answer: "El técnico evalúa la forma y tamaño de tu jardín el día del montaje. Las 4 bocinas se distribuyen para crear cobertura uniforme — no es ponerlas al frente y subir el volumen. Se busca que las mesas, la pista y las áreas de coctel reciban audio parejo." },
      { question: "¿Cuánto tarda el montaje al aire libre?", answer: "Entre 1 hora y 1.5 horas dependiendo del tamaño del jardín y la distancia entre los puntos de audio. Llegamos con tiempo suficiente para dejar todo montado, cableado, probado y ecualizado antes del evento." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes y Servicios"
        subtitle="¿Necesitas más potencia o complementar tu fiesta al aire libre?"
        paragraph1="Si tu evento es para más de 300 personas, el paquete Masivo trae line array con delays. Si es en salón cerrado, el paquete Salón es suficiente. Y para la decoración perfecta, las guirnaldas Edison son el complemento ideal en jardines."
        paragraph2="Armamos combos con descuento. Cuéntanos qué necesitas."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo el audio para tu fiesta al aire libre?</h2>
        <p>Mándanos fotos de tu jardín, la fecha y el número de invitados. Te cotizamos en minutos y te explicamos cómo distribuimos las bocinas en tu espacio.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza Gratis por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
