---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Renta de 1 Podium Acrílico para Conferencias — $1,500 + IVA | REDEIL";
const description = "Podium de acrílico transparente para conferencias y presentaciones. Entrega + instalación. $1,500 + IVA en CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/podiums/paquete-1-podium/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Renta de 1 Podium Acrílico para Conferencias",
    "description": "Podium de acrílico transparente de 10mm para conferencias pequeñas, presentaciones en sala de juntas y discursos individuales en CDMX. Incluye entrega, colocación, iluminación LED opcional y retiro.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/podiums/paquete-1-podium/",
      "priceCurrency": "MXN",
      "price": "1500",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "58",
      "reviewCount": "58"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Roberto Medina Torres" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Renté el podium para una conferencia de prensa en el WTC México. Llegó puntual, impecable y la iluminación LED azul le dio un toque muy profesional. El equipo lo colocó exactamente donde lo necesitábamos en el escenario."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Laura Castillo Vega" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Usamos el podium para una presentación ejecutiva en nuestra sala de juntas en Reforma. Se veía elegantísimo, transparente y moderno. La superficie soportó mi laptop sin problema. Muy recomendable para eventos íntimos."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Andrés Gutiérrez Ramos" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Contraté el podium para un discurso en una ceremonia institucional en el Centro Histórico. El acrílico de 10mm se ve muy sólido y profesional. La entrega fue puntual y el retiro al día siguiente sin complicaciones."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/podiums/conferencia-ejecutivo-podium-alto-iluminacion-profesional.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿El podium cabe en una sala de juntas pequeña?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestro podium de acrílico tiene dimensiones compactas que se adaptan a salas de juntas, oficinas ejecutivas y salones pequeños. No requiere espacio adicional para instalación — solo se coloca en el punto deseado y queda listo." }},
      { "@type": "Question", "name": "¿Puedo colocar una laptop sobre el podium?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. La superficie superior tiene espacio suficiente para laptop, tablet o documentos. Soporta hasta 15 kg y tiene un borde discreto antideslizante." }},
      { "@type": "Question", "name": "¿La iluminación LED está incluida en el precio?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. La iluminación LED en la base del podium es opcional y se incluye sin costo adicional. Solo solicítala al momento de reservar y elige el color: blanco, azul o tu color corporativo." }},
      { "@type": "Question", "name": "¿Incluyen micrófono con el podium?", "acceptedAnswer": { "@type": "Answer", "text": "No. El paquete de 1 podium incluye solo la estructura con entrega y retiro. Si necesitas micrófono o audio, lo cotizamos por separado o puedes optar por el paquete Escenario Completo que incluye audio." }},
      { "@type": "Question", "name": "¿Cuánto tiempo antes llegan a instalar?", "acceptedAnswer": { "@type": "Answer", "text": "Llegamos entre 1 y 2 horas antes del evento para colocar el podium, nivelarlo y verificar que todo esté perfecto. Si necesitas montaje más temprano, coordínalo con nosotros sin costo adicional." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "2 Podiums", image: "/img/podiums/conferencia-empresarial-podium-transparente-audiencia-profesional.avif", alt: "2 podiums de acrílico para mesa de honor en boda", description: "2 podiums para mesas de honor, bodas y galas con múltiples oradores. $2,500 + IVA.", link: "/servicios/podiums/paquete-2-podiums/" },
  { title: "Escenario Completo", image: "/img/podiums/conferencia-corporativa-podium-acrilico-auditorio-luces-azules.avif", alt: "Escenario completo con podiums y audio", description: "2 podiums + iluminación + audio profesional. La solución integral. $5,000 + IVA.", link: "/servicios/podiums/paquete-escenario-completo/" },
  { title: "Congreso", image: "/img/podiums/conferencia-masiva-podium-acrilico-pantallas-auditorio.avif", alt: "4 podiums para congreso en auditorio", description: "4+ podiums + staging + audio + iluminación + técnico para congresos. $8,500 + IVA.", link: "/servicios/podiums/paquete-congreso/" },
  { title: "PAR LED", image: "/img/par-led/renta-par-led-boda-salon-300w.avif", alt: "Iluminación PAR LED para escenarios", description: "Ilumina el escenario con PAR LED de colores. El complemento ideal para tu podium.", link: "/servicios/par-led/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Podiums", href: "/servicios/podiums/" },
    { label: "1 Podium" }
  ]} />
</Fragment>

  <Hero
    title="Renta de 1 Podium Acrílico para Conferencias"
    subtitle="Desde $1,500 + IVA. Entrega + colocación + retiro incluidos. Iluminación LED opcional."
    introParagraph1='El paquete de 1 podium de acrílico transparente es la opción ideal para conferencias íntimas, presentaciones ejecutivas en sala de juntas y discursos individuales. Un solo podium bien colocado transforma cualquier espacio en un escenario profesional — la transparencia del acrílico de <strong>10mm</strong> permite que la atención se centre completamente en el orador sin distracciones visuales. Perfecto para ruedas de prensa, juntas directivas y ceremonias institucionales.'
    introParagraph2='El servicio incluye entrega puntual en tu venue, colocación en el punto exacto del escenario, nivelación profesional y retiro al finalizar. Opcionalmente agregamos <strong>iluminación LED en la base</strong> del podium en color blanco, azul o tu color corporativo — sin costo adicional. La superficie soporta laptop, tablet y documentos. Cobertura en toda la <strong>CDMX y Estado de México</strong>.'
  />

  <CtaBar
    headline="¿Necesitas más podiums o servicios?"
    items={[
      { label: "2 Podiums — $2,500", href: "/servicios/podiums/paquete-2-podiums/", icon: "efectos" },
      { label: "Escenario — $5,000", href: "/servicios/podiums/paquete-escenario-completo/", icon: "efectos" },
      { label: "Congreso — $8,500", href: "/servicios/podiums/paquete-congreso/", icon: "efectos" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="1 Podium"
      price="$1,500"
      priceNote="+ IVA · Entrega incluida"
      features={[
        { text: "1 podium acrílico transparente 10mm" },
        { text: "Iluminación LED base opcional" },
        { text: "Superficie para laptop/tablet" },
        { text: "Soporta hasta 15 kg" },
        { text: "Entrega puntual en venue" },
        { text: "Colocación + nivelación" },
        { text: "Retiro al finalizar" },
        { text: "Cobertura CDMX y Edomex" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete de 1 podium acrílico para conferencia."
      packages={[
        { label: "1 Podium", price: "$1,500", href: "/servicios/podiums/paquete-1-podium/", active: true },
        { label: "2 Podiums", price: "$2,500", href: "/servicios/podiums/paquete-2-podiums/" },
        { label: "Escenario Completo", price: "$5,000", href: "/servicios/podiums/paquete-escenario-completo/" },
        { label: "Congreso", price: "$8,500", href: "/servicios/podiums/paquete-congreso/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="Perfecto para estos eventos"
          subtitle="1 podium cubre presentaciones individuales y conferencias íntimas."
          paragraph1="Este paquete está diseñado para eventos donde un solo orador necesita un atril profesional. La simplicidad del acrílico transparente se adapta a cualquier escenario — desde una sala de juntas ejecutiva hasta un auditorio corporativo."
          paragraph2="Si tu evento tiene múltiples oradores o necesitas audio, revisa nuestros paquetes de 2 podiums o Escenario Completo."
        />
        <FeatureGrid features={[
          { title: "Conferencias de Prensa", description: "Un podium profesional frente a cámaras y medios. El acrílico transparente luce impecable en video y fotografía." },
          { title: "Sala de Juntas", description: "Presentaciones ejecutivas en oficinas corporativas. El podium transforma cualquier sala en un espacio de presentación formal." },
          { title: "Discursos de Ceremonia", description: "Premiaciones, inauguraciones y ceremonias institucionales. Un solo podium es todo lo que necesitas para el orador principal." },
          { title: "Presentaciones Académicas", description: "Ponencias, tesis y conferencias en universidades. El podium aporta formalidad al evento académico." },
          { title: "Ruedas de Prensa", description: "El orador al frente con el podium transparente. Ideal para ruedas de prensa corporativas y gubernamentales." },
          { title: "Eventos Institucionales", description: "Inauguraciones, aniversarios y ceremonias oficiales donde un discurso formal lo requiere." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Acrílico transparente de 10mm: profesional y resistente"
          subtitle="El material que usan las mejores conferencias del mundo."
          paragraph1="Nuestros podiums de acrílico de 10mm de espesor ofrecen la combinación perfecta de elegancia y resistencia. El acabado cristalino permite ver a través del podium, centrando toda la atención en el orador. Se pulen a espejo antes de cada evento."
          paragraph2="La iluminación LED en la base es opcional y sin costo adicional — crea un efecto luminoso sutil que realza la presencia del podium en el escenario."
        />
        <FeatureGrid features={[
          { title: "Acrílico Cristalino 10mm", description: "Transparencia total con resistencia estructural. No se raya, no se empañe, no se quiebra con uso normal." },
          { title: "Acabado Pulido a Espejo", description: "Se limpia y pule antes de cada evento. Luce impecable frente a cámaras de foto y video." },
          { title: "LED Base Opcional", description: "Iluminación integrada en blanco, azul o color corporativo. Sin costo adicional al reservar." },
          { title: "Superficie Antideslizante", description: "Borde discreto que evita que laptop, documentos o tablet se deslicen durante el discurso." },
          { title: "Soporta hasta 15 kg", description: "Coloca laptop, tablet, documentos y micrófono de cuello de ganso sin preocupaciones." },
          { title: "Dimensiones Profesionales", description: "Altura y ancho estándar de conferencia. Se adapta a cualquier orador y escenario." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="5 estrellas en 58 reseñas."
          paragraph1="Cada reseña es de un cliente real que rentó el paquete de 1 podium para su conferencia o presentación."
          paragraph2="Pregunta por referencias de eventos similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Roberto Medina Torres", event: "Conferencia de prensa — WTC México", rating: 5, text: "El podium llegó puntual e impecable. La iluminación LED azul le dio un toque muy profesional al escenario. El equipo lo colocó exactamente donde lo necesitábamos. Totalmente recomendado para conferencias corporativas." },
          { name: "Laura Castillo Vega", event: "Presentación ejecutiva — Reforma", rating: 5, text: "Usamos el podium para una presentación en nuestra sala de juntas. Se veía elegantísimo — transparente, moderno y profesional. La superficie soportó mi laptop sin problema. Perfecto para eventos íntimos." },
          { name: "Andrés Gutiérrez Ramos", event: "Ceremonia institucional — Centro Histórico", rating: 5, text: "Contraté el podium para un discurso formal. El acrílico de 10mm se ve muy sólido y profesional. La entrega fue puntual y el retiro al día siguiente sin complicaciones. Servicio impecable." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Podium en conferencias reales"
        subtitle="1 podium de acrílico en salas de juntas, auditorios y escenarios de CDMX."
        paragraph1="Estas fotos son de eventos reales donde un solo podium fue suficiente para dar presencia profesional al escenario. Conferencias ejecutivas, discursos institucionales y presentaciones corporativas."
        paragraph2="¿Tu evento se parece a alguno de estos? Mándanos fotos del espacio y te asesoramos."
      />
      <Gallery4x4 images={[
        { src: "/img/podiums/conferencia-ejecutivo-podium-alto-iluminacion-profesional.avif", alt: "Ejecutivo en podium alto con iluminación profesional" },
        { src: "/img/podiums/conferencia-ejecutivo-podium-transparente-escenario-iluminado.avif", alt: "Ejecutivo en podium transparente sobre escenario iluminado" },
        { src: "/img/podiums/conferencia-ejecutivo-podium-transparente-graficos-financieros.avif", alt: "Ejecutivo presentando gráficos financieros desde podium" },
        { src: "/img/podiums/conferencia-mujer-podium-acrilico-tablet-presentacion.avif", alt: "Mujer usando tablet sobre podium de acrílico en presentación" },
        { src: "/img/podiums/conferencia-orador-microfono-podium-acrilico-escenario-azul.avif", alt: "Orador con micrófono en podium de acrílico" },
        { src: "/img/podiums/conferencia-podium-acrilico-alto-iluminacion-azul-cortinas.avif", alt: "Podium de acrílico con iluminación azul" },
        { src: "/img/podiums/presentacion-corporativa-podium-acrilico-graficos-audiencia.avif", alt: "Presentación corporativa con podium de acrílico" },
        { src: "/img/podiums/presentacion-ejecutivo-podium-acrilico-graficos-pantalla-azul.avif", alt: "Ejecutivo en podium con pantalla azul de gráficos" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el paquete de 1 Podium"
        subtitle="Todo lo que necesitas saber antes de reservar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
        paragraph2="Te asesoramos gratis sobre si 1 podium es suficiente para tu evento."
      />
    </div>
    <FaqSection items={[
      { question: "¿El podium cabe en una sala de juntas pequeña?", answer: "Sí. Nuestro podium de acrílico tiene dimensiones compactas que se adaptan a salas de juntas, oficinas ejecutivas y salones pequeños. No requiere espacio adicional para instalación — solo se coloca en el punto deseado y queda listo en minutos." },
      { question: "¿Puedo colocar una laptop sobre el podium?", answer: "Sí. La superficie superior tiene espacio suficiente para laptop, tablet o documentos. Soporta hasta 15 kg y tiene un borde discreto antideslizante que evita que los objetos se deslicen durante la presentación." },
      { question: "¿La iluminación LED está incluida en el precio?", answer: "Sí. La iluminación LED en la base del podium es opcional y se incluye sin costo adicional en los $1,500 + IVA. Solo solicítala al momento de reservar y elige el color: blanco, azul o tu color corporativo." },
      { question: "¿Incluyen micrófono con el podium?", answer: "No. El paquete de 1 podium incluye solo la estructura con entrega, colocación y retiro. Si necesitas micrófono o audio, lo cotizamos por separado. El paquete Escenario Completo ($5,000 + IVA) incluye podiums + audio + iluminación." },
      { question: "¿Cuánto tiempo antes llegan a instalar?", answer: "Llegamos entre 1 y 2 horas antes del evento para colocar el podium, nivelarlo y verificar que todo esté perfecto. Si necesitas montaje más temprano — por ejemplo para pruebas de sonido o cámaras — lo coordinamos sin costo adicional." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes y Servicios"
        subtitle="¿Necesitas más podiums o complementos para tu escenario?"
        paragraph1="Si tu evento tiene múltiples oradores o necesitas audio e iluminación, revisa nuestros paquetes más completos. Y si solo quieres agregar luces al escenario, el PAR LED es el complemento ideal."
        paragraph2="Armamos propuestas integrales con precio especial cuando combinas servicios."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para reservar tu podium de acrílico?</h2>
        <p>Mándanos la fecha, el venue y el tipo de conferencia. Te confirmamos disponibilidad y enviamos cotización en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Reservar — Cotiza Gratis</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
