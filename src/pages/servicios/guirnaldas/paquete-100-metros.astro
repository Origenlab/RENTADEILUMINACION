---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Paquete 100m Guirnaldas Edison — $6,500 + IVA | REDEIL";
const description = "100 metros de guirnaldas Edison para bodas en jardín y hacienda. Cubre ceremonia + recepción hasta 120 invitados. Instalación profesional IP65. El más pedido.";
const canonical = "https://rentadeiluminacion.com/servicios/guirnaldas/paquete-100-metros/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org", "@type": "Product",
    "name": "Paquete 100 Metros — Guirnaldas Edison para Bodas",
    "description": "Renta de 100 metros de guirnaldas con focos Edison para bodas en jardín y hacienda en CDMX. Cubre ceremonia y recepción para hasta 120 invitados.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "image": "https://rentadeiluminacion.com/img/guirnaldas/renta-guirnaldas-boda-hacienda-mexicana-guirnaldas-18.avif",
    "offers": { "@type": "Offer", "url": canonical, "priceCurrency": "MXN", "price": "6500", "priceValidUntil": "2027-12-31", "availability": "https://schema.org/InStock" },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5", "bestRating": "5", "ratingCount": "89", "reviewCount": "89" },
    "review": [
      { "@type": "Review", "author": { "@type": "Person", "name": "Daniela Herrera" }, "datePublished": "2026-02-22", "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "Contratamos los 100 metros para nuestra boda en una hacienda en Tlalpan. Cubrieron toda la ceremonia y la recepción. Las fotos quedaron de revista. El equipo llegó temprano y fue muy profesional." },
      { "@type": "Review", "author": { "@type": "Person", "name": "Roberto Sánchez" }, "datePublished": "2026-01-15", "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "Iluminaron todo el jardín para nuestra boda. El ambiente que crearon con las guirnaldas fue exactamente lo que imaginamos. Los invitados no paraban de tomar fotos. Muy recomendados." },
      { "@type": "Review", "author": { "@type": "Person", "name": "Fernanda López" }, "datePublished": "2025-11-28", "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "El paquete de 100 metros fue perfecto para nuestro jardín en Coyoacán. La coordinación con nuestra wedding planner fue impecable. El precio es justo por todo lo que incluye." }
    ]
  },
  {
    "@context": "https://schema.org", "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿100 metros alcanzan para ceremonia y recepción?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. 100 metros cubren perfectamente el área de ceremonia + la zona de recepción/cena para hasta 120 invitados en un jardín o hacienda promedio." }},
      { "@type": "Question", "name": "¿Se puede dividir en dos zonas separadas?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestro equipo diseña la distribución para cubrir múltiples áreas — por ejemplo, 40 metros en la ceremonia y 60 en la recepción." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Básico — 50m", image: "/img/guirnaldas/renta-guirnaldas-ceremonia-boda-pergola-focos-edison-15.avif", alt: "50 metros para ceremonia íntima", description: "Para terrazas y ceremonias íntimas de hasta 50 invitados. $3,500 + IVA.", link: "/servicios/guirnaldas/paquete-50-metros/" },
  { title: "Premium — 200m", image: "/img/guirnaldas/renta-guirnaldas-boda-patio-colonial-guirnaldas-21.avif", alt: "200 metros para evento grande", description: "Para haciendas grandes y eventos corporativos con 200+ invitados. $11,500 + IVA.", link: "/servicios/guirnaldas/paquete-200-metros/" },
  { title: "Producción — 500m", image: "/img/guirnaldas/renta-guirnaldas-baile-novios-hacienda-guirnaldas-41.avif", alt: "500 metros para festival", description: "Festivales, ferias y venues de gran escala. Producción completa. $24,000 + IVA.", link: "/servicios/guirnaldas/paquete-500-metros/" },
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Humo bajo para vals de boda", description: "El complemento más pedido para bodas. La nube mágica para el vals. Combínalo con guirnaldas.", link: "/servicios/humo-bajo/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Iluminación", href: "/servicios/iluminacion/" },
    { label: "Guirnaldas", href: "/servicios/guirnaldas/" },
    { label: "Paquete 100 metros" }
  ]} />
</Fragment>

    <Hero
      title="Paquete 100 Metros — Guirnaldas Edison para Bodas"
      subtitle="$6,500 + IVA. El más pedido para bodas en jardín. Ceremonia + recepción hasta 120 invitados."
      introParagraph1='El paquete de 100 metros es nuestra opción más popular para bodas en la Ciudad de México. Con esta cantidad de guirnaldas cubres el área de ceremonia y la zona de recepción completa — creando un ambiente cálido y continuo que conecta cada momento de tu celebración con luz vintage.'
      introParagraph2='Incluye focos Edison (LED o vintage a tu elección), cableado IP65 resistente a lluvia, transporte, montaje profesional y desmontaje. Nuestro equipo trabaja con tu wedding planner o decorador para integrar las luces al concepto de tu boda. Más de 300 bodas iluminadas en jardines, haciendas y fincas de CDMX y Estado de México.'
    />


    <!-- Contenido + Sidebar -->
    <section class="services-section">
      <ContentWithSidebar
        sidebarTitle="Paquete Estándar"
        price="$6,500"
        priceNote="+ IVA · El más popular"
        features={[
          { text: "100 metros lineales" },
          { text: "Focos Edison LED o vintage" },
          { text: "Certificación IP65 lluvia" },
          { text: "Transporte + montaje + desmontaje" },
          { text: "Diseño personalizado" },
          { text: "Asesoría de distribución" },
          { text: "Coordinación con wedding planner" },
          { text: "Tonos: cálido, ámbar, blanco" },
          { text: "Cubre ceremonia + recepción" },
          { text: "Hasta 120 invitados" },
        ]}
        waMessage="Hola REDEIL, quiero cotizar el paquete de 100 metros de guirnaldas para mi boda."
        packages={[
          { label: "50 metros", price: "$3,500", href: "/servicios/guirnaldas/paquete-50-metros/" },
          { label: "100 metros", price: "$6,500", href: "/servicios/guirnaldas/paquete-100-metros/", active: true },
          { label: "200 metros", price: "$11,500", href: "/servicios/guirnaldas/paquete-200-metros/" },
          { label: "500 metros", price: "$24,000", href: "/servicios/guirnaldas/paquete-500-metros/" },
        ]}
      >
        <div class="container">
          <SectionHeader
            title="Diseñado para bodas completas"
            subtitle="Ceremonia + recepción en un solo montaje continuo."
            paragraph1="100 metros te dan para crear un ambiente luminoso que acompaña a tus invitados desde la ceremonia hasta el último baile. La transición entre zonas se siente natural — no hay un 'aquí se acabaron las luces'."
            paragraph2="Nuestro equipo distribuye los metros según la geometría de tu venue para maximizar el impacto visual sin desperdiciar cable."
          />
          <FeatureGrid features={[
            { title: "Jardines de boda", description: "Distribución entre árboles, postes y estructuras naturales del jardín. Cobertura completa para 80-120 invitados." },
            { title: "Haciendas y fincas", description: "Iluminación de corredores, patios y áreas de recepción. Las guirnaldas resaltan la arquitectura colonial." },
            { title: "Ceremonia + recepción", description: "40-50 metros para el área de ceremonia y 50-60 para la recepción. Diseño integrado en un solo montaje." },
            { title: "Mesas imperiales", description: "Dosel colgante sobre mesas largas para cenas elegantes. Efecto espectacular para 60-80 comensales." },
            { title: "Carpas y toldos", description: "Distribución perimetral e interior en carpas. Las guirnaldas calientan visualmente el espacio." },
            { title: "Pistas de baile", description: "Marco luminoso alrededor de la pista. Crea el escenario perfecto para el vals y la fiesta." },
          ]} columns={2} />
        </div>

        <div class="container" style="margin-top: 3rem;">
          <SectionHeader
            title="Lo que diferencia este paquete"
            subtitle="No solo luces — asesoría y coordinación incluida."
            paragraph1="A diferencia del paquete básico, los 100 metros incluyen asesoría personalizada de distribución. Nuestro equipo puede visitar tu venue antes del evento o trabajar con planos y fotos para diseñar el montaje ideal."
            paragraph2="También nos coordinamos directamente con tu wedding planner o decorador para que las guirnaldas se integren al concepto general de la boda — colores, flores, mobiliario, todo armonizado."
          />
        </div>

        <div class="container" style="margin-top: 3rem;">
          <SectionHeader
            title="Reseñas de bodas con 100 metros"
            subtitle="⭐⭐⭐⭐⭐ 89 reseñas verificadas."
            paragraph1="Novias y novios que eligieron este paquete para su boda en CDMX y Estado de México."
            paragraph2="Las fotos bajo guirnaldas son las más compartidas en Instagram de cada boda que iluminamos."
          />
          <TestimonialCards testimonials={[
            { name: "Daniela Herrera", event: "Boda en hacienda — Tlalpan", rating: 5, text: "Cubrieron toda la ceremonia y la recepción en la hacienda. Las fotos quedaron de revista. El equipo llegó temprano y fue muy profesional. No cambiaríamos nada." },
            { name: "Roberto Sánchez", event: "Boda en jardín — Coyoacán", rating: 5, text: "Iluminaron todo el jardín para nuestra boda. El ambiente que crearon fue exactamente lo que imaginamos. Los invitados no paraban de tomar fotos." },
            { name: "Fernanda López", event: "Boda al aire libre — Huixquilucan", rating: 5, text: "La coordinación con nuestra wedding planner fue impecable. Las guirnaldas se integraron perfecto con la decoración floral. El precio es justo por todo lo que incluye." },
          ]} />
        </div>
      </ContentWithSidebar>
    </section>

    <!-- Galería -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Bodas iluminadas con 100 metros"
          subtitle="Jardines, haciendas y fincas en CDMX."
          paragraph1="Cada foto es de una boda real donde montamos nuestro paquete de 100 metros. El resultado habla por sí solo."
          paragraph2="¿Tu venue se parece? Mándanos fotos por WhatsApp y te mostramos cómo quedarían las guirnaldas."
        />
        <Gallery4x4 images={[
          { src: "/img/guirnaldas/renta-guirnaldas-boda-hacienda-mexicana-guirnaldas-18.avif", alt: "Boda en hacienda mexicana con 100 metros de guirnaldas" },
          { src: "/img/guirnaldas/renta-guirnaldas-baile-novios-hacienda-guirnaldas-41.avif", alt: "Baile de novios en hacienda bajo guirnaldas Edison" },
          { src: "/img/guirnaldas/renta-guirnaldas-boda-patio-colonial-guirnaldas-21.avif", alt: "Patio colonial de hacienda iluminado con guirnaldas vintage" },
          { src: "/img/guirnaldas/renta-guirnaldas-brindis-boda-guirnaldas-hacienda-43.avif", alt: "Brindis de boda en hacienda bajo guirnaldas cálidas" },
          { src: "/img/guirnaldas/renta-guirnaldas-boda-jardin-ceremonia-guirnaldas-05.avif", alt: "Ceremonia de boda en jardín con guirnaldas Edison" },
          { src: "/img/guirnaldas/renta-guirnaldas-pareja-novios-guirnaldas-boda-32.avif", alt: "Novios bajo guirnaldas en recepción de boda" },
          { src: "/img/guirnaldas/renta-guirnaldas-brindis-boda-novios-guirnaldas-emocion-42.avif", alt: "Momento emotivo de brindis bajo guirnaldas" },
          { src: "/img/guirnaldas/renta-guirnaldas-baile-novios-recepcion-08.avif", alt: "Recepción de boda iluminada con guirnaldas vintage" },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre el Paquete 100 Metros"
          subtitle="Todo lo que necesitas saber para tu boda."
          paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
          paragraph2="Cada boda es diferente — te asesoramos gratis sobre la distribución ideal."
        />
      </div>
      <FaqSection items={[
        { question: "¿100 metros alcanzan para ceremonia y recepción?", answer: "Sí. 100 metros cubren perfectamente ceremonia + recepción para hasta 120 invitados en un jardín o hacienda promedio. Distribuimos 40-50m en ceremonia y 50-60m en recepción, adaptándonos a tu espacio." },
        { question: "¿Se puede dividir en dos zonas separadas?", answer: "Sí. Nuestro equipo diseña la distribución para cubrir múltiples áreas. Podemos iluminar la ceremonia, el cocktail y la recepción como tres zonas independientes conectadas visualmente." },
        { question: "¿Se coordinan con mi wedding planner?", answer: "Sí. Nos comunicamos directamente con tu planner o decorador para integrar las guirnaldas al concepto general — colores, flores, mobiliario. Llevamos más de 300 bodas coordinadas." },
        { question: "¿Cuándo llegan a instalar?", answer: "Llegamos 3-4 horas antes del evento para un montaje de 100 metros. Si tu venue permite acceso el día anterior, podemos montar con más calma y hacer pruebas de iluminación." },
        { question: "¿Puedo agregar uplighting o seguidor al paquete?", answer: "Claro. La combinación más pedida es guirnaldas + uplighting en fachada + seguidor para el vals. Armamos paquetes combinados con precio especial." },
        { question: "¿Funciona bajo lluvia?", answer: "Sí. Certificación IP65 — resistente a lluvia y humedad. Hemos montado en temporada de lluvias sin problema. Todo el cableado está protegido." },
      ]} />
    </section>

    <!-- Otros paquetes -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Otros Paquetes y Complementos"
          subtitle="Compara opciones o agrega servicios a tu boda."
          paragraph1="Si necesitas menos o más metros, tenemos opciones para cada tamaño de evento. Y si quieres la experiencia completa, combinamos guirnaldas con otros servicios."
          paragraph2="Cotiza sin compromiso — armamos propuestas integrales con precio especial."
        />
        <div class="services-grid">
          {otrosPaquetes.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Listo para iluminar tu boda con 100 metros de guirnaldas?</h2>
          <p>Mándanos la fecha, el venue y cuántos invitados esperas. Te confirmamos disponibilidad y armamos tu propuesta en minutos.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza tu Boda</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
