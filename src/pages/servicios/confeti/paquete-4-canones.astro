---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "4 Cañones de Confeti para Bodas y XV Años — $3,500 + IVA | REDEIL";
const description = "4 cañones de confeti CO₂ para bodas y XV años. Múltiples disparos + colores a elegir. $3,500 + IVA en CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/confeti/paquete-4-canones/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "4 Cañones de Confeti para Bodas y XV Años",
    "description": "4 cañones de confeti profesionales de CO₂ con múltiples disparos para bodas y XV años. Colores a elegir, operador incluido, coordinación con fotógrafo y DJ. Transporte, montaje y desmontaje en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/confeti/paquete-4-canones/",
      "priceCurrency": "MXN",
      "price": "3500",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "67",
      "reviewCount": "67"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Carolina Villarreal" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Contratamos los 4 cañones para la boda de mi hija en Hacienda de los Morales. Hubo explosión de confeti dorado en el vals y confeti blanco en el brindis — los dos momentos fueron increíbles. El fotógrafo quedó encantado con las fotos."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Luis Ángel Moreno" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Usamos los 4 cañones para los XV años de mi hija en un salón de Satélite. Confeti rosa en el vals con el papá y multicolor en la hora loca. La quinceañera estaba feliz — fue el momento más emotivo de la fiesta."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Mariana Torres" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Renté los 4 cañones para nuestra boda en un jardín de Xochimilco. El operador fue muy profesional — posicionó los cañones perfectamente y cada disparo cubrió toda la pista. Tres momentos distintos con tres colores distintos. Superó nuestras expectativas."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/maquina-de-papelitos/confeti-dorado-xv-anos-vals-quinceañera.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Cuántos disparos incluye el paquete de 4 cañones?", "acceptedAnswer": { "@type": "Answer", "text": "El paquete incluye múltiples disparos — típicamente 2-3 momentos distintos durante el evento. Los 4 cañones se recargan entre disparos. Para bodas, lo más común es: vals de novios, brindis y hora loca. Para XV años: vals con el papá, vals con chambelanes y baile sorpresa." }},
      { "@type": "Question", "name": "¿Puedo elegir colores diferentes para cada momento?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Cada disparo puede tener un color distinto. Por ejemplo: dorado para el vals, blanco para el brindis y multicolor para la hora loca. Tenemos dorado, plateado, blanco, rosa, azul, rojo, multicolor, corazones, estrellas y círculos." }},
      { "@type": "Question", "name": "¿Los 4 cañones disparan al mismo tiempo?", "acceptedAnswer": { "@type": "Answer", "text": "Depende del efecto que quieras. Pueden disparar los 4 simultáneamente para una explosión masiva, o en secuencia (2+2) para un efecto tipo cascada. El operador programa el disparo según lo que funcione mejor para tu pista de baile." }},
      { "@type": "Question", "name": "¿Funciona para XV años con coreografía?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El operador se coordina con el coreógrafo para que el confeti explote en el momento clave de la coreografía. Es uno de los usos más populares — la explosión de confeti cuando la quinceañera hace el paso final es icónica." }},
      { "@type": "Question", "name": "¿Qué área cubren los 4 cañones?", "acceptedAnswer": { "@type": "Answer", "text": "4 cañones de CO₂ cubren una pista de baile de hasta 150m². Para bodas de 100-200 invitados y XV años con pista de baile amplia, es la cobertura ideal. Si tu evento es más grande, el paquete de producción con 8+ cañones cubre áreas mayores." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "2 Cañones de Confeti", image: "/img/maquina-de-papelitos/confeti-dorado-primer-baile-novios-romantico.avif", alt: "2 cañones de confeti en primer baile de novios", description: "Un disparo perfecto para el vals o entrada. 2 cañones CO₂ + operador. $2,000 + IVA.", link: "/servicios/confeti/paquete-2-canones/" },
  { title: "Confeti Biodegradable", image: "/img/maquina-de-papelitos/confeti-rosa-boda-jardin-atardecer-novios.avif", alt: "Confeti biodegradable en boda de jardín", description: "Se disuelve con agua. Ideal para jardines y haciendas. 3 máquinas + operador. $5,500 + IVA.", link: "/servicios/confeti/paquete-confeti-biodegradable/" },
  { title: "Producción Masiva", image: "/img/maquina-de-papelitos/explosion-confeti-concierto-multitud-luces.avif", alt: "Confeti profesional en concierto masivo", description: "8+ cañones para conciertos y festivales. Alcance 15m. $9,000 + IVA.", link: "/servicios/confeti/paquete-produccion/" },
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Efecto nubes en piso para boda en jardín", description: "Confeti + niebla baja para el vals. Los dos efectos más fotografiados de una boda.", link: "/servicios/humo-bajo/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Confeti y Papelitos", href: "/servicios/confeti/" },
    { label: "4 Cañones" }
  ]} />
</Fragment>

  <Hero
    title="4 Cañones de Confeti para Bodas y XV Años"
    subtitle="Desde $3,500 + IVA. Múltiples disparos + colores a elegir. Operador incluido."
    introParagraph1='Cuatro cañones de confeti profesionales de CO₂ estratégicamente posicionados para crear múltiples explosiones en los momentos clave de tu evento. Este es el paquete más solicitado para <strong>bodas y XV años</strong> porque permite cubrir varios momentos — vals, brindis, hora loca — cada uno con su propio color de confeti. En <strong>REDEIL</strong> operamos cañones de confeti profesionales con alcance de hasta 10 metros de altura y cobertura de pistas de hasta 150m².'
    introParagraph2='Cada disparo puede tener un color diferente: <strong>dorado para el vals, blanco para el brindis, multicolor para la hora loca</strong>. El operador recarga los cañones entre momentos y coordina el timing exacto con tu fotógrafo, DJ y maestro de ceremonias. Para XV años, los momentos más populares son el vals con el papá, el cambio de zapatos y el baile sorpresa con chambelanes. Los 4 cañones disparan simultáneamente o en secuencia según el efecto deseado. Servicio completo en toda la <strong>CDMX y Estado de México</strong>.'
  />

  <CtaBar
    headline="¿Necesitas más o menos cañones?"
    items={[
      { label: "2 Cañones — $2,000", href: "/servicios/confeti/paquete-2-canones/", icon: "efectos" },
      { label: "Biodegradable — $5,500", href: "/servicios/confeti/paquete-confeti-biodegradable/", icon: "efectos" },
      { label: "Producción — $9,000", href: "/servicios/confeti/paquete-produccion/", icon: "efectos" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <!-- Contenido principal + Sidebar sticky -->
  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="4 Cañones de Confeti"
      price="$3,500"
      priceNote="+ IVA · Operador incluido"
      badge="Más popular"
      features={[
        { text: "4 cañones de confeti CO₂" },
        { text: "Múltiples disparos incluidos" },
        { text: "Colores diferentes por momento" },
        { text: "Operador técnico incluido" },
        { text: "Coordinación con fotógrafo/DJ/MC" },
        { text: "Transporte ida y vuelta" },
        { text: "Montaje y desmontaje" },
        { text: "Recarga entre disparos" },
        { text: "Pista de baile hasta 150m²" },
        { text: "Cobertura CDMX y Edomex" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete de 4 cañones de confeti para mi boda/XV años."
      packages={[
        { label: "2 Cañones", price: "$2,000", href: "/servicios/confeti/paquete-2-canones/" },
        { label: "4 Cañones", price: "$3,500", href: "/servicios/confeti/paquete-4-canones/", active: true },
        { label: "Biodegradable", price: "$5,500", href: "/servicios/confeti/paquete-confeti-biodegradable/" },
        { label: "Producción", price: "$9,000", href: "/servicios/confeti/paquete-produccion/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="Perfecto para estos eventos"
          subtitle="4 cañones cubren pistas de baile de hasta 150m² con múltiples disparos."
          paragraph1="Este paquete está diseñado para bodas y XV años donde quieres confeti en varios momentos de la noche. Los 4 cañones se recargan entre disparos para que cada momento tenga su propia explosión con el color que elijas."
          paragraph2="Nuestro operador se coordina con el DJ, el fotógrafo y el MC para que cada disparo suceda en el segundo exacto — sin sorpresas ni retrasos."
        />
        <FeatureGrid features={[
          { title: "Bodas Completas", description: "Vals, brindis y hora loca — tres momentos con tres explosiones de confeti en colores distintos." },
          { title: "XV Años", description: "Vals con papá, cambio de zapatos y baile sorpresa. Confeti rosa para la quinceañera." },
          { title: "Recepciones Grandes", description: "Salones para 100-200 invitados. Los 4 cañones cubren toda la pista de baile." },
          { title: "Bodas en Salón", description: "Posicionamiento estratégico en las esquinas de la pista para cobertura completa." },
          { title: "Eventos Corporativos", description: "Lanzamientos, premiaciones y galas. Confeti dorado en el momento cumbre." },
          { title: "Fiestas de Graduación", description: "La explosión de confeti cuando suenan los diplomas. Momento épico para las fotos grupales." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Múltiples momentos, múltiples colores"
          subtitle="Cada disparo puede ser de un color diferente."
          paragraph1="La magia de tener 4 cañones es la versatilidad. El operador recarga entre momentos para que puedas tener dorado en el vals, blanco en la salida de la iglesia y multicolor en la hora loca. Cada momento tiene su propia identidad visual."
          paragraph2="Para XV años, lo más popular es rosa en el vals con papá, plateado en el cambio de zapatos y multicolor en el baile sorpresa. Tenemos todos los colores y formas: corazones, estrellas, círculos y confeti rectangular."
        />
        <FeatureGrid features={[
          { title: "Dorado — Elegante", description: "El color más popular para bodas. Confeti metálico que brilla con las luces del salón." },
          { title: "Blanco — Clásico", description: "Puro y elegante. Ideal para la salida de la iglesia y momentos solemnes." },
          { title: "Rosa — Quinceañera", description: "El favorito para XV años y gender reveals. Combinado con corazones es perfecto." },
          { title: "Multicolor — Fiesta", description: "Para la hora loca y los momentos de máxima energía. Explosión total de colores." },
          { title: "Corazones y Estrellas", description: "Formas especiales que agregan un toque único. Los corazones son icónicos para bodas." },
          { title: "Colores Personalizados", description: "¿Necesitas un color que combine con tu decoración? Consúltanos con anticipación." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="5 estrellas en 67 reseñas."
          paragraph1="Cada reseña es de un cliente real que contrató el paquete de 4 cañones de confeti."
          paragraph2="Pregunta por referencias de eventos similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Carolina Villarreal", event: "Boda — Hacienda de los Morales", rating: 5, text: "Hubo explosión de confeti dorado en el vals y confeti blanco en el brindis — los dos momentos fueron increíbles. El fotógrafo quedó encantado con las fotos que capturó." },
          { name: "Luis Ángel Moreno", event: "XV Años — Satélite", rating: 5, text: "Confeti rosa en el vals con el papá y multicolor en la hora loca. La quinceañera estaba feliz — fue el momento más emotivo de la fiesta. Totalmente recomendado." },
          { name: "Mariana Torres", event: "Boda en jardín — Xochimilco", rating: 5, text: "El operador posicionó los cañones perfectamente y cada disparo cubrió toda la pista. Tres momentos distintos con tres colores distintos. Superó nuestras expectativas." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <!-- Galería -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="4 cañones de confeti en bodas y XV años"
        subtitle="Múltiples momentos, múltiples colores — cada evento tiene su historia."
        paragraph1="Cada foto es de un evento real con cañones de confeti profesionales. Bodas en hacienda, XV años en salón, recepciones al aire libre — los 4 cañones cubren toda la pista y permiten varios disparos durante la noche."
        paragraph2="¿Tu venue se parece a alguno de estos? Mándanos fotos por WhatsApp y te decimos cómo posicionamos los cañones."
      />
      <Gallery4x4 images={[
        { src: "/img/maquina-de-papelitos/confeti-dorado-xv-anos-vals-quinceañera.avif", alt: "Confeti dorado en vals de quinceañera" },
        { src: "/img/maquina-de-papelitos/maquina-confeti-xv-anos-baile-padre-quinceañera.avif", alt: "Máquina de confeti en baile de padre con quinceañera" },
        { src: "/img/maquina-de-papelitos/lluvia-confeti-corazones-xv-anos-vestido-rosa.avif", alt: "Lluvia de confeti corazones en XV años con vestido rosa" },
        { src: "/img/maquina-de-papelitos/confeti-dorado-primer-baile-novios-romantico.avif", alt: "Confeti dorado en primer baile de novios" },
        { src: "/img/maquina-de-papelitos/explosion-confeti-blanco-boda-pista-baile.avif", alt: "Explosión de confeti blanco en pista de baile de boda" },
        { src: "/img/maquina-de-papelitos/lluvia-confeti-boda-candelier-chispas-frias.avif", alt: "Lluvia de confeti con candelier y chispas frías en boda" },
        { src: "/img/confeti/confeti-dorado-boda-novios-fiesta.avif", alt: "Confeti dorado en boda de novios fiesta" },
        { src: "/img/maquina-de-papelitos/confeti-rosa-boda-jardin-atardecer-novios.avif", alt: "Confeti rosa en boda de jardín al atardecer" },
      ]} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete de 4 Cañones"
        subtitle="Todo lo que necesitas saber antes de reservar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
        paragraph2="Cada evento es diferente — te asesoramos gratis sobre colores y momentos ideales para tu celebración."
      />
    </div>
    <FaqSection items={[
      { question: "¿Cuántos disparos incluye el paquete de 4 cañones?", answer: "El paquete incluye múltiples disparos — típicamente 2-3 momentos distintos durante el evento. Los 4 cañones se recargan entre disparos. Para bodas, lo más común es: vals de novios, brindis y hora loca. Para XV años: vals con el papá, vals con chambelanes y baile sorpresa." },
      { question: "¿Puedo elegir colores diferentes para cada momento?", answer: "Sí. Cada disparo puede tener un color distinto. Por ejemplo: dorado para el vals, blanco para el brindis y multicolor para la hora loca. Tenemos dorado, plateado, blanco, rosa, azul, rojo, multicolor, corazones, estrellas y círculos." },
      { question: "¿Los 4 cañones disparan al mismo tiempo?", answer: "Depende del efecto que quieras. Pueden disparar los 4 simultáneamente para una explosión masiva, o en secuencia (2+2) para un efecto tipo cascada. El operador programa el disparo según lo que funcione mejor para tu pista de baile y el momento del evento." },
      { question: "¿Funciona para XV años con coreografía?", answer: "Sí. El operador se coordina con el coreógrafo para que el confeti explote en el momento clave de la coreografía. Es uno de los usos más populares — la explosión de confeti cuando la quinceañera hace el paso final es icónica." },
      { question: "¿Qué área cubren los 4 cañones?", answer: "4 cañones de CO₂ cubren una pista de baile de hasta 150m². Para bodas de 100-200 invitados y XV años con pista de baile amplia, es la cobertura ideal. Si tu evento es más grande, el paquete de producción con 8+ cañones cubre áreas mayores ($9,000 + IVA)." },
      { question: "¿Con cuánta anticipación debo reservar?", answer: "Idealmente 2-3 semanas antes. En temporada alta (noviembre-enero y mayo-junio) las fechas se llenan rápido. Entre antes reserves, mejor — así garantizamos disponibilidad y podemos coordinar con tu equipo de producción." },
    ]} />
  </section>

  <!-- Otros paquetes -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes de Confeti"
        subtitle="¿Necesitas más o menos cañones?"
        paragraph1="Desde un disparo único para el vals hasta producción masiva para conciertos. Cada paquete incluye operador, transporte y montaje."
        paragraph2="Armamos propuestas integrales con precio especial cuando combinas servicios."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para llenar de confeti tu boda o XV años?</h2>
        <p>Cuéntanos cuántos momentos quieres con confeti y qué colores combinan con tu evento. Te cotizamos en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
