---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Confeti Biodegradable para Eventos al Aire Libre — $5,500 + IVA | REDEIL";
const description = "Confeti biodegradable para jardines y haciendas. Se disuelve con agua. 3 máquinas + operador. $5,500 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/confeti/paquete-confeti-biodegradable/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Confeti Biodegradable para Eventos al Aire Libre",
    "description": "Confeti biodegradable de papel que se disuelve con agua para bodas en jardines, haciendas y eventos outdoor. 3 máquinas de CO₂, múltiples disparos, operador incluido. Transporte, montaje y desmontaje en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/confeti/paquete-confeti-biodegradable/",
      "priceCurrency": "MXN",
      "price": "5500",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "43",
      "reviewCount": "43"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Gabriela Navarro" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Nos casamos en una hacienda en Tepotzotlán y el venue nos exigía confeti biodegradable. REDEIL lo tenía sin problema — las 3 máquinas cubrieron todo el jardín y al día siguiente con el riego matutino ya no había rastro de confeti. El efecto visual fue igual de espectacular."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Daniel Ochoa" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Evento corporativo al aire libre en un jardín de Santa Fe. El confeti biodegradable fue requisito del venue y REDEIL lo manejó perfectamente. 3 máquinas, múltiples disparos en la premiación y al final todo se disolvió con agua. Cero problemas con el venue."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Valentina Soto" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Boda en un jardín de Cuernavaca con áreas verdes protegidas. El confeti biodegradable era la única opción y quedó increíble — confeti blanco en forma de pétalos cayendo sobre los novios en medio del jardín. Fotos de ensueño y cero daño al entorno."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/maquina-de-papelitos/confeti-rosa-boda-jardin-atardecer-novios.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿El confeti biodegradable se ve igual que el normal?", "acceptedAnswer": { "@type": "Answer", "text": "El confeti biodegradable es de papel de arroz y celulosa — tiene un acabado mate diferente al confeti metálico (Mylar). Visualmente la nube de confeti es igual de espectacular en las fotos. La diferencia es que no tiene brillo metálico, pero a cambio se disuelve con agua en 24-72 horas sin dejar rastro." }},
      { "@type": "Question", "name": "¿En cuánto tiempo se disuelve?", "acceptedAnswer": { "@type": "Answer", "text": "Con lluvia o riego, el confeti biodegradable se disuelve en 24-72 horas. En contacto directo con agua se deshace en minutos. No daña plantas, césped ni jardines — está fabricado con tintas vegetales y papel de celulosa certificado." }},
      { "@type": "Question", "name": "¿Los venues exclusivos aceptan este confeti?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El confeti biodegradable es la opción que aceptan haciendas, jardines botánicos, fincas y venues con áreas verdes protegidas. Podemos enviar la ficha técnica del confeti a tu venue para su aprobación previa." }},
      { "@type": "Question", "name": "¿Tienen colores y formas especiales en biodegradable?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El confeti biodegradable viene en blanco, rosa, azul, multicolor y en formas de corazones, pétalos y círculos. Los colores son más suaves que el confeti metálico porque usan tintas vegetales, pero el efecto visual en las fotos es espectacular." }},
      { "@type": "Question", "name": "¿Cuántas máquinas incluye el paquete?", "acceptedAnswer": { "@type": "Answer", "text": "El paquete incluye 3 máquinas de confeti CO₂ profesionales, múltiples cargas de confeti biodegradable, operador técnico, transporte, montaje y desmontaje. Las 3 máquinas cubren jardines y áreas exteriores de hasta 200m²." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "2 Cañones de Confeti", image: "/img/maquina-de-papelitos/confeti-dorado-primer-baile-novios-romantico.avif", alt: "2 cañones de confeti en primer baile de novios", description: "Un disparo perfecto para el vals o entrada. 2 cañones CO₂ + operador. $2,000 + IVA.", link: "/servicios/confeti/paquete-2-canones/" },
  { title: "4 Cañones de Confeti", image: "/img/maquina-de-papelitos/confeti-dorado-xv-anos-vals-quinceañera.avif", alt: "4 cañones de confeti dorado en XV años", description: "Múltiples disparos para bodas y XV años. 4 cañones CO₂ + colores a elegir. $3,500 + IVA.", link: "/servicios/confeti/paquete-4-canones/" },
  { title: "Producción Masiva", image: "/img/maquina-de-papelitos/explosion-confeti-concierto-multitud-luces.avif", alt: "Confeti profesional en concierto masivo", description: "8+ cañones para conciertos y festivales. Alcance 15m. $9,000 + IVA.", link: "/servicios/confeti/paquete-produccion/" },
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Efecto nubes en piso para boda en jardín", description: "Confeti biodegradable + niebla baja en jardines. La combinación perfecta para bodas outdoor.", link: "/servicios/humo-bajo/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Confeti y Papelitos", href: "/servicios/confeti/" },
    { label: "Biodegradable" }
  ]} />
</Fragment>

  <Hero
    title="Confeti Biodegradable para Eventos al Aire Libre"
    subtitle="Desde $5,500 + IVA. Se disuelve con agua. 3 máquinas CO₂ + operador. Jardines y haciendas."
    introParagraph1='El confeti biodegradable es la única opción para venues exclusivos con áreas verdes protegidas — haciendas, jardines botánicos, fincas y espacios outdoor donde el confeti convencional está prohibido. En <strong>REDEIL</strong> operamos 3 máquinas de confeti CO₂ profesionales cargadas con confeti de papel de celulosa y tintas vegetales que se disuelve con agua en 24-72 horas sin dañar plantas, césped ni flores. El efecto visual es igual de espectacular que el confeti convencional.'
    introParagraph2='Disponible en <strong>blanco, rosa, azul, multicolor</strong> y en formas de corazones, pétalos y círculos — todo biodegradable. El operador posiciona las 3 máquinas estratégicamente para cubrir el jardín o área exterior y coordina los disparos con tu fotógrafo y DJ. Múltiples disparos incluidos para cubrir varios momentos del evento. Ideal para <strong>bodas en haciendas, eventos corporativos al aire libre y celebraciones en jardines</strong> de la CDMX, Estado de México y ciudades cercanas.'
  />

  <CtaBar
    headline="¿Prefieres confeti convencional o más cañones?"
    items={[
      { label: "2 Cañones — $2,000", href: "/servicios/confeti/paquete-2-canones/", icon: "efectos" },
      { label: "4 Cañones — $3,500", href: "/servicios/confeti/paquete-4-canones/", icon: "efectos" },
      { label: "Producción — $9,000", href: "/servicios/confeti/paquete-produccion/", icon: "efectos" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <!-- Contenido principal + Sidebar sticky -->
  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Confeti Biodegradable"
      price="$5,500"
      priceNote="+ IVA · Operador incluido"
      features={[
        { text: "3 máquinas de confeti CO₂" },
        { text: "Confeti 100% biodegradable" },
        { text: "Se disuelve con agua (24-72h)" },
        { text: "Múltiples disparos incluidos" },
        { text: "Colores y formas disponibles" },
        { text: "Operador técnico incluido" },
        { text: "Coordinación con fotógrafo/DJ" },
        { text: "Transporte ida y vuelta" },
        { text: "Montaje y desmontaje" },
        { text: "Cobertura CDMX y Edomex" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete de confeti biodegradable para mi evento al aire libre."
      packages={[
        { label: "2 Cañones", price: "$2,000", href: "/servicios/confeti/paquete-2-canones/" },
        { label: "4 Cañones", price: "$3,500", href: "/servicios/confeti/paquete-4-canones/" },
        { label: "Biodegradable", price: "$5,500", href: "/servicios/confeti/paquete-confeti-biodegradable/", active: true },
        { label: "Producción", price: "$9,000", href: "/servicios/confeti/paquete-produccion/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="Perfecto para estos espacios"
          subtitle="3 máquinas cubren jardines y áreas exteriores de hasta 200m²."
          paragraph1="El confeti biodegradable es la solución para venues que prohíben confeti convencional. Haciendas coloniales, jardines con áreas verdes protegidas, fincas ecológicas y espacios outdoor que exigen materiales que no dañen el entorno."
          paragraph2="Podemos enviar la ficha técnica del confeti biodegradable a tu venue para su aprobación antes del evento. Nunca hemos tenido un rechazo."
        />
        <FeatureGrid features={[
          { title: "Haciendas Coloniales", description: "Venues exclusivos que exigen confeti biodegradable. Se disuelve con el riego matutino." },
          { title: "Jardines Botánicos", description: "Áreas verdes protegidas donde solo se acepta material biodegradable certificado." },
          { title: "Bodas al Aire Libre", description: "Jardines, fincas y terrazas con vegetación. Cero rastro al día siguiente." },
          { title: "Eventos Corporativos Outdoor", description: "Premiaciones y galas al aire libre. Imagen eco-friendly para tu marca." },
          { title: "Fincas Ecológicas", description: "Venues comprometidos con el medio ambiente. El confeti se integra al suelo sin daño." },
          { title: "Venues con Restricciones", description: "Cualquier espacio que prohíba confeti convencional acepta nuestro biodegradable." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Biodegradable no significa menos espectacular"
          subtitle="Mismo impacto visual, cero impacto ambiental."
          paragraph1="El confeti biodegradable de papel de celulosa crea la misma nube densa y espectacular que el convencional. La diferencia está en el material — en vez de Mylar metálico, usa papel de arroz con tintas vegetales. En las fotos, la nube de confeti se ve igual de impactante."
          paragraph2="Lo que cambia es lo que pasa después: con lluvia o riego, el confeti se disuelve completamente en 24-72 horas. No hay que barrer, no hay que recoger — el jardín queda exactamente como estaba."
        />
        <FeatureGrid features={[
          { title: "Papel de Celulosa", description: "Fabricado con fibras vegetales certificadas. Sin plástico ni microplásticos." },
          { title: "Tintas Vegetales", description: "Los colores usan tintas 100% vegetales que no contaminan el suelo ni el agua." },
          { title: "Se Disuelve con Agua", description: "En contacto con agua se deshace en minutos. Con lluvia o riego, desaparece en 24-72h." },
          { title: "No Daña Plantas", description: "Certificado para uso en jardines con vegetación. No afecta césped, flores ni árboles." },
          { title: "Ficha Técnica", description: "Proporcionamos documentación del material para la aprobación de tu venue." },
          { title: "Colores Disponibles", description: "Blanco, rosa, azul, multicolor, corazones y pétalos — todo en versión biodegradable." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="5 estrellas en 43 reseñas."
          paragraph1="Cada reseña es de un cliente real que contrató el paquete de confeti biodegradable."
          paragraph2="Pregunta por referencias de eventos en venues similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Gabriela Navarro", event: "Boda en hacienda — Tepotzotlán", rating: 5, text: "El venue nos exigía confeti biodegradable. REDEIL lo tenía sin problema — las 3 máquinas cubrieron todo el jardín y al día siguiente con el riego ya no había rastro. El efecto visual fue igual de espectacular." },
          { name: "Daniel Ochoa", event: "Evento corporativo — Santa Fe", rating: 5, text: "El confeti biodegradable fue requisito del venue y REDEIL lo manejó perfectamente. 3 máquinas, múltiples disparos en la premiación y al final todo se disolvió con agua. Cero problemas." },
          { name: "Valentina Soto", event: "Boda en jardín — Cuernavaca", rating: 5, text: "Confeti blanco en forma de pétalos cayendo sobre los novios en medio del jardín. Fotos de ensueño y cero daño al entorno. La única opción para un jardín protegido." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <!-- Galería -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Confeti biodegradable en eventos reales"
        subtitle="Jardines, haciendas y espacios outdoor con confeti que desaparece solo."
        paragraph1="Cada foto es de un evento real donde se usó confeti biodegradable profesional. Bodas en hacienda, ceremonias al aire libre, eventos corporativos en jardines — el efecto visual es espectacular y el impacto ambiental es cero."
        paragraph2="¿Tu venue exige confeti biodegradable? Mándanos fotos del espacio y te diseñamos la propuesta ideal."
      />
      <Gallery4x4 images={[
        { src: "/img/maquina-de-papelitos/confeti-rosa-boda-jardin-atardecer-novios.avif", alt: "Confeti rosa biodegradable en boda de jardín al atardecer" },
        { src: "/img/maquina-de-papelitos/confeti-petalos-boda-jardin-camino-novios.avif", alt: "Confeti pétalos biodegradable en camino de novios en jardín" },
        { src: "/img/maquina-de-papelitos/confeti-rosa-boda-atardecer-beso-novios.avif", alt: "Confeti rosa al atardecer con beso de novios" },
        { src: "/img/maquina-de-papelitos/confeti-salida-iglesia-boda-novios-felices.avif", alt: "Confeti biodegradable en salida de iglesia novios felices" },
        { src: "/img/maquina-de-papelitos/confeti-dorado-primer-baile-novios-romantico.avif", alt: "Confeti dorado en primer baile de novios" },
        { src: "/img/maquina-de-papelitos/explosion-confeti-blanco-boda-pista-baile.avif", alt: "Explosión de confeti blanco en pista de baile" },
        { src: "/img/confeti/maquina-confeti-boda-novios-celebracion.avif", alt: "Máquina de confeti en boda novios celebración" },
        { src: "/img/maquina-de-papelitos/lluvia-papelitos-boda-elegante-candelabros.avif", alt: "Lluvia de papelitos en boda elegante con candelabros" },
      ]} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre Confeti Biodegradable"
        subtitle="Todo lo que necesitas saber antes de reservar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
        paragraph2="Podemos enviar la ficha técnica del confeti biodegradable a tu venue para su aprobación previa."
      />
    </div>
    <FaqSection items={[
      { question: "¿El confeti biodegradable se ve igual que el normal?", answer: "El confeti biodegradable es de papel de arroz y celulosa — tiene un acabado mate diferente al confeti metálico (Mylar). Visualmente la nube de confeti es igual de espectacular en las fotos. La diferencia es que no tiene brillo metálico, pero a cambio se disuelve con agua en 24-72 horas sin dejar rastro." },
      { question: "¿En cuánto tiempo se disuelve?", answer: "Con lluvia o riego, el confeti biodegradable se disuelve en 24-72 horas. En contacto directo con agua se deshace en minutos. No daña plantas, césped ni jardines — está fabricado con tintas vegetales y papel de celulosa certificado." },
      { question: "¿Los venues exclusivos aceptan este confeti?", answer: "Sí. El confeti biodegradable es la opción que aceptan haciendas, jardines botánicos, fincas y venues con áreas verdes protegidas. Podemos enviar la ficha técnica a tu venue para su aprobación previa — nunca hemos tenido un rechazo." },
      { question: "¿Tienen colores y formas especiales en biodegradable?", answer: "Sí. El confeti biodegradable viene en blanco, rosa, azul, multicolor y en formas de corazones, pétalos y círculos. Los colores son más suaves que el confeti metálico porque usan tintas vegetales, pero el efecto visual en las fotos es espectacular." },
      { question: "¿Cuántas máquinas incluye el paquete?", answer: "El paquete incluye 3 máquinas de confeti CO₂ profesionales, múltiples cargas de confeti biodegradable, operador técnico, transporte, montaje y desmontaje. Las 3 máquinas cubren jardines y áreas exteriores de hasta 200m²." },
    ]} />
  </section>

  <!-- Otros paquetes -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes de Confeti"
        subtitle="¿Prefieres confeti convencional o necesitas más cobertura?"
        paragraph1="Si tu venue acepta confeti convencional, los paquetes de 2 y 4 cañones son más económicos. Si necesitas cobertura masiva, el paquete de producción tiene 8+ cañones."
        paragraph2="Armamos propuestas integrales con precio especial cuando combinas servicios."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Tu venue exige confeti biodegradable?</h2>
        <p>Mándanos el nombre del venue y te enviamos la ficha técnica del confeti para su aprobación. Cotización completa en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
