---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Sonido y DJ para Eventos en CDMX | REDEIL";
const description = "Audio profesional JBL y QSC para bodas, XV años y fiestas. DJ, bocinas, micrófonos. Desde 50 hasta 2,000 personas. Instalación incluida. Cotiza gratis.";
const canonical = "https://rentadeiluminacion.com/servicios/sonido/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Sonido y DJ Profesional para Eventos",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Servicio profesional de renta de audio, bocinas y DJ para bodas, XV años y eventos en CDMX y Estado de México.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Renta de Sonido y DJ",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Cuántas bocinas necesito para mi evento?", "acceptedAnswer": { "@type": "Answer", "text": "Depende del espacio y la cantidad de personas. Para eventos de hasta 100 personas en salón cerrado, un par de bocinas JBL PRX es suficiente. Para 200+, usamos sistemas line array. Te asesoramos según las dimensiones de tu venue." }},
      { "@type": "Question", "name": "¿El DJ trae su propio equipo de sonido?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestro DJ llega con consola profesional, bocinas, subwoofer y todo lo necesario. Si ya tienes equipo de sonido contratado, también puede trabajar con tu setup existente." }},
      { "@type": "Question", "name": "¿Puedo rentar solo las bocinas sin DJ?", "acceptedAnswer": { "@type": "Answer", "text": "Claro. Muchos clientes rentan solo el equipo de audio con técnico. Conectamos tu playlist de Spotify, tu laptop o el micrófono que necesites. El técnico se encarga de que todo suene bien." }},
      { "@type": "Question", "name": "¿Incluyen micrófonos para la ceremonia?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, incluimos micrófonos inalámbricos profesionales. Para bodas, normalmente usamos 2: uno para los votos y otro para el oficiante. Para conferencias, hasta 4 micrófonos según necesidad." }},
      { "@type": "Question", "name": "¿Cubren eventos al aire libre?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Tenemos equipos diseñados para exteriores con la potencia necesaria para espacios abiertos. Si no hay toma eléctrica, incluimos planta de luz sin costo adicional." }}
    ]
  }
]);

const servicios = [
  { title: "Audio para Eventos", image: "/img/bocinas/renta-bocinas-line-array-concierto-400w.avif", alt: "Sistema de bocinas line array JBL para evento", description: "Bocinas JBL PRX y sistemas QSC desde 50 hasta 2,000+ personas. Técnico de audio incluido. Desde $4,000 + IVA.", link: "/servicios/bocinas/" },
  { title: "DJ para Fiestas y Bodas", image: "/img/bocinas-djs/dj-para-eventos-cdmx-cabina-profesional-300w.avif", alt: "DJ profesional con consola Pioneer en evento", description: "DJ con consola Pioneer DDJ y repertorio adaptado — vals, hora loca, cumbia, electrónica. Solo o con paquete completo.", link: "/servicios/bocinas-djs/" },
  { title: "Bocinas para Bodas", image: "/img/bocinas-bodas/renta-bocinas-boda-primer-baile-novios-truss-300w.avif", alt: "Audio profesional para ceremonia y fiesta de boda", description: "Audio JBL dimensionado para ceremonia, coctel, vals y fiesta. El técnico llega 2-3 horas antes para ecualizarlo al venue.", link: "/servicios/bocinas-bodas/" },
  { title: "Bocinas para XV Años", image: "/img/bocinas-xv/renta-bocinas-xv-anos-vals-padre-hija-dj-salon-300w.avif", alt: "Sistema de audio para fiesta de XV años", description: "DJ con Pioneer que conoce el protocolo de XV años. Vals, coreografía, hora loca, liga — cada canción en el momento exacto.", link: "/servicios/bocinas-xv/" },
  { title: "Bocinas para Fiestas", image: "/img/bocinas-fiestas/renta-bocinas-fiestas-eventos-profesionales-300w.avif", alt: "Bocinas profesionales para fiesta privada", description: "Cumpleaños, graduaciones, posadas, aniversarios. Audio JBL o QSC dimensionado para tu espacio y número de invitados.", link: "/servicios/bocinas-fiestas/" },
  { title: "Bocinas para Conferencias", image: "/img/bocinas-conferencias/renta-de-bocinas-para-conferencias-salon-ejecutivo-300w.avif", alt: "Audio para conferencia en salón ejecutivo", description: "Audio Bose y JBL para que cada palabra del ponente llegue clara a la última fila. Mezcladora Yamaha TF incluida.", link: "/servicios/bocinas-conferencias/" },
  { title: "Micrófonos Inalámbricos", image: "/img/bocinas/renta-bocinas-line-array-concierto-400w.avif", alt: "Micrófonos Shure y Sennheiser inalámbricos para eventos", description: "Shure y Sennheiser UHF — de mano, lavalier y diadema para brindis, ceremonias y conferencias. Técnico incluido.", link: "/servicios/microfonos/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Servicios", href: "/servicios/" },
    { label: "Sonido y DJ" }
  ]} />
</Fragment>

    <Hero
      hideCtas
      title="Renta de Sonido y DJ para Eventos en CDMX"
      subtitle="Audio JBL y QSC con técnico incluido. Desde 50 hasta 2,000+ personas."
      introParagraph1='La diferencia entre "se oye" y "se siente" es el equipo y quién lo opera. Un par de bocinas Bluetooth en un jardín de 200 personas no va a funcionar — el sonido se pierde en el aire libre, el bajo desaparece, y a las 11pm los vecinos se quejan del agudo. En <strong>REDEIL</strong> dimensionamos el audio al espacio: bocinas <strong>JBL PRX</strong> para fiestas de hasta 150 personas, sistemas <strong>QSC</strong> line array para 200+, y subwoofers dedicados cuando necesitas que el bajo se sienta.'
      introParagraph2='El técnico de audio llega 2-3 horas antes, ecualiza al venue específico (un salón de mármol rebota diferente que uno alfombrado), y se queda durante todo el evento. Si necesitas DJ, llega con consola <strong>Pioneer CDJ-2000NXS2</strong> y repertorio adaptado a tu protocolo. Si solo necesitas bocinas para tu playlist de Spotify, también. Transporte, montaje y desmontaje incluidos.'
    />


    <!-- Galería de sonido y DJ -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="Audio Profesional en Acción"
          subtitle="Así se ve el equipo montado en eventos reales."
          paragraph1="Un line array JBL en salón de bodas. Una cabina Pioneer en la pista. Bocinas QSC en jardín con subwoofer. El equipo cambia según el evento, pero el técnico siempre está ahí ajustando niveles en tiempo real."
          paragraph2="Estas fotos son de montajes nuestros — no de catálogo de fabricante."
        />
        <Gallery4x4 images={[
          { src: "/img/bocinas/bocinas-profesionales-evento-masivo.avif", alt: "Bocinas profesionales para evento masivo" },
          { src: "/img/bocinas/renta-bocinas-line-array-concierto.avif", alt: "Sistema line array para concierto" },
          { src: "/img/bocinas/sonido-profesional-concierto-estadio.avif", alt: "Sonido profesional en concierto" },
          { src: "/img/bocinas-bodas/renta-bocinas-boda-primer-baile-novios-romantico.avif", alt: "Primer baile con sonido profesional" },
          { src: "/img/bocinas-bodas/renta-bocinas-boda-salon-line-array-pioneer-dj.avif", alt: "Line array en salón de boda" },
          { src: "/img/bocinas-bodas/renta-bocinas-boda-dj-cabina-blanca-flores.avif", alt: "Cabina DJ en boda elegante" },
          { src: "/img/bocinas-bodas/renta-bocinas-boda-fiesta-confeti-chispas-dj.avif", alt: "Fiesta con confeti y DJ" },
          { src: "/img/bocinas-djs/dj-para-eventos-cdmx-cabina-profesional.avif", alt: "DJ profesional con cabina" },
          { src: "/img/bocinas-djs/dj-profesional-consola-pioneer-cdj.avif", alt: "Consola Pioneer CDJ profesional" },
          { src: "/img/bocinas-djs/dj-para-eventos-pista-iluminada.avif", alt: "Pista iluminada con DJ" },
          { src: "/img/bocinas-djs/dj-para-fiestas-hora-loca.avif", alt: "DJ animando hora loca" },
          { src: "/img/bocinas-conferencias/renta-de-bocinas-para-conferencias-salon-ejecutivo.avif", alt: "Audio para conferencia ejecutiva" },
          { src: "/img/bocinas-conferencias/renta-sonido-conferencias-auditorio-profesional.avif", alt: "Sonido en auditorio profesional" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-vals-padre-hija-dj-salon.avif", alt: "Vals XV años con DJ" },
          { src: "/img/bocinas-fiestas/renta-bocinas-fiestas-eventos-profesionales.avif", alt: "Bocinas para fiesta" },
          { src: "/img/bocinas-fiestas/bocinas-profesionales-fiestas-noche.avif", alt: "Sonido para fiesta nocturna" },
        ]} />
      </div>
    </section>

    <!-- Servicios de sonido -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Equipo de Audio Profesional"
          subtitle="7 servicios de sonido — cada uno dimensionado a tu tipo de evento."
          paragraph1="Una ceremonia de boda necesita claridad en los votos, no potencia. Una pista de baile necesita bajo y volumen. Una conferencia necesita que el ponente se entienda en la última fila sin feedback. Son tres problemas de audio completamente distintos y se resuelven con equipo diferente."
          paragraph2="El técnico ecualiza al venue: un salón con piso de mármol y techo alto rebota el sonido diferente que uno alfombrado con plafón bajo. Por eso no mandamos bocinas y ya — siempre va un técnico que ajusta en sitio."
        />
        <div class="services-grid">
          {servicios.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre Sonido y DJ"
          subtitle="Lo que nos preguntan por WhatsApp antes de apartar fecha."
          paragraph1="Si tu duda no está aquí, mándanos mensaje y te contestamos en minutos."
          paragraph2=""
        />
      </div>
      <FaqSection items={[
        { question: "¿Cuántas bocinas necesito?", answer: "Para salón cerrado hasta 100 personas, un par de JBL PRX315 es suficiente. De 100 a 200, agregamos subwoofer. Arriba de 200 personas o en jardín abierto, usamos line array. Mándanos las medidas de tu espacio y el número de invitados y te decimos exacto." },
        { question: "¿El DJ trae su propio equipo?", answer: "Sí. Llega con consola Pioneer, bocinas, sub y todo montado. Si ya contrataste audio aparte, también puede trabajar con tu equipo — solo necesita una entrada auxiliar o línea." },
        { question: "¿Puedo rentar bocinas sin DJ?", answer: "Sí. Muchos clientes rentan solo el audio con técnico. Conectamos tu celular por Bluetooth o cable, tu laptop, o los micrófonos que necesites. El técnico se encarga de los niveles y de que no haya feedback." },
        { question: "¿Qué pasa con el sonido en jardín abierto?", answer: "En exterior el sonido se pierde — no hay paredes que lo contengan. Necesitas más potencia que en salón cerrado, y subwoofer dedicado porque el bajo es lo primero que desaparece al aire libre. También orientamos las bocinas para minimizar la fuga hacia vecinos." },
        { question: "¿Incluyen micrófonos para la ceremonia?", answer: "Sí. Para bodas usamos 2 micrófonos inalámbricos Shure: uno para los votos y otro para el oficiante. Para conferencias podemos incluir hasta 4. Son UHF — no se interfieren con el WiFi del venue ni con otras señales." },
        { question: "¿Qué pasa si no hay electricidad en el venue?", answer: "Llevamos planta de luz. Es común en jardines y haciendas. La planta la colocamos alejada para que no se escuche el motor, y cableamos hasta el equipo. Va incluida cuando el venue no tiene instalación eléctrica suficiente." },
      ]} />
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Necesitas audio para tu evento?</h2>
          <p>Mándanos la fecha, el venue, cuántas personas esperas y si necesitas DJ o solo bocinas. Te cotizamos el mismo día.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
