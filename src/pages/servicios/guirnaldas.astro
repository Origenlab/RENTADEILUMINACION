---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import PricingCards from '../../components/PricingCards.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Guirnaldas de Luces para Bodas y Eventos CDMX | REDEIL";
const description = "Guirnaldas con focos Edison para bodas, XV años y eventos al aire libre en CDMX. Luces vintage LED con instalación profesional. Desde $3,500. Cotiza gratis.";
const canonical = "https://rentadeiluminacion.com/servicios/guirnaldas/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Guirnaldas de Luces para Eventos",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Alquiler de guirnaldas de luces con focos Edison vintage y LED para bodas, fiestas y eventos en CDMX y Estado de México. Instalación profesional incluida.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Renta de Guirnaldas de Luces",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Cuántos metros de guirnaldas necesito para mi evento?", "acceptedAnswer": { "@type": "Answer", "text": "Depende del espacio. Para un jardín de 100m² recomendamos entre 50 y 80 metros lineales. Para una terraza o pérgola, 30-50 metros. Para una carpa completa, 80-150 metros según el tamaño." }},
      { "@type": "Question", "name": "¿Cuánto cuesta la renta de guirnaldas?", "acceptedAnswer": { "@type": "Answer", "text": "El precio depende de los metros lineales y el tipo de foco. Un paquete básico para jardín arranca desde $3,500 MXN. Para bodas completas con 100+ metros, cotiza por WhatsApp para un precio personalizado." }},
      { "@type": "Question", "name": "¿Las guirnaldas funcionan bajo lluvia?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestras guirnaldas cuentan con certificación IP65 — resistentes a lluvia y humedad. El cableado y las conexiones están protegidos para uso en exteriores." }},
      { "@type": "Question", "name": "¿La instalación está incluida?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, siempre. El servicio incluye transporte, montaje profesional, operación durante el evento y desmontaje al finalizar." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "Iluminación Arquitectónica", image: "/img/iluminacion-arquitectonica/boda-patio-hacienda-iluminacion-fachada-ambar-string-lights-baile-400w.avif", alt: "Uplighting arquitectónico en fachada de hacienda para boda", description: "Complemento perfecto para guirnaldas. Uplighting que transforma fachadas y jardines con color.", link: "/servicios/iluminacion-arquitectonica/" },
  { title: "Seguidor", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Spotlight seguidor iluminando primer baile de novios", description: "Spotlight profesional para el vals y momentos especiales. El complemento ideal para tu boda.", link: "/servicios/seguidor/" },
  { title: "Gobos", image: "/img/gobos/renta-gobo-monograma-pista-baile-300w.avif", alt: "Gobo proyectando monograma en pista de baile", description: "Proyecta los nombres de los novios o tu logo en paredes y pisos. El detalle que todos recuerdan.", link: "/servicios/gobos/" },
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Humo bajo en vals de boda en jardín", description: "La nube mágica para el vals. Combínalo con guirnaldas para un efecto espectacular.", link: "/servicios/humo-bajo/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Iluminación", href: "/servicios/iluminacion/" },
    { label: "Guirnaldas" }
  ]} />
</Fragment>

    <Hero
      title="Renta de Guirnaldas de Luces para Bodas y Eventos en CDMX"
      subtitle="Focos Edison vintage y LED. Certificación IP65 para exteriores. Instalación profesional incluida. Desde $3,500."
      introParagraph1='Las guirnaldas con focos tipo Edison son el elemento de iluminación más solicitado para bodas al aire libre en la Ciudad de México. Su luz cálida y tono ámbar crean un ambiente romántico y acogedor que transforma jardines, terrazas, carpas y haciendas en espacios elegantes y fotogénicos. En <strong>REDEIL</strong> llevamos más de 500 eventos montando luces vintage en toda la CDMX y Edo. Méx.'
      introParagraph2='Nuestro servicio de alquiler de iluminación incluye asesoría sobre la cantidad de metros lineales según el tamaño de tu espacio, diseño personalizado del montaje, focos Edison LED de bajo consumo o bombillas vintage tradicionales — tú eliges el estilo. Todo con transporte, instalación profesional y desmontaje incluido. Trabajamos con wedding planners, decoradores y organizadores de fiestas para ambientar cada celebración de forma perfecta.'
    />

    <CtaBar
      headline="¿Para qué tipo de evento necesitas guirnaldas?"
      items={[
        { label: "Bodas", href: "/eventos/bodas/", icon: "iluminacion" },
        { label: "XV Años", href: "/eventos/xv-anos/", icon: "iluminacion" },
        { label: "Más iluminación", href: "/servicios/iluminacion/", icon: "iluminacion" },
        { label: "Cotiza Ahora", href: "https://wa.me/5530682988?text=Hola%20REDEIL,%20quiero%20cotizar%20guirnaldas%20para%20mi%20evento", icon: "cotizar" },
      ]}
    />

    <!-- Galería tipos de focos -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="Focos Edison: LED y Vintage Tradicional"
          subtitle="Dos opciones profesionales. Tú eliges la estética."
          paragraph1="Las bombillas Edison LED tienen la misma estética vintage con luz cálida y tono ámbar, pero consumen menos energía — ideales para montajes largos en carpas o pérgolas. Los focos vintage de filamento dan un brillo más natural y orgánico."
          paragraph2="Ambas opciones son resistentes y profesionales con certificación IP65 para uso en exteriores. Nuestro equipo te recomienda la mejor opción según tu espacio y tipo de evento."
        />
        <Gallery4x4 images={[
          { src: "/img/guirnaldas/guirnaldas-edison-hacienda-boda.avif", alt: "Guirnaldas Edison iluminando hacienda para boda" },
          { src: "/img/guirnaldas/guirnaldas-exterior-jardin-boda.avif", alt: "Guirnaldas vintage en jardín exterior para boda" },
          { src: "/img/guirnaldas/guirnaldas-focos-edison-eventos.avif", alt: "Focos Edison vintage para eventos nocturnos" },
          { src: "/img/guirnaldas/guirnaldas-luz-calida-fiestas.avif", alt: "Guirnaldas con luz cálida ámbar para fiestas" },
          { src: "/img/guirnaldas/renta-guirnaldas-ceremonia-boda-pergola-focos-edison-15.avif", alt: "Pérgola con focos Edison para ceremonia rústica" },
          { src: "/img/guirnaldas/renta-guirnaldas-boda-exterior-guirnaldas-arco-floral-07.avif", alt: "Arco floral con guirnaldas para boda al aire libre" },
          { src: "/img/guirnaldas/renta-guirnaldas-ceremonia-boda-guirnaldas-edison-06.avif", alt: "Ceremonia iluminada con guirnaldas Edison" },
          { src: "/img/guirnaldas/renta-guirnaldas-boda-jardin-ceremonia-guirnaldas-05.avif", alt: "Jardín decorado con guirnaldas vintage" },
          { src: "/img/guirnaldas/renta-guirnaldas-baile-novios-hacienda-guirnaldas-41.avif", alt: "Baile de novios en hacienda bajo guirnaldas" },
          { src: "/img/guirnaldas/renta-guirnaldas-boda-patio-colonial-guirnaldas-21.avif", alt: "Patio colonial con guirnaldas para recepción" },
          { src: "/img/guirnaldas/renta-guirnaldas-brindis-boda-guirnaldas-exterior-14.avif", alt: "Brindis de boda con guirnaldas cálidas" },
          { src: "/img/guirnaldas/luces-decorativas-eventos-cdmx.avif", alt: "Luces decorativas vintage para eventos CDMX" },
          { src: "/img/guirnaldas/guirnaldas-led-fiestas-cdmx.avif", alt: "Guirnaldas LED para fiestas en CDMX" },
          { src: "/img/guirnaldas/renta-guirnaldas-ceremonia-atardecer-jardin-12.avif", alt: "Guirnaldas Edison al atardecer en jardín" },
          { src: "/img/guirnaldas/guirnaldas-decoracion-xv-anos.avif", alt: "Guirnaldas decorativas para XV años" },
          { src: "/img/guirnaldas/renta-guirnaldas-bodas-cdmx.avif", alt: "Renta de guirnaldas para bodas CDMX" },
        ]} />
      </div>
    </section>

    <!-- Paquetes -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Paquetes de Guirnaldas"
          subtitle="4 opciones según el tamaño de tu evento. Instalación incluida en todos."
          paragraph1="Cada paquete incluye focos Edison (LED o vintage a tu elección), cableado certificado IP65, transporte, montaje profesional, operación y desmontaje. Sin costos ocultos — el precio es todo incluido."
          paragraph2="¿Tu evento necesita algo diferente? Armamos paquetes a la medida. Cotiza por WhatsApp y te hacemos una propuesta personalizada en menos de 24 horas."
        />
        <PricingCards packages={[
          {
            name: "Básico — 50 metros",
            price: "$3,500",
            priceNote: "IVA incluido",
            description: "Perfecto para terrazas pequeñas, pérgolas y ceremonias íntimas de hasta 50 invitados.",
            features: [
              { text: "50 metros lineales de guirnaldas", included: true },
              { text: "Focos Edison LED o vintage", included: true },
              { text: "Certificación IP65 exteriores", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Diseño de distribución incluido", included: true },
              { text: "Ideal para: pérgola, terraza, ceremonia", included: true },
              { text: "Asesoría personalizada", included: false },
              { text: "Dimmer para control de intensidad", included: false },
            ],
            ctaLabel: "Cotizar 50 metros",
            ctaHref: "https://wa.me/5530682988?text=Hola%20REDEIL,%20quiero%20cotizar%20el%20paquete%20de%2050%20metros%20de%20guirnaldas",
          },
          {
            name: "Estándar — 100 metros",
            price: "$6,500",
            priceNote: "IVA incluido",
            badge: "Más popular",
            highlight: true,
            description: "El más pedido para bodas en jardín. Cubre el área de ceremonia + recepción para hasta 120 invitados.",
            features: [
              { text: "100 metros lineales de guirnaldas", included: true },
              { text: "Focos Edison LED o vintage", included: true },
              { text: "Certificación IP65 exteriores", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Diseño de distribución incluido", included: true },
              { text: "Ideal para: bodas, jardines, haciendas", included: true },
              { text: "Asesoría personalizada de montaje", included: true },
              { text: "Dimmer para control de intensidad", included: false },
            ],
            ctaLabel: "Cotizar 100 metros",
            ctaHref: "https://wa.me/5530682988?text=Hola%20REDEIL,%20quiero%20cotizar%20el%20paquete%20de%20100%20metros%20de%20guirnaldas",
          },
          {
            name: "Premium — 200 metros",
            price: "$11,500",
            priceNote: "IVA incluido",
            description: "Para bodas grandes y eventos corporativos. Cubre áreas amplias con iluminación completa para 200+ invitados.",
            features: [
              { text: "200 metros lineales de guirnaldas", included: true },
              { text: "Focos Edison LED o vintage", included: true },
              { text: "Certificación IP65 exteriores", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Diseño personalizado del montaje", included: true },
              { text: "Ideal para: haciendas, fincas, eventos grandes", included: true },
              { text: "Asesoría en sitio antes del evento", included: true },
              { text: "Dimmer para control de intensidad", included: true },
            ],
            ctaLabel: "Cotizar 200 metros",
            ctaHref: "https://wa.me/5530682988?text=Hola%20REDEIL,%20quiero%20cotizar%20el%20paquete%20de%20200%20metros%20de%20guirnaldas",
          },
          {
            name: "Producción — 500 metros",
            price: "$24,000",
            priceNote: "IVA incluido",
            description: "Producción completa para festivales, ferias, eventos masivos y venues de gran escala con 500+ invitados.",
            features: [
              { text: "500 metros lineales de guirnaldas", included: true },
              { text: "Focos Edison LED o vintage", included: true },
              { text: "Certificación IP65 exteriores", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Diseño personalizado + visita previa", included: true },
              { text: "Ideal para: festivales, ferias, venues grandes", included: true },
              { text: "Asesoría en sitio + prueba de iluminación", included: true },
              { text: "Dimmer + plantas de luz si se requiere", included: true },
            ],
            ctaLabel: "Cotizar 500 metros",
            ctaHref: "https://wa.me/5530682988?text=Hola%20REDEIL,%20quiero%20cotizar%20el%20paquete%20de%20500%20metros%20de%20guirnaldas",
          },
        ]} />
      </div>
    </section>

    <!-- Servicios relacionados -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Combina con Otros Servicios"
          subtitle="Las guirnaldas se ven aún mejor cuando las complementas."
          paragraph1="La mayoría de nuestros clientes de bodas combinan las guirnaldas con 2-3 servicios más para crear una experiencia completa. El resultado: un evento con iluminación profesional que se ve y se siente de otro nivel."
          paragraph2="Armamos paquetes personalizados con precio especial cuando combinas servicios. Cuéntanos tu evento y te hacemos una propuesta integral."
        />
        <div class="services-grid">
          {serviciosRelacionados.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre Guirnaldas"
          subtitle="Lo que todos preguntan antes de cotizar."
          paragraph1="Si tienes otra duda sobre la renta de guirnaldas, escríbenos por WhatsApp y te respondemos en minutos."
          paragraph2="Cada espacio es diferente — por eso hacemos propuestas a la medida con el número exacto de metros que necesitas."
        />
      </div>
      <FaqSection items={[
        { question: "¿Cuántos metros de guirnaldas necesito para mi evento?", answer: "Depende del tamaño del área. Para un jardín de 100m² recomendamos entre 50 y 80 metros lineales. Para una terraza o pérgola, 30-50 metros. Para ambientar una carpa completa, 80-150 metros según las dimensiones. Te asesoramos gratis según tu venue." },
        { question: "¿Cuánto cuesta la renta de guirnaldas?", answer: "El precio depende de los metros lineales y el tipo de foco. Un paquete básico para jardín arranca desde $3,500 MXN. Bodas completas con 100+ metros van desde $8,000. Cotiza por WhatsApp y te armamos algo a tu presupuesto — sin compromiso." },
        { question: "¿Las guirnaldas funcionan al aire libre bajo lluvia?", answer: "Sí. Nuestras guirnaldas cuentan con certificación IP65 — resistentes a lluvia y humedad. El cableado eléctrico y las conexiones están protegidos para uso en exteriores. Hemos montado en temporada de lluvias sin ningún problema." },
        { question: "¿Puedo elegir entre focos LED y focos Edison vintage?", answer: "Sí, ofrecemos ambas opciones. Las bombillas Edison LED tienen la misma estética vintage con luz cálida pero consumen menos energía y son más eficientes — ideales para montajes largos. Los focos de filamento vintage dan un brillo más natural y orgánico." },
        { question: "¿Se pueden combinar con otros servicios de iluminación?", answer: "Claro, es lo más recomendable para bodas y fiestas de XV años. Las guirnaldas combinan perfectamente con uplighting arquitectónico, seguidor para el vals, gobos con nombres o logos, y humo bajo. Armamos paquetes con precio especial." },
        { question: "¿También rentan series navideñas y cortinas de luces?", answer: "Sí. Además de las guirnaldas tipo Edison, ofrecemos series navideñas LED, cortinas de luces, y cascadas LED para decoración de eventos. Todos con la misma calidad de instalación profesional." },
      ]} />
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Listo para iluminar tu evento con guirnaldas?</h2>
          <p>Mándanos fotos de tu venue por WhatsApp y te decimos cuántos metros necesitas, qué tipo de foco te conviene y el precio exacto.</p>
          <div class="cta-buttons">
            <a href="https://wa.me/5530682988?text=Hola%20REDEIL,%20quiero%20cotizar%20guirnaldas%20para%20mi%20evento" class="btn btn-whatsapp btn-lg" target="_blank" rel="noopener noreferrer">WhatsApp — 55 3068 2988</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
