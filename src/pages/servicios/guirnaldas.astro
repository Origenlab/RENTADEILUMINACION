---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import PricingCards from '../../components/PricingCards.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Guirnaldas Edison para Bodas en CDMX | REDEIL";
const description = "Guirnaldas con focos Edison para bodas, XV años y eventos al aire libre en CDMX. IP65. Instalación incluida. Desde $3,500 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/guirnaldas/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Guirnaldas de Luces para Eventos",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Alquiler de guirnaldas de luces con focos Edison vintage y LED para bodas, fiestas y eventos en CDMX y Estado de México. Instalación profesional incluida.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Renta de Guirnaldas de Luces",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Cuántos metros de guirnaldas necesito para mi evento?", "acceptedAnswer": { "@type": "Answer", "text": "Depende del espacio. Para un jardín de 100m² recomendamos entre 50 y 80 metros lineales. Para una terraza o pérgola, 30-50 metros. Para una carpa completa, 80-150 metros según el tamaño." }},
      { "@type": "Question", "name": "¿Cuánto cuesta la renta de guirnaldas?", "acceptedAnswer": { "@type": "Answer", "text": "El precio depende de los metros lineales y el tipo de foco. Un paquete básico para jardín arranca desde $3,500 MXN. Para bodas completas con 100+ metros, cotiza por WhatsApp para un precio personalizado." }},
      { "@type": "Question", "name": "¿La instalación está incluida?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, siempre. El servicio incluye transporte, montaje profesional, operación durante el evento y desmontaje al finalizar." }},
      { "@type": "Question", "name": "¿Las guirnaldas funcionan bajo lluvia?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestras guirnaldas cuentan con certificación IP65 — resistentes a lluvia y humedad. El cableado y las conexiones están protegidos para uso en exteriores. Hemos montado en temporada de lluvias sin ningún problema." }},
      { "@type": "Question", "name": "¿Con cuánta anticipación debo reservar?", "acceptedAnswer": { "@type": "Answer", "text": "Idealmente 2-3 semanas antes. En temporada alta (noviembre-enero y mayo-junio) las fechas se llenan rápido. Para garantizar disponibilidad, entre antes reserves mejor." }},
      { "@type": "Question", "name": "¿Puedo elegir entre focos Edison LED y vintage?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Las bombillas Edison LED tienen la misma estética vintage con luz cálida y tono ámbar, pero consumen menos energía — ideales para montajes largos. Los focos vintage de filamento dan un brillo más natural y orgánico. Mismo precio en ambas opciones." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "Iluminación Arquitectónica", image: "/img/iluminacion-arquitectonica/boda-patio-hacienda-iluminacion-fachada-ambar-string-lights-baile-400w.avif", alt: "Uplighting en hacienda con string lights", description: "Guirnaldas en el techo + uplighting en las columnas. La combinación más solicitada para bodas en hacienda.", link: "/servicios/iluminacion-arquitectonica/" },
  { title: "Seguidor de Luz", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Seguidor de luz en primer baile", description: "Guirnaldas creando el ambiente cálido + spotlight siguiendo a los novios en el vals. La boda perfecta.", link: "/servicios/seguidor/" },
  { title: "Cascadas LED", image: "/img/cascadas-led/cascadas-led-novios-mesa-romantica-boda-300w.avif", alt: "Cascadas LED para mesa de novios", description: "Guirnaldas en el techo + cascadas LED detrás de la mesa de novios. El backdrop que todos fotografían.", link: "/servicios/cascadas-led/" },
  { title: "Gobos", image: "/img/gobos/renta-gobo-monograma-pista-baile-300w.avif", alt: "Gobo proyectando monograma en pista", description: "Guirnaldas ambientando el jardín + nombres de los novios proyectados en la pista. Detalles que marcan la diferencia.", link: "/servicios/gobos/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Iluminación", href: "/servicios/iluminacion/" },
    { label: "Guirnaldas" }
  ]} />
</Fragment>

    <Hero
      title="Renta de Guirnaldas de Luces para Bodas y Eventos en CDMX"
      subtitle="Focos Edison vintage y LED. Certificación IP65 para exteriores. Instalación profesional incluida. Desde $3,500."
      introParagraph1='Las guirnaldas con focos Edison son lo que más montamos en bodas al aire libre. Jardines en Coyoacán, haciendas en Huixquilucan, terrazas en Condesa, carpas en Tepotzotlán. La regla para calcular metros es sencilla: multiplica el largo de tu espacio por 1.5 si quieres líneas paralelas, o por 2 si quieres cruce en zigzag. Un jardín de 100m² lleva entre 50 y 80 metros. En <strong>REDEIL</strong> llevamos más de 500 montajes con guirnaldas, y sabemos que lo que hace la diferencia no es la cantidad de focos sino la altura y el ángulo de cada línea.'
      introParagraph2='Todo el cableado es IP65, certificado para lluvia. Hemos montado en plena temporada de lluvias en julio sin un solo corto. Ofrecemos dos tipos de foco: Edison LED de bajo consumo (mismo tono ámbar, aguantan montajes largos de 8+ horas sin calentarse) y bombillas vintage de filamento real (brillo más cálido y orgánico, pero consumen más). Mismo precio en ambas. El servicio incluye transporte, instalación profesional, operación y desmontaje. Nos coordinamos con tu wedding planner o decorador para que el montaje coincida con la distribución de mesas y el flujo del evento.'
    />

    <CtaBar
      headline="¿Para qué tipo de evento necesitas guirnaldas?"
      items={[
        { label: "Bodas", href: "/eventos/bodas/", icon: "iluminacion" },
        { label: "Toda la iluminación", href: "/servicios/iluminacion/", icon: "iluminacion" },
        { label: "XV Años", href: "/eventos/xv-anos/", icon: "iluminacion" },
        { label: "Cotiza Ahora", href: "/contacto/", icon: "cotizar" },
      ]}
    />

    <!-- Galería tipos de focos -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="Focos Edison: LED y Vintage Tradicional"
          subtitle="LED o filamento. Misma estética, distinto consumo."
          paragraph1="Los focos Edison LED producen el mismo tono ámbar cálido que los de filamento, pero consumen un tercio de la energía. Eso importa cuando montas 200 metros de guirnaldas en una hacienda con planta de luz limitada. Los de filamento vintage dan un brillo que oscila ligeramente, más parecido a una vela. La diferencia es sutil, pero los fotógrafos la notan."
          paragraph2="Las dos opciones llevan cableado IP65 y funcionan bajo lluvia. Lo que cambia es la durabilidad: los LED no se calientan aunque estén encendidos 10 horas, los de filamento sí se calientan y ocasionalmente hay que reemplazar uno durante el evento. Llevamos focos de repuesto siempre."
        />
        <Gallery4x4 images={[
          { src: "/img/guirnaldas/guirnaldas-edison-hacienda-boda.avif", alt: "Guirnaldas Edison iluminando hacienda para boda" },
          { src: "/img/guirnaldas/guirnaldas-exterior-jardin-boda.avif", alt: "Guirnaldas vintage en jardín exterior para boda" },
          { src: "/img/guirnaldas/guirnaldas-focos-edison-eventos.avif", alt: "Focos Edison vintage para eventos nocturnos" },
          { src: "/img/guirnaldas/guirnaldas-luz-calida-fiestas.avif", alt: "Guirnaldas con luz cálida ámbar para fiestas" },
          { src: "/img/guirnaldas/renta-guirnaldas-ceremonia-boda-pergola-focos-edison-15.avif", alt: "Pérgola con focos Edison para ceremonia rústica" },
          { src: "/img/guirnaldas/renta-guirnaldas-boda-exterior-guirnaldas-arco-floral-07.avif", alt: "Arco floral con guirnaldas para boda al aire libre" },
          { src: "/img/guirnaldas/renta-guirnaldas-ceremonia-boda-guirnaldas-edison-06.avif", alt: "Ceremonia iluminada con guirnaldas Edison" },
          { src: "/img/guirnaldas/renta-guirnaldas-boda-jardin-ceremonia-guirnaldas-05.avif", alt: "Jardín decorado con guirnaldas vintage" },
          { src: "/img/guirnaldas/renta-guirnaldas-baile-novios-hacienda-guirnaldas-41.avif", alt: "Baile de novios en hacienda bajo guirnaldas" },
          { src: "/img/guirnaldas/renta-guirnaldas-boda-patio-colonial-guirnaldas-21.avif", alt: "Patio colonial con guirnaldas para recepción" },
          { src: "/img/guirnaldas/renta-guirnaldas-brindis-boda-guirnaldas-exterior-14.avif", alt: "Brindis de boda con guirnaldas cálidas" },
          { src: "/img/guirnaldas/luces-decorativas-eventos-cdmx.avif", alt: "Luces decorativas vintage para eventos CDMX" },
          { src: "/img/guirnaldas/guirnaldas-led-fiestas-cdmx.avif", alt: "Guirnaldas LED para fiestas en CDMX" },
          { src: "/img/guirnaldas/renta-guirnaldas-ceremonia-atardecer-jardin-12.avif", alt: "Guirnaldas Edison al atardecer en jardín" },
          { src: "/img/guirnaldas/guirnaldas-decoracion-xv-anos.avif", alt: "Guirnaldas decorativas para XV años" },
          { src: "/img/guirnaldas/renta-guirnaldas-bodas-cdmx.avif", alt: "Renta de guirnaldas para bodas CDMX" },
        ]} />
      </div>
    </section>

    <!-- Paquetes -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Paquetes de Guirnaldas"
          subtitle="Desde una pérgola chica hasta un festival de 500+ personas."
          paragraph1="Cada paquete incluye focos Edison (LED o filamento a tu elección), cableado IP65, transporte, montaje, operación durante el evento y desmontaje. El precio ya incluye todo, no hay cargo extra por instalación ni por planta de luz si tu venue la necesita."
          paragraph2="Si tu evento no encaja en estos paquetes, armamos uno a la medida. Mándanos fotos del venue por WhatsApp y te respondemos con una propuesta en menos de 24 horas."
        />
        <PricingCards packages={[
          {
            name: "Básico — 50 metros",
            price: "$3,500",
            priceNote: "+ IVA",
            description: "Perfecto para terrazas pequeñas, pérgolas y ceremonias íntimas de hasta 50 invitados.",
            features: [
              { text: "50 metros lineales de guirnaldas", included: true },
              { text: "Focos Edison LED o vintage", included: true },
              { text: "Certificación IP65 exteriores", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Diseño de distribución incluido", included: true },
              { text: "Ideal para: pérgola, terraza, ceremonia", included: true },
              { text: "Asesoría personalizada", included: false },
              { text: "Dimmer para control de intensidad", included: false },
            ],
            ctaLabel: "Ver paquete 50 metros",
            ctaHref: "/servicios/guirnaldas/paquete-50-metros/",
          },
          {
            name: "Estándar — 100 metros",
            ctaHref: "/servicios/guirnaldas/paquete-100-metros/",
            price: "$6,500",
            priceNote: "+ IVA",
            badge: "Más popular",
            highlight: true,
            description: "El más pedido para bodas en jardín. Cubre el área de ceremonia + recepción para hasta 120 invitados.",
            features: [
              { text: "100 metros lineales de guirnaldas", included: true },
              { text: "Focos Edison LED o vintage", included: true },
              { text: "Certificación IP65 exteriores", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Diseño de distribución incluido", included: true },
              { text: "Ideal para: bodas, jardines, haciendas", included: true },
              { text: "Asesoría personalizada de montaje", included: true },
              { text: "Dimmer para control de intensidad", included: false },
            ],
            ctaLabel: "Ver paquete 100 metros",
          },
          {
            name: "Premium — 200 metros",
            ctaHref: "/servicios/guirnaldas/paquete-200-metros/",
            price: "$11,500",
            priceNote: "+ IVA",
            description: "Para bodas grandes y eventos corporativos. Cubre áreas amplias con iluminación completa para 200+ invitados.",
            features: [
              { text: "200 metros lineales de guirnaldas", included: true },
              { text: "Focos Edison LED o vintage", included: true },
              { text: "Certificación IP65 exteriores", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Diseño personalizado del montaje", included: true },
              { text: "Ideal para: haciendas, fincas, eventos grandes", included: true },
              { text: "Asesoría en sitio antes del evento", included: true },
              { text: "Dimmer para control de intensidad", included: true },
            ],
            ctaLabel: "Ver paquete 200 metros",
          },
          {
            name: "Producción — 500 metros",
            ctaHref: "/servicios/guirnaldas/paquete-500-metros/",
            price: "$24,000",
            priceNote: "+ IVA",
            description: "Producción completa para festivales, ferias, eventos masivos y venues de gran escala con 500+ invitados.",
            features: [
              { text: "500 metros lineales de guirnaldas", included: true },
              { text: "Focos Edison LED o vintage", included: true },
              { text: "Certificación IP65 exteriores", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Diseño personalizado + visita previa", included: true },
              { text: "Ideal para: festivales, ferias, venues grandes", included: true },
              { text: "Asesoría en sitio + prueba de iluminación", included: true },
              { text: "Dimmer + plantas de luz si se requiere", included: true },
            ],
            ctaLabel: "Ver paquete 500 metros",
          },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre Guirnaldas"
          subtitle="Lo que todos preguntan antes de cotizar."
          paragraph1="Si tienes otra duda sobre la renta de guirnaldas, escríbenos por WhatsApp y te respondemos en minutos."
          paragraph2="Cada espacio es diferente — por eso hacemos propuestas a la medida con el número exacto de metros que necesitas."
        />
      </div>
      <FaqSection items={[
        { question: "¿Cuántos metros de guirnaldas necesito?", answer: "Depende de cómo quieras distribuirlas. La regla rápida: multiplica el largo de tu espacio por 1.5 para líneas paralelas, o por 2 para cruce en zigzag. Un jardín de 100m² lleva entre 50 y 80 metros lineales. Una pérgola de 4x6m, unos 30 metros. Una carpa grande, 80-150 metros. Mándanos fotos de tu venue y te calculamos el metraje exacto." },
        { question: "¿Cuánto cuesta la renta?", answer: "Desde $3,500 para 50 metros (pérgola o terraza chica). Una boda estándar con 100 metros sale $6,500. Bodas grandes con 200+ metros, $11,500. Todo incluido: focos, cableado IP65, transporte, montaje y desmontaje. Cotiza por WhatsApp con fotos de tu espacio y te damos precio exacto." },
        { question: "¿Funcionan bajo lluvia?", answer: "Sí. Todo el cableado y las conexiones son IP65, certificados para lluvia directa. Hemos montado en julio y agosto en plena temporada de lluvias sin un solo problema. Lo único que cambia con lluvia es que los focos de filamento se ven todavía mejor porque el agua refleja la luz." },
        { question: "¿Cuál es la diferencia entre focos LED y filamento?", answer: "Los Edison LED producen el mismo tono ámbar pero consumen un tercio de la energía y no se calientan, ideales para montajes largos o venues con planta de luz limitada. Los de filamento real dan un brillo que oscila ligeramente, más parecido a una vela. Mismo precio. La diferencia es sutil en persona, pero los fotógrafos suelen preferir el filamento." },
        { question: "¿Cómo se instalan en jardines sin postes?", answer: "Llevamos postes telescópicos de aluminio que clavamos o lastramos con base de arena. En haciendas usamos las columnas y vigas existentes. En carpas, las guirnaldas van tensadas entre los postes de la estructura. El montaje toma 2-4 horas según la cantidad de metros. Llegamos temprano para que todo esté listo antes de que lleguen los invitados." },
        { question: "¿Puedo ver cómo va a quedar antes del evento?", answer: "Si contratas 100 metros o más, hacemos una visita previa al venue donde medimos, tomamos fotos y te mandamos un diagrama del montaje propuesto. En la visita definimos alturas, puntos de anclaje y la distribución de líneas. Así no hay sorpresas el día del evento." },
      ]} />
    </section>

    <!-- Servicios relacionados -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Combina con Otros Servicios"
          subtitle="Lo que más se pide junto con guirnaldas."
          paragraph1="La combinación más común en bodas: guirnaldas en el techo del jardín + uplighting ámbar en las columnas de la hacienda. Cubre arriba y abajo con un solo proveedor, y el técnico coordina todo junto."
          paragraph2="Cuando combinas dos o más servicios, el precio baja porque compartimos traslado, montaje y operador. Cuéntanos qué tienes en mente."
        />
        <div class="services-grid">
          {serviciosRelacionados.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Listo para iluminar tu evento con guirnaldas?</h2>
          <p>Mándanos fotos de tu venue por WhatsApp y te decimos cuántos metros necesitas, qué tipo de foco te conviene y el precio exacto.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
