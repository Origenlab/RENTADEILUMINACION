        </figure>
        <figure class="gallery-item">
          <img src="/img/guirnaldas/renta-guirnaldas-pareja-novios-guirnaldas-boda-32.avif" alt="Pareja de novios bajo guirnaldas de luces LED durante fiesta de boda al aire libre" width="800" height="533" loading="lazy">
