              { text: "50 metros lineales de guirnaldas", included: true },
              { text: "Focos Edison LED o vintage", included: true },
              { text: "Certificación IP65 exteriores", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Diseño de distribución incluido", included: true },
              { text: "Ideal para: pérgola, terraza, ceremonia", included: true },
              { text: "Asesoría personalizada", included: false },
              { text: "Dimmer para control de intensidad", included: false },
            ],
            ctaLabel: "Cotizar 50 metros",
