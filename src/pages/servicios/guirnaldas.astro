        </figure>
        <figure class="gallery-item">
          <img src="/img/guirnaldas/renta-guirnaldas-renta-luces-colgantes-fiestas-18.avif" alt="Series de luces colgantes tipo vintage iluminando fiesta nocturna en terraza" width="800" height="533" loading="lazy">
        </figure>
