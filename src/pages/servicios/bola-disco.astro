---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import PricingCards from '../../components/PricingCards.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Bola Disco para Fiestas y Bodas en CDMX | REDEIL";
const description = "Bola disco de espejos para pistas de baile — 30cm a 1.2m. Bodas, fiestas retro y XV años en CDMX. Desde $2,000 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/bola-disco/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Bola Disco para Eventos",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Servicio profesional de renta de bolas de espejos (bola disco) de 30cm a 1.2m para bodas, fiestas retro y eventos en CDMX. Instalación con motor y focos PAR incluidos.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Renta de Bola Disco",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿En qué tamaños viene la bola disco?", "acceptedAnswer": { "@type": "Answer", "text": "Contamos con bolas de espejos de 30cm (íntima), 50cm (estándar para salones), 80cm (grande para venues amplios) y 1.2m (gigante para producción). El tamaño ideal depende de la altura del techo y el tamaño de la pista de baile." }},
      { "@type": "Question", "name": "¿La instalación requiere estructura especial?", "acceptedAnswer": { "@type": "Answer", "text": "Necesitamos un punto de anclaje en el techo sobre la pista de baile — una viga, una argolla o un gancho de resistencia suficiente. Llevamos todo el cableado, el motor giratorio y los focos PAR para iluminar la bola. Inspeccionamos el punto de anclaje antes de instalar." }},
      { "@type": "Question", "name": "¿La bola disco viene con motor y focos?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Todos nuestros paquetes incluyen la bola, el motor giratorio de velocidad variable y los focos PAR de color que apuntan a la bola para crear el efecto de miles de destellos. Sin los focos PAR, la bola no produce el efecto visual completo." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "Máquina de Humo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Humo en pista de baile", description: "Los reflejos de la bola disco en el humo crean miles de puntos de luz flotantes. El combo más instagrameable.", link: "/servicios/maquina-humo/" },
  { title: "DJ para Fiestas", image: "/img/bocinas-djs/dj-para-eventos-cdmx-cabina-profesional-300w.avif", alt: "DJ profesional en cabina", description: "DJ + bola disco = fiesta completa. Música perfecta con el efecto visual clásico que nunca falla.", link: "/servicios/bocinas-djs/" },
  { title: "Luces Neón y UV", image: "/img/luces-neon/renta-luces-neon-glow-party-celebracion-neon-300w.avif", alt: "Luces neón en fiesta", description: "Bola disco dorada + luces UV = fiesta temática de otro nivel. Combinación perfecta para XV años.", link: "/servicios/luces-neon/" },
  { title: "Cabezas Móviles", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante-300w.avif", alt: "Cabezas móviles con beams", description: "Show de luces DMX + bola disco. Los beams + los destellos crean un espectáculo visual completo.", link: "/servicios/cabezas-moviles/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Bola Disco" }
  ]} />
</Fragment>

    <Hero
      title="Renta de Bola Disco para Bodas y Fiestas en CDMX"
      subtitle="Bolas de espejos de 30cm hasta 1.2m. Con motor, focos PAR y instalación profesional. Desde $2,000 + IVA."
      introParagraph1='Algo que la gente no sabe: una bola disco sin focos PAR apuntándole no hace nada. Los destellos que ves en la pista los producen los focos rebotando en los espejos, no la bola sola. Por eso todos nuestros paquetes incluyen la bola, el motor giratorio y los focos PAR de color. Sin los tres elementos juntos, no hay efecto. En <strong>REDEIL</strong> rentamos bolas de espejos en cuatro tamaños: 30cm para espacios íntimos, 50-60cm para salones estándar, 80cm para venues grandes y 1.2 metros para producciones.'
      introParagraph2='El tamaño correcto depende de la altura del techo, no del tamaño de la pista. Con techo de 3 metros, una bola de 30-40cm se ve bien. Con techo de 5 metros, necesitas mínimo 50-60cm para que los destellos lleguen al piso. La de 1.2 metros necesita techo de 8m+ y un punto de anclaje que aguante el peso. Nuestro equipo revisa el punto de anclaje antes de instalar. Si no hay dónde colgarla, llevamos estructura de truss portátil. El servicio incluye transporte, instalación, motor, focos PAR y desmontaje.'
    />

    <CtaBar
      headline="¿Para qué tipo de fiesta?"
      items={[
        { label: "Fiestas Retro", href: "#paquetes", icon: "efectos" },
        { label: "Bodas", href: "/eventos/bodas/", icon: "efectos" },
        { label: "XV Años", href: "/eventos/xv-anos/", icon: "efectos" },
        { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
      ]}
    />

    <!-- Galería -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="Bola disco en cuatro tamaños, cuatro ambientes"
          subtitle="El carácter lo definen los focos PAR, no la bola."
          paragraph1="La misma bola de 60cm se ve vintage y romántica con PAR en tono ámbar entre guirnaldas Edison. Con PAR multicolor en una fiesta de los 80s, es otro objeto. Con PAR azul en un coctel corporativo, se ve sofisticada. Lo que cambia no es la bola sino el color de los focos que la iluminan."
          paragraph2="En bodas rústicas en hacienda, la bola de espejos colgada entre guirnaldas es una combinación que nunca falla. Los reflejos dorados moviéndose por las paredes de piedra generan un ambiente que los invitados fotografían sin parar."
        />
        <Gallery4x4 images={[
          { src: "/img/bola-disco/bola-disco-gigante-fiesta-nocturna.avif", alt: "Bola disco gigante en fiesta nocturna" },
          { src: "/img/bola-disco/bola-disco-dj-pista-baile-evento.avif", alt: "Bola disco con DJ en pista de baile" },
          { src: "/img/bola-disco/bola-disco-dorada-boda-hacienda-romantica.avif", alt: "Bola disco dorada en boda romántica en hacienda" },
          { src: "/img/bola-disco/bola-disco-dorada-pista-baile-colores.avif", alt: "Bola disco dorada con destellos de colores en pista" },
          { src: "/img/bola-disco/renta-bola-disco-para-fiestas-cdmx.avif", alt: "Renta de bola disco para fiestas en CDMX" },
          { src: "/img/bola-disco/bola-disco-para-fiestas-tematicas-70s.avif", alt: "Bola disco para fiesta temática de los 70s" },
          { src: "/img/bola-disco/renta-bola-disco-fiesta-80s-90s.avif", alt: "Bola disco para fiesta de los 80s y 90s" },
          { src: "/img/bola-disco/bola-espejos-para-bodas-elegantes.avif", alt: "Bola de espejos para bodas elegantes" },
          { src: "/img/bola-disco/renta-bola-disco-salon-eventos.avif", alt: "Bola disco en salón de eventos" },
          { src: "/img/bola-disco/bola-disco-gigante-para-eventos.avif", alt: "Bola disco gigante para eventos especiales" },
          { src: "/img/bola-disco/bola-disco-moderna-coctel-corporativo.avif", alt: "Bola disco en coctel corporativo moderno" },
          { src: "/img/bola-disco/renta-bola-espejos-primer-baile-novios.avif", alt: "Bola de espejos para primer baile de novios" },
          { src: "/img/bola-disco/renta-de-bola-disco-pista-iluminada.avif", alt: "Pista de baile iluminada con bola disco" },
          { src: "/img/bola-disco/renta-de-bola-disco-xv-anos.avif", alt: "Bola disco para XV años" },
          { src: "/img/bola-disco/bola-disco-boda-rustica-guirnaldas.avif", alt: "Bola disco en boda rústica con guirnaldas" },
          { src: "/img/bola-disco/renta-bola-espejos-evento-premium.avif", alt: "Bola de espejos premium para evento especial" },
        ]} />
      </div>
    </section>

    <!-- Paquetes -->
    <section class="services-section services-alt" id="paquetes">
      <div class="container">
        <SectionHeader
          title="Paquetes de Bola Disco"
          subtitle="4 tamaños según tu pista de baile. Motor y focos PAR incluidos."
          paragraph1="Cada paquete incluye la bola de espejos, motor giratorio de velocidad variable, 2 focos PAR de color, sistema de anclaje, instalación profesional y desmontaje. El tamaño correcto depende de la altura del techo y el diámetro de la pista."
          paragraph2="¿No sabes qué tamaño necesitas? Mándanos fotos de tu venue y te recomendamos el ideal."
        />
        <PricingCards packages={[
          {
            name: "Compacta — 30-40cm",
            price: "$2,000",
            priceNote: "+ IVA",
            description: "La opción íntima para salones bajos y espacios pequeños. Destellos suaves para bodas vintage y fiestas privadas.",
            features: [
              { text: "Bola de espejos 30-40cm de diámetro", included: true },
              { text: "Motor giratorio con velocidad variable", included: true },
              { text: "2 focos PAR de color incluidos", included: true },
              { text: "Traslado + instalación + desmontaje", included: true },
              { text: "Ideal para: salones bajos, eventos íntimos", included: true },
              { text: "Instalación: techo hasta 3.5m de altura", included: true },
              { text: "Focos PAR adicionales", included: false },
              { text: "Motor de alta velocidad", included: false },
            ],
            ctaLabel: "Cotizar bola compacta",
            ctaHref: "/servicios/bola-disco/paquete-30cm/",
          },
          {
            name: "Estándar — 50-60cm",
            price: "$3,000",
            priceNote: "+ IVA",
            badge: "Más popular",
            highlight: true,
            description: "El tamaño más versátil — funciona en cualquier salón estándar de bodas y eventos. Destellos que cubren toda la pista.",
            features: [
              { text: "Bola de espejos 50-60cm de diámetro", included: true },
              { text: "Motor giratorio de velocidad variable", included: true },
              { text: "2 focos PAR de color incluidos", included: true },
              { text: "Traslado + instalación + desmontaje", included: true },
              { text: "Ideal para: salones estándar, bodas, XV años", included: true },
              { text: "Instalación: techo de 3m a 5m de altura", included: true },
              { text: "Cobertura completa de la pista", included: true },
              { text: "Focos PAR adicionales", included: false },
            ],
            ctaLabel: "Cotizar bola estándar",
            ctaHref: "/servicios/bola-disco/paquete-60cm/",
          },
          {
            name: "Grande — 80cm",
            price: "$4,500",
            priceNote: "+ IVA",
            description: "Para venues amplios y techos altos. Destellos de mayor alcance que cubren un salón completo de 300m².",
            features: [
              { text: "Bola de espejos 80cm de diámetro", included: true },
              { text: "Motor de alta potencia con velocidad variable", included: true },
              { text: "4 focos PAR de color incluidos", included: true },
              { text: "Traslado + instalación + desmontaje", included: true },
              { text: "Ideal para: salones grandes, haciendas", included: true },
              { text: "Instalación: techo de 4m a 8m de altura", included: true },
              { text: "Cobertura 300m² de pista", included: true },
              { text: "Instalación con andamio si requerido", included: true },
            ],
            ctaLabel: "Cotizar bola grande",
            ctaHref: "/servicios/bola-disco/paquete-90cm/",
          },
          {
            name: "Gigante — 1.2m",
            price: "$8,000",
            priceNote: "+ IVA",
            description: "La bola disco de producción. 1.2 metros de puro espectáculo para eventos masivos, festivales y venues de gran escala.",
            features: [
              { text: "Bola de espejos 1.2m de diámetro", included: true },
              { text: "Motor industrial de alta potencia", included: true },
              { text: "6 focos PAR de alta potencia", included: true },
              { text: "Traslado + instalación especializada", included: true },
              { text: "Andamio + equipo técnico completo", included: true },
              { text: "Inspección estructural del punto de anclaje", included: true },
              { text: "Ideal para: festivales, clubs, mega eventos", included: true },
              { text: "Visita previa obligatoria", included: true },
            ],
            ctaLabel: "Cotizar bola gigante",
            ctaHref: "/servicios/bola-disco/paquete-120cm/",
          },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre la Bola Disco"
          subtitle="Todo lo que necesitas saber antes de reservar."
          paragraph1="Si tienes otra duda, escríbenos por WhatsApp y te respondemos en minutos."
          paragraph2="Mándanos fotos de tu venue y te recomendamos el tamaño exacto que necesitas."
        />
      </div>
      <FaqSection items={[
        { question: "¿Qué tamaño de bola disco necesito para mi salón?", answer: "Como regla general: bola de 30-40cm para salones con techo de hasta 3.5m; 50-60cm para techos de 3 a 5m; 80cm para techos de 4 a 8m; 1.2m para venues de producción con techos de 8m+. Mándanos fotos de tu pista de baile y el techo y te recomendamos el tamaño exacto." },
        { question: "¿La bola de espejos viene con motor y focos?", answer: "Sí, siempre. Sin el motor, la bola no gira y sin los focos PAR apuntando a ella, no produce el efecto de destellos. Todos nuestros paquetes incluyen los tres elementos. Si quieres cambiar los colores durante la noche, usamos focos PAR con geles intercambiables." },
        { question: "¿Se puede instalar en el techo de cualquier salón?", answer: "En la mayoría de los salones, sí. Necesitamos un punto de anclaje resistente en el techo sobre la pista de baile — una viga, una argolla instalada o un punto de rigging. Nuestro equipo revisa el punto antes de instalar. Si no hay punto de anclaje, usamos una estructura de truss portátil (costo adicional)." },
        { question: "¿La bola disco es buena para bodas?", answer: "Absolutamente — especialmente para bodas con temática vintage, rústica o retro. Una bola de espejos de 50-60cm colgada entre guirnaldas Edison crea un ambiente único y muy fotogénico. Los reflejos sobre la pista de baile se ven increíbles en las fotos y videos." },
        { question: "¿Se puede combinar con máquina de humo?", answer: "Sí, y es uno de los combos más populares. Cuando el humo llena la pista y los focos PAR iluminan la bola disco, los reflejos se hacen visibles en el humo — miles de puntos de luz flotando en la neblina. El efecto es espectacular y muy fotogénico." },
        { question: "¿Cuánto tiempo toma la instalación?", answer: "Entre 30 y 60 minutos dependiendo del tamaño y la accesibilidad del punto de anclaje. Para bolas gigantes (1.2m) con andamio, 2-3 horas. Llegamos con tiempo suficiente para que todo esté listo antes del evento." },
      ]} />
    </section>

    <!-- Servicios relacionados -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Lo que más se combina con la bola disco"
          subtitle="Bola disco + máquina de humo = miles de puntos de luz flotando."
          paragraph1="Cuando el humo llena la pista y los focos PAR iluminan la bola, cada reflejo se hace visible flotando en la neblina. Son miles de puntos de luz moviéndose en el aire. El efecto se ve en persona mucho mejor que en fotos. Si agregas un DJ, la velocidad de giro de la bola se coordina con el ritmo."
          paragraph2="Precio especial cuando combinas bola disco con otros servicios."
        />
        <div class="services-grid">
          {serviciosRelacionados.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Lista para llenar tu pista de destellos?</h2>
          <p>Mándanos fotos de tu salón y el tipo de evento. Te decimos qué tamaño de bola es el ideal y te cotizamos en minutos.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
