---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import GallerySection from "../../components/GallerySection.astro";
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const title = "Renta de Bola de Disco para Eventos | REDEIL CDMX";
const description = "Renta de bola de disco y esfera de espejos para fiestas y eventos en CDMX. REDEIL instala bolas de disco profesionales para bodas, cumpleaños y fiestas temáticas.";
const canonical = "https://rentadeiluminacion.com/servicios/bola-disco/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Bola de Disco para Eventos",
  "provider": {
    "@type": "LocalBusiness",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com",
    "telephone": "+525530682988",
    "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressCountry": "MX" }
  },
  "description": "Servicio profesional de renta de bolas de disco y esferas de espejos para fiestas, bodas, cumpleaños y eventos temáticos en Ciudad de México.",
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "serviceType": "Renta de Bola de Disco"
});
---
<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Servicios", href: "/servicios/" }, { label: "Bola de Disco" }]} />
</Fragment>
<Hero
      title="Bola de Disco para Eventos en CDMX"
      subtitle="La esfera de espejos clásica que llena de brillo cualquier celebración"
      introParagraph1="REDEIL ofrece renta de bolas de disco profesionales para todo tipo de eventos en la Ciudad de México. Nuestras esferas de espejos, combinadas con iluminación adecuada, crean un espectáculo de reflejos que transforma la pista de baile y el ambiente general de tu fiesta."
      introParagraph2="Con experiencia en bodas, cumpleaños, fiestas retro, eventos corporativos y celebraciones temáticas, instalamos bolas de disco de distintos tamaños según las necesidades de cada espacio. Nuestro equipo técnico se encarga de todo el proceso de montaje y desmontaje."
    />
    <section class="service-detail">
      <SectionHeader
          title="Esferas de espejos que transforman la pista de baile"
          subtitle="Instalación profesional incluida en CDMX y Edomex."
          paragraph1="La bola de disco es un elemento icónico que nunca pasa de moda. Sus cientos de pequeños espejos reflejan la luz en todas direcciones, creando un manto de destellos que envuelve a los invitados y convierte cualquier espacio en una pista de baile vibrante y festiva."
          paragraph2="En REDEIL contamos con esferas de espejos de diferentes dimensiones, adecuadas tanto para salones amplios como para espacios más íntimos. Cada bola de disco se instala con un motor de rotación y se complementa con luminarias tipo pinspot o LED para maximizar el efecto de reflejos."
        />
        <p>Ya sea para una fiesta temática de los 70s, un cumpleaños retro o una boda con toque divertido, la bola de disco aporta un elemento visual y emocional que eleva la energía de la celebración. Cubrimos eventos en toda la CDMX y zona metropolitana con servicio profesional completo.</p>
      </div>
    </section>
    <GallerySection title="Galería de Bola de Disco" subtitle="Instalaciones de esferas de espejos en eventos reales">
      <figure class="gallery-item">
        <img src="/img/bola-disco/bola-disco-para-fiestas-tematicas-70s.avif" alt="Bola de disco brillando en fiesta temática de los años 70" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bola-disco/detalle-espejos-bola-disco-profesional.avif" alt="Detalle de los espejos de una bola de disco profesional reflejando luces" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bola-disco/renta-bola-espejos-gala-empresarial.avif" alt="Esfera de espejos instalada en gala empresarial con iluminación elegante" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bola-disco/bola-disco-grande-para-salones.avif" alt="Bola de disco de gran tamaño iluminando salón de eventos" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bola-disco/bola-disco-fiesta-salon-clasico.avif" alt="Bola de disco proyectando reflejos en salón clásico durante fiesta" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bola-disco/bola-disco-para-eventos-corporativos.avif" alt="Bola de disco como elemento decorativo en evento corporativo nocturno" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bola-disco/renta-bola-disco-fiesta-tematica.avif" alt="Esfera de espejos girando durante fiesta temática con luces de colores" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bola-disco/bola-disco-para-cumpleanos-retro.avif" alt="Bola de disco iluminando pista de baile en cumpleaños retro" width="800" height="533" loading="lazy">
      </figure>
    </GallerySection>
</BaseLayout>
