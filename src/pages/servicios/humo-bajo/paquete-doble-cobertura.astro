const title = "Humo Bajo Doble Cobertura para Haciendas — $8,500 + IVA | REDEIL";
const description = "2 máquinas de niebla baja para haciendas y salones grandes. Pista completamente cubierta. $8,500 + IVA en CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/humo-bajo/paquete-doble-cobertura/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Paquete Doble Cobertura — Humo Bajo para Haciendas y Salones Grandes",
    "description": "2 máquinas de niebla baja profesional para haciendas, salones grandes y eventos corporativos. Doble caudal para cobertura completa de pistas amplias. Fluido ilimitado, 2 operadores y activaciones sincronizadas. Traslado incluido en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/humo-bajo/paquete-doble-cobertura/",
      "priceCurrency": "MXN",
      "price": "8500",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "61",
      "reviewCount": "61"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Gabriela Herrera Montoya" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Nuestra boda fue en la Hacienda San Miguel de Allende en Tepotzotlán. La pista de baile era enorme y con 2 máquinas quedó completamente cubierta de niebla. Los novios entramos caminando sobre nubes de lado a lado. Las fotos del dron quedaron espectaculares."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Eduardo Jiménez Salazar" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Evento corporativo en el Salón Real de la Hacienda de los Morales. Necesitábamos que toda la pista central tuviera niebla para la presentación de producto. Las 2 máquinas cubrieron los 10 metros de ancho sin problema. El equipo de REDEIL fue impecable."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Lucía Reyes Domínguez" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Boda en la Hacienda Buenavista de Cuernavaca. El jardín donde fue el vals era muy grande y una sola máquina no habría alcanzado. Con 2 máquinas sincronizadas, la niebla cubrió toda el área. El vals fue espectacular. Todos los invitados lo comentaron."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/humo-bajo/niebla-baja-boda-hacienda-mexicana.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Por qué necesito 2 máquinas de humo bajo?", "acceptedAnswer": { "@type": "Answer", "text": "En haciendas con jardines amplios, salones grandes o pistas de baile de más de 6 metros de ancho, una sola máquina no alcanza a cubrir toda la superficie con niebla densa. Con 2 máquinas posicionadas en lados opuestos de la pista, la cobertura es completa y uniforme — la niebla se encuentra en el centro y crea una capa densa de lado a lado." }},
      { "@type": "Question", "name": "¿Las 2 máquinas se activan al mismo tiempo?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Los 2 operadores trabajan sincronizados — ambas máquinas se activan simultáneamente para que la niebla avance desde ambos lados de la pista y se encuentre en el centro. El resultado es una cobertura uniforme sin huecos ni zonas sin niebla." }},
      { "@type": "Question", "name": "¿El paquete funciona en jardines de hacienda al aire libre?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. En jardines al aire libre, la ventaja de tener 2 máquinas es que compensan la disipación por el viento. Mientras una máquina cubre el lado protegido, la otra refuerza el lado expuesto. El efecto en haciendas al aire libre sigue siendo espectacular." }},
      { "@type": "Question", "name": "¿Cuánto mide la cobertura con 2 máquinas?", "acceptedAnswer": { "@type": "Answer", "text": "Con 2 máquinas de niebla baja profesional, la cobertura alcanza pistas de hasta 12x12 metros o más. Es suficiente para los jardines y patios centrales de la mayoría de las haciendas en CDMX y Estado de México." }},
      { "@type": "Question", "name": "¿El paquete incluye activaciones múltiples?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El paquete Doble Cobertura incluye fluido ilimitado y operadores durante 4-6 horas. Puedes activar la niebla en el vals, la entrada, el brindis y cualquier otro momento de la recepción. Cada activación cubre la pista completa con doble caudal." }},
      { "@type": "Question", "name": "¿Es adecuado para eventos corporativos en haciendas?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El paquete Doble Cobertura es popular para presentaciones de producto, cenas de gala y convenciones en haciendas y salones grandes. La niebla baja crea un efecto dramático para momentos de revelación o entradas especiales. La operación es completamente discreta y profesional." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Vals Único", image: "/img/humo-bajo/humo-bajo-primer-vals-romantico.avif", alt: "Humo bajo para vals único de boda", description: "1 máquina para un solo momento estelar. Ideal para bodas íntimas. $3,500 + IVA.", link: "/servicios/humo-bajo/paquete-vals-unico/" },
  { title: "Recepción Completa", image: "/img/humo-bajo/humo-bajo-boda-salon-iluminacion.avif", alt: "Niebla baja para toda la recepción", description: "1 máquina con fluido ilimitado para toda la noche. Activaciones múltiples. $5,500 + IVA.", link: "/servicios/humo-bajo/paquete-recepcion-completa/" },
  { title: "Producción Premium", image: "/img/humo-bajo/primer-baile-novios-humo-bajo-seguidor.avif", alt: "Producción premium con humo bajo y seguidor", description: "Humo bajo + seguidor de luz + cabezas móviles. La producción completa. $13,000 + IVA.", link: "/servicios/humo-bajo/paquete-produccion-premium/" },
  { title: "Seguidor de Luz", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Seguidor de luz para vals en hacienda", description: "Niebla baja cubriendo la pista + spotlight siguiendo a los novios. El combo favorito en haciendas.", link: "/servicios/seguidor/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Humo Bajo", href: "/servicios/humo-bajo/" },
    { label: "Doble Cobertura" }
  ]} />
</Fragment>

  <Hero
    title="Humo Bajo Doble Cobertura — 2 Máquinas para Haciendas"
    subtitle="Desde $8,500 + IVA. 2 máquinas sincronizadas. Pista completamente cubierta. Para haciendas y salones grandes."
    introParagraph1='Las haciendas y los salones grandes tienen pistas de baile que una sola máquina de niebla baja no alcanza a cubrir. El paquete <strong>Doble Cobertura</strong> de <strong>REDEIL</strong> resuelve eso con 2 máquinas profesionales posicionadas en lados opuestos de la pista: la niebla avanza desde ambos extremos, se encuentra en el centro y crea una capa densa y uniforme de lado a lado. Sin huecos, sin zonas descubiertas.'
    introParagraph2='Es el paquete preferido para bodas en haciendas de Tepotzotlán, Cuernavaca, Valle de Bravo y la zona metropolitana de la CDMX — venues donde los jardines son amplios y el viento puede disipar la niebla de una sola máquina. Con doble caudal, fluido ilimitado y 2 operadores sincronizados, la cobertura es completa durante toda la recepción. También es la opción ideal para eventos corporativos en salones grandes donde se necesita un efecto dramático en pistas de más de 8 metros. Traslado, montaje y desmontaje incluidos.'
  />


  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Doble Cobertura"
      price="$8,500"
      priceNote="+ IVA · 2 máquinas · Cobertura total"
      features={[
        { text: "2 máquinas de niebla baja profesional" },
        { text: "Doble caudal — pista cubierta de lado a lado" },
        { text: "Fluido ilimitado toda la noche" },
        { text: "2 operadores técnicos sincronizados" },
        { text: "Activaciones múltiples a demanda" },
        { text: "Coordinación con DJ/MC/wedding planner" },
        { text: "Traslado ida y vuelta" },
        { text: "Montaje y desmontaje incluidos" },
        { text: "Ideal: haciendas y salones grandes" },
        { text: "Cobertura: pistas hasta 12x12 metros" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete Doble Cobertura de humo bajo para una hacienda grande."
      packages={[
        { label: "Vals Único", price: "$3,500", href: "/servicios/humo-bajo/paquete-vals-unico/" },
        { label: "Recepción Completa", price: "$5,500", href: "/servicios/humo-bajo/paquete-recepcion-completa/" },
        { label: "Doble Cobertura", price: "$8,500", href: "/servicios/humo-bajo/paquete-doble-cobertura/", active: true },
        { label: "Producción Premium", price: "$13,000", href: "/servicios/humo-bajo/paquete-produccion-premium/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="¿Dónde rinde la doble cobertura de niebla baja?"
          subtitle="Haciendas, jardines amplios y salones de más de 200 invitados."
          paragraph1="La doble cobertura no es solo más niebla — es niebla uniforme. En pistas grandes, una sola máquina crea niebla densa cerca del equipo pero tenue en el extremo opuesto. Con 2 máquinas, la densidad es igual en toda la superficie."
          paragraph2="Los operadores posicionan las máquinas estratégicamente según la forma de la pista, la dirección del viento y la ubicación de los novios para maximizar el impacto visual."
        />
        <FeatureGrid features={[
          { title: "Haciendas con Patio Central", description: "Los patios centrales de haciendas son amplios. 2 máquinas en esquinas opuestas cubren todo el patio con niebla densa." },
          { title: "Jardines al Aire Libre", description: "En jardines donde el viento disipa la niebla, el doble caudal compensa la pérdida y mantiene la cobertura." },
          { title: "Salones de más de 200 Invitados", description: "Pistas de baile de 8-12 metros necesitan doble cobertura para que el efecto sea visible desde todas las mesas." },
          { title: "Eventos Corporativos", description: "Presentaciones de producto, cenas de gala y convenciones donde la pista central debe tener cobertura completa." },
          { title: "Bodas en Haciendas de Tepotzotlán", description: "Las haciendas de Tepotzotlán tienen jardines amplios. La doble cobertura es la opción correcta." },
          { title: "Producciones con Escenario", description: "Cuando el escenario y la pista necesitan niebla simultánea, 2 máquinas cubren ambas zonas." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="2 máquinas sincronizadas: cobertura sin huecos"
          subtitle="La niebla avanza desde ambos lados y se encuentra en el centro de la pista."
          paragraph1="La clave del paquete Doble Cobertura es la sincronización. Los 2 operadores activan las máquinas al mismo tiempo y con el mismo caudal. La niebla avanza hacia el centro desde ambos extremos y crea una capa uniforme sin zonas descubiertas."
          paragraph2="El resultado visual desde las mesas de los invitados y desde el dron de video es una alfombra blanca perfecta de pared a pared. No hay ningún ángulo donde el efecto se vea incompleto."
        />
        <FeatureGrid features={[
          { title: "Activación Simultánea", description: "Ambas máquinas arrancan al mismo tiempo. La niebla llega al centro de la pista en segundos." },
          { title: "Posicionamiento Estratégico", description: "Los operadores eligen la posición según el viento, la forma de la pista y la dirección de las cámaras." },
          { title: "Caudal Coordinado", description: "Ambas máquinas producen la misma cantidad de niebla para que la densidad sea uniforme." },
          { title: "Cobertura 12x12m", description: "Con 2 máquinas, la cobertura alcanza pistas de hasta 12 metros por lado sin perder densidad." },
          { title: "Compensación de Viento", description: "En exteriores, la máquina en el lado del viento aumenta el caudal para compensar la disipación." },
          { title: "Vista Espectacular para Dron", description: "La cobertura total de la pista se ve espectacular en tomas aéreas de dron y video." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="5 estrellas en 61 reseñas verificadas."
          paragraph1="Bodas en haciendas y eventos corporativos en salones grandes de CDMX y Estado de México."
          paragraph2="Pregunta por referencias de haciendas similares a la tuya cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Gabriela Herrera Montoya", event: "Boda — Hacienda San Miguel, Tepotzotlán", rating: 5, text: "La pista de baile era enorme y con 2 máquinas quedó completamente cubierta de niebla. Entramos caminando sobre nubes de lado a lado. Las fotos del dron quedaron espectaculares." },
          { name: "Eduardo Jiménez Salazar", event: "Corporativo — Hacienda de los Morales", rating: 5, text: "Necesitábamos que toda la pista central tuviera niebla para la presentación de producto. Las 2 máquinas cubrieron los 10 metros de ancho sin problema. Impecable." },
          { name: "Lucía Reyes Domínguez", event: "Boda — Hacienda Buenavista, Cuernavaca", rating: 5, text: "El jardín del vals era muy grande y con 2 máquinas sincronizadas la niebla cubrió toda el área. El vals fue espectacular. Todos los invitados lo comentaron." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Niebla baja en haciendas y salones grandes"
        subtitle="Doble cobertura para pistas amplias — eventos reales en CDMX y Estado de México."
        paragraph1="Estas fotos son de bodas y eventos donde se usaron 2 máquinas de niebla baja para cubrir pistas grandes. La diferencia entre una y dos máquinas es visible: la niebla es densa y uniforme en toda la superficie."
        paragraph2="¿Quieres ver cómo quedaría en tu hacienda? Mándanos fotos del espacio por WhatsApp y te decimos la posición ideal para las 2 máquinas."
      />
      <Gallery4x4 images={[
        { src: "/img/humo-bajo/niebla-baja-boda-hacienda-mexicana.avif", alt: "Niebla baja en boda de hacienda mexicana con doble cobertura" },
        { src: "/img/humo-bajo/renta-humo-bajo-evento-hacienda.avif", alt: "Renta de humo bajo para evento en hacienda grande" },
        { src: "/img/humo-bajo/primer-baile-novios-humo-bajo-seguidor.avif", alt: "Primer baile de novios con humo bajo y seguidor en hacienda" },
        { src: "/img/humo-bajo/humo-bajo-profesional-evento-nocturno.avif", alt: "Humo bajo profesional en evento nocturno de hacienda" },
        { src: "/img/humo-bajo/renta-niebla-baja-pista-baile-boda.avif", alt: "Pista de baile grande con niebla baja para boda en hacienda" },
        { src: "/img/humo-bajo/humo-bajo-boda-salon-iluminacion.avif", alt: "Salón grande con humo bajo e iluminación profesional" },
        { src: "/img/humo-bajo/efecto-nubes-piso-boda-jardin.avif", alt: "Efecto de nubes en el piso de jardín amplio de hacienda" },
        { src: "/img/humo-bajo/vals-boda-humo-bajo-iluminacion-romantica.avif", alt: "Vals de boda con humo bajo en hacienda iluminada" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete Doble Cobertura"
        subtitle="Todo sobre niebla baja con 2 máquinas para haciendas y salones grandes."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp al 55 3068 2988. Respondemos en minutos."
        paragraph2="Cuéntanos el tamaño de la pista y el tipo de venue — te confirmamos si necesitas 1 o 2 máquinas."
      />
    </div>
    <FaqSection items={[
      { question: "¿Por qué necesito 2 máquinas de humo bajo?", answer: "En haciendas con jardines amplios, salones grandes o pistas de baile de más de 6 metros de ancho, una sola máquina no alcanza a cubrir toda la superficie con niebla densa. Con 2 máquinas posicionadas en lados opuestos de la pista, la cobertura es completa y uniforme — la niebla se encuentra en el centro y crea una capa densa de lado a lado." },
      { question: "¿Las 2 máquinas se activan al mismo tiempo?", answer: "Sí. Los 2 operadores trabajan sincronizados — ambas máquinas se activan simultáneamente para que la niebla avance desde ambos lados de la pista y se encuentre en el centro. El resultado es una cobertura uniforme sin huecos ni zonas sin niebla." },
      { question: "¿El paquete funciona en jardines de hacienda al aire libre?", answer: "Sí. En jardines al aire libre, la ventaja de tener 2 máquinas es que compensan la disipación por el viento. Mientras una máquina cubre el lado protegido, la otra refuerza el lado expuesto. El efecto en haciendas al aire libre sigue siendo espectacular." },
      { question: "¿Cuánto mide la cobertura con 2 máquinas?", answer: "Con 2 máquinas de niebla baja profesional, la cobertura alcanza pistas de hasta 12x12 metros o más. Es suficiente para los jardines y patios centrales de la mayoría de las haciendas en CDMX y Estado de México." },
      { question: "¿El paquete incluye activaciones múltiples?", answer: "Sí. El paquete Doble Cobertura incluye fluido ilimitado y operadores durante 4-6 horas. Puedes activar la niebla en el vals, la entrada, el brindis y cualquier otro momento de la recepción. Cada activación cubre la pista completa con doble caudal." },
      { question: "¿Es adecuado para eventos corporativos en haciendas?", answer: "Sí. El paquete Doble Cobertura es popular para presentaciones de producto, cenas de gala y convenciones en haciendas y salones grandes. La niebla baja crea un efecto dramático para momentos de revelación o entradas especiales. La operación es completamente discreta y profesional." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes de Humo Bajo"
        subtitle="¿Necesitas menos cobertura o una producción completa?"
        paragraph1="Si tu pista es más pequeña, el paquete Recepción Completa con 1 máquina es suficiente. Para una producción integral con humo bajo + seguidor + cabezas móviles, el paquete Premium lo incluye todo."
        paragraph2="Propuestas integrales con precio especial cuando combinas 2 o más servicios."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Tu hacienda necesita doble cobertura de niebla?</h2>
        <p>Mándanos fotos de la pista y del jardín por WhatsApp. Te decimos la posición ideal para las 2 máquinas y te cotizamos en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
