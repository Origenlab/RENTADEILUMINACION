---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Humo Bajo para Vals de Boda — Paquete $3,500 + IVA | REDEIL";
const description = "Niebla baja para el vals de tu boda. 1 máquina CO₂, operador y fluido incluidos. Sin olor, sin residuo. $3,500 + IVA en CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/humo-bajo/paquete-vals-unico/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Paquete Vals Único — Humo Bajo para Primer Baile de Boda",
    "description": "1 máquina de niebla baja CO₂ profesional para el vals de tu boda. Incluye operador técnico, fluido de glicol certificado, traslado y coordinación con DJ. Sin olor, sin residuo. Ideal para bodas íntimas en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/humo-bajo/paquete-vals-unico/",
      "priceCurrency": "MXN",
      "price": "3500",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "58",
      "reviewCount": "58"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Mariana López Herrera" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Contratamos el paquete de vals único para nuestra boda íntima en la Terraza Palmas de Coyoacán. Éramos 60 invitados y el efecto fue perfecto — las nubes cubrieron toda la pista pequeña. El operador activó la niebla justo cuando empezó la canción. Fotos increíbles."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Ricardo Fuentes Garza" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Boda en casa con terraza en San Ángel. La máquina de humo bajo fue el detalle que hizo diferente nuestro vals. Sin olor, sin residuo en el piso de madera. Los invitados no dejaban de tomar fotos. Muy profesional el equipo de REDEIL."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Daniela Ortiz Ramírez" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Nuestro vals en el Jardín Florencia de Tlalpan quedó como de película. La niebla baja cubrió el piso y con la iluminación del jardín se veía mágico. El operador llegó 2 horas antes y coordinó todo con el DJ. Precio justo para lo que ofrecen."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/humo-bajo/humo-bajo-primer-vals-romantico.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿1 máquina de humo bajo es suficiente para el vals?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Para el vals de una boda íntima o una pista de baile estándar (hasta 6x6 metros), una máquina de niebla baja profesional cubre toda la superficie. El operador posiciona el equipo estratégicamente para que la niebla se distribuya de manera uniforme durante los 3-4 minutos que dura el vals." }},
      { "@type": "Question", "name": "¿El humo bajo funciona en terrazas o jardines pequeños?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, funciona perfectamente. En espacios al aire libre pequeños como terrazas o jardines de casa, la niebla baja permanece pegada al piso. Si hay brisa ligera, el operador ajusta el caudal para compensar. En terrazas techadas el efecto es aún más denso y duradero." }},
      { "@type": "Question", "name": "¿Cuánto dura el efecto de niebla durante el vals?", "acceptedAnswer": { "@type": "Answer", "text": "Cada activación produce niebla densa durante 3-5 minutos — exactamente lo que dura un vals. El operador activa la máquina 30 segundos antes de que los novios salgan a la pista para que el efecto esté en su punto máximo cuando empieza la música." }},
      { "@type": "Question", "name": "¿El paquete de $3,500 incluye todo?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Los $3,500 + IVA incluyen la máquina de niebla baja profesional, fluido de glicol certificado (1 carga), operador técnico, traslado ida y vuelta, montaje, desmontaje y coordinación con el DJ o maestro de ceremonias. Sin costos ocultos en CDMX y zona metropolitana." }},
      { "@type": "Question", "name": "¿Se puede usar en una boda en casa?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, es uno de los usos más populares del paquete Vals Único. La máquina es compacta y el fluido de glicol no mancha pisos de madera, mármol ni alfombras. No genera olor y se disipa sin dejar residuo. Ideal para bodas íntimas en casa o terraza." }},
      { "@type": "Question", "name": "¿Puedo agregar una segunda activación?", "acceptedAnswer": { "@type": "Answer", "text": "El paquete Vals Único incluye fluido para una activación principal. Si necesitas niebla baja para el vals y otro momento (entrada, brindis, corte de pastel), te recomendamos el paquete Recepción Completa ($5,500 + IVA) que incluye fluido ilimitado y activaciones múltiples toda la noche." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Recepción Completa", image: "/img/humo-bajo/humo-bajo-boda-salon-iluminacion.avif", alt: "Niebla baja para toda la recepción de boda", description: "Niebla baja para todos los momentos: vals, entrada, brindis. Activaciones múltiples. $5,500 + IVA.", link: "/servicios/humo-bajo/paquete-recepcion-completa/" },
  { title: "Doble Cobertura", image: "/img/humo-bajo/niebla-baja-boda-hacienda-mexicana.avif", alt: "2 máquinas de humo bajo para hacienda", description: "2 máquinas para haciendas y salones grandes. Pista completamente cubierta. $8,500 + IVA.", link: "/servicios/humo-bajo/paquete-doble-cobertura/" },
  { title: "Producción Premium", image: "/img/humo-bajo/primer-baile-novios-humo-bajo-seguidor.avif", alt: "Producción premium con humo bajo y seguidor", description: "Humo bajo + seguidor de luz + cabezas móviles. La producción completa. $13,000 + IVA.", link: "/servicios/humo-bajo/paquete-produccion-premium/" },
  { title: "Seguidor de Luz", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Seguidor de luz para vals de boda", description: "La combinación perfecta: niebla baja + spotlight siguiendo a los novios. El vals que todos recuerdan.", link: "/servicios/seguidor/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Humo Bajo", href: "/servicios/humo-bajo/" },
    { label: "Paquete Vals Único" }
  ]} />
</Fragment>

  <Hero
    title="Humo Bajo para Vals de Boda — Paquete Vals Único"
    subtitle="Desde $3,500 + IVA. 1 máquina de niebla baja CO₂. Operador y fluido incluidos. El vals sobre nubes."
    introParagraph1='El vals es el momento más fotografiado de una boda — y cuando los novios bailan sobre una capa de nubes blancas a nivel del piso, ese momento se convierte en la imagen que todos comparten. El paquete <strong>Vals Único</strong> de <strong>REDEIL</strong> está diseñado para bodas íntimas: una máquina de niebla baja profesional que cubre la pista de baile con humo bajo denso y uniforme durante los 3-4 minutos que dura la canción.'
    introParagraph2='Usamos equipos de niebla baja con fluido de glicol farmacéutico certificado: sin olor, sin residuo, sin manchar vestidos ni pisos. Ideal para bodas en casa, terrazas pequeñas, jardines íntimos y salones de hasta 100 invitados. El operador llega con anticipación, coordina con el DJ el momento exacto de activación y controla el caudal para que la niebla esté en su punto máximo cuando la música empieza. Traslado, montaje y desmontaje incluidos en toda la <strong>CDMX y Estado de México</strong>.'
  />


  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Vals Único"
      price="$3,500"
      priceNote="+ IVA · 1 máquina · Operador incluido"
      features={[
        { text: "1 máquina de niebla baja profesional" },
        { text: "Fluido de glicol certificado (1 carga)" },
        { text: "Operador técnico incluido" },
        { text: "Traslado ida y vuelta CDMX" },
        { text: "Montaje y desmontaje incluidos" },
        { text: "Coordinación con DJ/MC" },
        { text: "Sin olor, sin residuo" },
        { text: "Ideal: vals, entrada o corte de pastel" },
        { text: "Cobertura: pista hasta 6x6 metros" },
        { text: "Compatible con cualquier tipo de piso" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete Vals Único de humo bajo para el vals de mi boda íntima."
      packages={[
        { label: "Vals Único", price: "$3,500", href: "/servicios/humo-bajo/paquete-vals-unico/", active: true },
        { label: "Recepción Completa", price: "$5,500", href: "/servicios/humo-bajo/paquete-recepcion-completa/" },
        { label: "Doble Cobertura", price: "$8,500", href: "/servicios/humo-bajo/paquete-doble-cobertura/" },
        { label: "Producción Premium", price: "$13,000", href: "/servicios/humo-bajo/paquete-produccion-premium/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="¿Para qué momentos es ideal el paquete Vals Único?"
          subtitle="Un solo momento estelar: el vals sobre nubes blancas."
          paragraph1="El paquete Vals Único está pensado para bodas íntimas donde un solo momento necesita niebla baja. No necesitas cubrir toda la noche — necesitas que el vals sea perfecto."
          paragraph2="La máquina se coloca a un lado de la pista y el operador controla el caudal para una cobertura densa y uniforme durante toda la canción."
        />
        <FeatureGrid features={[
          { title: "Vals de Novios", description: "El primer baile sobre una capa de nubes blancas. La foto que los novios enmarcan." },
          { title: "Boda Íntima en Casa", description: "Perfecto para bodas de 30-80 invitados en casa o terraza. La máquina es compacta y discreta." },
          { title: "Entrada de la Novia", description: "La novia camina hacia el altar o la pista sobre niebla baja. Un momento cinematográfico." },
          { title: "Terraza o Jardín Pequeño", description: "Funciona perfecto en espacios al aire libre pequeños. El efecto se mantiene pegado al piso." },
          { title: "Corte de Pastel", description: "Niebla baja alrededor de la mesa del pastel para un momento fotogénico único." },
          { title: "Brindis Especial", description: "El brindis de los padres o padrinos con una capa de niebla que eleva el momento." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="¿Por qué elegir niebla baja en lugar de humo convencional?"
          subtitle="El humo bajo permanece en el piso — el humo convencional llena el salón."
          paragraph1="La diferencia es fundamental: una máquina de humo convencional genera una nube que sube y llena todo el espacio, dificulta la visibilidad y puede irritar los ojos. La niebla baja permanece pegada al piso durante 3-5 minutos y se disipa sin subir."
          paragraph2="El resultado es una capa blanca densa a nivel del suelo que hace que los novios parezcan flotar. Los invitados ven todo con claridad, las fotos quedan perfectas y el efecto no activa alarmas de humo."
        />
        <FeatureGrid features={[
          { title: "Permanece en el Piso", description: "La niebla no sube — crea una alfombra blanca densa que cubre solo el suelo." },
          { title: "Sin Olor ni Residuo", description: "Fluido de glicol farmacéutico. No mancha vestidos, zapatos ni pisos de ningún material." },
          { title: "No Activa Alarmas", description: "Al mantenerse a nivel del piso, la niebla generalmente no llega a los detectores de humo." },
          { title: "Fotos Espectaculares", description: "Las fotos del vals con niebla baja son las más compartidas en redes sociales." },
          { title: "Seguro para Invitados", description: "Los invitados pueden caminar sobre la niebla sin problema. Apto para niños y adultos mayores." },
          { title: "Control de Timing", description: "El operador activa el efecto en el segundo exacto. Coordinación perfecta con el DJ." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="5 estrellas en 58 reseñas verificadas."
          paragraph1="Bodas íntimas en casas, terrazas y jardines de CDMX con el paquete Vals Único."
          paragraph2="Pregunta por referencias de venues similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Mariana López Herrera", event: "Boda — Terraza Palmas, Coyoacán", rating: 5, text: "Éramos 60 invitados y el efecto fue perfecto — las nubes cubrieron toda la pista. El operador activó la niebla justo cuando empezó la canción. Fotos increíbles." },
          { name: "Ricardo Fuentes Garza", event: "Boda en casa — San Ángel", rating: 5, text: "La máquina de humo bajo fue el detalle que hizo diferente nuestro vals. Sin olor, sin residuo en el piso de madera. Muy profesional." },
          { name: "Daniela Ortiz Ramírez", event: "Boda — Jardín Florencia, Tlalpan", rating: 5, text: "Nuestro vals quedó como de película. La niebla baja cubrió el piso y con la iluminación del jardín se veía mágico. Precio justo para lo que ofrecen." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="El vals sobre nubes — bodas íntimas reales"
        subtitle="Niebla baja en terrazas, jardines y salones pequeños de CDMX."
        paragraph1="Estas fotos son de bodas reales donde se contrató el paquete Vals Único. Una sola máquina, bien posicionada, transforma por completo el momento del primer baile."
        paragraph2="¿Quieres ver cómo quedaría en tu venue? Mándanos fotos de la pista por WhatsApp y te mostramos el resultado esperado."
      />
      <Gallery4x4 images={[
        { src: "/img/humo-bajo/humo-bajo-primer-vals-romantico.avif", alt: "Primer vals romántico con niebla baja en el piso" },
        { src: "/img/humo-bajo/vals-boda-humo-bajo-iluminacion-romantica.avif", alt: "Vals de boda con humo bajo e iluminación romántica" },
        { src: "/img/humo-bajo/humo-bajo-romantico-primer-baile.avif", alt: "Primer baile romántico de novios con niebla baja" },
        { src: "/img/humo-bajo/renta-humo-bajo-primer-baile-boda.avif", alt: "Renta de humo bajo para primer baile de boda íntima" },
        { src: "/img/humo-bajo/efecto-humo-bajo-baile-novios.avif", alt: "Efecto de humo bajo durante el baile de novios" },
        { src: "/img/humo-bajo/niebla-baja-boda-terraza-romantica.avif", alt: "Niebla baja en terraza romántica para boda íntima" },
        { src: "/img/humo-bajo/humo-bajo-vals-boda-pista-luz.avif", alt: "Pista de baile con humo bajo y luces para vals de boda" },
        { src: "/img/humo-bajo/efecto-nubes-piso-boda-jardin.avif", alt: "Efecto de nubes en el piso de jardín para boda" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete Vals Único"
        subtitle="Todo lo que necesitas saber sobre humo bajo para el vals de tu boda."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp al 55 3068 2988. Respondemos en minutos."
        paragraph2="Cuéntanos el tipo de venue y la cantidad de invitados — te decimos si el paquete Vals Único es el indicado."
      />
    </div>
    <FaqSection items={[
      { question: "¿1 máquina de humo bajo es suficiente para el vals?", answer: "Sí. Para el vals de una boda íntima o una pista de baile estándar (hasta 6x6 metros), una máquina de niebla baja profesional cubre toda la superficie. El operador posiciona el equipo estratégicamente para que la niebla se distribuya de manera uniforme durante los 3-4 minutos que dura el vals." },
      { question: "¿El humo bajo funciona en terrazas o jardines pequeños?", answer: "Sí, funciona perfectamente. En espacios al aire libre pequeños como terrazas o jardines de casa, la niebla baja permanece pegada al piso. Si hay brisa ligera, el operador ajusta el caudal para compensar. En terrazas techadas el efecto es aún más denso y duradero." },
      { question: "¿Cuánto dura el efecto de niebla durante el vals?", answer: "Cada activación produce niebla densa durante 3-5 minutos — exactamente lo que dura un vals. El operador activa la máquina 30 segundos antes de que los novios salgan a la pista para que el efecto esté en su punto máximo cuando empieza la música." },
      { question: "¿El paquete de $3,500 incluye todo?", answer: "Sí. Los $3,500 + IVA incluyen la máquina de niebla baja profesional, fluido de glicol certificado (1 carga), operador técnico, traslado ida y vuelta, montaje, desmontaje y coordinación con el DJ o maestro de ceremonias. Sin costos ocultos en CDMX y zona metropolitana." },
      { question: "¿Se puede usar en una boda en casa?", answer: "Sí, es uno de los usos más populares del paquete Vals Único. La máquina es compacta y el fluido de glicol no mancha pisos de madera, mármol ni alfombras. No genera olor y se disipa sin dejar residuo. Ideal para bodas íntimas en casa o terraza." },
      { question: "¿Puedo agregar una segunda activación?", answer: "El paquete Vals Único incluye fluido para una activación principal. Si necesitas niebla baja para el vals y otro momento (entrada, brindis, corte de pastel), te recomendamos el paquete Recepción Completa ($5,500 + IVA) que incluye fluido ilimitado y activaciones múltiples toda la noche." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes de Humo Bajo"
        subtitle="¿Necesitas niebla para más momentos o una pista más grande?"
        paragraph1="Si tu boda es para más de 100 invitados o necesitas niebla en varios momentos de la noche, los paquetes de Recepción Completa o Doble Cobertura te dan más capacidad. Y combinar con un seguidor de luz eleva el vals a otro nivel."
        paragraph2="Armamos propuestas integrales con precio especial cuando combinas 2 o más servicios."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Quieres que tu vals sea sobre nubes?</h2>
        <p>Cuéntanos la fecha, el venue y cuántos invitados esperas. Te confirmamos disponibilidad y te enviamos la cotización en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
