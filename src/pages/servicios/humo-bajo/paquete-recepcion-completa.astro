---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Niebla Baja Recepción Completa — Paquete $5,500 + IVA | REDEIL";
const description = "Humo bajo para toda la recepción: vals, entrada, brindis. Activaciones múltiples. Fluido ilimitado. $5,500 + IVA en CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/humo-bajo/paquete-recepcion-completa/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Paquete Recepción Completa — Niebla Baja para Boda y XV Años",
    "description": "Niebla baja para toda la recepción de boda o XV años. 1 máquina profesional con fluido ilimitado, activaciones múltiples para vals, entrada, brindis y más. Operador técnico 4-6 horas. Traslado incluido en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/humo-bajo/paquete-recepcion-completa/",
      "priceCurrency": "MXN",
      "price": "5500",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "72",
      "reviewCount": "72"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Alejandra Mendoza Ruiz" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Contratamos el paquete Recepción Completa para nuestra boda en el Salón Versalles de Polanco. Humo bajo en el vals, en la entrada de los novios y cuando brindamos. El operador estaba atento a cada momento. El DJ solo le hacía una señal y activaba la niebla. Perfecto."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Fernando Castañeda Ríos" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Los XV años de mi hija en el Salón Royal de Naucalpan quedaron espectaculares. Niebla baja en el vals, en el cambio de zapatillas y en el baile con chambelanes. Activaron el efecto 4 veces y cada vez los invitados se emocionaban igual. Muy recomendable."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Patricia Vargas León" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Nuestra boda en el Jardín El Tepozteco de Tepoztlán tuvo niebla baja en 3 momentos distintos. El paquete Recepción Completa fue la mejor decisión. El fluido ilimitado nos dio la tranquilidad de no preocuparnos por cuántas veces se usaba. Las fotos del vals y de la entrada quedaron hermosas."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/humo-bajo/humo-bajo-boda-salon-iluminacion.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Cuántas activaciones de niebla baja incluye el paquete?", "acceptedAnswer": { "@type": "Answer", "text": "El paquete Recepción Completa incluye activaciones ilimitadas durante 4-6 horas. El operador activa la niebla baja en cada momento que necesites: vals, entrada de novios, brindis, baile con padres, cambio de zapatillas en XV años, o cualquier otro momento especial de la recepción." }},
      { "@type": "Question", "name": "¿El operador se queda toda la recepción?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El operador técnico permanece en el venue durante 4-6 horas — todo el tiempo que dura la recepción. Está en coordinación constante con el DJ y el maestro de ceremonias para activar el efecto en el segundo exacto. No necesitas preocuparte por nada." }},
      { "@type": "Question", "name": "¿El paquete funciona para XV años?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, es el paquete más contratado para XV años. La niebla baja se usa en el vals de la quinceañera, la entrada al salón, el cambio de zapatillas y el baile con chambelanes. Con activaciones múltiples, cada momento especial tiene su efecto de nubes en el piso." }},
      { "@type": "Question", "name": "¿Cuál es la diferencia entre este paquete y el de Vals Único?", "acceptedAnswer": { "@type": "Answer", "text": "El paquete Vals Único ($3,500) incluye 1 activación para un solo momento. El paquete Recepción Completa ($5,500) incluye fluido ilimitado, operador 4-6 horas y activaciones múltiples para cubrir todos los momentos especiales de la noche. Si necesitas niebla solo para el vals, el paquete Vals Único es suficiente." }},
      { "@type": "Question", "name": "¿Funciona en salones con aire acondicionado?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. En salones con aire acondicionado la niebla baja permanece más tiempo pegada al piso porque el aire frío la mantiene densa. Es uno de los mejores ambientes para el efecto. El operador ajusta el caudal según las condiciones del salón." }},
      { "@type": "Question", "name": "¿Se puede combinar con seguidor de luz?", "acceptedAnswer": { "@type": "Answer", "text": "Sí — es la combinación más solicitada en bodas. Niebla baja en el piso + seguidor de luz enfocando a los novios = el vals cinematográfico que todos quieren. REDEIL ofrece precio especial cuando se contratan ambos servicios juntos." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Vals Único", image: "/img/humo-bajo/humo-bajo-primer-vals-romantico.avif", alt: "Humo bajo para vals único de boda", description: "1 máquina para un solo momento estelar. Ideal para bodas íntimas. $3,500 + IVA.", link: "/servicios/humo-bajo/paquete-vals-unico/" },
  { title: "Doble Cobertura", image: "/img/humo-bajo/niebla-baja-boda-hacienda-mexicana.avif", alt: "2 máquinas de humo bajo para hacienda", description: "2 máquinas para haciendas y salones grandes. Pista completamente cubierta. $8,500 + IVA.", link: "/servicios/humo-bajo/paquete-doble-cobertura/" },
  { title: "Producción Premium", image: "/img/humo-bajo/primer-baile-novios-humo-bajo-seguidor.avif", alt: "Producción premium con humo bajo y seguidor", description: "Humo bajo + seguidor de luz + cabezas móviles. La producción completa. $13,000 + IVA.", link: "/servicios/humo-bajo/paquete-produccion-premium/" },
  { title: "Seguidor de Luz", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Seguidor de luz para vals de boda", description: "Spotlight siguiendo a los novios sobre la niebla baja. La combinación más contratada en bodas.", link: "/servicios/seguidor/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Humo Bajo", href: "/servicios/humo-bajo/" },
    { label: "Recepción Completa" }
  ]} />
</Fragment>

  <Hero
    title="Niebla Baja para Recepción Completa — Bodas y XV Años"
    subtitle="Desde $5,500 + IVA. Fluido ilimitado. Activaciones múltiples. El paquete más popular para bodas."
    introParagraph1='Una boda tiene más de un momento especial — la entrada de los novios al salón, el vals, el brindis, el baile con los padres. ¿Por qué limitar la niebla baja a un solo instante? El paquete <strong>Recepción Completa</strong> de <strong>REDEIL</strong> cubre toda la noche: fluido ilimitado, operador presente durante 4-6 horas y activaciones en cada momento que necesites. Es el paquete más contratado para bodas completas y XV años en la CDMX.'
    introParagraph2='El operador técnico permanece en coordinación constante con el DJ y el maestro de ceremonias. Cuando llega el momento, una señal basta para que la niebla baja cubra la pista en segundos. El fluido de glicol farmacéutico no genera olor ni residuo — los invitados pueden bailar sobre las nubes toda la noche sin preocupación. Traslado, montaje, desmontaje y coordinación incluidos en toda la <strong>CDMX y Estado de México</strong>.'
  />


  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Recepción Completa"
      price="$5,500"
      priceNote="+ IVA · Más popular · Fluido ilimitado"
      features={[
        { text: "1 máquina de niebla baja profesional" },
        { text: "Fluido de glicol ilimitado toda la noche" },
        { text: "Operador técnico 4-6 horas" },
        { text: "Activaciones múltiples a demanda" },
        { text: "Coordinación completa con DJ/MC" },
        { text: "Traslado ida y vuelta CDMX" },
        { text: "Montaje y desmontaje incluidos" },
        { text: "Sin olor, sin residuo" },
        { text: "Ideal: bodas y XV años completos" },
        { text: "Cobertura CDMX y Estado de México" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete Recepción Completa de humo bajo para mi boda/XV años."
      packages={[
        { label: "Vals Único", price: "$3,500", href: "/servicios/humo-bajo/paquete-vals-unico/" },
        { label: "Recepción Completa", price: "$5,500", href: "/servicios/humo-bajo/paquete-recepcion-completa/", active: true },
        { label: "Doble Cobertura", price: "$8,500", href: "/servicios/humo-bajo/paquete-doble-cobertura/" },
        { label: "Producción Premium", price: "$13,000", href: "/servicios/humo-bajo/paquete-produccion-premium/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="Todos los momentos especiales con niebla baja"
          subtitle="Vals, entrada, brindis, cambio de zapatillas — cada momento merece nubes en el piso."
          paragraph1="La recepción de una boda o XV años tiene entre 3 y 6 momentos estelares donde la niebla baja transforma el ambiente. Con el paquete Recepción Completa, el operador está listo para cada uno de ellos sin que tengas que preocuparte por el fluido."
          paragraph2="El DJ o MC da la señal, el operador activa la niebla, y en 30 segundos la pista está cubierta de nubes blancas. Así de simple, así de efectivo."
        />
        <FeatureGrid features={[
          { title: "Vals de Novios", description: "El momento estelar de la boda. Los novios bailan sobre nubes mientras los invitados fotografían cada segundo." },
          { title: "Entrada al Salón", description: "Los novios cruzan la puerta del salón y caminan sobre niebla hacia la pista. Una entrada triunfal." },
          { title: "Brindis y Mesa Principal", description: "Niebla baja alrededor de la mesa principal durante el brindis. Un toque elegante y fotogénico." },
          { title: "XV Años — Vals y Chambelanes", description: "Niebla para el vals de la quinceañera y para el baile con chambelanes. Dos momentos, dos activaciones." },
          { title: "Cambio de Zapatillas", description: "El momento en que la quinceañera cambia de zapatos sobre una alfombra de nubes. Emotivo y espectacular." },
          { title: "Baile con Padres", description: "El baile de la novia con su padre o del novio con su madre. Niebla baja para un momento íntimo y emotivo." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Fluido ilimitado: la tranquilidad de no contar activaciones"
          subtitle="El operador activa la niebla cada vez que lo necesites — sin costo extra."
          paragraph1="La diferencia principal entre el paquete Vals Único y el de Recepción Completa es el fluido ilimitado. No tienes que decidir de antemano cuántas veces se usará la niebla. Si durante la fiesta surge un momento que merece niebla baja, el operador la activa sin consultar costos adicionales."
          paragraph2="El fluido de glicol se recarga en la máquina en segundos. No hay tiempo de espera entre activaciones. El operador lleva reserva suficiente para cubrir toda la noche sin interrupción."
        />
        <FeatureGrid features={[
          { title: "Sin Límite de Activaciones", description: "Vals, entrada, brindis, baile libre — tantas veces como quieras durante la recepción." },
          { title: "Operador 4-6 Horas", description: "El técnico permanece en el venue durante toda la recepción. Siempre listo para la siguiente señal." },
          { title: "Coordinación en Tiempo Real", description: "El operador trabaja en sincronía con el DJ y MC. Una señal basta para activar el efecto." },
          { title: "Fluido de Reserva", description: "Llevamos fluido extra al evento. Nunca nos quedamos sin material para una activación más." },
          { title: "Recarga en Segundos", description: "La máquina se recarga en menos de un minuto. No hay pausas largas entre momentos." },
          { title: "Adaptable al Momento", description: "¿Momento improvisado? ¿Los novios quieren repetir? El operador está listo para cualquier cambio." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="5 estrellas en 72 reseñas verificadas."
          paragraph1="Bodas y XV años en salones y jardines de CDMX con el paquete Recepción Completa."
          paragraph2="Pregunta por referencias de venues similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Alejandra Mendoza Ruiz", event: "Boda — Salón Versalles, Polanco", rating: 5, text: "Humo bajo en el vals, en la entrada y en el brindis. El operador estaba atento a cada momento. El DJ solo le hacía una señal y activaba la niebla. Perfecto." },
          { name: "Fernando Castañeda Ríos", event: "XV Años — Salón Royal, Naucalpan", rating: 5, text: "Niebla baja en el vals, en el cambio de zapatillas y en el baile con chambelanes. Activaron el efecto 4 veces y cada vez los invitados se emocionaban igual." },
          { name: "Patricia Vargas León", event: "Boda — Jardín El Tepozteco, Tepoztlán", rating: 5, text: "Niebla baja en 3 momentos distintos. El fluido ilimitado nos dio tranquilidad total. Las fotos del vals y de la entrada quedaron hermosas." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Niebla baja en bodas y XV años — recepción completa"
        subtitle="Activaciones múltiples en salones, jardines y haciendas de CDMX."
        paragraph1="Estas fotos son de recepciones reales donde se activó la niebla baja en varios momentos de la noche. Con el paquete Recepción Completa, cada momento estelar tiene su efecto de nubes en el piso."
        paragraph2="¿Quieres ver cómo quedaría en tu venue? Mándanos fotos del salón por WhatsApp y te mostramos el resultado esperado."
      />
      <Gallery4x4 images={[
        { src: "/img/humo-bajo/humo-bajo-boda-salon-iluminacion.avif", alt: "Salón de boda con humo bajo e iluminación profesional" },
        { src: "/img/humo-bajo/humo-bajo-vals-xv-anos-quinceanos.avif", alt: "Vals de XV años con efecto de humo bajo" },
        { src: "/img/humo-bajo/humo-bajo-entrada-quinceanos-salon.avif", alt: "Entrada de quinceañera al salón con humo bajo" },
        { src: "/img/humo-bajo/niebla-baja-vals-quinceanos-elegante.avif", alt: "Niebla baja elegante en vals de quinceañera" },
        { src: "/img/humo-bajo/renta-niebla-baja-pista-baile-boda.avif", alt: "Pista de baile con niebla baja para recepción de boda" },
        { src: "/img/humo-bajo/humo-bajo-primer-baile-boda-romantico.avif", alt: "Primer baile romántico con niebla baja en recepción" },
        { src: "/img/humo-bajo/efecto-niebla-baja-aniversario.avif", alt: "Efecto de niebla baja en recepción de aniversario" },
        { src: "/img/humo-bajo/humo-bajo-pista-baile-luces-led.avif", alt: "Pista de baile con humo bajo y luces LED en recepción" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete Recepción Completa"
        subtitle="Todo sobre niebla baja para toda la noche de tu boda o XV años."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp al 55 3068 2988. Respondemos en minutos."
        paragraph2="Cuéntanos cuántos momentos quieres cubrir y te confirmamos que este paquete es el indicado."
      />
    </div>
    <FaqSection items={[
      { question: "¿Cuántas activaciones de niebla baja incluye el paquete?", answer: "El paquete Recepción Completa incluye activaciones ilimitadas durante 4-6 horas. El operador activa la niebla baja en cada momento que necesites: vals, entrada de novios, brindis, baile con padres, cambio de zapatillas en XV años, o cualquier otro momento especial de la recepción." },
      { question: "¿El operador se queda toda la recepción?", answer: "Sí. El operador técnico permanece en el venue durante 4-6 horas — todo el tiempo que dura la recepción. Está en coordinación constante con el DJ y el maestro de ceremonias para activar el efecto en el segundo exacto. No necesitas preocuparte por nada." },
      { question: "¿El paquete funciona para XV años?", answer: "Sí, es el paquete más contratado para XV años. La niebla baja se usa en el vals de la quinceañera, la entrada al salón, el cambio de zapatillas y el baile con chambelanes. Con activaciones múltiples, cada momento especial tiene su efecto de nubes en el piso." },
      { question: "¿Cuál es la diferencia entre este paquete y el de Vals Único?", answer: "El paquete Vals Único ($3,500) incluye 1 activación para un solo momento. El paquete Recepción Completa ($5,500) incluye fluido ilimitado, operador 4-6 horas y activaciones múltiples para cubrir todos los momentos especiales de la noche. Si necesitas niebla solo para el vals, el paquete Vals Único es suficiente." },
      { question: "¿Funciona en salones con aire acondicionado?", answer: "Sí. En salones con aire acondicionado la niebla baja permanece más tiempo pegada al piso porque el aire frío la mantiene densa. Es uno de los mejores ambientes para el efecto. El operador ajusta el caudal según las condiciones del salón." },
      { question: "¿Se puede combinar con seguidor de luz?", answer: "Sí — es la combinación más solicitada en bodas. Niebla baja en el piso + seguidor de luz enfocando a los novios = el vals cinematográfico que todos quieren. REDEIL ofrece precio especial cuando se contratan ambos servicios juntos." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes de Humo Bajo"
        subtitle="¿Un solo momento o una producción completa?"
        paragraph1="Si solo necesitas niebla para el vals, el paquete Vals Único es suficiente. Si tu venue es grande y necesitas 2 máquinas, el paquete Doble Cobertura cubre pistas amplias. Y para la producción completa, el Premium incluye humo + seguidor + cabezas móviles."
        paragraph2="Propuestas integrales con precio especial cuando combinas 2 o más servicios."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para que toda la recepción tenga nubes en el piso?</h2>
        <p>Cuéntanos la fecha, el venue y los momentos que quieres cubrir. Te cotizamos en minutos y te confirmamos disponibilidad.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
