---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Boda con DJ y Audio Completo CDMX — $11,000 + IVA | REDEIL";
const description = "DJ profesional con Pioneer DDJ-1000 + audio JBL completo para boda 150-300 invitados. Coordinación total con MC. CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/bocinas-bodas/paquete-boda-con-dj/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Paquete Boda con DJ — DJ Profesional + Audio Completo para Boda",
    "description": "DJ profesional con Pioneer DDJ-1000 + 4 bocinas JBL PRX825 + 2 subwoofers QSC + 4 micrófonos Shure + mezcladora Yamaha TF1 + iluminación básica de pista. Coordinación total con MC y wedding planner. 150-300 invitados. CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/bocinas-bodas/paquete-boda-con-dj/",
      "priceCurrency": "MXN",
      "price": "11000",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "58",
      "reviewCount": "58"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Patricia Hernández" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "El DJ coordinó todo con nuestro MC sin que le dijéramos nada. Desde el vals hasta la hora loca, cada canción fue perfecta. El equipo Pioneer se escuchó increíble."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Diego Morales" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Nuestro DJ de REDEIL leyó al público como nadie. Empezó suave con la cena, subió con los brindis y cuando arrancó la hora loca, la pista estaba llena. Coordinó perfecto con el fotógrafo."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Mónica Salazar" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Lo que más valoramos fue la coordinación del DJ con nuestro wedding planner. Cada momento tuvo su canción exacta. La transición de la cena a la fiesta fue impecable."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/bocinas-bodas/renta-bocinas-boda-dj-cabina-blanca-flores.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿El DJ se coordina con nuestro MC y wedding planner?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El DJ de REDEIL hace una llamada previa con tu MC y wedding planner para alinear la lista de canciones, los momentos clave (vals, brindis, ramo, liga, hora loca) y las señales de transición. El día del evento, todo fluye sin que nadie tenga que dirigir al DJ." }},
      { "@type": "Question", "name": "¿Podemos elegir la música o el DJ decide?", "acceptedAnswer": { "@type": "Answer", "text": "Tú decides. Antes de la boda recibes un formulario donde pones canciones obligatorias (primer baile, vals padre-hija, entrada de novios), canciones que quieres escuchar y canciones prohibidas. El DJ respeta tu lista y llena los espacios leyendo al público." }},
      { "@type": "Question", "name": "¿Qué equipo usa el DJ?", "acceptedAnswer": { "@type": "Answer", "text": "Controladora Pioneer DDJ-1000 con software Rekordbox. El audio sale por 4 bocinas JBL PRX825 + 2 subwoofers QSC a través de la mezcladora Yamaha TF1. El DJ también trae iluminación básica de pista con luces LED sincronizadas a la música." }},
      { "@type": "Question", "name": "¿El paquete incluye iluminación de pista?", "acceptedAnswer": { "@type": "Answer", "text": "Incluye iluminación básica de pista — luces LED que se sincronizan con la música para crear ambiente en la zona de baile. Si quieres cabezas móviles, seguidor de luz o producción de iluminación completa, se cotizan por separado con precio especial por paquete combinado." }},
      { "@type": "Question", "name": "¿Cuántas horas dura el servicio del DJ?", "acceptedAnswer": { "@type": "Answer", "text": "El DJ cubre desde la ceremonia hasta el cierre de la fiesta — normalmente entre 8 y 10 horas. Música ambiental durante la cena, coordinación de momentos especiales y set de fiesta continuo. No hay límite de horas fijo; el DJ se queda hasta que la fiesta termine." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Boda Completa — $7,500", image: "/img/bocinas-bodas/renta-bocinas-boda-brindis-discurso-invitados-400w.avif", alt: "Audio completo para boda sin DJ", description: "El mismo equipo de audio pero sin DJ. Perfecto si ya tienes tu propio DJ o prefieres playlist.", link: "/servicios/bocinas-bodas/paquete-boda-completa/" },
  { title: "Producción Boda Premium — $18,000", image: "/img/bocinas-bodas/renta-bocinas-boda-stack-qsc-subwoofer-escenario.avif", alt: "Producción de audio para boda premium", description: "Line array JBL VTX + 4 subwoofers + ingeniería FOH. Para bodas de 300+ invitados.", link: "/servicios/bocinas-bodas/paquete-produccion-boda/" },
  { title: "Humo Bajo", image: "/img/humo-bajo/humo-bajo-romantico-primer-baile-400w.avif", alt: "Humo bajo para primer baile de boda", description: "Efecto nubes en el piso para el primer baile. El DJ coordina la canción con el efecto.", link: "/servicios/humo-bajo/" },
  { title: "Cabezas Móviles", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante-300w.avif", alt: "Cabezas móviles para fiesta de boda", description: "Beams y wash que convierten la pista en un show. El DJ las controla desde su cabina.", link: "/servicios/cabezas-moviles/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Sonido y DJ", href: "/servicios/sonido/" },
    { label: "Bocinas para Bodas", href: "/servicios/bocinas-bodas/" },
    { label: "Paquete Boda con DJ" }
  ]} />
</Fragment>

  <Hero
    title="Paquete Boda con DJ — DJ Profesional + Audio Completo"
    subtitle="Desde $11,000 + IVA. DJ con Pioneer DDJ-1000 + 4 bocinas JBL + 2 subwoofers QSC. Bodas 150-300 invitados."
    introParagraph1='Un buen DJ de bodas no es el que tiene más canciones — es el que sabe cuándo poner cada una. El que lee la pista y sube el reggaetón cuando ve que los invitados ya están listos, el que baja el volumen justo antes del brindis del papá, el que coordina con el fotógrafo para que la foto del ramo tenga la canción perfecta de fondo. El paquete Boda con DJ incluye un DJ profesional con <strong>Pioneer DDJ-1000</strong> más el sistema de audio completo: 4 bocinas <strong>JBL PRX825</strong>, 2 subwoofers <strong>QSC</strong> y 4 micrófonos <strong>Shure</strong>.'
    introParagraph2='Antes de la boda, el DJ se reúne (por llamada o en persona) con tu MC y wedding planner para alinear la lista de canciones, los momentos clave y las señales de transición. El día del evento, el DJ opera desde su cabina con la controladora Pioneer y la mezcladora <strong>Yamaha TF1</strong> — cubriendo desde la música ambiental de la ceremonia hasta la hora loca a las 3 AM. Incluye iluminación básica de pista. Haciendas, jardines, salones y hoteles en toda la <strong>CDMX y Estado de México</strong>.'
  />


  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Boda con DJ"
      price="$11,000"
      priceNote="+ IVA · DJ + audio completo · Iluminación básica"
      features={[
        { text: "DJ profesional con Pioneer DDJ-1000" },
        { text: "4 bocinas JBL PRX825 de alta potencia" },
        { text: "2 subwoofers QSC para pista de baile" },
        { text: "4 micrófonos Shure inalámbricos" },
        { text: "Mezcladora Yamaha TF1 digital" },
        { text: "Iluminación básica de pista incluida" },
        { text: "Coordinación previa con MC y planner" },
        { text: "Lista de canciones personalizada" },
        { text: "Transporte + montaje + desmontaje" },
        { text: "Ideal: bodas 150-300 invitados" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete Boda con DJ para mi boda."
      packages={[
        { label: "Solo Ceremonia", price: "$3,500", href: "/servicios/bocinas-bodas/paquete-solo-ceremonia/" },
        { label: "Boda Completa", price: "$7,500", href: "/servicios/bocinas-bodas/paquete-boda-completa/" },
        { label: "Boda con DJ", price: "$11,000", href: "/servicios/bocinas-bodas/paquete-boda-con-dj/", active: true },
        { label: "Producción", price: "$18,000", href: "/servicios/bocinas-bodas/paquete-produccion-boda/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="Un DJ que lee la pista y coordina tu boda"
          subtitle="No es solo poner canciones — es orquestar cada momento."
          paragraph1="El DJ de REDEIL tiene experiencia específica en bodas. Sabe que el vals padre-hija necesita un volumen diferente al del reggaetón de las 2 AM. Sabe que la transición de cena a fiesta no puede ser abrupta — se construye gradualmente con la música correcta."
          paragraph2="Antes del evento reciben un formulario donde indican canciones obligatorias, canciones deseadas y canciones prohibidas. El DJ respeta la lista al pie de la letra y llena los espacios leyendo al público en vivo."
        />
        <FeatureGrid features={[
          { title: "Vals y Primer Baile", description: "La canción que eligieron, con la entrada perfecta y el volumen justo para el momento." },
          { title: "Brindis y Discursos", description: "Micrófono listo, volumen de fondo bajado, spotlight si lo contrataste. El DJ coordina todo." },
          { title: "Hora Loca y Fiesta", description: "El DJ lee al público y sube la energía gradualmente. La pista se llena y no se vacía." },
          { title: "Transición Cena a Fiesta", description: "Música ambiental durante la cena que sube progresivamente hasta arrancar la fiesta." },
          { title: "Ramo, Liga y Momentos Especiales", description: "Cada momento tiene su canción precargada y su señal de entrada coordinada con el MC." },
          { title: "Cierre de Fiesta", description: "La última canción, el agradecimiento a los novios, la despedida — todo planeado." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Equipo de DJ profesional para bodas"
          subtitle="Pioneer DDJ-1000 + JBL PRX825 + QSC + Yamaha TF1."
          paragraph1="El DJ trabaja con la controladora Pioneer DDJ-1000 y el software Rekordbox — el estándar de la industria para mezcla en vivo. El audio pasa por la mezcladora Yamaha TF1 que permite ecualizar cada zona del venue de forma independiente."
          paragraph2="Con más de 30 años produciendo eventos, nuestros DJs saben que la clave de una buena fiesta no es el volumen — es la canción correcta en el momento correcto con el volumen correcto."
        />
        <FeatureGrid features={[
          { title: "Pioneer DDJ-1000 + Rekordbox", description: "Mezcla profesional en vivo con la controladora estándar de la industria." },
          { title: "Biblioteca Musical Completa", description: "Cumbia, reggaetón, pop, rock, electrónica, jazz, regional — lo que tu boda necesite." },
          { title: "Iluminación Básica de Pista", description: "Luces LED sincronizadas a la música para crear ambiente sin costo extra." },
          { title: "Cabina de DJ Elegante", description: "Setup limpio y profesional que se integra con la decoración de tu boda." },
          { title: "Micrófono para el MC", description: "Shure inalámbrico dedicado para el MC con canal independiente en la mezcladora." },
          { title: "Backup de Equipo", description: "Laptop de respaldo y cables duplicados. Si algo falla, la música no para." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="4.9 estrellas en 58 reseñas verificadas."
          paragraph1="Bodas con DJ en haciendas, jardines, salones y hoteles de CDMX y Estado de México."
          paragraph2="Pregunta por referencias de venues similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Patricia Hernández", event: "Boda — Hacienda Peñafiel Tepotzotlán, 250 invitados", rating: 5, text: "El DJ coordinó todo con nuestro MC sin que le dijéramos nada. Desde el vals hasta la hora loca, cada canción fue perfecta." },
          { name: "Diego Morales", event: "Boda — Ex-Hacienda San Mateo Atenco, 200 invitados", rating: 5, text: "Nuestro DJ leyó al público como nadie. Empezó suave con la cena y cuando arrancó la hora loca, la pista estaba llena." },
          { name: "Mónica Salazar", event: "Boda — Quinta Los Almendros Tlalpan, 180 invitados", rating: 5, text: "La coordinación del DJ con nuestro wedding planner fue impecable. Cada momento tuvo su canción exacta." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Bodas con DJ profesional REDEIL"
        subtitle="El DJ que lee la pista, coordina con tu equipo y hace que la fiesta no pare."
        paragraph1="Estas fotos son de bodas reales con nuestro paquete Boda con DJ. Pioneer DDJ-1000, bocinas JBL, subwoofers QSC y un DJ que sabe cuándo subir y cuándo bajar."
        paragraph2="¿Quieres ver cómo quedaría en tu venue? Mándanos la ubicación por WhatsApp y te explicamos el montaje."
      />
      <Gallery4x4 images={[
        { src: "/img/bocinas-bodas/renta-bocinas-boda-dj-cabina-blanca-flores.avif", alt: "DJ profesional en cabina elegante para boda" },
        { src: "/img/bocinas-bodas/renta-bocinas-boda-fiesta-confeti-chispas-dj.avif", alt: "Fiesta de boda con DJ y confeti" },
        { src: "/img/bocinas-bodas/renta-bocinas-boda-dj-consola-mesa-novios.avif", alt: "DJ con consola Pioneer cerca de mesa de novios" },
        { src: "/img/bocinas-bodas/renta-bocinas-boda-entrada-novios-humo-dj.avif", alt: "Entrada de novios con DJ y efectos de humo" },
        { src: "/img/bocinas-bodas/renta-bocinas-boda-primer-baile-salon-ambar.avif", alt: "Primer baile con DJ en salón iluminado en ámbar" },
        { src: "/img/bocinas-bodas/renta-bocinas-boda-banda-jazz-consola-salon.avif", alt: "DJ y banda en vivo coordinados en boda" },
        { src: "/img/bocinas-bodas/renta-bocinas-boda-baile-padre-hija-iluminacion.avif", alt: "Baile padre-hija con música del DJ" },
        { src: "/img/bocinas-bodas/renta-bocinas-boda-corte-pastel-animador-microfono.avif", alt: "DJ coordinando corte de pastel en boda" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete Boda con DJ"
        subtitle="Todo lo que necesitas saber sobre DJ profesional para boda."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp al 55 3068 2988. Respondemos en minutos."
        paragraph2="Cuéntanos el venue, el estilo musical y el número de invitados — te decimos exactamente cómo quedaría."
      />
    </div>
    <FaqSection items={[
      { question: "¿El DJ se coordina con nuestro MC y wedding planner?", answer: "Sí. El DJ de REDEIL hace una llamada previa con tu MC y wedding planner para alinear la lista de canciones, los momentos clave (vals, brindis, ramo, liga, hora loca) y las señales de transición. El día del evento, todo fluye sin que nadie tenga que dirigir al DJ." },
      { question: "¿Podemos elegir la música o el DJ decide?", answer: "Tú decides. Antes de la boda recibes un formulario donde pones canciones obligatorias (primer baile, vals padre-hija, entrada de novios), canciones que quieres escuchar y canciones prohibidas. El DJ respeta tu lista y llena los espacios leyendo al público." },
      { question: "¿Qué equipo usa el DJ?", answer: "Controladora Pioneer DDJ-1000 con software Rekordbox. El audio sale por 4 bocinas JBL PRX825 + 2 subwoofers QSC a través de la mezcladora Yamaha TF1. El DJ también trae iluminación básica de pista con luces LED sincronizadas a la música." },
      { question: "¿El paquete incluye iluminación de pista?", answer: "Incluye iluminación básica de pista — luces LED que se sincronizan con la música para crear ambiente en la zona de baile. Si quieres cabezas móviles, seguidor de luz o producción de iluminación completa, se cotizan por separado con precio especial por paquete combinado." },
      { question: "¿Cuántas horas dura el servicio del DJ?", answer: "El DJ cubre desde la ceremonia hasta el cierre de la fiesta — normalmente entre 8 y 10 horas. Música ambiental durante la cena, coordinación de momentos especiales y set de fiesta continuo. No hay límite de horas fijo; el DJ se queda hasta que la fiesta termine." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes y Servicios"
        subtitle="¿Quieres solo audio o producción premium?"
        paragraph1="Si ya tienes DJ, el paquete Boda Completa te da el audio sin DJ. Si tu boda es de 300+ invitados, la Producción Premium tiene line array y FOH."
        paragraph2="Precio especial cuando combinas DJ con efectos especiales o iluminación."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para tener el DJ perfecto en tu boda?</h2>
        <p>Mándanos la fecha, el venue y tu estilo musical. Te presentamos al DJ, te enviamos su portafolio y cotizamos en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Reservar — Cotiza Gratis</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
