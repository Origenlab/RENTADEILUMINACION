---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Iluminación para Eventos en CDMX | REDEIL";
const description = "11 tipos de iluminación profesional para bodas, XV años y eventos. Guirnaldas, sky tracker, cabezas móviles. Instalación incluida. Cotiza por WhatsApp.";
const canonical = "https://rentadeiluminacion.com/servicios/iluminacion/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Iluminación Profesional para Eventos",
  "provider": { "@type": "LocalBusiness", "name": "REDEIL", "url": "https://rentadeiluminacion.com", "telephone": "+525530682988" },
  "description": "Servicio profesional de renta de iluminación para bodas, XV años y eventos en CDMX. 11 tipos de luces con instalación incluida.",
  "areaServed": { "@type": "City", "name": "Ciudad de México" }
});

const servicios = [
  { title: "Guirnaldas Edison", image: "/img/guirnaldas/renta-guirnaldas-edison-terraza-recepcion-02-300w.avif", alt: "Guirnaldas con focos Edison para boda al aire libre", description: "Focos Edison LED o vintage con luz cálida ámbar. Cableado IP65. Las más pedidas para bodas al aire libre — desde $3,500 + IVA.", link: "/servicios/guirnaldas/" },
  { title: "Luces Neón y UV", image: "/img/luces-neon/renta-luces-neon-glow-party-celebracion-neon-300w.avif", alt: "Luces neón y UV en fiesta glow party", description: "Barras UV Chauvet, letreros neón LED y accesorios fluorescentes para glow parties completas desde $4,500 + IVA.", link: "/servicios/luces-neon/" },
  { title: "Luz Negra", image: "/img/luz-negra/luz-negra-fiesta-neon-300w.avif", alt: "Luz negra UV para fiesta neón", description: "Iluminación UV profesional que hace brillar todo lo blanco y fluorescente. El motor de cualquier fiesta neón.", link: "/servicios/luz-negra/" },
  { title: "Sky Tracker", image: "/img/sky-tracker/renta-skytracker-cielo-nocturno-potente-300w.avif", alt: "Sky tracker proyectando haces de luz al cielo", description: "Xenón Strong y Syncrolite de 7,000W visibles a 5-7 km. El efecto que hace que tu evento se vea desde kilómetros.", link: "/servicios/sky-tracker/" },
  { title: "Cabezas Móviles", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante-300w.avif", alt: "Cabezas móviles LED en boda elegante", description: "Beam, Spot y Wash con control DMX. Martin, Chauvet y Elation para shows de luces de nivel producción.", link: "/servicios/cabezas-moviles/" },
  { title: "Cascadas LED", image: "/img/cascadas-led/cascadas-led-arco-ceremonia-luces-moradas-400w.avif", alt: "Cascadas LED en arco de ceremonia", description: "Cortinas LED de 3×3m con efecto twinkle sobre estructura de truss portátil. El backdrop más fotografiado.", link: "/servicios/cascadas-led/" },
  { title: "City Color", image: "/img/city-color/renta-luces-hacienda-boda-fuente-300w.avif", alt: "City Color iluminando hacienda para boda", description: "Wash lights Elation SixPar y Chauvet Colorado de 180-360W para bañar fachadas y escenarios con color potente.", link: "/servicios/city-color/" },
  { title: "City Light", image: "/img/city-light/iluminacion-profesional-bodas-cdmx-400w.avif", alt: "City Light iluminando salón de eventos", description: "PAR LED Chauvet SlimPAR y ADJ Mega Par con mezcla RGBW. Cambios de color en tiempo real por momentos del evento.", link: "/servicios/city-light/" },
  { title: "Iluminación Arquitectónica", image: "/img/iluminacion-arquitectonica/boda-patio-hacienda-iluminacion-fachada-ambar-string-lights-baile-400w.avif", alt: "Uplighting en fachada de hacienda", description: "Uplighters inalámbricos Chauvet Freedom Par con batería 12h. Sin cables en el piso ni perforaciones en el venue.", link: "/servicios/iluminacion-arquitectonica/" },
  { title: "Gobos", image: "/img/gobos/renta-gobo-monograma-pista-baile-300w.avif", alt: "Gobo proyectando monograma en pista de baile", description: "Proyección de nombres y logos con ETC Source Four. Gobos metálicos y de vidrio a color. El detalle que todos recuerdan.", link: "/servicios/gobos/" },
  { title: "Seguidor", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Spotlight seguidor en primer baile de novios", description: "Follow spots Robert Juliat y Strong Super Trouper 575W-2500W con operador profesional para vals, entrada y brindis.", link: "/servicios/seguidor/" },
  { title: "Luces LED", image: "/img/city-light/iluminacion-profesional-bodas-cdmx-400w.avif", alt: "Luces LED profesionales en colores personalizados", description: "Par LED RGBW con colores programados al código HEX de tu paleta. Uplighting perimetral desde $4,500 + IVA.", link: "/servicios/luces-led/" },
  { title: "Robot LED", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante-300w.avif", alt: "Robot LED automatizado que reacciona a la música", description: "Robots de luz con movimiento motorizado y modo sound-active. Show de luces autónomo desde $4,500 + IVA.", link: "/servicios/robot-led/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Servicios", href: "/servicios/" }, { label: "Iluminación" }]} />
</Fragment>

    <Hero
      title="Renta de Iluminación Profesional para Eventos en CDMX"
      subtitle="13 servicios de iluminación con instalación incluida. Equipo Martin Professional, Chauvet y Elation."
      introParagraph1='La iluminación define cómo se ve y cómo se siente un evento. No es decoración — es lo que hace que una hacienda se vea imponente, que la pista de baile funcione, que las fotos salgan bien. En <strong>REDEIL</strong> manejamos 13 tipos de iluminación: guirnaldas Edison, uplighting arquitectónico, cabezas móviles DMX, seguidor, gobos, cascadas LED, sky tracker, luces UV, city color y más. Cada uno resuelve algo distinto.'
      introParagraph2='Trabajamos con <strong>Martin Professional</strong>, <strong>Chauvet</strong> y <strong>Elation</strong> — el mismo equipo que se usa en conciertos y televisión. Lo que cambia es cómo se programa: no es lo mismo iluminar un salón de 200m² que un jardín abierto donde la luz se pierde. Nuestro técnico llega horas antes, monta, ecualiza la luz al espacio y opera todo durante el evento. Transporte, instalación, operación y desmontaje van incluidos.'
    />


    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="Catálogo de Iluminación"
          subtitle="13 servicios — cada uno resuelve algo distinto en tu evento."
          paragraph1="Las guirnaldas dan calidez a un jardín. El uplighting convierte una fachada de cantera en el fondo de todas las fotos. Las cabezas móviles arman el show en la pista. El seguidor convierte el vals en cine. Los gobos proyectan los nombres de los novios en la pista. No necesitas todo — necesitas los correctos para tu espacio."
          paragraph2="La mayoría de bodas llevan 3 a 5 tipos de iluminación. Para XV años el paquete más común incluye cabezas móviles, seguidor y luces UV para la hora loca. Te ayudamos a elegir lo que realmente funciona en tu venue."
        />
        <div class="services-grid">
          {servicios.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre Iluminación"
          subtitle="Lo que nos preguntan por WhatsApp antes de apartar fecha."
          paragraph1="Si tu duda no está aquí, mándanos mensaje y te contestamos en minutos."
          paragraph2=""
        />
      </div>
      <FaqSection items={[
        { question: "¿Qué iluminación funciona para una boda en jardín?", answer: "Guirnaldas Edison para la zona de mesas — es lo que da el ambiente cálido en las fotos. Uplighting en la fachada o los árboles si el venue tiene arquitectura interesante. Seguidor para el vals. Y si hay pista techada, cabezas móviles para la fiesta. Esa combinación cubre el 90% de las bodas en jardín que hacemos." },
        { question: "¿Cuántas luces necesito?", answer: "Depende del espacio. Un jardín de 300m² necesita más uplighting que un salón cerrado de 150m². Si nos mandas las medidas del venue o fotos por WhatsApp, te decimos la cantidad exacta. No cotizamos de más — si con 8 reflectores se cubre, no te ponemos 12." },
        { question: "¿La instalación va incluida?", answer: "Sí, siempre. Transporte, montaje, operación durante el evento y desmontaje al final. Nuestro equipo llega 4-6 horas antes. Tú no tocas nada." },
        { question: "¿Se pueden combinar varios tipos de luz?", answer: "Sí, y es lo normal. Una boda promedio lleva 3-5 tipos: guirnaldas + uplighting + seguidor + cabezas móviles. Para XV años lo más pedido es cabezas móviles + seguidor + luz UV para la hora loca. Armamos paquete con precio especial cuando combinas." },
        { question: "¿Qué pasa si llueve y mi evento es en jardín?", answer: "Las guirnaldas son IP65 — aguantan lluvia. El uplighting inalámbrico también. Las cabezas móviles y el seguidor necesitan techo o carpa. Si tu venue tiene plan B techado, movemos el equipo. Por eso llegamos con tiempo de sobra." },
        { question: "¿Puedo elegir colores específicos para la iluminación?", answer: "Sí. Con LED programamos cualquier color al código HEX de tu paleta. Si tu wedding planner tiene un moodboard con colores específicos, igualamos. El técnico ajusta en sitio porque el color se ve distinto en cantera que en muro blanco." },
      ]} />
    </section>

    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Necesitas iluminación para tu evento?</h2>
          <p>Mándanos la fecha, el venue y el tipo de evento. Te decimos qué luces funcionan para tu espacio y cuánto cuesta.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
