---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import GallerySection from "../../components/GallerySection.astro";

const title = "Iluminación Arquitectónica para Eventos | REDEIL CDMX";
const description = "Renta de iluminación arquitectónica para eventos en CDMX. REDEIL transforma fachadas, jardines y espacios con reflectores LED RGB y técnicas profesionales de iluminación.";
const canonical = "https://rentadeiluminacion.com/servicios/iluminacion-arquitectonica/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Iluminación Arquitectónica para Eventos",
  "provider": {
    "@type": "LocalBusiness",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com",
    "telephone": "+525530682988",
    "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressCountry": "MX" }
  },
  "description": "Servicio profesional de iluminación arquitectónica para eventos en Ciudad de México. Transformamos fachadas, jardines y espacios con reflectores LED RGB y control DMX.",
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "serviceType": "Renta de Iluminación Arquitectónica"
});
---
<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <nav class="breadcrumb-section" aria-label="Breadcrumb">
    <div class="container">
      <div class="breadcrumb"><ol><li><a href="/">Inicio</a></li><li><a href="/servicios/">Servicios</a></li><li>Iluminación Arquitectónica</li></ol></div>
    </div>
  </nav>
  <main id="main-content">
    <Hero
      title="Iluminación Arquitectónica para Eventos en CDMX"
      subtitle="Transforma fachadas, jardines y espacios con luz profesional"
      introParagraph1="REDEIL ofrece servicios de iluminación arquitectónica para eventos en toda la Ciudad de México. Utilizamos reflectores LED RGB con control DMX para resaltar fachadas, arcos, columnas, fuentes y árboles, creando ambientes espectaculares que elevan la experiencia de cada celebración."
      introParagraph2="Nuestro equipo técnico cuenta con amplia experiencia iluminando haciendas, jardines, terrazas y recintos históricos. Trabajamos con bodas, eventos corporativos, galas y fiestas privadas, adaptando la paleta de colores y la intensidad lumínica al concepto de cada evento."
    />
    <section class="service-detail">
      <div class="container">
        <h2>Iluminación que realza la arquitectura de tu evento</h2>
        <p>La iluminación arquitectónica permite transformar por completo la apariencia de un espacio. Mediante reflectores LED RGB estratégicamente colocados, es posible bañar de color fachadas coloniales, resaltar la textura de muros de piedra, iluminar árboles centenarios y crear atmósferas que van desde lo romántico hasta lo dramático.</p>
        <p>En REDEIL contamos con equipos de iluminación profesional y operadores técnicos que programan cada escena a través de consolas DMX. Esto nos permite realizar cambios de color sincronizados, transiciones suaves y efectos personalizados que se adaptan a los distintos momentos de tu evento.</p>
        <p>Nuestro servicio incluye visita previa al venue, diseño del esquema de iluminación, traslado de equipo, montaje completo y operación técnica durante el evento. Cubrimos haciendas, jardines, salones, terrazas y cualquier espacio en CDMX y área metropolitana.</p>
      </div>
    </section>
    <GallerySection title="Galería de Iluminación Arquitectónica" subtitle="Proyectos reales en haciendas, jardines y recintos de CDMX">
      <figure class="gallery-item">
        <img src="/img/iluminacion-arquitectonica/iluminacion-arbol-grande-hacienda-jardin-evento-nocturno-verde.avif" alt="Árbol grande iluminado en verde dentro del jardín de una hacienda durante evento nocturno" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/iluminacion-arquitectonica/reflector-led-par-morado-ajuste-tecnico-iluminacion-fachada.avif" alt="Técnico ajustando reflector LED par morado para iluminación de fachada" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/iluminacion-arquitectonica/iluminacion-fuente-colonial-luz-aqua-patio-hacienda-evento.avif" alt="Fuente colonial iluminada con luz aqua en el patio de hacienda durante evento" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/iluminacion-arquitectonica/iluminacion-patio-hacienda-rosa-arcos-coloniales-evento-social.avif" alt="Patio de hacienda con arcos coloniales iluminados en rosa durante evento social" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/iluminacion-arquitectonica/iluminacion-boda-lujo-rosa-columnas-pista-baile-pastel.avif" alt="Boda de lujo con columnas iluminadas en rosa, pista de baile y mesa de pastel" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/iluminacion-arquitectonica/tecnico-control-dmx-reflector-led-rgb-multicolor-fachada.avif" alt="Técnico operando control DMX con reflector LED RGB multicolor sobre fachada" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/iluminacion-arquitectonica/reflectores-led-rgb-multicolor-arcoiris-iluminacion-pared.avif" alt="Reflectores LED RGB proyectando colores de arcoíris sobre pared de recinto" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/iluminacion-arquitectonica/iluminacion-terraza-mirador-arboles-luz-calida-cena-romantica.avif" alt="Terraza mirador con árboles iluminados en luz cálida durante cena romántica" width="800" height="533" loading="lazy">
      </figure>
    </GallerySection>
  </main>
</BaseLayout>
