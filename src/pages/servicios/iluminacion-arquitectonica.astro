---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import PricingCards from '../../components/PricingCards.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Uplighting para Haciendas y Eventos CDMX | REDEIL";
const description = "Uplighting LED inalámbrico para fachadas, columnas, árboles y arcos de haciendas en CDMX. Sin cables. Instalación incluida. Desde $3,500 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/iluminacion-arquitectonica/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Iluminación Arquitectónica para Eventos",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Servicio profesional de uplighting e iluminación arquitectónica LED para fachadas, columnas, árboles y arcos en bodas y eventos en CDMX.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Renta de Iluminación Arquitectónica",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Qué es el uplighting?", "acceptedAnswer": { "@type": "Answer", "text": "El uplighting consiste en colocar reflectores LED en el piso apuntando hacia arriba para bañar de luz y color fachadas, columnas, árboles, arcos y muros. Transforma la arquitectura del venue en un elemento decorativo espectacular." }},
      { "@type": "Question", "name": "¿Los reflectores son inalámbricos?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Usamos uplighters LED con batería recargable que duran hasta 12 horas. Sin cables en el piso — se colocan al pie de columnas, árboles y fachadas sin instalación eléctrica." }},
      { "@type": "Question", "name": "¿Funciona en haciendas y patios coloniales?", "acceptedAnswer": { "@type": "Answer", "text": "Es donde mejor se ve. Las haciendas con arcos de cantera, columnas coloniales y árboles centenarios son el escenario perfecto para uplighting. La luz resalta la textura de la piedra y crea sombras dramáticas que transforman el espacio." }},
      { "@type": "Question", "name": "¿Cuántos reflectores necesito?", "acceptedAnswer": { "@type": "Answer", "text": "Depende de lo que quieras iluminar. Para una fachada frontal con arcos, 6 uplighters. Para fachada + jardín con árboles, 12. Para una hacienda completa, 20 o más. Te asesoramos según fotos de tu venue." }},
      { "@type": "Question", "name": "¿Se puede cambiar el color del uplighting durante el evento?", "acceptedAnswer": { "@type": "Answer", "text": "En los paquetes Premium y Producción con control DMX, sí. Los uplighters cambian de color en tiempo real — ámbar durante la cena, rosa durante el vals, multicolor en la fiesta. En los paquetes básicos, el color se fija al inicio del evento." }},
      { "@type": "Question", "name": "¿El uplighting se puede combinar con otros servicios?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, es el complemento perfecto para cualquier otro servicio. Con guirnaldas Edison en el techo y uplighting en las columnas, la hacienda queda completamente transformada. También combina con city color para fachadas grandes y gobos para personalización." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "Guirnaldas Edison", image: "/img/guirnaldas/renta-guirnaldas-edison-terraza-recepcion-02-300w.avif", alt: "Guirnaldas Edison en terraza", description: "Uplighting en las columnas + guirnaldas cálidas en el techo. La combinación más romántica para bodas en hacienda.", link: "/servicios/guirnaldas/" },
  { title: "City Color", image: "/img/city-color/iluminacion-ceremonia-boda-hacienda-300w.avif", alt: "City color en hacienda", description: "Uplighting para los detalles + city color para las fachadas grandes. Cobertura total del venue.", link: "/servicios/city-color/" },
  { title: "Sky Tracker", image: "/img/sky-tracker/renta-skytracker-cielo-nocturno-potente-300w.avif", alt: "Sky tracker al cielo", description: "Uplighting en el suelo + haces al cielo. Una producción completa de arriba abajo para eventos nocturnos.", link: "/servicios/sky-tracker/" },
  { title: "Cascadas LED", image: "/img/cascadas-led/cascadas-led-novios-mesa-romantica-boda-300w.avif", alt: "Cascadas LED para boda", description: "Columnas iluminadas afuera + cascadas brillantes dentro. El venue completamente transformado.", link: "/servicios/cascadas-led/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Iluminación", href: "/servicios/iluminacion/" },
    { label: "Iluminación Arquitectónica" }
  ]} />
</Fragment>

    <Hero
      title="Renta de Iluminación Arquitectónica y Uplighting en CDMX"
      subtitle="Reflectores LED inalámbricos para fachadas, columnas, árboles y arcos. Sin cables. Desde $3,500 + IVA."
      introParagraph1='El uplighting funciona por un principio simple: la luz que viene de abajo genera sombras hacia arriba, y eso resalta la textura de cualquier superficie. Una columna de cantera que de día se ve gris, de noche con un reflector LED ámbar en la base se convierte en una pieza dorada con cada grieta y cada relieve marcado. Usamos <strong>Chauvet Freedom Par</strong> y <strong>ADJ Element</strong> inalámbricos con batería de hasta 12 horas — se colocan en el piso sin cables.'
      introParagraph2='Los reflectores inalámbricos resuelven el problema más común en haciendas: no hay contactos cerca de las columnas ni de los árboles. Con batería, el reflector se pone al pie de donde quieras iluminar y listo. No hay cables cruzando el piso donde los invitados caminan. Para las haciendas coloniales de CDMX y Edomex — que es donde más montamos este servicio — la combinación clásica es ámbar en los arcos, verde en los árboles y violeta en la fachada principal. El equipo diseña la distribución según la arquitectura específica del venue.'
    />


    <!-- Galería -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="¿Cómo se ve la iluminación arquitectónica en un evento real?"
          subtitle="La arquitectura de tu venue se convierte en decoración."
          paragraph1="La posición del reflector importa. Si está demasiado pegado a la columna, ilumina solo la base. Demasiado lejos, el haz se abre y pierde intensidad. La distancia ideal es entre 30cm y 1 metro de la superficie, dependiendo de la altura. Cada columna, cada árbol, cada arco requiere su propio ajuste."
          paragraph2="El color también cambia según el material. La cantera absorbe los tonos cálidos (ámbar, dorado) de forma natural. El ladrillo rojo se ve bien con violeta porque el contraste crea profundidad. Los árboles con follaje verde se iluminan mejor en verde o blanco frío — el ámbar los hace ver amarillos."
        />
        <Gallery4x4 images={[
          { src: "/img/iluminacion-arquitectonica/boda-patio-hacienda-iluminacion-fachada-ambar-string-lights-baile.avif", alt: "Patio de hacienda con uplighting ámbar y guirnaldas para boda" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-arbol-centenario-verde-jardin-boda-luces-decorativas.avif", alt: "Árbol centenario iluminado en verde para boda en jardín" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-arbol-majestuoso-uplighting-verde-hacienda-colonial.avif", alt: "Uplighting verde en árbol majestuoso de hacienda colonial" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-arcada-hacienda-plantas-luz-ambar-evento-social.avif", alt: "Arcada de hacienda iluminada en ámbar para evento social" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-arcos-coloniales-columnas-piedra-luz-calida-boda.avif", alt: "Arcos coloniales y columnas de piedra con luz cálida para boda" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-arquitectonica-arcos-coloniales-luz-violeta-fachada.avif", alt: "Fachada con arcos coloniales en luz violeta" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-arboles-morados-boda-exterior-mesas-velas-romantico.avif", alt: "Árboles iluminados en morado para boda exterior romántica" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-boda-fachada-rosa-luces-colgantes-arboles-mesas.avif", alt: "Fachada rosa con luces colgantes y árboles iluminados" },
          { src: "/img/iluminacion-arquitectonica/boda-exterior-hacienda-luces-string-fachada-ambar-parejas-bailando.avif", alt: "Boda exterior en hacienda con fachada ámbar y parejas bailando" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-arcos-coloniales-luces-cadena-cielo-nocturno-hacienda.avif", alt: "Arcos coloniales con luces cadena bajo cielo nocturno" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-arquitectonica-moderna-azul-turquesa-terraza-lounge.avif", alt: "Iluminación arquitectónica moderna azul turquesa en terraza lounge" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-boda-hacienda-dosel-luces-fachada-rosa-flores.avif", alt: "Boda en hacienda con dosel de luces y fachada rosa" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-boda-lujo-rosa-columnas-pista-baile-pastel.avif", alt: "Boda de lujo con columnas rosa y pista de baile" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-camino-hacienda-mexicana-agaves-palmeras-entrada.avif", alt: "Camino de hacienda mexicana iluminado con agaves y palmeras" },
          { src: "/img/iluminacion-arquitectonica/iluminacion-boda-jardin-arboles-violeta-mesa-imperial-hacienda.avif", alt: "Jardín con árboles violeta y mesa imperial en hacienda" },
          { src: "/img/iluminacion-arquitectonica/equipo-reflectores-led-wash-calido-instalacion-profesional.avif", alt: "Equipo de reflectores LED wash cálido instalación profesional" },
        ]} />
      </div>
    </section>

    <!-- Paquetes -->
    <section class="services-section services-alt" id="paquetes">
      <div class="container">
        <SectionHeader
          title="¿Cuánto cuesta rentar iluminación arquitectónica en CDMX?"
          subtitle="4 opciones según lo que quieras iluminar. Reflectores inalámbricos."
          paragraph1="Cada paquete incluye reflectores LED inalámbricos con batería (sin cables en el piso), diseño de distribución según tu venue, montaje profesional y desmontaje. Los colores se controlan de forma inalámbrica o vía DMX según el modelo."
          paragraph2="¿Tu venue tiene una arquitectura especial? Mándanos fotos por WhatsApp y te diseñamos la distribución de reflectores ideal."
        />
        <PricingCards packages={[
          {
            name: "Básico — 6 Uplighters",
            price: "$3,500",
            priceNote: "+ IVA",
            description: "Fachada frontal o arco de ceremonia iluminado. El detalle que transforma la primera impresión de tu venue.",
            features: [
              { text: "6 uplighters LED inalámbricos", included: true },
              { text: "Batería hasta 12h (sin cables)", included: true },
              { text: "Color a tu elección (RGBW)", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Ideal para: fachada frontal, arco, entrada", included: true },
              { text: "Diseño de distribución incluido", included: true },
              { text: "Múltiples zonas de color", included: false },
              { text: "Cambios de color durante el evento", included: false },
            ],
            ctaLabel: "Ver paquete 6 uplighters",
            ctaHref: "/servicios/iluminacion-arquitectonica/paquete-6-uplighters/",
          },
          {
            name: "Estándar — 12 Uplighters",
            price: "$6,000",
            priceNote: "+ IVA",
            badge: "Más popular",
            highlight: true,
            description: "Fachada completa + jardín con árboles. El más pedido para bodas en haciendas coloniales.",
            features: [
              { text: "12 uplighters LED inalámbricos", included: true },
              { text: "Batería hasta 12h (sin cables)", included: true },
              { text: "2 zonas de color independientes", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Fachada + árboles + columnas", included: true },
              { text: "Ideal para: bodas en hacienda, jardines", included: true },
              { text: "Diseño personalizado de distribución", included: true },
              { text: "Cambios de color durante el evento", included: false },
            ],
            ctaLabel: "Ver paquete 12 uplighters",
            ctaHref: "/servicios/iluminacion-arquitectonica/paquete-12-uplighters/",
          },
          {
            name: "Premium — 20 Uplighters",
            price: "$9,500",
            priceNote: "+ IVA",
            description: "Hacienda completa: fachada, columnas, arcos, árboles, fuentes. Múltiples zonas con paletas diferentes.",
            features: [
              { text: "20 uplighters LED con control DMX", included: true },
              { text: "4+ zonas de color independientes", included: true },
              { text: "Cambios de color durante el evento", included: true },
              { text: "Operador con control inalámbrico", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Visita previa al venue", included: true },
              { text: "Ideal para: haciendas completas, fincas", included: true },
              { text: "Diseño de iluminación personalizado", included: true },
            ],
            ctaLabel: "Ver paquete 20 uplighters",
            ctaHref: "/servicios/iluminacion-arquitectonica/paquete-20-uplighters/",
          },
          {
            name: "Producción — 30+ Uplighters",
            price: "$14,000",
            priceNote: "+ IVA",
            description: "Iluminación arquitectónica completa para venues grandes, edificios históricos y producciones especiales.",
            features: [
              { text: "30+ uplighters de alta potencia", included: true },
              { text: "Coreografía de color programada", included: true },
              { text: "Múltiples fachadas y zonas", included: true },
              { text: "Equipo técnico completo", included: true },
              { text: "Sincronización con otros servicios", included: true },
              { text: "Logística + generadores si requerido", included: true },
              { text: "Visita técnica previa", included: true },
              { text: "Ideal para: edificios históricos, mega venues", included: true },
            ],
            ctaLabel: "Ver producción 30+",
            ctaHref: "/servicios/iluminacion-arquitectonica/paquete-produccion/",
          },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas frecuentes sobre iluminación arquitectónica"
          subtitle="Lo que nuestros clientes preguntan antes de contratar."
          paragraph1="Si tienes otra duda, escríbenos por WhatsApp y te respondemos en minutos."
          paragraph2="Cada venue tiene su arquitectura — te recomendamos la distribución de reflectores ideal para resaltar lo mejor de tu espacio."
        />
      </div>
      <FaqSection items={[
        { question: "¿De verdad son inalámbricos?", answer: "Sí. Batería recargable interna de hasta 12 horas. Se ponen en el piso al pie de la columna o el árbol y no necesitan contacto eléctrico cerca. Sin cables cruzando el piso donde caminan los invitados. Es la razón principal por la que funcionan en haciendas donde los contactos están lejos." },
        { question: "¿Cuántos reflectores necesito?", answer: "Depende de qué quieras iluminar. 6 uplighters cubren una fachada frontal con arcos. 12 cubren fachada + árboles del jardín. 20+ para una hacienda completa con múltiples fachadas, columnas y caminos. Mándanos fotos del venue y te decimos el número exacto." },
        { question: "¿Puedo cambiar colores durante la noche?", answer: "En paquetes Premium y Producción con DMX, sí — el operador cambia colores en tiempo real. En los paquetes Básico y Estándar, el color se fija al inicio del evento y se queda así toda la noche. La mayoría de las bodas eligen un solo color (ámbar o dorado) para toda la noche." },
        { question: "¿Dañan las fachadas?", answer: "No. Los reflectores van en el piso apuntando hacia arriba. No se pegan, atornillan ni fijan a nada. Al terminar, los recogemos y el venue queda igual. Los encargados de haciendas ya conocen este sistema y lo prefieren sobre cualquier instalación invasiva." },
        { question: "¿Funciona bajo lluvia?", answer: "Sí. Los reflectores tienen protección IP para exteriores. Operan bajo lluvia sin problema. De hecho, la superficie mojada refleja más la luz y el efecto se ve más intenso. Hemos montado en temporada de lluvias sin inconvenientes." },
        { question: "¿Qué color queda mejor en cantera?", answer: "Ámbar y dorado son los más pedidos — resaltan la textura natural de la piedra. Violeta genera un contraste dramático. Rosa es popular para bodas. Blanco frío da un look más moderno. Cada hacienda es diferente — si nos mandas fotos, te sugerimos la paleta." },
      ]} />
    </section>

    <!-- Servicios relacionados -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="¿Qué otros servicios combinan con iluminación arquitectónica?"
          subtitle="Columnas en ámbar abajo, guirnaldas cálidas arriba."
          paragraph1="Es la combinación más montada en haciendas de CDMX: uplighting en las columnas del patio y guirnaldas Edison cruzando el techo entre los arcos. Las dos capas de luz crean un ambiente cálido donde cada foto sale bien sin necesidad de flash."
          paragraph2="Si la hacienda tiene fachadas grandes, le sumamos city color para cubrir la superficie completa. El uplighting queda para los detalles (columnas, árboles, fuentes) y el city color para las paredes largas."
        />
        <div class="services-grid">
          {serviciosRelacionados.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Listo para que tu venue brille como nunca?</h2>
          <p>Mándanos fotos de las fachadas, columnas y jardines de tu venue. Te diseñamos la distribución de uplighting perfecta y te cotizamos en minutos.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
