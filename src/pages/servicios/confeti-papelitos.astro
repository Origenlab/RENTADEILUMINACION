---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import PricingCards from '../../components/PricingCards.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Confeti y Papelitos para Bodas y Salidas de Iglesia CDMX | REDEIL";
const description = "Lluvia de confeti para la salida de iglesia, el vals y el primer beso. Cañones de CO₂ y confeti manual biodegradable. Desde $1,500 + IVA en CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/confeti-papelitos/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Confeti y Papelitos para Bodas y Salidas de Iglesia",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Servicio de confeti y papelitos para bodas — lluvia de pétalos en salida de iglesia, confeti biodegradable para el vals y cañones de CO₂ sutiles para momentos ceremoniales en CDMX.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Confeti y Papelitos para Bodas",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿El confeti biodegradable se puede usar en la salida de la iglesia?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El confeti de papel biodegradable es la opción ideal para salidas de iglesia — se disuelve con agua en 24-72 horas sin dejar residuo en la banqueta ni dañar jardines. Es el tipo de confeti que recomendamos para cualquier espacio al aire libre." }},
      { "@type": "Question", "name": "¿Cuántos cañones necesito para mi boda?", "acceptedAnswer": { "@type": "Answer", "text": "Depende del momento. Para la salida de iglesia con 50-80 personas, basta con confeti manual biodegradable sin cañones. Para el vals en salón, 2 cañones de CO₂ sutiles cubren bien una pista de 100m². Para una boda completa con múltiples momentos (entrada, vals, salida), recomendamos 4 cañones posicionados estratégicamente." }},
      { "@type": "Question", "name": "¿El confeti de pétalos es real o artificial?", "acceptedAnswer": { "@type": "Answer", "text": "Ofrecemos ambas opciones. Los pétalos naturales son ideales para ceremonias íntimas y fotografías románticas. Los pétalos de tela y papel biodegradable son más económicos y funcionan mejor con cañones de CO₂ porque tienen el peso correcto para flotar en el aire." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "Máquinas de Confeti CO₂", image: "/img/confeti/maquina-confeti-boda-novios-celebracion.avif", alt: "Máquina de confeti CO₂ para eventos masivos", description: "¿Necesitas explosiones de confeti para un concierto, festival o evento masivo? Las máquinas de CO₂ profesionales cubren estadios completos.", link: "/servicios/confeti/" },
  { title: "Humo Bajo", image: "/img/humo-bajo/humo-bajo-primer-baile-boda-romantico.avif", alt: "Humo bajo en primer baile de boda", description: "Confeti cayendo + niebla baja en el piso = la foto más cinematográfica de tu boda. Dos efectos que se complementan perfecto.", link: "/servicios/humo-bajo/" },
  { title: "Burbujas", image: "/img/burbujas/burbujas-efecto-especial-fotografia-video.avif", alt: "Burbujas en boda de jardín", description: "Burbujas + pétalos en la salida de iglesia. Una combinación delicada y romántica que encanta a todos los invitados.", link: "/servicios/burbujas/" },
  { title: "Seguidor de Luz", image: "/img/seguidor/luz-seguidor-boda-baile-novios-salon-candil.avif", alt: "Seguidor iluminando vals de novios", description: "Spotlight en los novios + lluvia de confeti = la imagen que la gente enmarca. El efecto más fotografiado en bodas.", link: "/servicios/seguidor/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Confeti y Papelitos para Bodas" }
  ]} />
</Fragment>

    <Hero
      title="Confeti y Papelitos para el Momento Más Fotografiado de tu Boda"
      subtitle="Lluvia de confeti en la salida de iglesia, el primer beso y el vals. Pétalos, confeti biodegradable y cañones de CO₂ sutiles. Desde $1,500 + IVA."
      introParagraph1='Hay un momento en cada boda que todo el mundo recuerda: los novios cruzando la puerta de la iglesia bajo una lluvia de pétalos y confeti. Las cámaras disparan, los invitados aplauden y por un segundo el tiempo se detiene. Ese momento no necesita una máquina de CO₂ industrial — necesita <strong>confeti manual biodegradable, pétalos naturales o cañones sutiles</strong> que crean una nube delicada, íntima y perfectamente coordinada con el fotógrafo.'
      introParagraph2='En <strong>REDEIL</strong> nos especializamos en los momentos ceremoniales de la boda: la salida de iglesia, el primer beso como esposos, el vals padre-hija y el primer baile. Cada momento tiene su propio tipo de confeti — pétalos para la ceremonia, confeti biodegradable para exteriores, corazones dorados para el vals. Coordinamos cada disparo con el fotógrafo y el videógrafo para que la lluvia suceda exactamente cuando la cámara está lista. Bodas íntimas de 50 personas hasta celebraciones de 400+ en toda la CDMX y Estado de México.'
    />


    <!-- Galería -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="Confeti y pétalos en bodas reales"
          subtitle="Salidas de iglesia, vals, primer beso — cada momento con su confeti ideal."
          paragraph1="El confeti dorado cayendo sobre los novios en su primer baile. Los pétalos rosas volando en la salida de la iglesia. Los corazones de papel flotando mientras se dan el primer beso como esposos. Cada uno de estos momentos merece un tipo diferente de confeti y un timing perfecto."
          paragraph2="Nuestro equipo trabaja directamente con tu fotógrafo y videógrafo. El operador espera la señal exacta para que la lluvia de confeti coincida con el momento en que las cámaras están listas."
        />
        <Gallery4x4 images={[
          { src: "/img/maquina-de-papelitos/confeti-salida-iglesia-boda-novios-felices.avif", alt: "Confeti en salida de iglesia de boda con novios felices" },
          { src: "/img/maquina-de-papelitos/confeti-rosa-boda-atardecer-beso-novios.avif", alt: "Confeti rosa en boda al atardecer con beso de novios" },
          { src: "/img/maquina-de-papelitos/confeti-dorado-primer-baile-novios-romantico.avif", alt: "Confeti dorado en primer baile de novios romántico" },
          { src: "/img/maquina-de-papelitos/confeti-petalos-boda-jardin-camino-novios.avif", alt: "Pétalos y confeti en camino de novios en boda de jardín" },
          { src: "/img/confeti/confeti-dorado-boda-novios-fiesta.avif", alt: "Confeti dorado en fiesta de boda con novios" },
          { src: "/img/maquina-de-papelitos/maquina-confeti-primer-baile-boda-salon-elegante.avif", alt: "Confeti en primer baile de boda en salón elegante" },
          { src: "/img/maquina-de-papelitos/explosion-confeti-blanco-boda-pista-baile.avif", alt: "Explosión de confeti blanco en pista de baile de boda" },
          { src: "/img/maquina-de-papelitos/confeti-rosa-boda-jardin-atardecer-novios.avif", alt: "Confeti rosa en boda de jardín al atardecer" },
          { src: "/img/maquina-de-papelitos/lluvia-papelitos-boda-elegante-candelabros.avif", alt: "Lluvia de papelitos en boda elegante con candelabros" },
          { src: "/img/maquina-de-papelitos/maquina-confeti-baile-padre-novia-recepcion.avif", alt: "Confeti en baile de padre con novia en recepción" },
          { src: "/img/confeti/maquina-confeti-boda-novios-celebracion.avif", alt: "Máquina de confeti en celebración de boda" },
          { src: "/img/maquina-de-papelitos/lluvia-confeti-corazones-xv-anos-vestido-rosa.avif", alt: "Lluvia de confeti corazones en celebración con vestido rosa" },
          { src: "/img/maquina-de-papelitos/lluvia-confeti-boda-candelier-chispas-frias.avif", alt: "Lluvia de confeti con candelier y chispas frías en boda" },
          { src: "/img/maquina-de-papelitos/confeti-dorado-xv-anos-vals-quinceañera.avif", alt: "Confeti dorado en vals de celebración" },
          { src: "/img/maquina-de-papelitos/maquina-confeti-xv-anos-baile-padre-quinceañera.avif", alt: "Confeti en baile emotivo padre e hija" },
          { src: "/img/maquina-de-papelitos/explosion-confeti-rosa-revelacion-sexo-bebe-nina.avif", alt: "Explosión de confeti rosa en celebración especial" },
        ]} />
      </div>
    </section>

    <!-- Paquetes -->
    <section class="services-section services-alt" id="paquetes">
      <div class="container">
        <SectionHeader
          title="Paquetes de Confeti para Bodas"
          subtitle="Desde la salida de iglesia hasta la producción completa. Operador y coordinación incluidos."
          paragraph1="Cada paquete incluye el confeti en el color y forma que elijas, operador técnico, traslado y coordinación con tu fotógrafo. El operador sincroniza cada disparo con las cámaras para que la lluvia suceda en el momento exacto."
          paragraph2="¿Pétalos naturales, confeti biodegradable o corazones dorados? Te asesoramos según el venue, el momento y el estilo de tu boda."
        />
        <PricingCards packages={[
          {
            name: "Salida de Iglesia",
            price: "$1,500",
            priceNote: "+ IVA",
            description: "Confeti manual biodegradable y pétalos para la salida de iglesia. El momento más clásico y fotografiado.",
            features: [
              { text: "Confeti manual biodegradable para invitados", included: true },
              { text: "Pétalos naturales o de tela incluidos", included: true },
              { text: "Distribución a 50-80 invitados", included: true },
              { text: "Coordinación con fotógrafo/videógrafo", included: true },
              { text: "Ideal para: salida de iglesia, ceremonia civil", included: true },
              { text: "Cañones de CO₂", included: false },
              { text: "Múltiples momentos", included: false },
              { text: "Confeti metálico o dorado", included: false },
            ],
            ctaLabel: "Cotizar salida de iglesia",
            ctaHref: "/contacto/",
          },
          {
            name: "Bodas Íntimas",
            price: "$2,500",
            priceNote: "+ IVA",
            badge: "Más popular",
            highlight: true,
            description: "2 cañones de CO₂ sutiles + confeti biodegradable + pétalos para el vals y un momento adicional.",
            features: [
              { text: "2 cañones de CO₂ sutiles", included: true },
              { text: "Confeti biodegradable + pétalos", included: true },
              { text: "2 momentos: vals + salida o primer beso", included: true },
              { text: "Operador técnico incluido", included: true },
              { text: "Coordinación con fotógrafo y DJ", included: true },
              { text: "Traslado + montaje + desmontaje", included: true },
              { text: "Ideal para: bodas íntimas 50-150 personas", included: true },
              { text: "Colores a tu elección", included: true },
            ],
            ctaLabel: "Cotizar bodas íntimas",
            ctaHref: "/contacto/",
          },
          {
            name: "Boda Completa",
            price: "$4,500",
            priceNote: "+ IVA",
            description: "4 cañones + confeti biodegradable para múltiples momentos: entrada, vals, primer beso y salida.",
            features: [
              { text: "4 cañones de CO₂ profesionales", included: true },
              { text: "Confeti biodegradable en varios colores", included: true },
              { text: "Cobertura de 3-4 momentos del evento", included: true },
              { text: "Entrada + vals + primer beso + salida", included: true },
              { text: "Operador técnico toda la recepción", included: true },
              { text: "Coordinación completa con DJ y MC", included: true },
              { text: "Pétalos + corazones + confeti circular", included: true },
              { text: "Ideal para: bodas 150-300 personas", included: true },
            ],
            ctaLabel: "Cotizar boda completa",
            ctaHref: "/contacto/",
          },
          {
            name: "Producción Boda Premium",
            price: "$7,500",
            priceNote: "+ IVA",
            description: "8 cañones + confeti dorado premium + pétalos + coordinación completa de todos los momentos ceremoniales.",
            features: [
              { text: "8 cañones de CO₂ posicionados estratégicamente", included: true },
              { text: "Confeti dorado, corazones y pétalos premium", included: true },
              { text: "Cobertura ilimitada de momentos", included: true },
              { text: "Equipo técnico completo (2 operadores)", included: true },
              { text: "Visita previa al venue", included: true },
              { text: "Coordinación con wedding planner", included: true },
              { text: "Confeti biodegradable para exteriores", included: true },
              { text: "Ideal para: bodas 300+ personas", included: true },
            ],
            ctaLabel: "Cotizar producción premium",
            ctaHref: "/contacto/",
          },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre Confeti para Bodas"
          subtitle="Todo lo que necesitas saber antes de tu boda."
          paragraph1="Si tienes otra duda, escríbenos por WhatsApp y te respondemos en minutos."
          paragraph2="Te asesoramos sobre tipo de confeti, colores y logística según tu venue y estilo de boda."
        />
      </div>
      <FaqSection items={[
        { question: "¿El confeti biodegradable se puede usar en la salida de la iglesia?", answer: "Sí. El confeti de papel biodegradable es la opción ideal para salidas de iglesia — se disuelve con agua en 24-72 horas sin dejar residuo en la banqueta ni dañar jardines. Es el tipo de confeti que recomendamos para cualquier espacio al aire libre. Muchas iglesias y haciendas lo permiten sin problema." },
        { question: "¿Cuántos cañones necesito para mi boda?", answer: "Depende del momento. Para la salida de iglesia con 50-80 personas, basta con confeti manual biodegradable sin cañones. Para el vals en salón, 2 cañones de CO₂ sutiles cubren bien una pista de 100m². Para una boda completa con múltiples momentos (entrada, vals, salida), recomendamos 4 cañones posicionados estratégicamente." },
        { question: "¿El confeti de pétalos es real o artificial?", answer: "Ofrecemos ambas opciones. Los pétalos naturales son ideales para ceremonias íntimas y fotografías románticas. Los pétalos de tela y papel biodegradable son más económicos y funcionan mejor con cañones de CO₂ porque tienen el peso correcto para flotar en el aire. Te asesoramos según el estilo de tu boda." },
        { question: "¿Qué diferencia hay entre este servicio y las máquinas de confeti CO₂?", answer: "Este servicio está diseñado para momentos ceremoniales de bodas — salida de iglesia, primer beso, vals. Usamos confeti sutil, pétalos y cañones de CO₂ discretos. Las máquinas de confeti CO₂ (servicio aparte) son explosiones de gran alcance para conciertos, festivales y eventos masivos donde el impacto visual debe llegar a cientos de personas." },
        { question: "¿Coordinan con mi fotógrafo?", answer: "Siempre. El operador se presenta con tu fotógrafo y videógrafo antes de la ceremonia para acordar las señales de timing. La lluvia de confeti sucede exactamente cuando las cámaras están listas — eso es lo que diferencia un servicio profesional de lanzar confeti al azar." },
        { question: "¿Qué colores y formas de confeti tienen?", answer: "Para bodas tenemos: dorado, plateado, blanco, rosa, champagne y colores personalizados. En formas: corazones, círculos, estrellas, mariposas y pétalos. El confeti dorado con corazones es el más solicitado para el vals, y los pétalos blancos o rosas para la salida de iglesia." },
      ]} />
    </section>

    <!-- Servicios relacionados -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Combina con Otros Efectos para tu Boda"
          subtitle="El confeti es solo uno de los momentos mágicos."
          paragraph1="Confeti en el primer baile + humo bajo en el piso + spotlight del seguidor iluminando a los novios. Esa combinación es la foto que la gente enmarca y comparte. Cada efecto se potencia cuando se combina con los demás."
          paragraph2="Armamos paquetes combinados con precio especial para bodas completas."
        />
        <div class="services-grid">
          {serviciosRelacionados.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Lista para la lluvia de confeti en tu boda?</h2>
          <p>Cuéntanos en qué momento quieres el confeti — salida de iglesia, vals, primer beso — y te armamos el paquete perfecto.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
