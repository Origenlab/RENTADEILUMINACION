---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Paquete Blacklight Básico — UV para Fiestas CDMX | REDEIL";
const description = "Renta de 4-6 barras UV LED para pista de baile hasta 80m². Iluminación blacklight profesional para fiestas y cumpleaños en CDMX. Desde $3,500 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/luz-negra/paquete-blacklight-basico/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Paquete Blacklight Básico — Luz Negra UV",
    "description": "Renta de 4-6 barras UV LED para pista de baile hasta 80m². Iluminación blacklight profesional para fiestas íntimas y cumpleaños en CDMX. Incluye transporte, instalación y desmontaje.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/luz-negra/paquete-blacklight-basico/",
      "priceCurrency": "MXN",
      "price": "3500",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "38",
      "reviewCount": "38"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "María del Carmen" },
        "datePublished": "2026-01-18",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Contratamos el Blacklight Básico para los XV años de mi hija en un salón de Coyoacán. Eran 60 invitados y la pista quedó espectacular — todo lo blanco brillaba increíble. La instalación fue rápida y sin contratiempos. 100% recomendados."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Ricardo Guzmán" },
        "datePublished": "2025-11-30",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Primera vez que usaba luz UV en mi fiesta de cumpleaños en Polanco. El efecto con las camisas blancas de los invitados fue impresionante. REDEIL llegó puntual, montó todo en menos de una hora y el resultado fue increíble."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Sofía Herrera" },
        "datePublished": "2025-10-15",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Usamos las barras UV para nuestra fiesta universitaria con temática neón. Transformaron el salón completamente. El maquillaje UV de mis amigas brillaba increíble. Super recomendados para cualquier fiesta íntima."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/luz-negra/renta-luz-negra-profesional.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿4-6 barras UV son suficientes para mi salón?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. 4-6 barras UV LED profesionales cubren pistas de baile de hasta 80m² con cobertura uniforme. Para salones completos más grandes, te recomendamos el Paquete Blacklight Party con 8-12 barras." }},
      { "@type": "Question", "name": "¿El Blacklight Básico incluye accesorios fluorescentes?", "acceptedAnswer": { "@type": "Answer", "text": "El paquete básico se enfoca en la iluminación UV para pista de baile. No incluye accesorios fluorescentes. Si quieres pulseras, collares y pintura facial, el Paquete Blacklight Party incluye 50 accesorios desde $6,500 + IVA." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Blacklight Party", description: "Glow party completa con 8-12 barras UV + 50 accesorios fluorescentes. El más pedido para XV años. $6,500 + IVA.", image: "/img/luz-negra/ambiente-glow-xv-anos.avif", alt: "Glow party con UV para XV años", link: "/servicios/luz-negra/paquete-blacklight-party/" },
  { title: "UV Premium", description: "UV completo + letreros neón personalizados. Bodas neón y eventos premium. $10,000 + IVA.", image: "/img/luz-negra/ambiente-neon-boda.avif", alt: "UV premium para boda neón", link: "/servicios/luz-negra/paquete-uv-premium/" },
  { title: "Producción UV", description: "Producción completa para eventos masivos. 20+ barras UV + decoración + DJ. $15,000 + IVA.", image: "/img/luz-negra/ambiente-glow-party-neon.avif", alt: "Producción UV para evento masivo", link: "/servicios/luz-negra/paquete-produccion-uv/" },
  { title: "Luces Neón LED", description: "Letreros neón personalizados y efectos decorativos. El complemento perfecto para el UV.", image: "/img/luces-neon/renta-luces-neon-glow-party-celebracion-neon-300w.avif", alt: "Luces neón para glow party", link: "/servicios/luces-neon/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Iluminación", href: "/servicios/iluminacion/" },
    { label: "Luz Negra", href: "/servicios/luz-negra/" },
    { label: "Blacklight Básico" }
  ]} />
</Fragment>

    <Hero
      title="Paquete Blacklight Básico — Luz Negra UV para tu Pista"
      subtitle="Desde $3,500 + IVA · 4-6 barras UV LED · Pista de baile hasta 80m² · Instalación incluida"
      introParagraph1='¿Tienes un salón pequeño o mediano y quieres que la pista de baile brille con luz negra? El Paquete Blacklight Básico es exactamente lo que necesitas. Con 4-6 barras UV LED profesionales cubrimos hasta 80m² de pista — suficiente para un salón íntimo de hasta 80 invitados. El efecto es inmediato: todo lo blanco brilla intensamente, el maquillaje UV de las invitadas se dispara, las camisas blancas de los chambelanes resplandecen. Es la transformación perfecta para cumpleaños, fiestas privadas y eventos con temática neón en un espacio recogido.'
      introParagraph2='En <strong>REDEIL</strong> llevamos más de 30 años en iluminación profesional para eventos. Usamos equipo de marcas reconocidas como <strong>Chauvet</strong> y <strong>Elation</strong> — no material de segunda categoría. El servicio incluye transporte a tu venue en CDMX o Estado de México, montaje, operador durante el evento y desmontaje al finalizar. Sin sorpresas. Sin costos ocultos. Solo le dices el tamaño de tu salón y el tipo de evento, y nosotros nos encargamos del resto.'
    />


    <!-- Contenido principal + Sidebar sticky -->
    <section class="services-section">
      <ContentWithSidebar
        sidebarTitle="Paquete Blacklight Básico"
        price="$3,500"
        priceNote="+ IVA · Instalación incluida"
        features={[
          { text: "4-6 barras UV LED profesionales" },
          { text: "Cobertura pista hasta 80m²" },
          { text: "Equipo Chauvet / Elation" },
          { text: "Transporte ida y vuelta" },
          { text: "Montaje profesional" },
          { text: "Operador durante el evento" },
          { text: "Desmontaje al finalizar" },
          { text: "Control DMX incluido" },
          { text: "Cobertura CDMX y Edomex" },
          { text: "Asesoría gratuita de distribución" },
        ]}
        waMessage="Hola REDEIL, quiero cotizar el Paquete Blacklight Básico de luz negra para mi evento."
        packages={[
          { label: "Blacklight Básico", price: "$3,500", href: "/servicios/luz-negra/paquete-blacklight-basico/", active: true },
          { label: "Blacklight Party", price: "$6,500", href: "/servicios/luz-negra/paquete-blacklight-party/" },
          { label: "UV Premium", price: "$10,000", href: "/servicios/luz-negra/paquete-uv-premium/" },
          { label: "Producción UV", price: "$15,000", href: "/servicios/luz-negra/paquete-produccion-uv/" },
        ]}
      >
        <div class="container">
          <SectionHeader
            title="Ideal para estos espacios y eventos"
            subtitle="4-6 barras UV cubren la pista de cualquier salón íntimo."
            paragraph1="El Paquete Blacklight Básico fue diseñado para eventos donde el espacio es reducido pero el impacto visual necesita ser máximo. La concentración de las barras UV sobre la pista crea un efecto de luz negra más intenso que si las distribuyeras en un espacio grande."
            paragraph2="Si tu salón tiene techo de hasta 3 metros y la pista no supera 80m², este paquete te da exactamente lo que necesitas. Sin pagar por cobertura que no vas a usar."
          />
          <FeatureGrid features={[
            { title: "Pista de baile hasta 80m²", description: "Cobertura completa y uniforme para que no haya zonas oscuras en la pista." },
            { title: "Salones con techo de hasta 3m", description: "Las barras UV funcionan mejor cerca del espacio. Techos bajos = mayor intensidad." },
            { title: "Fiestas privadas y cumpleaños", description: "El ambiente íntimo potencia el efecto blacklight — menos luz ambiente, más impacto." },
            { title: "Cumpleaños temáticos universitarios", description: "El favorito de generaciones. La temática neón nunca falla para fiestas juveniles." },
            { title: "Hora loca con toque UV", description: "Enciende el UV en la hora loca y transforma el ambiente en segundos. Efecto garantizado." },
            { title: "Espacio de coctel con ambiente", description: "Una o dos barras UV en la zona de coctel crean un ambiente diferente al resto del salón." },
          ]} columns={2} />
        </div>

        <div class="container" style="margin-top: 3rem;">
          <SectionHeader
            title="Equipo profesional Chauvet y Elation"
            subtitle="No cualquier barra UV — equipo de grado profesional."
            paragraph1="La diferencia entre una barra UV de ferretería y una profesional se nota a simple vista. Nuestro equipo Chauvet y Elation tiene mayor potencia, cobertura angular más amplia y vida útil garantizada — no se calientan ni parpadean durante tu evento."
            paragraph2="Control DMX incluido: podemos sincronizar el UV con otras luces del evento para crear momentos de impacto máximo. La hora loca con UV activado al mismo tiempo que otros efectos es siempre el momento más fotografiado de la noche."
          />
        </div>

        <div class="container" style="margin-top: 3rem;">
          <SectionHeader
            title="Lo que dicen nuestros clientes"
            subtitle="⭐⭐⭐⭐⭐ 5 estrellas en 38 reseñas verificadas."
            paragraph1="Cada reseña es de un cliente real que contrató el Blacklight Básico para su evento."
            paragraph2="Pregúntanos por referencias de eventos similares al tuyo cuando nos contactes."
          />
          <TestimonialCards testimonials={[
            { name: "María del Carmen", event: "XV años en salón — Coyoacán, 60 invitados", rating: 5, text: "La pista quedó espectacular — todo lo blanco brillaba increíble. La instalación fue rápida y sin contratiempos. 100% recomendados para fiestas íntimas con temática neón." },
            { name: "Ricardo Guzmán", event: "Cumpleaños adultos — Polanco, primera vez con UV", rating: 5, text: "Primera vez que usaba luz UV en mi cumpleaños. El efecto con las camisas blancas de los invitados fue impresionante. REDEIL llegó puntual y el resultado fue increíble." },
            { name: "Sofía Herrera", event: "Fiesta universitaria — temática neón", rating: 5, text: "Transformaron el salón completamente con solo las barras básicas. El maquillaje UV de mis amigas brillaba increíble. Super recomendados para cualquier fiesta íntima." },
          ]} />
        </div>
      </ContentWithSidebar>
    </section>

    <!-- Galería -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Así se ve el Paquete Blacklight Básico"
          subtitle="Pistas pequeñas, salones íntimos, fiestas privadas con luz negra UV."
          paragraph1="Cada imagen muestra el tipo de ambiente que crea el efecto blacklight en espacios íntimos. La intensidad del UV en un salón pequeño es mayor que en un espacio grande — aprovecha esa ventaja."
          paragraph2="¿Tu salón es parecido a alguno de estos? Mándanos fotos por WhatsApp y te decimos cómo quedarían las barras UV distribuidas."
        />
        <Gallery4x4 images={[
          { src: "/img/luz-negra/ambiente-blacklight-fiesta.avif", alt: "Fiesta íntima con luz negra UV blacklight" },
          { src: "/img/luz-negra/ambiente-uv-cumpleanos.avif", alt: "Cumpleaños con efecto UV luz negra" },
          { src: "/img/luz-negra/decoracion-uv-fiesta.avif", alt: "Decoración fluorescente UV para fiesta privada" },
          { src: "/img/luz-negra/luz-uv-fiesta-tematica.avif", alt: "Fiesta temática neón con luz UV profesional" },
          { src: "/img/luz-negra/ambiente-blacklight-disco.avif", alt: "Pista de baile con iluminación blacklight" },
          { src: "/img/luz-negra/luz-ultravioleta-salon.avif", alt: "Salón pequeño iluminado con luz ultravioleta" },
          { src: "/img/luz-negra/renta-luz-negra-profesional.avif", alt: "Renta de luz negra profesional para evento íntimo" },
          { src: "/img/luz-negra/decoracion-fluorescente-salon.avif", alt: "Decoración fluorescente en salón con luz negra" },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre el Paquete Blacklight Básico"
          subtitle="Todo lo que necesitas saber antes de reservar."
          paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
          paragraph2="Cada espacio es diferente — te asesoramos gratis sobre si 4-6 barras UV son suficientes para tu venue."
        />
      </div>
      <FaqSection items={[
        { question: "¿4-6 barras UV son suficientes para mi salón?", answer: "Depende del tamaño. Para pistas de baile de hasta 80m² y salones íntimos de hasta 80 invitados, sí son suficientes. Si tu salón es más grande o quieres cubrir el espacio completo (no solo la pista), te recomendamos el Paquete Blacklight Party con 8-12 barras desde $6,500 + IVA." },
        { question: "¿El Blacklight Básico incluye accesorios fluorescentes?", answer: "No. El paquete básico se enfoca en la iluminación UV para la pista de baile. Si quieres pulseras neón, collares fluorescentes y pintura facial UV para tus invitados, el Paquete Blacklight Party incluye 50 accesorios por $6,500 + IVA." },
        { question: "¿Funciona en un salón con techo bajo (2.5-3m)?", answer: "Perfectamente. Las barras UV funcionan mejor a corta distancia — en techos bajos el efecto es incluso más intenso. Montamos las barras en soportes o las anclamos según la estructura del venue para optimizar la cobertura." },
        { question: "¿Se puede combinar con otras luces de color?", answer: "Sí, y es lo que recomendamos para crear ambientes dinámicos. El UV se puede combinar con PAR LED de colores, cabezas móviles o city lights para alternar entre un ambiente de colores y el efecto blacklight. El control DMX incluido permite sincronizar todo." },
        { question: "¿Cuánto tiempo antes llega el equipo?", answer: "Llegamos entre 1 y 2 horas antes del evento para montar e instalar. Para salones con condiciones especiales (techo alto, estructuras complejas), podemos coordinar llegada anticipada. Todo queda probado antes de que lleguen tus invitados." },
        { question: "¿Qué debo pedir a mis invitados para que se vea bien?", answer: "Lo básico: que usen ropa blanca o colores neón (amarillo, verde, naranja, rosa fluorescente). Todo lo blanco brilla intensamente con el UV. El maquillaje luminoso también funciona excelente. Si quieres que todos brillen por igual, el Paquete Blacklight Party incluye accesorios fluorescentes para todos." },
      ]} />
    </section>

    <!-- Otros paquetes -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Otros Paquetes de Luz Negra"
          subtitle="¿Necesitas más cobertura UV o accesorios fluorescentes?"
          paragraph1="Si tu evento es más grande, si quieres accesorios para todos tus invitados, o si buscas una producción completa con letreros neón y DJ, tenemos el paquete que se ajusta a tu evento."
          paragraph2="También puedes combinar el blacklight con luces neón LED decorativas para una fiesta aún más impactante."
        />
        <div class="services-grid">
          {otrosPaquetes.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Listo para que tu pista de baile brille?</h2>
          <p>Dinos el tamaño de tu salón y el tipo de evento. Confirmamos si 4-6 barras UV son suficientes y te cotizamos en minutos.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza tu Paquete UV</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
