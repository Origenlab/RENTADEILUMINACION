---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import GallerySection from "../../components/GallerySection.astro";
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const title = "Renta de Bocinas para Conferencias | REDEIL CDMX";
const description = "Renta de bocinas y sonido profesional para conferencias, seminarios y eventos corporativos en CDMX. Audio claro para presentaciones y ponencias. REDEIL.";
const canonical = "https://rentadeiluminacion.com/servicios/bocinas-conferencias/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Bocinas para Conferencias",
  "provider": {
    "@type": "LocalBusiness",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com",
    "telephone": "+525530682988",
    "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressCountry": "MX" }
  },
  "description": "Servicio de renta de bocinas y sonido profesional para conferencias, seminarios, congresos y eventos corporativos en Ciudad de México.",
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "serviceType": "Renta de Bocinas para Conferencias"
});
---
<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Servicios", href: "/servicios/" }, { label: "Bocinas para Conferencias" }]} />
</Fragment>
<Hero
      title="Renta de Bocinas para Conferencias en CDMX"
      subtitle="Audio profesional que garantiza claridad en cada ponencia y presentación"
      introParagraph1="En REDEIL ofrecemos renta de bocinas y sistemas de sonido profesional para conferencias, seminarios, congresos y eventos corporativos en la Ciudad de México. Nuestros equipos están diseñados para lograr inteligibilidad de voz perfecta en auditorios, salones de hotel y centros de convenciones."
      introParagraph2="Cada montaje incluye bocinas de rango completo, micrófonos de solapa e inalámbricos, mezcladoras digitales y técnicos de audio que se encargan de la operación durante todo el evento. Garantizamos que cada palabra llegue con claridad a todos los asistentes."
    />
    <section class="service-detail">
      <SectionHeader
          title="Sonido claro y profesional para eventos corporativos"
          subtitle="Instalación profesional incluida en CDMX y Edomex."
          paragraph1="En una conferencia, la calidad del audio es fundamental para que el mensaje llegue con claridad a cada asistente. Un sistema de sonido mal configurado puede arruinar una presentación importante, generar fatiga auditiva y restar profesionalismo al evento. En REDEIL entendemos estas necesidades y ofrecemos soluciones de audio a la medida."
          paragraph2="Nuestro inventario incluye bocinas de alta definición, sistemas de line array para auditorios grandes, micrófonos de solapa para ponentes, micrófonos de mano para sesiones de preguntas y respuestas, y mezcladoras digitales con procesamiento de voz. Cada equipo es seleccionado según las dimensiones del espacio y el número de asistentes."
        />
        <p>Cubrimos conferencias en hoteles, centros de convenciones, universidades, salas de capacitación y auditorios en toda la CDMX y zona metropolitana. Nuestro equipo técnico realiza pruebas de audio previas para asegurar cobertura uniforme.</p>
      </div>
    </section>
    <GallerySection title="Galería de Sonido para Conferencias" subtitle="Montajes de audio en eventos corporativos reales">
      <figure class="gallery-item">
        <img src="/img/bocinas-conferencias/renta-de-bocinas-para-conferencias-salon-ejecutivo.avif" alt="Bocinas profesionales instaladas en salón ejecutivo para conferencia corporativa" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-conferencias/alquiler-bocinas-conferencias-sala-juntas.avif" alt="Sistema de audio profesional en sala de juntas para conferencia empresarial" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-conferencias/renta-sonido-conferencias-auditorio-profesional.avif" alt="Sonido profesional montado en auditorio para conferencia magistral" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-conferencias/renta-bocinas-conferencias-empresariales-profesional.avif" alt="Montaje de bocinas profesionales para conferencia empresarial" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-conferencias/renta-de-bocinas-conferencias-centro-convenciones.avif" alt="Sistema de sonido en centro de convenciones para congreso" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-conferencias/alquiler-bocinas-eventos-corporativos-premium.avif" alt="Equipo de audio premium instalado para evento corporativo" width="800" height="533" loading="lazy">
      </figure>
    </GallerySection>
</BaseLayout>
