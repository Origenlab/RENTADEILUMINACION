---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Hero from "../../components/Hero.astro";
import CtaBar from "../../components/CtaBar.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import Gallery4x4 from "../../components/Gallery4x4.astro";
import PricingCards from "../../components/PricingCards.astro";
import FaqSection from "../../components/FaqSection.astro";

const title = "Renta de Bengalas Frías CDMX | REDEIL — Sparklers para Eventos";
const description = "Renta de bengalas frías y sparklers en CDMX. Chispas sin calor, sin humo, sin riesgo. Para entrada de novios, XV años y momentos especiales. Cotiza gratis.";
const canonical = "https://rentadeiluminacion.com/servicios/sparklers/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Bengalas Frías y Sparklers CDMX",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Renta de bengalas frías y sparklers en CDMX. Efectos de chispas sin humo ni calor para entradas de novios, XV años y lanzamientos de marca.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Renta de Bengalas Frías",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Las bengalas frías son seguras en interiores?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Las bengalas frías producen chispas a temperatura ambiente que no queman ni dejan residuo caliente. Son el único efecto de chispas aprobado para interiores. No generan humo, no activan alarmas y no dañan pisos, telas ni decoración." } },
      { "@type": "Question", "name": "¿Cuánto duran las bengalas frías?", "acceptedAnswer": { "@type": "Answer", "text": "El tiempo estándar es 30 segundos por bengala. Hay versiones de 60 y 90 segundos según el paquete. Nuestro técnico sincroniza la duración con la entrada de los novios o el momento que elijas para que el efecto ocurra exactamente durante el paso." } },
      { "@type": "Question", "name": "¿Las chispas de las bengalas frías queman?", "acceptedAnswer": { "@type": "Answer", "text": "No. Las bengalas frías (cold sparks) utilizan titanio granulado que produce chispas a temperatura ambiente. Son seguras al tacto y no queman piel, tela ni madera. Son el único efecto pirotécnico aprobado para uso en interiores sin ventilación especial." } },
      { "@type": "Question", "name": "¿Cuántas bengalas necesito para mi evento?", "acceptedAnswer": { "@type": "Answer", "text": "Para un pasillo nupcial estándar, 4 bengalas (2 por lado) crean el efecto clásico. Para una entrada más dramática, 6 u 8 bengalas cubren un arco completo. Para escenarios en presentaciones de marca, desde 2 hasta 20 unidades según el tamaño." } },
      { "@type": "Question", "name": "¿Las bengalas frías necesitan permiso especial?", "acceptedAnswer": { "@type": "Answer", "text": "No requieren permiso de pirotecnia al ser un efecto frío no explosivo. Sin embargo, recomendamos avisar al venue con anticipación ya que algunos salones tienen políticas propias. Nosotros podemos acompañarlos con una nota técnica del equipo si el venue lo requiere." } },
      { "@type": "Question", "name": "¿Se pueden combinar con CO2 o confeti?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, es la combinación más solicitada para bodas de alto impacto. Bengalas frías + CO2 en la entrada de novios, o bengalas + confeti durante el brindis. Nuestro equipo técnico coordina todos los efectos de forma simultánea." } }
    ]
  }
]);

const serviciosRelacionados = [
  { title: "Máquina CO2", image: "/img/galeria/humo-bajo-01.avif", alt: "Máquina de CO2 con vapor frío en evento", description: "Combinados con bengalas frías, los cañones de CO2 crean el efecto de entrada más impactante. Vapor y chispas al mismo tiempo.", link: "/servicios/co2/" },
  { title: "Confeti", image: "/img/confeti/confeti-dorado-boda-novios-fiesta.avif", alt: "Cañón de confeti dorado en boda", description: "Confeti + bengalas para el brindis. La lluvia de papel y chispas frías es uno de los momentos más fotografiados.", link: "/servicios/confeti/" },
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Nubes de humo bajo en pista de baile", description: "Para el vals, bengalas frías en el pasillo y humo bajo en la pista. La combinación perfecta para el primer baile.", link: "/servicios/humo-bajo/" },
  { title: "Seguidor de Luz", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Seguidor de luz en primer baile de novios", description: "Ilumina a los novios mientras caminan entre las bengalas. El spotlight que hace que la entrada luzca como producción de TV.", link: "/servicios/seguidor/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Bengalas Frías" }
  ]} />
</Fragment>

  <Hero
    title="Renta de Bengalas Frías en CDMX"
    subtitle="Sparklers que producen lluvia de chispas frías — sin calor, sin humo — para los momentos más icónicos de tu evento."
    whatsappText="Hola,%20quiero%20cotizar%20bengalas%20fr%C3%ADas%20para%20mi%20evento"
    introParagraph1='Las bengalas frías (cold sparks) son el efecto que hace que la entrada de novios o de quinceañera se vea como una producción de Hollywood. En <strong>REDEIL</strong> rentamos sparklers profesionales que producen columnas de chispas de 1 a 3 metros de altura sin calor real, sin humo tóxico y sin activar alarmas de incendio. Por eso son el único efecto de chispas aprobado para interiores — salones, hoteles, haciendas y cualquier espacio sin ventilación especial.'
    introParagraph2='Nuestro técnico instala las bengalas en el pasillo o escenario y las detona de forma remota y sincronizada exactamente en el momento que defines. El efecto dura entre 30 y 90 segundos, tiempo perfecto para que los novios o la quinceañera caminen entre las chispas mientras el fotógrafo captura las imágenes más memorables de la noche. Disponible en CDMX y Estado de México con transporte e instalación incluidos.'
  />


  <section class="services-section">
    <div class="container">
      <SectionHeader
        title="Bengalas frías profesionales para el momento más fotografiado"
        subtitle="Detonación remota, chispas seguras, coordinación con DJ y fotógrafo."
        paragraph1="La diferencia entre una bengala de mano y un sparkler profesional es enorme. Los equipos que usamos en REDEIL producen columnas de chispas uniformes de 1.5 a 3 metros de altura, con control de intensidad y duración. El técnico las opera desde una consola inalámbrica para que el timing sea milimétrico."
        paragraph2="Usamos sparklers Showven y Sparkular — los mismos equipos que se ven en conciertos internacionales y producciones de TV. La diferencia entre lo que ves en Instagram y lo que obtienes con equipo de segunda mano es visible en cada foto."
      />
      <Gallery4x4 images={[
        { src: "/img/galeria/confeti-01.avif", alt: "Bengalas frías en pasillo de entrada de novios boda CDMX" },
        { src: "/img/galeria/confeti-02.avif", alt: "Sparklers profesionales en ceremonia de boda" },
        { src: "/img/galeria/confeti-03.avif", alt: "Cold sparks en entrada de quinceañera salón" },
        { src: "/img/galeria/confeti-04.avif", alt: "Bengalas frías columnas de chispas boda hacienda" },
        { src: "/img/galeria/confeti-05.avif", alt: "Sparklers en evento corporativo lanzamiento de marca" },
        { src: "/img/galeria/confeti-06.avif", alt: "Bengalas frías en XV años vals con chambelanes" },
        { src: "/img/galeria/confeti-07.avif", alt: "Cold sparks efecto en pista de baile evento CDMX" },
        { src: "/img/galeria/confeti-08.avif", alt: "Sparklers profesionales en salón de bodas CDMX" },
        { src: "/img/galeria/humo-bajo-01.avif", alt: "Bengalas frías con CO2 entrada de novios combinada" },
        { src: "/img/galeria/humo-bajo-02.avif", alt: "Efecto cold sparks con vapor frío en boda" },
        { src: "/img/galeria/humo-bajo-03.avif", alt: "Sparklers y humo bajo en primer baile boda" },
        { src: "/img/galeria/humo-bajo-04.avif", alt: "Bengalas frías iluminadas con seguidor de luz" },
        { src: "/img/galeria/seguidor-01.avif", alt: "Entrada de novios entre bengalas frías con spotlight" },
        { src: "/img/galeria/seguidor-02.avif", alt: "Quinceañera entre sparklers con luz seguidor" },
        { src: "/img/galeria/seguidor-03.avif", alt: "Bengalas cold sparks con cabezas móviles en boda" },
        { src: "/img/galeria/seguidor-04.avif", alt: "Show de efectos especiales con sparklers CDMX" },
      ]} />
    </div>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Paquetes de Bengalas Frías para Eventos"
        subtitle="4 configuraciones desde 4 hasta 12 sparklers. Detonación remota en todos."
        paragraph1="Todos los paquetes incluyen el equipo Sparkular o Showven, técnico operador, detonador remoto inalámbrico, transporte, instalación y retiro. Sin costos adicionales."
        paragraph2="¿Quieres combinarlo con CO2, confeti o seguidor de luz? Armamos un paquete de efectos con precio especial para el evento completo."
      />
      <PricingCards packages={[
        {
          name: "Básico — 4 Sparklers",
          price: "$4,500",
          priceNote: "+ IVA",
          description: "4 bengalas frías para el pasillo de entrada. Ideal para salones pequeños y entradas estándar de novios o quinceañera.",
          features: [
            { text: "4 sparklers fríos profesionales", included: true },
            { text: "2 disparos de 30 seg. cada uno", included: true },
            { text: "Técnico operador incluido", included: true },
            { text: "Detonador remoto inalámbrico", included: true },
            { text: "Transporte + instalación + retiro", included: true },
            { text: "Coordinación con DJ/fotógrafo", included: true },
            { text: "Chispas 1.5 m de altura", included: true },
            { text: "8+ sparklers simultáneos", included: false },
          ],
          ctaLabel: "Cotizar paquete básico",
          ctaHref: "/contacto/",
        },
        {
          name: "Estándar — 6 Sparklers",
          price: "$6,500",
          priceNote: "+ IVA",
          badge: "Más popular",
          highlight: true,
          description: "6 bengalas para pasillo completo. Cobertura total del ancho estándar de entrada con chispas de 2 m de altura.",
          features: [
            { text: "6 sparklers fríos profesionales", included: true },
            { text: "3 disparos de 30 seg. cada uno", included: true },
            { text: "Técnico operador incluido", included: true },
            { text: "Detonador remoto inalámbrico", included: true },
            { text: "Transporte + instalación + retiro", included: true },
            { text: "Coordinación con DJ/fotógrafo", included: true },
            { text: "Chispas 2 m de altura", included: true },
            { text: "Ideal: bodas y XV años en salones", included: true },
          ],
          ctaLabel: "Cotizar paquete estándar",
          ctaHref: "/contacto/",
        },
        {
          name: "Premium — 8 Sparklers",
          price: "$8,500",
          priceNote: "+ IVA",
          description: "8 bengalas para venues grandes o escenarios. Cobertura completa con hasta 3 m de altura de chispas.",
          features: [
            { text: "8 sparklers fríos profesionales", included: true },
            { text: "4 disparos de 45 seg. cada uno", included: true },
            { text: "Técnico operador + asistente", included: true },
            { text: "Detonador remoto inalámbrico doble", included: true },
            { text: "Transporte + instalación + retiro", included: true },
            { text: "Chispas 2.5 m de altura", included: true },
            { text: "Ideal: haciendas, jardines grandes", included: true },
            { text: "Disparo simultáneo o secuencial", included: true },
          ],
          ctaLabel: "Cotizar paquete premium",
          ctaHref: "/contacto/",
        },
        {
          name: "Total — 12 Sparklers",
          price: "$12,000",
          priceNote: "+ IVA",
          description: "12 bengalas para el máximo impacto. Arco completo, escenario o pasillo de doble fila con chispas de 3 m.",
          features: [
            { text: "12 sparklers fríos profesionales", included: true },
            { text: "Disparos múltiples sin límite", included: true },
            { text: "Equipo técnico completo", included: true },
            { text: "Detonador remoto profesional", included: true },
            { text: "Transporte + instalación + retiro", included: true },
            { text: "Chispas 3 m de altura", included: true },
            { text: "Ideal: bodas de lujo, producciones", included: true },
            { text: "Sincronización beat-sync disponible", included: true },
          ],
          ctaLabel: "Cotizar paquete total",
          ctaHref: "/contacto/",
        },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre Bengalas Frías"
        subtitle="Todo lo que necesitas saber antes de contratar sparklers para tu evento."
        paragraph1="Si tu duda no está aquí, escríbenos por WhatsApp y te respondemos en minutos."
        paragraph2="Las bengalas frías son uno de nuestros efectos más solicitados en CDMX. Más de 500 eventos con sparklers en los últimos años."
      />
    </div>
    <FaqSection items={[
      { question: "¿Las bengalas frías son seguras en interiores?", answer: "Sí. Las bengalas frías producen chispas a temperatura ambiente que no queman ni dejan residuo caliente. Son el único efecto de chispas aprobado para interiores. No generan humo, no activan alarmas y no dañan pisos, telas ni decoración." },
      { question: "¿Cuánto duran las bengalas frías?", answer: "El tiempo estándar es 30 segundos por bengala. Hay versiones de 60 y 90 segundos según el paquete. Nuestro técnico sincroniza la duración con la entrada de los novios o el momento que elijas para que el efecto ocurra exactamente durante el paso." },
      { question: "¿Las chispas de las bengalas frías queman?", answer: "No. Las bengalas frías (cold sparks) utilizan titanio granulado que produce chispas a temperatura ambiente. Son seguras al tacto y no queman piel, tela ni madera. Son el único efecto pirotécnico aprobado para uso en interiores sin ventilación especial." },
      { question: "¿Cuántas bengalas necesito para mi evento?", answer: "Para un pasillo nupcial estándar, 4 bengalas (2 por lado) crean el efecto clásico. Para una entrada más dramática, 6 u 8 bengalas cubren un arco completo. Para escenarios en presentaciones de marca, desde 2 hasta 20 unidades según el tamaño." },
      { question: "¿Las bengalas frías necesitan permiso especial?", answer: "No requieren permiso de pirotecnia al ser un efecto frío no explosivo. Sin embargo, recomendamos avisar al venue con anticipación ya que algunos salones tienen políticas propias. Nosotros podemos acompañarlos con una nota técnica del equipo si el venue lo requiere." },
      { question: "¿Se pueden combinar con CO2 o confeti?", answer: "Sí, es la combinación más solicitada para bodas de alto impacto. Bengalas frías + CO2 en la entrada de novios, o bengalas + confeti durante el brindis. Nuestro equipo técnico coordina todos los efectos de forma simultánea." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Combina con Otros Efectos"
        subtitle="Las bengalas frías son más impactantes en combinación."
        paragraph1="El efecto máximo se logra cuando las bengalas frías forman parte de un paquete coordinado. CO2 + sparklers para la entrada, confeti + sparklers para el brindis. Nuestro equipo maneja todos los efectos en sincronía con el DJ."
        paragraph2="Armamos propuestas de efectos completas para el evento entero con precio especial por paquete."
      />
      <div class="services-grid">
        {serviciosRelacionados.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para la entrada más impactante de tu evento?</h2>
        <p>Cuéntanos la fecha, el venue y cuántos metros tiene el pasillo. Te cotizamos el número exacto de sparklers que necesitas.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
