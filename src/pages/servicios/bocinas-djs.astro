---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import GallerySection from "../../components/GallerySection.astro";

const title = "Renta de DJ para Eventos | REDEIL CDMX";
const description = "Renta de DJ profesional para eventos en CDMX. DJ para bodas, fiestas, XV años y corporativos con equipo de sonido, luces y cabina profesional. REDEIL.";
const canonical = "https://rentadeiluminacion.com/servicios/bocinas-djs/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de DJ para Eventos",
  "provider": {
    "@type": "LocalBusiness",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com",
    "telephone": "+525530682988",
    "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressCountry": "MX" }
  },
  "description": "Servicio de renta de DJ profesional para eventos en Ciudad de México. DJ para bodas, fiestas, XV años y eventos corporativos con equipo completo.",
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "serviceType": "Renta de DJ para Eventos"
});
---
<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <nav class="breadcrumb-section" aria-label="Breadcrumb">
    <div class="container">
      <div class="breadcrumb"><ol><li><a href="/">Inicio</a></li><li><a href="/servicios/">Servicios</a></li><li>DJ para Eventos</li></ol></div>
    </div>
  </nav>
  <main id="main-content">
    <Hero
      title="Renta de DJ para Eventos en CDMX"
      subtitle="DJ profesional con equipo de sonido y luces para hacer inolvidable tu evento"
      introParagraph1="En REDEIL ofrecemos servicio de DJ profesional para todo tipo de eventos en la Ciudad de México. Nuestros DJs cuentan con amplia experiencia en bodas, fiestas, XV años, eventos corporativos y celebraciones privadas, adaptando la música al estilo y ambiente de cada ocasión."
      introParagraph2="El servicio incluye DJ con equipo completo: consola profesional Pioneer, bocinas de alta potencia, subwoofers, micrófonos para animación, cabina DJ y luces básicas. Nos encargamos del montaje, la ambientación musical y la animación durante todo tu evento."
    />
    <section class="service-detail">
      <div class="container">
        <h2>DJ profesional que marca el ritmo de tu celebración</h2>
        <p>Un buen DJ no solo pone música: lee al público, crea atmósferas y guía los momentos clave de tu evento. En REDEIL nuestros DJs tienen experiencia en todo tipo de celebraciones y manejan géneros variados, desde música romántica para vals y primer baile hasta los éxitos más actuales para la pista de baile.</p>
        <p>Trabajamos con equipo de última generación de marcas como Pioneer, QSC y JBL. Cada DJ llega con su consola profesional, bocinas, subwoofer, micrófono para animación y cabina. Para eventos que requieren mayor producción, podemos agregar luces, pantallas LED y efectos especiales.</p>
        <p>Cubrimos eventos en salones, jardines, haciendas, terrazas, rooftops y cualquier venue en la CDMX y zona metropolitana. Nuestros DJs llegan con anticipación para montar y hacer pruebas de sonido, garantizando un inicio puntual.</p>
      </div>
    </section>
    <GallerySection title="Galería de DJ para Eventos" subtitle="DJs profesionales en eventos reales en la Ciudad de México">
      <figure class="gallery-item">
        <img src="/img/bocinas-djs/dj-para-eventos-cdmx-cabina-profesional.avif" alt="DJ profesional con cabina completa en evento en CDMX" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-djs/dj-para-bodas-mezclando-musica-evento.avif" alt="DJ mezclando música durante recepción de boda" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-djs/dj-profesional-consola-pioneer-cdj.avif" alt="DJ profesional operando consola Pioneer CDJ en evento" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-djs/dj-para-eventos-pista-iluminada.avif" alt="DJ animando pista de baile iluminada durante fiesta" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-djs/dj-para-bodas-vals-primer-baile.avif" alt="DJ acompañando el vals y primer baile en boda" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-djs/dj-profesional-cabina-led-neon.avif" alt="DJ profesional con cabina LED neón en fiesta nocturna" width="800" height="533" loading="lazy">
      </figure>
    </GallerySection>
  </main>
</BaseLayout>
