---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "¿Qué tipo de DJ necesito? Guía para eventos CDMX | REDEIL";
const description = "DJ para bodas vs fiestas vs corporativos: cómo elegir el correcto. Géneros, equipo, precios y qué preguntar antes de contratar en CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/dj/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Guía para Elegir DJ para Eventos en CDMX",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Guía completa para elegir el tipo de DJ correcto para tu evento en CDMX — bodas, fiestas privadas, corporativos y festivales. Comparativa de perfiles, géneros musicales y equipo necesario.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "DJ para Eventos",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Cuánto cuesta un DJ para un evento en CDMX?", "acceptedAnswer": { "@type": "Answer", "text": "El precio varía según el tipo de evento y la duración. Un DJ para fiesta privada de 4 horas empieza desde $4,500 + IVA. Un DJ para bodas con protocolo completo (8+ horas) va desde $8,000 + IVA. Un DJ para eventos corporativos con equipo premium empieza desde $12,000 + IVA. Todos nuestros paquetes incluyen equipo de sonido profesional." }},
      { "@type": "Question", "name": "¿Cómo sé qué tipo de DJ necesito?", "acceptedAnswer": { "@type": "Answer", "text": "Depende de tu evento. Para bodas necesitas un DJ que domine el protocolo (vals, ramo, liga, hora loca) y sepa leer a un público multigeneracional. Para fiestas privadas, un DJ que mantenga la pista llena con música bailable. Para corporativos, un DJ discreto que maneje ambiente lounge y momentos de energía. Para festivales, un DJ con experiencia en géneros electrónicos y sets largos." }},
      { "@type": "Question", "name": "¿El DJ trae su propio equipo de sonido?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Todos nuestros DJs llegan con equipo completo: consola profesional Pioneer, bocinas amplificadas QSC o JBL, subwoofer para graves, micrófono inalámbrico para animación y cabina iluminada. Para eventos grandes, agregamos bocinas adicionales, monitores y line array." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "DJ + Sonido Profesional", image: "/img/bocinas-djs/dj-para-eventos-cdmx-cabina-profesional.avif", alt: "DJ con cabina profesional en evento CDMX", description: "¿Ya sabes qué DJ necesitas? Ve directo a nuestros paquetes de DJ con precios, equipo incluido y opciones de personalización.", link: "/servicios/bocinas-djs/" },
  { title: "Sonido para Bodas", image: "/img/bocinas-djs/dj-para-bodas-mezclando-musica-evento.avif", alt: "DJ mezclando música en boda", description: "DJ especializado en bodas con protocolo completo — vals, brindis, ramo, liga y hora loca. Repertorio multigeneracional.", link: "/servicios/bocinas-bodas/" },
  { title: "Sonido para XV Años", image: "/img/bocinas-xv/renta-bocinas-xv-anos-baile-chambelanes-dorados-jbl.avif", alt: "DJ en fiesta de XV años con chambelanes", description: "DJ que domina el protocolo de XV años — entrada, vals, coreografía, cambio de zapato y fiesta libre.", link: "/servicios/bocinas-xv/" },
  { title: "Sonido para Fiestas", image: "/img/bocinas-djs/dj-para-fiestas-hora-loca.avif", alt: "DJ animando hora loca en fiesta", description: "DJ para cumpleaños, graduaciones, despedidas y fiestas temáticas. Pista llena toda la noche.", link: "/servicios/bocinas-fiestas/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Servicios", href: "/servicios/" },
    { label: "¿Qué tipo de DJ necesito?" }
  ]} />
</Fragment>

    <Hero
      title="¿Qué Tipo de DJ Necesitas para tu Evento en CDMX?"
      subtitle="DJ para bodas, XV años, fiestas privadas o corporativos — cada evento necesita un perfil diferente. Te explicamos cuál es el tuyo."
      introParagraph1='No es lo mismo un DJ para bodas que un DJ para una fiesta de cumpleaños o un evento corporativo. El DJ de bodas necesita dominar un protocolo de 15+ momentos (vals, brindis, ramo, liga, hora loca) y saber leer a un público que va desde abuelos hasta adolescentes. El DJ de fiestas necesita mantener la pista llena con sets de alta energía. Y el DJ corporativo necesita discreción, timing perfecto y la capacidad de pasar de un ambiente lounge a un momento de celebración sin que nadie note la transición.'
      introParagraph2='En <strong>REDEIL</strong> tenemos DJs especializados por tipo de evento — no mandamos al mismo DJ a una boda que a un festival. Esta guía te ayuda a entender <strong>qué perfil de DJ necesitas</strong>, qué equipo debe traer, qué géneros musicales debe dominar y qué preguntas hacerle antes de contratarlo. Si al final de la guía ya sabes qué necesitas, ve directo a nuestros <a href="/servicios/bocinas-djs/" style="color: #ff5722; font-weight: 600;">paquetes de DJ con precios</a>.'
    />

    <CtaBar
      headline="¿Para qué tipo de evento buscas DJ?"
      items={[
        { label: "DJ para Bodas", href: "/servicios/bocinas-bodas/", icon: "sonido" },
        { label: "DJ para XV Años", href: "/servicios/bocinas-xv/", icon: "sonido" },
        { label: "Ver precios DJ", href: "/servicios/bocinas-djs/", icon: "cotizar" },
        { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
      ]}
    />

    <!-- Galería -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="DJs profesionales en eventos reales en CDMX"
          subtitle="Bodas, fiestas, corporativos y festivales — cada evento con el DJ correcto."
          paragraph1="Un DJ leyendo al público en una boda de hacienda. Otro manteniendo la energía en una fiesta de cumpleaños de rooftop. Otro manejando el timing perfecto en un lanzamiento corporativo. Cada contexto exige un perfil diferente — la experiencia, los géneros y hasta el equipo cambian."
          paragraph2="Estas son fotos reales de nuestros DJs operando en diferentes tipos de eventos en la Ciudad de México."
        />
        <Gallery4x4 images={[
          { src: "/img/bocinas-djs/dj-para-bodas-mezclando-musica-evento.avif", alt: "DJ mezclando música en recepción de boda" },
          { src: "/img/bocinas-djs/dj-para-eventos-cdmx-cabina-profesional.avif", alt: "DJ con cabina profesional en evento CDMX" },
          { src: "/img/bocinas-djs/dj-para-bodas-vals-primer-baile.avif", alt: "DJ acompañando el vals y primer baile en boda" },
          { src: "/img/bocinas-djs/dj-para-eventos-fiesta-empresa.avif", alt: "DJ en fiesta de empresa corporativa" },
          { src: "/img/bocinas-djs/dj-para-eventos-xv-anos-vals.avif", alt: "DJ en vals de XV años" },
          { src: "/img/bocinas-djs/dj-para-eventos-terraza-rooftop.avif", alt: "DJ en terraza rooftop de evento" },
          { src: "/img/bocinas-djs/dj-para-bodas-recepcion-baile.avif", alt: "DJ en recepción de boda con pista de baile" },
          { src: "/img/bocinas-djs/renta-dj-para-eventos-corporativos.avif", alt: "DJ en evento corporativo profesional" },
          { src: "/img/bocinas-djs/dj-para-eventos-musica-latina.avif", alt: "DJ tocando música latina en evento" },
          { src: "/img/bocinas-djs/dj-para-fiestas-hora-loca.avif", alt: "DJ animando hora loca en fiesta" },
          { src: "/img/bocinas-djs/dj-para-eventos-boda-hacienda.avif", alt: "DJ en boda de hacienda" },
          { src: "/img/bocinas-djs/dj-profesional-consola-pioneer-cdj.avif", alt: "DJ profesional con consola Pioneer CDJ" },
          { src: "/img/bocinas-djs/dj-para-eventos-salon-banquetes.avif", alt: "DJ en salón de banquetes para evento" },
          { src: "/img/bocinas-djs/dj-para-fiestas-graduacion-universitaria.avif", alt: "DJ en fiesta de graduación universitaria" },
          { src: "/img/bocinas-djs/dj-para-eventos-musica-electronica.avif", alt: "DJ tocando música electrónica en festival" },
          { src: "/img/bocinas-djs/dj-para-eventos-ambiente-lounge.avif", alt: "DJ en ambiente lounge de evento corporativo" },
        ]} />
      </div>
    </section>

    <!-- Los 4 tipos de DJ -->
    <section class="services-section services-alt" id="tipos-dj">
      <div class="container">
        <SectionHeader
          title="Los 4 Tipos de DJ Según tu Evento"
          subtitle="Cada evento necesita un perfil diferente. Esta es la guía para elegir bien."
          paragraph1="El error más común al contratar DJ es pensar que todos hacen lo mismo. Un DJ que es increíble en fiestas de cumpleaños puede ser un desastre en una boda — porque no domina el protocolo, no sabe leer a un público multigeneracional o no tiene la delicadeza para los momentos emotivos."
          paragraph2="Aquí te explicamos qué buscar según tu tipo de evento para que contrates al DJ correcto desde el primer intento."
        />
        <FeatureGrid columns={2} features={[
          { title: "DJ para Bodas", description: "Domina el protocolo completo: vals, brindis, ramo, liga, hora loca. Lee a un público multigeneracional (abuelos + adolescentes). Sabe cuándo subir la energía y cuándo crear momentos íntimos. Coordina con MC, fotógrafo y wedding planner. Repertorio: romántico, pop, regional mexicano, cumbia, electrónica suave." },
          { title: "DJ para Fiestas Privadas", description: "Energía pura. Mantiene la pista llena desde el primer momento hasta que se acaba la fiesta. Especialista en cumpleaños, graduaciones, despedidas y celebraciones. No necesita protocolo — necesita feeling para leer la pista y ajustar el set en tiempo real. Repertorio: reggaetón, pop, cumbia, hip-hop, electrónica." },
          { title: "DJ para Corporativos", description: "Discreto y profesional. Maneja ambiente lounge durante cena y networking, sube la energía gradualmente para momentos de celebración. Timing perfecto para premiaciones, discursos y brindis. Equipo premium y cabina elegante. Repertorio: lounge, jazz moderno, pop internacional, música sin letra para discursos." },
          { title: "DJ para Festivales y Eventos Masivos", description: "Experiencia en sets largos (4-8 horas) con progresión musical. Domina géneros electrónicos: house, techno, EDM, trance. Equipo de alto poder (line array, subwoofers múltiples). Sabe manejar multitudes grandes y crear build-ups y drops que hacen explotar al público. Producción visual sincronizada." },
        ]} />
      </div>
    </section>

    <!-- Checklist para elegir DJ -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="¿Cómo Elegir al DJ Correcto?"
          subtitle="7 preguntas que debes hacerle antes de contratarlo."
          paragraph1="Contratar un DJ sin hacer estas preguntas es como contratar un fotógrafo sin ver su portafolio. La diferencia entre un DJ que llena la pista y uno que la vacía casi siempre se reduce a la experiencia en tu tipo de evento."
          paragraph2="Hazle estas preguntas a cualquier DJ que estés considerando — las respuestas te dirán si es el correcto para tu evento."
        />
        <FeatureGrid columns={2} features={[
          { title: "¿Cuántos eventos como el mío has hecho?", description: "Un DJ con 50+ bodas sabe exactamente cuándo poner el vals y cuándo soltar la cumbia. Un DJ que solo ha hecho fiestas privadas puede no dominar el protocolo de boda. Pide referencias específicas de tu tipo de evento." },
          { title: "¿Qué equipo traes incluido?", description: "El equipo mínimo: consola profesional, 2 bocinas amplificadas, subwoofer, micrófono inalámbrico y cabina. Para 200+ personas necesitas más potencia. Pregunta marcas — Pioneer, QSC y JBL son el estándar profesional." },
          { title: "¿Te coordinas con el MC y el fotógrafo?", description: "Un DJ profesional para bodas y XV años llega temprano para coordinarse con el maestro de ceremonias y el fotógrafo. Los tiempos de cada momento del protocolo se acuerdan antes de que lleguen los invitados." },
          { title: "¿Qué pasa si falla el equipo?", description: "Pregunta si tiene equipo de respaldo en el venue o en un vehículo cercano. Un DJ profesional siempre lleva cables, consola y bocina de respaldo. La fiesta no puede detenerse por una falla técnica." },
          { title: "¿Puedo elegir la lista de canciones?", description: "El DJ debe aceptar tu playlist de must-play y tu lista de canciones prohibidas. Pero también debe tener libertad para leer la pista y ajustar. Los mejores DJs mezclan tus peticiones con su experiencia leyendo al público." },
          { title: "¿Cuántas horas incluye el servicio?", description: "Confirma horas exactas y costo por hora extra. La mayoría de los paquetes incluyen 5-8 horas. Para bodas, calcula desde la ceremonia civil o coctel hasta que se apaga la música — suelen ser 8-10 horas." },
          { title: "¿Incluyes iluminación o solo sonido?", description: "Algunos DJs incluyen luces básicas en su cabina. Para iluminación profesional (cabezas móviles, seguidor, humo bajo) necesitas un servicio de iluminación aparte. En REDEIL ofrecemos paquetes combinados de DJ + iluminación." },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas Frecuentes sobre DJs para Eventos"
          subtitle="Lo que todo el mundo quiere saber antes de contratar."
          paragraph1="Si tienes otra duda, escríbenos por WhatsApp y te respondemos en minutos."
          paragraph2="Te asesoramos gratis sobre qué tipo de DJ necesitas según tu evento, venue y presupuesto."
        />
      </div>
      <FaqSection items={[
        { question: "¿Cuánto cuesta un DJ para un evento en CDMX?", answer: "El precio varía según el tipo de evento y la duración. Un DJ para fiesta privada de 4 horas empieza desde $4,500 + IVA. Un DJ para bodas con protocolo completo (8+ horas) va desde $8,000 + IVA. Un DJ para eventos corporativos con equipo premium empieza desde $12,000 + IVA. Todos nuestros paquetes incluyen equipo de sonido profesional, traslado, montaje y prueba de sonido." },
        { question: "¿Cómo sé qué tipo de DJ necesito?", answer: "Depende de tu evento. Para bodas necesitas un DJ que domine el protocolo (vals, ramo, liga, hora loca) y sepa leer a un público multigeneracional. Para fiestas privadas, un DJ que mantenga la pista llena con música bailable. Para corporativos, un DJ discreto que maneje ambiente lounge y momentos de energía. Para festivales, un DJ con experiencia en géneros electrónicos y sets largos." },
        { question: "¿El DJ trae su propio equipo de sonido?", answer: "Sí. Todos nuestros DJs llegan con equipo completo: consola profesional Pioneer, bocinas amplificadas QSC o JBL, subwoofer para graves, micrófono inalámbrico para animación y cabina iluminada. Para eventos grandes, agregamos bocinas adicionales, monitores y line array según el tamaño del venue." },
        { question: "¿Puedo ver al DJ antes de contratarlo?", answer: "Sí. Te compartimos videos de eventos recientes del DJ que mejor se ajuste a tu tipo de evento. También podemos agendar una videollamada para que conozcas al DJ, platiques sobre tu evento y acuerden el estilo musical antes del día." },
        { question: "¿El DJ también anima el evento?", answer: "Depende de lo que necesites. Nuestros DJs para bodas y XV años incluyen animación del protocolo — anuncian el vals, el brindis, el ramo, etc. Para fiestas privadas, el DJ puede animar o solo mezclar música según prefieras. Para corporativos, recomendamos un MC profesional separado y el DJ solo en música." },
        { question: "¿Qué pasa si necesito cancelar o cambiar la fecha?", answer: "Cambios de fecha se aceptan sin costo con 15+ días de anticipación, sujeto a disponibilidad. Cancelaciones con más de 30 días de anticipación tienen reembolso del 80% del anticipo. Con menos de 15 días, el anticipo no es reembolsable. Todo queda especificado en el contrato de servicio." },
      ]} />
    </section>

    <!-- Servicios relacionados -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="¿Ya sabes qué DJ necesitas? Ve los precios"
          subtitle="Paquetes de DJ con equipo incluido para cada tipo de evento."
          paragraph1="Si ya identificaste qué perfil de DJ necesitas, el siguiente paso es ver los paquetes con precios específicos. Cada paquete incluye DJ, equipo de sonido profesional, traslado, montaje y prueba de sonido."
          paragraph2="También puedes cotizar directamente por WhatsApp — te respondemos en minutos."
        />
        <div class="services-grid">
          {serviciosRelacionados.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿No estás seguro qué DJ necesitas? Te asesoramos gratis</h2>
          <p>Cuéntanos sobre tu evento — tipo, fecha, venue y número de personas — y te recomendamos el perfil de DJ ideal con precio incluido.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Asesórate por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
