---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Renta Audio Estándar para Eventos CDMX — $7,000 + IVA | REDEIL";
const description = "4 bocinas JBL PRX825 + 2 subwoofers QSC + 4 micrófonos Shure + Yamaha TF1 para eventos de 100-200 personas. CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/bocinas/paquete-audio-estandar/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Paquete Audio Estándar — Renta de Bocinas para Eventos Medianos",
    "description": "Audio profesional para eventos de 100-200 personas. 4 bocinas JBL PRX825 + 2 subwoofers QSC + 4 micrófonos Shure inalámbricos + mezcladora Yamaha TF1. Técnico de audio, transporte e instalación incluidos en CDMX.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/bocinas/paquete-audio-estandar/",
      "priceCurrency": "MXN",
      "price": "7000",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "76",
      "reviewCount": "76"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Gabriela Mendoza" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Las 4 JBL PRX825 cubrieron la hacienda completa — ceremonia en el jardín y fiesta en el salón. La Yamaha TF1 permitió ecualizar cada zona por separado."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Luis Torres" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "El paquete estándar fue exacto para nuestra graduación. Discursos claros, música con potencia en la fiesta. El técnico ajustó todo perfecto."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Patricia Vargas" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Audio profesional para una presentación con 150 asistentes. Los 4 micrófonos Shure cubrieron el panel de ponentes y las preguntas del público sin problema."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/bocinas/bocinas-profesionales-evento-masivo.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Por qué el Audio Estándar es el más popular?", "acceptedAnswer": { "@type": "Answer", "text": "Porque cubre el 80% de los eventos: bodas de 150 invitados, graduaciones de 200 personas, presentaciones corporativas y fiestas en salón. Las 4 bocinas JBL PRX825 + 2 subwoofers QSC + Yamaha TF1 dan potencia, claridad y flexibilidad suficiente para la mayoría de los venues en CDMX." }},
      { "@type": "Question", "name": "¿Qué diferencia hay entre el Audio Básico y el Estándar?", "acceptedAnswer": { "@type": "Answer", "text": "El Básico ($4,000) lleva 2 bocinas JBL PRX315 y cubre 30-80 personas. El Estándar ($7,000) lleva 4 bocinas JBL PRX825 + 2 subwoofers + mezcladora Yamaha TF1 y cubre 100-200 personas. El salto es en potencia, cobertura y la capacidad de ecualizar por zonas." }},
      { "@type": "Question", "name": "¿La Yamaha TF1 es necesaria o es un extra?", "acceptedAnswer": { "@type": "Answer", "text": "Es necesaria. La Yamaha TF1 es una mezcladora digital de 32 canales que permite ecualizar cada bocina y micrófono de forma independiente, crear memorias de escena para distintos momentos del evento, y ajustar todo desde un iPad. Sin ella, el sonido sería genérico en vez de profesional." }},
      { "@type": "Question", "name": "¿Pueden cubrir dos áreas separadas (jardín + salón)?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Con 4 bocinas JBL PRX825, montamos 2 en cada área y las controlamos independientemente desde la Yamaha TF1. Cuando la ceremonia en el jardín termina, apagamos esa zona y subimos el salón. Sin mover equipo." }},
      { "@type": "Question", "name": "¿El paquete funciona para eventos con banda en vivo?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. La Yamaha TF1 tiene 32 canales — suficientes para microfonear una banda de hasta 6 músicos más los 4 micrófonos inalámbricos Shure incluidos. La banda conecta directamente a la mezcladora y suena a través de las JBL PRX825." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "Audio Básico — $4,000", image: "/img/bocinas-fiestas/bocinas-amplificadas-fiestas-jardines.avif", alt: "Bocinas amplificadas para eventos pequeños", description: "2 bocinas JBL PRX315 + subwoofer + 2 micrófonos Shure. Para eventos de 30-80 personas.", link: "/servicios/bocinas/paquete-audio-basico/" },
  { title: "Audio Premium — $12,000", image: "/img/bocinas/renta-bocinas-line-array-concierto.avif", alt: "Line array QSC KLA para eventos grandes", description: "Line array QSC KLA + 4 subs + 6 micrófonos Shure ULXD + Yamaha TF3. Para 300-500 personas.", link: "/servicios/bocinas/paquete-audio-premium/" },
  { title: "DJ para Bodas", image: "/img/bocinas-djs/dj-para-bodas-mezclando-musica-evento.avif", alt: "DJ profesional mezclando en boda", description: "DJ profesional con Pioneer DDJ-1000 + audio completo. Complemento ideal para el paquete estándar.", link: "/servicios/bocinas-bodas/" },
  { title: "Guirnaldas Edison", image: "/img/guirnaldas/guirnaldas-edison-hacienda-boda.avif", alt: "Guirnaldas Edison para decoración de eventos", description: "Iluminación cálida para transformar haciendas y jardines. Combina con audio para un evento completo.", link: "/servicios/guirnaldas/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Sonido y DJ", href: "/servicios/sonido/" },
    { label: "Audio para Eventos", href: "/servicios/bocinas/" },
    { label: "Paquete Audio Estándar" }
  ]} />
</Fragment>

  <Hero
    title="Paquete Audio Estándar — Eventos de 100 a 200 Personas"
    subtitle="Desde $7,000 + IVA. 4 bocinas JBL PRX825 + 2 subwoofers QSC + 4 micrófonos Shure + Yamaha TF1. El más popular."
    introParagraph1='El 80% de los eventos en CDMX tienen entre 100 y 200 personas: una boda en hacienda, una graduación en salón, una presentación corporativa en hotel, una fiesta en jardín. Para ese rango, el paquete Audio Estándar es el punto exacto entre potencia y costo. 4 bocinas <strong>JBL PRX825</strong> cubren el espacio sin puntos muertos, 2 subwoofers <strong>QSC</strong> agregan el bajo que la pista de baile necesita, y la mezcladora <strong>Yamaha TF1</strong> permite ecualizar cada zona por separado.'
    introParagraph2='Los 4 micrófonos <strong>Shure</strong> inalámbricos cubren discursos, brindis, paneles de ponentes o karaoke — lo que necesite tu evento. El técnico opera la Yamaha TF1 durante todo el evento con memorias de escena: volumen de conversación para la cena, potencia total para la fiesta, niveles calibrados para la ceremonia. Haciendas, salones, jardines, hoteles y terrazas en toda la <strong>CDMX y Estado de México</strong>.'
  />

  <CtaBar
    headline="¿Evento más grande o más pequeño?"
    items={[
      { label: "Audio Básico $4,000", href: "/servicios/bocinas/paquete-audio-basico/", icon: "sonido" },
      { label: "Audio Premium $12,000", href: "/servicios/bocinas/paquete-audio-premium/", icon: "sonido" },
      { label: "Producción $20,000", href: "/servicios/bocinas/paquete-produccion-audio/", icon: "sonido" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Audio Estándar"
      price="$7,000"
      priceNote="+ IVA · Más popular · Técnico incluido"
      badge="Más popular"
      features={[
        { text: "4 bocinas JBL PRX825 de alta potencia" },
        { text: "2 subwoofers QSC para pista de baile" },
        { text: "4 micrófonos Shure inalámbricos" },
        { text: "Mezcladora digital Yamaha TF1" },
        { text: "Ecualización por zonas independientes" },
        { text: "Memorias de escena por momento" },
        { text: "Técnico de audio todo el evento" },
        { text: "Transporte + montaje + desmontaje" },
        { text: "Cobertura CDMX y Edomex" },
        { text: "Ideal: eventos 100-200 personas" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete Audio Estándar para un evento."
      packages={[
        { label: "Audio Básico", price: "$4,000", href: "/servicios/bocinas/paquete-audio-basico/" },
        { label: "Audio Estándar", price: "$7,000", href: "/servicios/bocinas/paquete-audio-estandar/", active: true },
        { label: "Premium", price: "$12,000", href: "/servicios/bocinas/paquete-audio-premium/" },
        { label: "Producción", price: "$20,000", href: "/servicios/bocinas/paquete-produccion-audio/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="El paquete que cubre el 80% de los eventos"
          subtitle="Bodas, graduaciones, corporativos y fiestas — un solo equipo para todos."
          paragraph1="El Audio Estándar no es el paquete más barato ni el más caro — es el que funciona para la mayoría de los eventos. Las 4 bocinas JBL PRX825 se distribuyen para cubrir el venue completo y los 2 subwoofers QSC activan la pista de baile cuando es momento."
          paragraph2="La Yamaha TF1 es la diferencia: una mezcladora digital de 32 canales con memorias de escena. El técnico programa los niveles para cada momento y cambia de escena con un toque — sin silencios incómodos ni picos de volumen."
        />
        <FeatureGrid features={[
          { title: "Boda 100-200 Invitados", description: "Ceremonia, brindis y fiesta cubiertos con 4 bocinas, 2 subs y 4 micrófonos." },
          { title: "Graduación en Salón", description: "Discursos claros del presídium y música potente para la fiesta posterior." },
          { title: "Presentación Corporativa", description: "4 micrófonos para panel de ponentes + audio de videos y presentaciones." },
          { title: "Fiesta en Jardín o Hacienda", description: "Las JBL PRX825 cubren espacios abiertos sin perder potencia ni claridad." },
          { title: "Evento con Banda en Vivo", description: "Yamaha TF1 microfonea hasta 6 músicos + micrófonos inalámbricos para MC." },
          { title: "Gala o Cena de Premiación", description: "Transiciones suaves entre discursos, premiación y música — todo controlado." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Equipo profesional que hace la diferencia"
          subtitle="JBL PRX825 + QSC + Yamaha TF1 — el estándar de eventos corporativos y sociales."
          paragraph1="Las JBL PRX825 son bocinas de doble driver que entregan SPL alto con distorsión baja. Los subwoofers QSC se activan solo cuando el evento lo requiere — en la cena están apagados, en la fiesta se encienden."
          paragraph2="La Yamaha TF1 guarda memorias de escena: el técnico preprograma los niveles para cada momento del evento y cambia con un toque. Cena → ceremonia → fiesta, sin pausas ni ajustes manuales frente a los invitados."
        />
        <FeatureGrid features={[
          { title: "4 Bocinas = Cobertura Total", description: "Sin puntos muertos. Las 4 JBL PRX825 se posicionan para cubrir cada rincón del venue." },
          { title: "Subwoofers QSC Controlados", description: "Se activan solo para la fiesta. En la cena y los discursos, el bajo está controlado." },
          { title: "Yamaha TF1 con Memorias", description: "Escenas preprogramadas para cada momento. Cambios instantáneos sin silencios." },
          { title: "4 Micrófonos Shure", description: "Inalámbricos, con cápsula de condensador. Para paneles, brindis o karaoke." },
          { title: "Ecualización por Zona", description: "Mesas con volumen conversacional, pista de baile con potencia total — simultáneamente." },
          { title: "Control desde iPad", description: "El técnico monitorea y ajusta desde cualquier punto del venue vía iPad." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="4.9 estrellas en 76 reseñas verificadas."
          paragraph1="Bodas, graduaciones, corporativos y galas en haciendas, salones, jardines y hoteles de CDMX."
          paragraph2="Pregunta por referencias de venues similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Gabriela Mendoza", event: "Boda — Hacienda Xochimilco, 180 invitados", rating: 5, text: "Las 4 JBL PRX825 cubrieron la hacienda completa — ceremonia en el jardín y fiesta en el salón. La Yamaha TF1 permitió ecualizar cada zona por separado." },
          { name: "Luis Torres", event: "Graduación — Salón Tlalpan, 200 personas", rating: 5, text: "El paquete estándar fue exacto para nuestra graduación. Discursos claros, música con potencia en la fiesta. El técnico ajustó todo perfecto." },
          { name: "Patricia Vargas", event: "Presentación corporativa — Hotel Reforma, 150 personas", rating: 5, text: "Audio profesional para una presentación con 150 asistentes. Los 4 micrófonos Shure cubrieron el panel de ponentes y las preguntas del público sin problema." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Audio estándar REDEIL en eventos reales"
        subtitle="Bodas, graduaciones, corporativos y fiestas con sonido profesional."
        paragraph1="Estas fotos son de eventos reales donde montamos el paquete Audio Estándar. 4 bocinas, 2 subwoofers, 4 micrófonos y un técnico operando toda la noche."
        paragraph2="¿Quieres ver cómo quedaría en tu venue? Mándanos la ubicación por WhatsApp y te explicamos el montaje."
      />
      <Gallery4x4 images={[
        { src: "/img/bocinas-bodas/renta-bocinas-boda-salon-line-array-pioneer-dj.avif", alt: "Audio profesional con bocinas JBL en salón de eventos" },
        { src: "/img/bocinas/bocinas-profesionales-evento-masivo.avif", alt: "Bocinas JBL PRX825 para evento de 200 personas" },
        { src: "/img/bocinas-bodas/renta-bocinas-boda-brindis-microfono-salon.avif", alt: "Micrófono Shure para brindis en evento corporativo" },
        { src: "/img/bocinas-fiestas/bocinas-grandes-eventos-masivos.avif", alt: "Audio potente para eventos con pista de baile" },
        { src: "/img/bocinas-bodas/renta-bocinas-boda-instalacion-equipo-cases.avif", alt: "Instalación de equipo de audio profesional" },
        { src: "/img/bocinas-djs/dj-para-eventos-equipo-sonido-luces.avif", alt: "DJ y equipo de sonido para eventos" },
        { src: "/img/bocinas-bodas/renta-bocinas-boda-dj-consola-pioneer-salon.avif", alt: "Consola de mezcla profesional en evento" },
        { src: "/img/bocinas-fiestas/audio-eventos-corporativos-conferencias.avif", alt: "Audio profesional en presentación corporativa" },
      ]} />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete Audio Estándar"
        subtitle="Todo lo que necesitas saber sobre audio para eventos de 100-200 personas."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp al 55 3068 2988. Respondemos en minutos."
        paragraph2="Cuéntanos el venue y el número de asistentes — te decimos exactamente cómo quedaría el montaje."
      />
    </div>
    <FaqSection items={[
      { question: "¿Por qué el Audio Estándar es el más popular?", answer: "Porque cubre el 80% de los eventos: bodas de 150 invitados, graduaciones de 200 personas, presentaciones corporativas y fiestas en salón. Las 4 bocinas JBL PRX825 + 2 subwoofers QSC + Yamaha TF1 dan potencia, claridad y flexibilidad suficiente para la mayoría de los venues en CDMX." },
      { question: "¿Qué diferencia hay entre el Audio Básico y el Estándar?", answer: "El Básico ($4,000) lleva 2 bocinas JBL PRX315 y cubre 30-80 personas. El Estándar ($7,000) lleva 4 bocinas JBL PRX825 + 2 subwoofers + mezcladora Yamaha TF1 y cubre 100-200 personas. El salto es en potencia, cobertura y la capacidad de ecualizar por zonas." },
      { question: "¿La Yamaha TF1 es necesaria o es un extra?", answer: "Es necesaria. La Yamaha TF1 es una mezcladora digital de 32 canales que permite ecualizar cada bocina y micrófono de forma independiente, crear memorias de escena para distintos momentos del evento, y ajustar todo desde un iPad. Sin ella, el sonido sería genérico en vez de profesional." },
      { question: "¿Pueden cubrir dos áreas separadas (jardín + salón)?", answer: "Sí. Con 4 bocinas JBL PRX825, montamos 2 en cada área y las controlamos independientemente desde la Yamaha TF1. Cuando la ceremonia en el jardín termina, apagamos esa zona y subimos el salón. Sin mover equipo." },
      { question: "¿El paquete funciona para eventos con banda en vivo?", answer: "Sí. La Yamaha TF1 tiene 32 canales — suficientes para microfonear una banda de hasta 6 músicos más los 4 micrófonos inalámbricos Shure incluidos. La banda conecta directamente a la mezcladora y suena a través de las JBL PRX825." },
    ]} />
  </section>

  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes y Servicios"
        subtitle="¿Evento más chico, más grande o quieres agregar algo?"
        paragraph1="El Audio Básico funciona para eventos de 30-80 personas. Si necesitas cobertura para 300+, el Premium o Producción es mejor opción."
        paragraph2="Precio especial cuando combinas audio con iluminación o efectos especiales."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para que tu evento suene profesional?</h2>
        <p>Mándanos la fecha, el venue y el número de asistentes. Te confirmamos disponibilidad y te enviamos el presupuesto en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Reservar — Cotiza Gratis</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
