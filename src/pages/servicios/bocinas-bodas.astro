---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import GallerySection from "../../components/GallerySection.astro";

const title = "Renta de Bocinas para Bodas | REDEIL CDMX";
const description = "Renta de bocinas y sonido profesional para bodas en CDMX. Equipos de audio para ceremonia, recepción y fiesta. DJ, micrófonos y line array. REDEIL.";
const canonical = "https://rentadeiluminacion.com/servicios/bocinas-bodas/";

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Bocinas para Bodas",
  "provider": {
    "@type": "LocalBusiness",
    "name": "REDEIL",
    "url": "https://rentadeiluminacion.com",
    "telephone": "+525530682988",
    "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressCountry": "MX" }
  },
  "description": "Servicio de renta de bocinas y sonido profesional para bodas en Ciudad de México. Audio para ceremonia, recepción, brindis y fiesta con DJ.",
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "serviceType": "Renta de Bocinas para Bodas"
});
---
<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>
  <nav class="breadcrumb-section" aria-label="Breadcrumb">
    <div class="container">
      <div class="breadcrumb"><ol><li><a href="/">Inicio</a></li><li><a href="/servicios/">Servicios</a></li><li>Bocinas para Bodas</li></ol></div>
    </div>
  </nav>
  <main id="main-content">
    <Hero
      title="Renta de Bocinas para Bodas en CDMX"
      subtitle="Sonido profesional que acompaña cada momento especial de tu boda"
      introParagraph1="En REDEIL nos especializamos en la renta de bocinas y sonido profesional para bodas en toda la Ciudad de México. Cubrimos cada etapa de tu celebración: ceremonia religiosa o civil, recepción, brindis, vals y fiesta con equipos de audio de alta fidelidad."
      introParagraph2="Nuestros paquetes de sonido para bodas incluyen bocinas activas, subwoofers, micrófonos inalámbricos para votos y discursos, mezcladoras digitales y operadores de audio que garantizan una experiencia sonora impecable durante toda la celebración."
    />
    <section class="service-detail">
      <div class="container">
        <h2>Sonido perfecto para cada momento de tu boda</h2>
        <p>Una boda tiene múltiples momentos que requieren atención sonora diferente: la música suave durante la ceremonia, la claridad del micrófono para los votos y brindis, la ambientación durante la cena y la potencia en la pista de baile. En REDEIL diseñamos el montaje de audio considerando cada uno de estos momentos.</p>
        <p>Trabajamos con equipos profesionales de marcas como QSC, JBL y Pioneer que aseguran nitidez y potencia en cualquier tipo de venue. Ya sea un jardín al aire libre, una hacienda colonial o un salón de banquetes, adaptamos la configuración de bocinas para lograr cobertura uniforme en todo el espacio.</p>
        <p>Nuestro servicio incluye montaje previo al evento, pruebas de sonido, operación técnica durante la boda y desmontaje al finalizar. Cubrimos bodas en toda la CDMX y zona metropolitana con puntualidad y profesionalismo.</p>
      </div>
    </section>
    <GallerySection title="Galería de Sonido para Bodas" subtitle="Montajes de audio en bodas reales en la Ciudad de México">
      <figure class="gallery-item">
        <img src="/img/bocinas-bodas/renta-bocinas-boda-primer-baile-novios-romantico.avif" alt="Primer baile de novios con sonido profesional y ambiente romántico en salón" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-bodas/renta-bocinas-boda-brindis-discurso-invitados.avif" alt="Brindis y discurso con micrófono profesional durante recepción de boda" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-bodas/renta-bocinas-boda-dj-cabina-blanca-flores.avif" alt="DJ con cabina blanca decorada con flores en boda elegante" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-bodas/renta-bocinas-boda-salon-line-array-pioneer-dj.avif" alt="Sistema line array y equipo Pioneer DJ instalado en salón de boda" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-bodas/renta-bocinas-boda-playa-montaje-tripie-carpa.avif" alt="Montaje de bocinas en tripié bajo carpa para boda en playa" width="800" height="533" loading="lazy">
      </figure>
      <figure class="gallery-item">
        <img src="/img/bocinas-bodas/renta-bocinas-ceremonia-boda-jardin-guitarrista.avif" alt="Ceremonia de boda en jardín con guitarrista y sonido profesional" width="800" height="533" loading="lazy">
      </figure>
    </GallerySection>
  </main>
</BaseLayout>
