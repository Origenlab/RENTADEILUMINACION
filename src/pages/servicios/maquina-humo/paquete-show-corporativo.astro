---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Gallery4x4 from '../../../components/Gallery4x4.astro';
import FeatureGrid from '../../../components/FeatureGrid.astro';
import TestimonialCards from '../../../components/TestimonialCards.astro';
import ContentWithSidebar from '../../../components/ContentWithSidebar.astro';
import FaqSection from '../../../components/FaqSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

const title = "Humo para Escenario y Eventos Corporativos — $7,500 + IVA | REDEIL";
const description = "Humo atmosférico profesional para escenarios corporativos. 2 máquinas + operador + coordinación producción. $7,500 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/maquina-humo/paquete-show-corporativo/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Humo para Escenario y Eventos Corporativos",
    "description": "Renta de 2 máquinas de humo profesional para escenarios corporativos, presentaciones, lanzamientos de producto y eventos de producción en CDMX. Incluye operador técnico, coordinación con producción, fluido ilimitado, transporte, montaje y desmontaje.",
    "brand": { "@type": "Brand", "name": "REDEIL" },
    "offers": {
      "@type": "Offer",
      "url": "https://rentadeiluminacion.com/servicios/maquina-humo/paquete-show-corporativo/",
      "priceCurrency": "MXN",
      "price": "7500",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "LocalBusiness",
        "name": "REDEIL",
        "telephone": "+525530682988",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "45",
      "reviewCount": "45"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Fernando Castillo" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Contratamos el humo para el lanzamiento de producto de nuestra marca en el Centro Citibanamex. Las 2 máquinas cubrieron el escenario perfectamente y el operador se coordinó con nuestro equipo de producción como si fuera parte del staff. Muy profesionales."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Laura Mejía" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Usamos el servicio para una presentación ejecutiva en un hotel de Reforma. El humo en el escenario durante la entrada del CEO fue espectacular — se veía como un evento de Apple. El equipo llegó 3 horas antes y todo estuvo impecable."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Arturo Domínguez" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Lo contraté para una convención corporativa en una hacienda grande en Edomex. Las 2 máquinas dieron cobertura total al escenario principal. El operador fue muy flexible con los cambios de último momento del programa. Totalmente profesional."
      }
    ],
    "image": "https://rentadeiluminacion.com/img/humo/efecto-humo-evento-corporativo-escenario.avif"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Las 2 máquinas pueden cubrir un escenario grande?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. 2 máquinas de 1,500W posicionadas estratégicamente cubren escenarios de hasta 200m². El operador coordina las activaciones para crear un efecto uniforme en todo el escenario. Para venues más grandes como centros de convenciones, te recomendamos el paquete Festival de 4 máquinas." }},
      { "@type": "Question", "name": "¿Se coordinan con nuestro equipo de producción?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestro operador se integra con tu equipo de producción como un proveedor más. Llegamos a la llamada técnica, seguimos el guion del evento y coordinamos las activaciones según los cues de tu director técnico o stage manager." }},
      { "@type": "Question", "name": "¿El humo afecta las cámaras de video?", "acceptedAnswer": { "@type": "Answer", "text": "Al contrario — el humo mejora la imagen de video porque crea profundidad y hace visibles los haces de luz. Es un recurso estándar en producción audiovisual. El operador controla la densidad para que sea fotogénico sin obstruir la visibilidad del escenario." }}
    ]
  }
]);

const otrosPaquetes = [
  { title: "DJ y Fiesta — 1 Máquina", image: "/img/humo/maquina-humo-fiesta-neon-discoteca.avif", alt: "Máquina de humo en fiesta con DJ", description: "1 máquina de humo para fiestas privadas y cumpleaños. Paquete básico. $2,500 + IVA.", link: "/servicios/maquina-humo/paquete-dj-fiesta/" },
  { title: "Noche Completa — Fluido Ilimitado", image: "/img/humo/maquina-humo-profesional-boda-pista-baile.avif", alt: "Humo profesional en boda toda la noche", description: "Humo toda la noche para bodas y XV años. Fluido ilimitado. $4,500 + IVA.", link: "/servicios/maquina-humo/paquete-noche-completa/" },
  { title: "Festival — 4 Máquinas", image: "/img/humo/maquina-humo-concierto-festival-luces.avif", alt: "Humo en festival con luces", description: "4 máquinas + fog chiller + técnico para festivales y conciertos masivos. $12,000 + IVA.", link: "/servicios/maquina-humo/paquete-festival/" },
  { title: "Cabezas Móviles", image: "/img/cabezas-moviles/renta-cabezas-moviles-show-luces-beams-colores-300w.avif", alt: "Show de cabezas móviles con beams de colores", description: "Los beams de las cabezas móviles cortando el humo crean el efecto de producción más impactante.", link: "/servicios/cabezas-moviles/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Máquina de Humo", href: "/servicios/maquina-humo/" },
    { label: "Show Corporativo" }
  ]} />
</Fragment>

  <Hero
    title="Humo para Escenario y Eventos Corporativos — Producción Profesional"
    subtitle="Desde $7,500 + IVA. 2 máquinas 1,500W + operador + coordinación de producción."
    introParagraph1='El humo escénico profesional es un estándar en producciones corporativas de primer nivel — lanzamientos de producto, convenciones, presentaciones ejecutivas y galas donde el escenario necesita un efecto visual que eleve la producción. En <strong>REDEIL</strong> operamos 2 máquinas de humo de 1,500W posicionadas estratégicamente para cubrir todo el escenario con neblina controlada. El operador técnico se integra con tu equipo de producción y sigue el guion del evento.'
    introParagraph2='Este paquete incluye 2 máquinas profesionales <strong>Antari</strong> y <strong>Chauvet</strong>, fluido ilimitado certificado, operador técnico con experiencia en producción corporativa, coordinación con tu director técnico o stage manager, transporte, montaje y desmontaje. Ideal para escenarios en centros de convenciones, hoteles, haciendas grandes y recintos corporativos en la CDMX y Estado de México.'
  />


  <!-- Contenido principal + Sidebar sticky -->
  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Show Corporativo"
      price="$7,500"
      priceNote="+ IVA · 2 máquinas incluidas"
      features={[
        { text: "2 máquinas de humo 1,500W" },
        { text: "Fluido ilimitado certificado" },
        { text: "Operador técnico de producción" },
        { text: "Coordinación con stage manager" },
        { text: "Cobertura de escenario completo" },
        { text: "Control de intensidad variable" },
        { text: "Transporte ida y vuelta" },
        { text: "Montaje y desmontaje" },
        { text: "Equipo Antari / Chauvet" },
        { text: "Cobertura CDMX y Edomex" },
      ]}
      waMessage="Hola REDEIL, quiero cotizar el paquete Show Corporativo de máquina de humo para mi evento corporativo."
      packages={[
        { label: "DJ y Fiesta", price: "$2,500", href: "/servicios/maquina-humo/paquete-dj-fiesta/" },
        { label: "Noche Completa", price: "$4,500", href: "/servicios/maquina-humo/paquete-noche-completa/" },
        { label: "Show Corporativo", price: "$7,500", href: "/servicios/maquina-humo/paquete-show-corporativo/", active: true },
        { label: "Festival", price: "$12,000", href: "/servicios/maquina-humo/paquete-festival/" },
      ]}
    >
      <div class="container">
        <SectionHeader
          title="Perfecto para estos eventos"
          subtitle="2 máquinas de humo cubren escenarios corporativos hasta 200m²."
          paragraph1="Este paquete está diseñado para producciones donde el humo es parte del show — no solo ambiente. Lanzamientos de producto donde el CEO aparece entre la neblina, convenciones donde los speakers suben al escenario con efecto dramático, galas corporativas con producción de primer nivel."
          paragraph2="Nuestro operador tiene experiencia en eventos corporativos y sabe trabajar con equipos de producción, directors técnicos y stage managers."
        />
        <FeatureGrid features={[
          { title: "Lanzamientos de Producto", description: "El humo crea el efecto dramático de revelación. Las cámaras capturan una imagen de producción premium." },
          { title: "Convenciones Corporativas", description: "Escenario principal con humo controlado para presentaciones ejecutivas y keynotes de impacto." },
          { title: "Galas y Premiaciones", description: "Ambiente de alfombra roja con neblina sutil en el escenario durante entregas de premio." },
          { title: "Presentaciones Ejecutivas", description: "Efecto de entrada para CEOs y directivos. El humo en escenario eleva cualquier presentación." },
          { title: "Eventos en Hacienda Grande", description: "Salones amplios de haciendas necesitan 2 máquinas para cobertura uniforme del escenario." },
          { title: "Eventos de Fin de Año", description: "Fiestas corporativas de fin de año con producción profesional y pista de baile tipo concierto." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Producción integrada: nos coordinamos con tu equipo"
          subtitle="Nuestro operador se integra como parte de tu staff de producción."
          paragraph1="A diferencia de los paquetes de fiesta, el Show Corporativo incluye coordinación profesional con tu equipo de producción. Nuestro operador asiste a la llamada técnica, revisa el guion del evento y programa las activaciones según los cues del director técnico."
          paragraph2="Esto garantiza que el humo se active en el momento exacto — la entrada del speaker, la revelación del producto, el video introductorio — con la intensidad precisa que la producción requiere."
        />
        <FeatureGrid features={[
          { title: "Llamada Técnica Previa", description: "Nos integramos a la junta de producción para alinear tiempos, cues y posiciones." },
          { title: "Guion del Evento", description: "Seguimos el rundown de tu producción. Cada activación coordinada al segundo." },
          { title: "2 Máquinas Sincronizadas", description: "Posicionadas en lados opuestos del escenario para cobertura uniforme de 180°." },
          { title: "Control de Densidad", description: "Humo sutil para ambiente o denso para efecto dramático. El operador ajusta en tiempo real." },
          { title: "Compatibilidad de Video", description: "El humo mejora la imagen de cámara — crea profundidad y hace visibles los haces de luz." },
          { title: "Flexibilidad de Cambios", description: "Adaptamos las activaciones si el programa del evento cambia sobre la marcha." },
        ]} columns={2} />
      </div>

      <div class="container" style="margin-top: 3rem;">
        <SectionHeader
          title="Lo que dicen nuestros clientes"
          subtitle="5 estrellas en 45 reseñas."
          paragraph1="Cada reseña es de un cliente real que contrató el Show Corporativo de humo para su evento."
          paragraph2="Pregunta por referencias de eventos corporativos similares al tuyo cuando nos contactes."
        />
        <TestimonialCards testimonials={[
          { name: "Fernando Castillo", event: "Lanzamiento de producto — Centro Citibanamex", rating: 5, text: "Las 2 máquinas cubrieron el escenario perfectamente y el operador se coordinó con nuestro equipo de producción como si fuera parte del staff. Muy profesionales." },
          { name: "Laura Mejía", event: "Presentación ejecutiva — Hotel en Reforma", rating: 5, text: "El humo en el escenario durante la entrada del CEO fue espectacular — se veía como un evento de Apple. El equipo llegó 3 horas antes y todo estuvo impecable." },
          { name: "Arturo Domínguez", event: "Convención corporativa — Hacienda en Edomex", rating: 5, text: "Las 2 máquinas dieron cobertura total al escenario principal. El operador fue muy flexible con los cambios de último momento del programa. Totalmente profesional." },
        ]} />
      </div>
    </ContentWithSidebar>
  </section>

  <!-- Galería -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Humo en escenarios corporativos reales"
        subtitle="Lanzamientos, convenciones, galas y presentaciones ejecutivas."
        paragraph1="Cada foto es de un montaje real con el paquete Show Corporativo. Centros de convenciones, hoteles, haciendas y recintos corporativos — 2 máquinas cubren el escenario completo con humo profesional."
        paragraph2="¿Tu venue se parece a alguno de estos? Mándanos fotos por WhatsApp y te decimos cómo quedarían las máquinas."
      />
      <Gallery4x4 images={[
        { src: "/img/humo/efecto-humo-evento-corporativo-escenario.avif", alt: "Humo en escenario de evento corporativo" },
        { src: "/img/humo/renta-humo-evento-empresarial-lanzamiento.avif", alt: "Humo en lanzamiento empresarial" },
        { src: "/img/humo/renta-humo-escenario-presentacion-dj.avif", alt: "Humo en escenario de presentación" },
        { src: "/img/humo/humo-teatral-obra-teatro-escenario.avif", alt: "Humo teatral en escenario" },
        { src: "/img/humo/humo-profesional-evento-nocturno-iluminacion.avif", alt: "Humo profesional con iluminación nocturna" },
        { src: "/img/humo/renta-humo-espectaculo-magia-show.avif", alt: "Humo en espectáculo y show" },
        { src: "/img/humo/efecto-humo-sesion-fotos-profesional.avif", alt: "Humo en sesión de fotos profesional" },
        { src: "/img/humo/renta-humo-atmosferico-fiesta-tematica.avif", alt: "Humo atmosférico en evento temático" },
      ]} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre el Paquete Show Corporativo"
        subtitle="Todo lo que necesitas saber antes de contratar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respondemos en minutos."
        paragraph2="Cada producción es diferente — te asesoramos gratis sobre la mejor configuración para tu escenario."
      />
    </div>
    <FaqSection items={[
      { question: "¿Las 2 máquinas pueden cubrir un escenario grande?", answer: "Sí. 2 máquinas de 1,500W posicionadas estratégicamente cubren escenarios de hasta 200m². El operador coordina las activaciones para crear un efecto uniforme. Para venues más grandes como centros de convenciones con escenarios mayores a 200m², te recomendamos el paquete Festival de 4 máquinas ($12,000 + IVA)." },
      { question: "¿Se coordinan con nuestro equipo de producción?", answer: "Sí. Nuestro operador se integra con tu equipo de producción como un proveedor más. Asistimos a la llamada técnica, seguimos el guion del evento y coordinamos las activaciones según los cues de tu director técnico o stage manager. Tenemos experiencia en producciones corporativas de gran escala." },
      { question: "¿El humo afecta las cámaras de video?", answer: "Al contrario — el humo mejora la imagen de video porque crea profundidad y hace visibles los haces de luz. Es un recurso estándar en producción audiovisual. El operador controla la densidad para que sea fotogénico sin obstruir la visibilidad del escenario ni de los speakers." },
      { question: "¿Se puede usar en centros de convenciones con sistemas de ventilación?", answer: "Sí. Los centros de convenciones tienen sistemas de ventilación que disipan el humo gradualmente. Nuestro operador ajusta la frecuencia de activación para compensar. Coordinamos con el personal del venue para que el sistema de ventilación no trabaje en contra del efecto." },
      { question: "¿Cuánto tiempo antes llegan para el montaje?", answer: "Llegamos 2-3 horas antes del evento o según lo indique tu producción. Para eventos corporativos con ensayo técnico, podemos estar desde el día anterior si es necesario. El tiempo de montaje de las 2 máquinas es de aproximadamente 45 minutos." },
    ]} />
  </section>

  <!-- Otros paquetes -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Otros Paquetes de Máquina de Humo"
        subtitle="¿Necesitas más cobertura o un paquete diferente?"
        paragraph1="Desde una máquina para fiestas íntimas hasta 4 máquinas con fog chiller para festivales. Cada paquete incluye operador y equipo profesional."
        paragraph2="Armamos propuestas integrales con precio especial cuando combinas servicios de humo e iluminación."
      />
      <div class="services-grid">
        {otrosPaquetes.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para elevar la producción de tu evento corporativo?</h2>
        <p>Cuéntanos el tipo de producción, el venue y la fecha. Nos integramos con tu equipo y te cotizamos todo en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
