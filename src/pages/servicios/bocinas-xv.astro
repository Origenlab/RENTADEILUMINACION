          paragraph2="El resultado: una coreografía que fluye perfecta, un vals que hace llorar a papá, y una hora loca que no deja a nadie sentado."
        />
        <Gallery4x4 images={[
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-baile-chambelanes-dorados-jbl.avif", alt: "Chambelanes bailando con bocinas JBL en XV años" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-baile-chambelanes-vestido-rosa.avif", alt: "Quinceañera con vestido rosa bailando con chambelanes" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-coreografia-chambelanes-escenario.avif", alt: "Coreografía de chambelanes en escenario de XV años" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-coronacion-tiara-flores-bocinas.avif", alt: "Coronación con tiara y flores en XV años" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-baile-sorpresa-chambelanes-dj.avif", alt: "Baile sorpresa de chambelanes con DJ" },
