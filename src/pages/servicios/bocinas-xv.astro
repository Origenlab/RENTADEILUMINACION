---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import PricingCards from '../../components/PricingCards.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Bocinas para XV Años en CDMX | Sonido y DJ | REDEIL";
const description = "Sonido profesional para XV años en CDMX. Audio para vals, chambelanes y fiesta. DJ, bocinas QSC, micrófonos. Instalación incluida. Cotiza gratis.";
const canonical = "https://rentadeiluminacion.com/servicios/bocinas-xv/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Bocinas para XV Años",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Servicio de renta de bocinas y sonido profesional para fiestas de XV años en Ciudad de México y Estado de México. Audio para vals, chambelanes, coronación y fiesta con DJ profesional.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Renta de Bocinas para XV Años",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿El DJ sabe la secuencia típica de un XV?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestros DJs tienen amplia experiencia en XV años y conocen perfectamente la secuencia: entrada triunfal, vals padre-hija, vals madre-hija, coreografía de chambelanes, coronación, cambio de zapatilla, brindis, hora loca y fiesta libre." }},
      { "@type": "Question", "name": "¿Pueden coordinarse con mi coreógrafo?", "acceptedAnswer": { "@type": "Answer", "text": "Por supuesto. Nos coordinamos con tu coreógrafo para los tiempos de música del vals y la coreografía de chambelanes. Hacemos pruebas de sonido con la música exacta que van a usar." }},
      { "@type": "Question", "name": "¿Incluyen micrófono para el brindis?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, incluimos micrófonos inalámbricos para los brindis, discursos del padrino y la ceremonia de la última muñeca. Nuestro DJ se encarga de pasarlo en el momento adecuado." }},
      { "@type": "Question", "name": "¿Pueden poner mariachi y DJ en el mismo evento?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Muchos XV años incluyen mariachi para la serenata y DJ para la fiesta. Nuestro equipo gestiona la transición de audio para que el cambio sea fluido y profesional." }},
      { "@type": "Question", "name": "¿Qué pasa si quiero humo bajo para el vals?", "acceptedAnswer": { "@type": "Answer", "text": "Lo incluimos en el paquete XV Premium. También lo puedes agregar a cualquier paquete. El efecto de nubes en el piso para el vals es espectacular y uno de los favoritos en XV años." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "DJ para Eventos", image: "/img/bocinas-djs/dj-para-eventos-cdmx-cabina-profesional.avif", alt: "DJ profesional con cabina para eventos en CDMX", description: "DJ profesional con cabina Pioneer para fiestas, bodas y eventos corporativos en CDMX.", link: "/servicios/bocinas-djs/" },
  { title: "Bocinas para Fiestas", image: "/img/bocinas-fiestas/renta-bocinas-fiestas-eventos-profesionales.avif", alt: "Bocinas profesionales para fiestas y eventos", description: "Sonido profesional para fiestas privadas, cumpleaños y celebraciones. Bocinas QSC, JBL y más.", link: "/servicios/bocinas-fiestas/" },
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Efecto humo bajo nubes en piso para vals", description: "Efecto de nubes en el piso para el vals y la entrada. El favorito en XV años y bodas.", link: "/servicios/humo-bajo/" },
  { title: "Seguidor", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Luz seguidor para primer baile y vals", description: "Spotlight profesional que sigue a la quinceañera en su vals y momentos especiales.", link: "/servicios/seguidor/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Sonido", href: "/servicios/sonido/" },
    { label: "Bocinas para XV Años" }
  ]} />
</Fragment>

    <Hero
      title="Renta de Bocinas para XV Años en CDMX"
      subtitle="Sonido profesional para vals, chambelanes y fiesta. DJ con experiencia en quinceañeras. Instalación incluida."
      introParagraph1='Una fiesta de XV años tiene momentos de audio únicos: la entrada triunfal, el vals con papá, la coreografía de chambelanes, la coronación, el brindis y la fiesta libre. En <strong>REDEIL</strong> nos especializamos en sonido para quinceañeras en CDMX — cada momento suena perfecto porque conocemos la secuencia de memoria.'
      introParagraph2='Nuestros paquetes incluyen bocinas QSC y JBL, micrófonos inalámbricos para la ceremonia, mezcladoras digitales y DJ profesional que conoce la secuencia típica de un XV. Montaje, prueba de sonido, operación y desmontaje incluidos en todos los paquetes.'
    />

    <CtaBar
      headline="¿Qué tipo de sonido necesitas?"
      items={[
        { label: "XV Años", href: "/servicios/bocinas-xv/", icon: "sonido" },
        { label: "DJ Eventos", href: "/servicios/bocinas-djs/", icon: "sonido" },
        { label: "Bocinas Fiestas", href: "/servicios/bocinas-fiestas/", icon: "sonido" },
        { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
      ]}
    />

    <!-- Galería de sonido para XV años -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="Sonido Profesional para XV Años"
          subtitle="Montajes reales en quinceañeras de CDMX y Edomex."
          paragraph1="Desde el vals emotivo hasta la fiesta con los éxitos del momento, cada montaje se diseña para el salón o jardín específico. Nuestros sistemas cubren desde espacios íntimos hasta haciendas de 300+ invitados."
          paragraph2="Trabajamos con equipos QSC, JBL y consolas Pioneer. Nuestros DJs se coordinan con coreógrafos, maestros de ceremonia y mariachis para que cada transición sea perfecta."
        />
        <Gallery4x4 images={[
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-vals-padre-hija-dj-salon.avif", alt: "Vals padre-hija con DJ profesional en salón" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-baile-chambelanes-dorados-jbl.avif", alt: "Baile de chambelanes con bocinas JBL" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-entrada-escalera-dj-subwoofer.avif", alt: "Entrada por escalera con DJ y subwoofer" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-coronacion-tiara-flores-bocinas.avif", alt: "Coronación con tiara y sonido profesional" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-fiesta-line-array-qsc-dj.avif", alt: "Fiesta con line array QSC y DJ" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-mariachi-hacienda-luces.avif", alt: "Mariachi en hacienda con luces y sonido" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-baile-chambelanes-vestido-rosa.avif", alt: "Chambelanes con quinceañera de vestido rosa" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-coreografia-chambelanes-escenario.avif", alt: "Coreografía de chambelanes en escenario" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-coreografia-vestido-magenta-jbl.avif", alt: "Coreografía con vestido magenta y bocinas JBL" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-coronacion-tiara-mama-dj.avif", alt: "Coronación con mamá y DJ de fondo" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-entrada-escalera-humo-bajo.avif", alt: "Entrada con escalera y humo bajo" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-fiesta-invitados-qsc-luces.avif", alt: "Fiesta con invitados bailando y luces QSC" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-fiesta-pista-baile-line-array.avif", alt: "Pista de baile con sistema line array" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-vals-padre-hija-qsc-salon.avif", alt: "Vals padre-hija con bocinas QSC en salón" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-mariachi-serenata-salon.avif", alt: "Mariachi con serenata en salón de XV" },
          { src: "/img/bocinas-xv/renta-bocinas-xv-anos-show-baile-teatro-monitores.avif", alt: "Show de baile con monitores de escenario" },
        ]} />
      </div>
    </section>

    <!-- Paquetes -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Paquetes de Sonido para XV Años"
          subtitle="3 opciones según el tamaño de tu fiesta. Instalación incluida en todos."
          paragraph1="Cada paquete incluye transporte, montaje profesional, prueba de sonido, operación durante todo el evento y desmontaje. Sin costos ocultos — el precio es todo incluido."
          paragraph2="¿Tu XV necesita algo diferente? Armamos paquetes a la medida. Cotiza por WhatsApp y te hacemos una propuesta personalizada en menos de 24 horas."
        />
        <PricingCards packages={[
          {
            name: "XV Básico",
            price: "$8,500",
            priceNote: "+IVA",
            description: "Sonido para vals + fiesta",
            features: [
              { text: "2 bocinas QSC K12 + subwoofer", included: true },
              { text: "2 micrófonos inalámbricos", included: true },
              { text: "Música para vals y momentos clave", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Ideal para: XV íntimo hasta 100 personas", included: true },
              { text: "DJ profesional", included: false },
              { text: "Show de luces", included: false },
            ],
            ctaLabel: "Cotizar XV Básico",
            ctaHref: "/contacto/",
          },
          {
            name: "XV Completo",
            price: "$15,000",
            priceNote: "+IVA",
            badge: "Más popular",
            highlight: true,
            description: "Sonido completo + DJ profesional",
            features: [
              { text: "4 bocinas QSC + 2 subwoofers", included: true },
              { text: "3 micrófonos inalámbricos", included: true },
              { text: "DJ con experiencia en XV años", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Ideal para: XV hasta 200 personas", included: true },
              { text: "Iluminación básica de pista", included: true },
              { text: "Show de luces completo", included: false },
            ],
            ctaLabel: "Cotizar XV Completo",
            ctaHref: "/contacto/",
          },
          {
            name: "XV Premium",
            price: "$24,000",
            priceNote: "+IVA",
            description: "Sistema line array para 200+ personas",
            features: [
              { text: "4 micrófonos inalámbricos profesionales", included: true },
              { text: "DJ profesional + animador", included: true },
              { text: "Consola Pioneer CDJ + DJM", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Ideal para: XV grande en salón o hacienda", included: true },
              { text: "Show de luces con robóticas", included: true },
              { text: "Humo bajo para entrada y vals incluido", included: true },
            ],
            ctaLabel: "Cotizar XV Premium",
            ctaHref: "/contacto/",
          },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre Sonido para XV Años"
          subtitle="Lo que todos preguntan antes de cotizar."
          paragraph1="Si tienes otra duda sobre la renta de sonido para tu quinceañera, escríbenos por WhatsApp y te respondemos en minutos."
          paragraph2="Cada XV es diferente — por eso hacemos propuestas a la medida según tu salón, número de invitados y los momentos que quieres incluir."
        />
      </div>
      <FaqSection items={[
        { question: "¿El DJ sabe la secuencia típica de un XV?", answer: "Sí. Nuestros DJs tienen amplia experiencia en XV años y conocen perfectamente la secuencia: entrada triunfal, vals padre-hija, vals madre-hija, coreografía de chambelanes, coronación, cambio de zapatilla, brindis, hora loca y fiesta libre." },
        { question: "¿Pueden coordinarse con mi coreógrafo?", answer: "Por supuesto. Nos coordinamos con tu coreógrafo para los tiempos de música del vals y la coreografía de chambelanes. Hacemos pruebas de sonido con la música exacta que van a usar." },
        { question: "¿Incluyen micrófono para el brindis?", answer: "Sí, incluimos micrófonos inalámbricos para los brindis, discursos del padrino y la ceremonia de la última muñeca. Nuestro DJ se encarga de pasarlo en el momento adecuado." },
        { question: "¿Pueden poner mariachi y DJ en el mismo evento?", answer: "Sí. Muchos XV años incluyen mariachi para la serenata y DJ para la fiesta. Nuestro equipo gestiona la transición de audio para que el cambio sea fluido y profesional." },
        { question: "¿Qué pasa si quiero humo bajo para el vals?", answer: "Lo incluimos en el paquete XV Premium. También lo puedes agregar a cualquier paquete. El efecto de nubes en el piso para el vals es espectacular y uno de los favoritos en XV años." },
      ]} />
    </section>

    <!-- Servicios relacionados -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="Combina con Otros Servicios"
          subtitle="Tu XV se ve y suena mejor cuando complementas el sonido."
          paragraph1="La mayoría de nuestras quinceañeras combinan el sonido con humo bajo para el vals, luz seguidor y show de luces. El resultado: un evento que se ve y se siente profesional de principio a fin."
          paragraph2="Armamos paquetes personalizados con precio especial cuando combinas servicios. Cuéntanos tu evento y te hacemos una propuesta integral."
        />
        <div class="services-grid">
          {serviciosRelacionados.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Listo para que los XV años suenen espectaculares?</h2>
          <p>Cuéntanos la fecha, el salón y cuántos invitados esperas. Te armamos el paquete de sonido perfecto para tu quinceañera.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
