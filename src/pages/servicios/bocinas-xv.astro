              { text: "6 horas de operación", included: true },
              { text: "Ideal para: XV años completos", included: true },
              { text: "Iluminación incluida", included: false },
            ],
            ctaLabel: "Cotizar XV con DJ",
            ctaHref: "/contacto/",
