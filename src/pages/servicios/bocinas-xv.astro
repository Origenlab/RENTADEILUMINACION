            badge: "Más popular",
            highlight: true,
            description: "El más pedido. DJ + audio completo + coordinación con MC y coreógrafo. Cubre vals, chambelanes y hora loca.",
            features: [
              { text: "DJ con consola Pioneer DDJ", included: true },
              { text: "4-6 bocinas + 2 subwoofers", included: true },
              { text: "4 micrófonos Shure inalámbricos", included: true },
