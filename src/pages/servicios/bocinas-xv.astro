---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import PricingCards from '../../components/PricingCards.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "DJ y Bocinas para XV Años en CDMX | REDEIL";
const description = "DJ profesional + audio JBL para XV años en CDMX. Vals, coreografía y hora loca con repertorio adaptado. Desde $4,500 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/bocinas-xv/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "DJ y Audio Profesional para XV Años",
    "provider": { "@type": "LocalBusiness", "name": "REDEIL", "url": "https://rentadeiluminacion.com", "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "DJ profesional y audio JBL para XV años en CDMX. Vals con papá, coreografía con chambelanes, hora loca. Repertorio adaptado a quinceañeras.",
    "areaServed": [{ "@type": "City", "name": "Ciudad de México" }, { "@type": "State", "name": "Estado de México" }],
    "serviceType": "DJ y Audio para XV Años",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org", "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿El DJ conoce el protocolo de XV años?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestros DJs llevan años en XV años y conocen la secuencia completa: entrada, vals con papá, cambio de zapatillas, vals con chambelanes, hora loca, brindis. Coordinan con el MC y el coreógrafo para que cada momento tenga su canción exacta." }},
      { "@type": "Question", "name": "¿El DJ coordina con el coreógrafo de los chambelanes?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, siempre. El DJ necesita las canciones exactas de la coreografía, los tiempos de entrada y las señales de cambio. Se reúne con el coreógrafo antes del evento para ensayar la secuencia." }},
      { "@type": "Question", "name": "¿Cuánto dura el servicio de DJ para XV años?", "acceptedAnswer": { "@type": "Answer", "text": "El paquete estándar cubre 6 horas — desde el inicio de la recepción hasta la fiesta. Para eventos más largos o con ceremonia religiosa antes, ajustamos las horas y el precio." }},
      { "@type": "Question", "name": "¿Qué géneros musicales maneja para XV años?", "acceptedAnswer": { "@type": "Answer", "text": "De todo: desde valses clásicos y boleros para el momento con papá, hasta reggaetón, electrónica, cumbia y pop para la hora loca. El DJ adapta el repertorio a lo que le gusta a la quinceañera y a lo que bailan los invitados." }},
      { "@type": "Question", "name": "¿Incluye micrófonos para el brindis?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Todos los paquetes incluyen micrófonos Shure inalámbricos para brindis, discursos y el MC. El técnico se asegura de que cada persona que hable se escuche claro." }},
      { "@type": "Question", "name": "¿Se puede combinar con luces neón o UV?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, es la tendencia más fuerte en XV años. DJ + luces UV para glow party. Armamos paquetes combinados de audio + iluminación neón con precio especial." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "Luces Neón y UV", image: "/img/luces-neon/renta-luces-neon-glow-party-celebracion-neon-300w.avif", alt: "Glow party con luces neón UV para XV años", description: "La tendencia en XV años: glow party con UV. DJ + luces neón = la fiesta que todos van a recordar.", link: "/servicios/luces-neon/" },
  { title: "Seguidor de Luz", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Spotlight para vals de quinceañera", description: "Spotlight siguiendo a la quinceañera en el vals con papá y en la coreografía. El momento más emotivo.", link: "/servicios/seguidor/" },
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Humo bajo para vals de XV años", description: "La quinceañera bailando sobre nubes con sus chambelanes. El efecto que hace llorar a las mamás.", link: "/servicios/humo-bajo/" },
  { title: "Confeti", image: "/img/maquina-de-papelitos/confeti-dorado-primer-baile-novios-romantico-400w.avif", alt: "Confeti en fiesta de XV años", description: "Explosión de confeti en el momento de la hora loca. El momento más fotografiado después del vals.", link: "/servicios/confeti/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Sonido y DJ", href: "/servicios/sonido/" },
    { label: "XV Años" }
  ]} />
</Fragment>

    <Hero
      title="DJ y Audio Profesional para XV Años en CDMX"
      subtitle="DJ + bocinas JBL + coordinación completa para vals, coreografía y hora loca. Desde $4,500 + IVA."
      introParagraph1='Los XV años tienen una coreografía sonora que ningún otro evento tiene. Arranca con la entrada triunfal y la canción que eligió la quinceañera hace meses. Sigue el vals con papá — emotivo, suave, con la voz del cantante quebrándose en las bocinas. Después el vals con chambelanes, la coreografía ensayada durante semanas con cambios de canción exactos al segundo. La hora loca, el brindis, la liga, el ramo. Cada momento tiene su canción y su energía. Nuestros DJs en <strong>REDEIL</strong> llevan años en XV años de la CDMX — conocen el protocolo de memoria.'
