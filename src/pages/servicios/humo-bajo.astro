---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import PricingCards from '../../components/PricingCards.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Humo Bajo para Bodas y XV Años en CDMX | REDEIL";
const description = "Efecto de niebla baja que crea nubes en el piso para el vals de bodas y XV años. Equipo CO₂ profesional. Sin olor, sin residuo. Desde $3,500 + IVA en CDMX.";
const canonical = "https://rentadeiluminacion.com/servicios/humo-bajo/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Humo Bajo para Bodas y Eventos",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Servicio profesional de niebla baja (humo bajo) para el vals de bodas y XV años en CDMX. Efecto de nubes en el piso con equipo CO₂ profesional, sin olor ni residuo.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Renta de Humo Bajo",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿El humo bajo es peligroso para los invitados?", "acceptedAnswer": { "@type": "Answer", "text": "No. Usamos máquinas de niebla baja con glicol farmacéutico certificado — el mismo fluido que usan los teatros y producciones de televisión. No contiene sustancias tóxicas, no mancha la ropa y se disipa en segundos sin dejar residuo en el piso." }},
      { "@type": "Question", "name": "¿Cuánto tiempo dura el efecto de niebla baja?", "acceptedAnswer": { "@type": "Answer", "text": "Cada carga de fluido dura entre 3 y 8 minutos de efecto continuo. Para el vals de una boda (3-4 minutos), una carga es más que suficiente. Llevamos fluido extra para repetir el efecto si lo necesitas." }},
      { "@type": "Question", "name": "¿La niebla baja activa las alarmas de humo?", "acceptedAnswer": { "@type": "Answer", "text": "Las máquinas de niebla baja de CO₂ generalmente no activan detectores de humo porque el efecto permanece pegado al piso. Sin embargo, coordinamos con el venue antes del evento para verificar el tipo de detectores instalados." }},
      { "@type": "Question", "name": "¿Cuánto cuesta la renta de humo bajo?", "acceptedAnswer": { "@type": "Answer", "text": "El paquete para el vals de bodas arranca desde $3,500 + IVA con equipo, fluido, operador y traslado incluidos. Para cobertura de varios momentos (vals + entrada + otros), desde $5,500 + IVA." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "Seguidor de Luz", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", alt: "Seguidor de luz en vals de novios", description: "La combinación más solicitada en bodas: niebla baja en el piso + spotlight siguiendo a los novios. El vals que todos recuerdan.", link: "/servicios/seguidor/" },
  { title: "Guirnaldas Edison", image: "/img/guirnaldas/renta-guirnaldas-edison-terraza-recepcion-02-300w.avif", alt: "Guirnaldas Edison cálidas para boda", description: "Guirnaldas cálidas sobre la pista + niebla baja en el piso. Romántico y espectacular para bodas al aire libre.", link: "/servicios/guirnaldas/" },
  { title: "Cabezas Móviles", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante-300w.avif", alt: "Cabezas móviles con beams en boda", description: "Los beams de las cabezas móviles se ven espectaculares cortando la niebla. El efecto de concierto en tu boda.", link: "/servicios/cabezas-moviles/" },
  { title: "Sky Tracker", image: "/img/sky-tracker/renta-skytracker-cielo-nocturno-potente-300w.avif", alt: "Sky tracker con haz al cielo", description: "Niebla en el piso + haces de luz al cielo. Una producción completa de arriba a abajo para eventos al aire libre.", link: "/servicios/sky-tracker/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Efectos Especiales", href: "/servicios/efectos-especiales/" },
    { label: "Humo Bajo" }
  ]} />
</Fragment>

    <Hero
      title="Renta de Humo Bajo para Bodas y XV Años en CDMX"
      subtitle="Niebla baja que crea nubes en el piso para el vals. Equipo CO₂ profesional. Sin olor, sin residuo. Desde $3,500 + IVA."
      introParagraph1='El humo bajo es el efecto más pedido para bodas. Pero hay dos formas muy diferentes de hacerlo, y la mayoría de los proveedores no te explican cuál están usando. El método con CO₂ líquido enfría el humo y lo pega al piso de inmediato, pero dura poco (60-90 segundos) y el tanque es caro. El método con máquina de glicol (como la <strong>JEM ZR33</strong> o la <strong>Antari ICE-101</strong> que usamos en <strong>REDEIL</strong>) produce niebla continua durante 3-5 minutos con fluido farmacéutico certificado. Sin olor, sin residuo en el piso, sin manchar vestidos. Llevamos más de 800 bodas con este equipo en CDMX y Edo. Méx.'
      introParagraph2='La diferencia contra una máquina de humo convencional es que la niebla baja no sube. Se queda a nivel del piso, a la altura de los tobillos, y se va disipando sola conforme avanza el vals. El operador activa el equipo 30 segundos antes de que los novios salgan a la pista, coordinado con el DJ o el MC. Cuando la música arranca, la niebla ya está en su punto. En exteriores (jardines, haciendas) el viento la dispersa más rápido, así que usamos dos máquinas para compensar. En salones cerrados, con una sola basta. Traslado, operador y fluido incluidos.'
    />


    <!-- Galería -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="¿Cómo se ve el humo bajo en un evento real?"
          subtitle="Así se ve el efecto con equipo profesional, no con hielo seco casero."
          paragraph1="La diferencia entre hielo seco en una hielera y una máquina profesional de niebla baja es enorme. El hielo seco dura 30 segundos, no lo controlas, y si lo pisas quema. La máquina profesional produce niebla continua durante 3-5 minutos, el operador regula el caudal en tiempo real, y el fluido de glicol es completamente seguro para la piel."
          paragraph2="El timing lo es todo. El operador espera la señal del DJ, activa el equipo 30 segundos antes de que los novios salgan, y la niebla está en su punto cuando arranca la canción. Si el MC se atrasa o la canción cambia, el operador ajusta. Eso no lo puedes hacer con hielo seco."
        />
        <Gallery4x4 images={[
          { src: "/img/humo-bajo/primer-baile-novios-humo-bajo-seguidor.avif", alt: "Primer baile de novios sobre niebla baja con seguidor de luz" },
          { src: "/img/humo-bajo/vals-boda-humo-bajo-iluminacion-romantica.avif", alt: "Vals de boda con humo bajo e iluminación romántica" },
          { src: "/img/humo-bajo/humo-bajo-primer-baile-boda-romantico.avif", alt: "Primer baile romántico de boda con niebla baja en el piso" },
          { src: "/img/humo-bajo/renta-humo-bajo-primer-baile-boda.avif", alt: "Renta de humo bajo para primer baile de boda" },
          { src: "/img/humo-bajo/efecto-nubes-piso-boda-jardin.avif", alt: "Efecto de nubes en el piso de jardín para boda" },
          { src: "/img/humo-bajo/humo-bajo-primer-vals-romantico.avif", alt: "Primer vals romántico con niebla baja" },
          { src: "/img/humo-bajo/humo-bajo-vals-boda-pista-luz.avif", alt: "Pista de baile con humo bajo y luces para vals" },
          { src: "/img/humo-bajo/humo-bajo-vals-xv-anos-quinceanos.avif", alt: "Vals de XV años con efecto de humo bajo" },
          { src: "/img/humo-bajo/niebla-baja-vals-quinceanos-elegante.avif", alt: "Niebla baja elegante en vals de quinceañera" },
          { src: "/img/humo-bajo/humo-bajo-entrada-quinceanos-salon.avif", alt: "Entrada de quinceañera al salón con humo bajo" },
          { src: "/img/humo-bajo/humo-bajo-boda-salon-iluminacion.avif", alt: "Salón de boda con humo bajo e iluminación profesional" },
          { src: "/img/humo-bajo/niebla-baja-boda-hacienda-mexicana.avif", alt: "Niebla baja en boda de hacienda mexicana" },
          { src: "/img/humo-bajo/niebla-baja-boda-terraza-romantica.avif", alt: "Terraza romántica de boda con niebla baja" },
          { src: "/img/humo-bajo/renta-humo-bajo-evento-hacienda.avif", alt: "Humo bajo en evento de hacienda" },
          { src: "/img/humo-bajo/renta-niebla-baja-pista-baile-boda.avif", alt: "Pista de baile con niebla baja para boda" },
          { src: "/img/humo-bajo/efecto-humo-bajo-baile-novios.avif", alt: "Efecto de humo bajo durante baile de novios" },
        ]} />
      </div>
    </section>

    <!-- Paquetes -->
    <section class="services-section services-alt" id="paquetes">
      <div class="container">
        <SectionHeader
          title="¿Cuánto cuesta rentar humo bajo en CDMX?"
          subtitle="Desde un solo vals hasta cobertura de toda la noche."
          paragraph1="Todos los paquetes incluyen máquina profesional, fluido de glicol certificado, operador técnico, traslado y coordinación directa con tu DJ o MC. El operador sabe cuándo activar y cuándo parar sin que nadie se lo tenga que recordar."
          paragraph2="La combinación más contratada: humo bajo + seguidor de luz. Los novios bailan sobre nubes con un spotlight encima. Si te interesa, pregunta por el paquete combinado con precio especial."
        />
        <PricingCards packages={[
          {
            name: "Val o Momento Único",
            price: "$3,500",
            priceNote: "+ IVA",
            description: "Niebla baja para un solo momento estelar: el vals, la entrada, el corte de pastel. El efecto más fotografiado de la noche.",
            features: [
              { text: "1 máquina de niebla baja profesional", included: true },
              { text: "Fluido glicol certificado (1 carga)", included: true },
              { text: "Operador técnico incluido", included: true },
              { text: "Traslado + montaje + desmontaje", included: true },
              { text: "Coordinación con DJ/MC", included: true },
              { text: "Ideal para: vals, entrada, corte pastel", included: true },
              { text: "Múltiples activaciones", included: false },
              { text: "Segunda máquina para mayor cobertura", included: false },
            ],
            ctaLabel: "Cotizar vals o momento único",
            ctaHref: "/servicios/humo-bajo/paquete-vals-unico/",
          },
          {
            name: "Recepción Completa",
            price: "$5,500",
            priceNote: "+ IVA",
            badge: "Más popular",
            highlight: true,
            description: "Niebla baja para todos los momentos especiales de la recepción. Vals, entrada, brindis — el operador está listo para cada uno.",
            features: [
              { text: "1 máquina de niebla baja profesional", included: true },
              { text: "Fluido glicol ilimitado (toda la noche)", included: true },
              { text: "Operador técnico 4-6 horas", included: true },
              { text: "Traslado + montaje + desmontaje", included: true },
              { text: "Activaciones múltiples a demanda", included: true },
              { text: "Coordinación completa con DJ/MC", included: true },
              { text: "Ideal para: bodas, XV años completos", included: true },
              { text: "Segunda máquina", included: false },
            ],
            ctaLabel: "Cotizar recepción completa",
            ctaHref: "/servicios/humo-bajo/paquete-recepcion-completa/",
          },
          {
            name: "Doble Cobertura",
            price: "$8,500",
            priceNote: "+ IVA",
            description: "2 máquinas para mayor caudal de niebla y cobertura uniforme en pistas de baile grandes o venues amplios.",
            features: [
              { text: "2 máquinas de niebla baja", included: true },
              { text: "Doble caudal — pista completamente cubierta", included: true },
              { text: "Fluido ilimitado toda la noche", included: true },
              { text: "2 operadores técnicos", included: true },
              { text: "Traslado + montaje + desmontaje", included: true },
              { text: "Activaciones múltiples sincronizadas", included: true },
              { text: "Ideal para: haciendas, salones grandes", included: true },
              { text: "Combinable con seguidor y cabezas móviles", included: true },
            ],
            ctaLabel: "Cotizar doble cobertura",
            ctaHref: "/servicios/humo-bajo/paquete-doble-cobertura/",
          },
          {
            name: "Producción Premium",
            price: "$13,000",
            priceNote: "+ IVA",
            description: "Humo bajo + seguidor de luz + cabezas móviles. El paquete de iluminación más solicitado para bodas de alto impacto.",
            features: [
              { text: "2 máquinas de niebla baja", included: true },
              { text: "1 seguidor de luz profesional con operador", included: true },
              { text: "4 cabezas móviles para show de luces", included: true },
              { text: "Fluido ilimitado + fluido de larga duración", included: true },
              { text: "Equipo técnico completo", included: true },
              { text: "Coordinación con DJ, MC y wedding planner", included: true },
              { text: "Visita previa al venue", included: true },
              { text: "Ideal para: bodas premium, producciones", included: true },
            ],
            ctaLabel: "Cotizar producción premium",
            ctaHref: "/servicios/humo-bajo/paquete-produccion-premium/",
          },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas frecuentes sobre humo bajo"
          subtitle="Lo que nos preguntan por WhatsApp antes de cada boda."
          paragraph1="El humo bajo genera dudas porque mucha gente lo confunde con máquina de humo o con hielo seco. No es lo mismo. Aquí aclaramos las más comunes."
          paragraph2="Si tu venue tiene reglas específicas sobre efectos, escríbenos y verificamos compatibilidad antes de que reserves."
        />
      </div>
      <FaqSection items={[
        { question: "¿Es lo mismo que una máquina de humo?", answer: "No. La máquina de humo convencional llena el salón de niebla que sube y se queda flotando en el aire. Eso dificulta la visibilidad y puede activar alarmas. La niebla baja se queda pegada al piso, a la altura de los tobillos, y se disipa sola en 3-5 minutos. Son equipos completamente diferentes." },
        { question: "¿Es seguro para los invitados?", answer: "Sí. Usamos fluido de glicol farmacéutico grado alimenticio, el mismo que usan en teatros y producciones de TV. No irrita ojos ni garganta, no mancha vestidos, no deja residuo en el piso. Los invitados pueden caminar sobre la niebla sin problema. Llevamos décadas usándolo sin un solo incidente." },
        { question: "¿Activa las alarmas de humo del salón?", answer: "Generalmente no, porque la niebla permanece a nivel del piso y no sube hacia los detectores. Pero cada salón tiene detectores diferentes. Antes del evento verificamos con el venue qué tipo de sensores tienen. Si son detectores de partículas muy sensibles, los desactivamos temporalmente con autorización del salón o ajustamos el caudal." },
        { question: "¿Cuánto dura el efecto?", answer: "Entre 3 y 5 minutos por activación. Un vals dura 3-4 minutos, así que una carga cubre el momento completo. El operador regula el caudal para que la niebla sea densa cuando arranca la canción y se vaya disipando naturalmente. Si quieres repetir el efecto en otro momento (brindis, corte de pastel), llevamos fluido extra." },
        { question: "¿Funciona en jardines al aire libre?", answer: "Sí, pero el viento la dispersa más rápido. En jardines y haciendas con brisa, la niebla dura menos y se mueve hacia un lado en vez de quedarse quieta sobre la pista. Compensamos usando dos máquinas posicionadas en lados opuestos. El efecto sigue siendo bueno, pero honestamente, en un salón cerrado se ve más denso y dura más." },
        { question: "¿Cuánto antes llega el equipo?", answer: "1-2 horas antes. El operador monta, hace prueba de caudal, y se coordina con el DJ para definir la señal de activación. Necesita saber qué canción es el vals y acordar una señal clara (puede ser visual o por radio) para activar el equipo 30 segundos antes de que los novios salgan a la pista." },
      ]} />
    </section>

    <!-- Servicios relacionados -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="¿Qué otros servicios combinan con humo bajo?"
          subtitle="Seguidor de luz + niebla baja es la combinación más pedida en bodas."
          paragraph1="La niebla cubre el piso. El seguidor ilumina a los novios desde arriba. Las guirnaldas dan el techo cálido. Cuando los tres coinciden, sale la foto que los novios van a enmarcar. Eso solo funciona bien cuando audio, luces y efectos son del mismo proveedor, porque el timing tiene que ser exacto."
          paragraph2="Si combinas dos o más servicios, el precio baja porque compartimos traslado y equipo técnico."
        />
        <div class="services-grid">
          {serviciosRelacionados.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Quieres que los novios bailen sobre nubes?</h2>
          <p>Cuéntanos la fecha, el venue y qué momentos quieres iluminar. Te cotizamos en minutos y te decimos si el salón es compatible con el equipo.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
