---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import PricingCards from '../../components/PricingCards.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de City Color LED para Bodas y Eventos CDMX | REDEIL";
const description = "Cañones de luz LED RGBW para bañar de color fachadas, salones y escenarios. Bodas, corporativos y festivales en CDMX. Desde $4,000 + IVA.";
const canonical = "https://rentadeiluminacion.com/servicios/city-color/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de City Color para Eventos",
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de México", "addressRegion": "CDMX", "addressCountry": "MX" }
    },
    "description": "Servicio profesional de renta de city color y cañones de luz LED RGBW para bañar de color fachadas, salones y escenarios en bodas y eventos en CDMX.",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "serviceType": "Renta de City Color",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Qué es un city color?", "acceptedAnswer": { "@type": "Answer", "text": "Un city color es un cañón de luz LED RGBW de alto impacto diseñado para bañar grandes superficies con color — fachadas de haciendas, muros de salones, columnas, escenarios. Proyecta un haz ancho y potente que cubre de 10 a 30 metros cuadrados por unidad." }},
      { "@type": "Question", "name": "¿Cuántos city colors necesito para mi evento?", "acceptedAnswer": { "@type": "Answer", "text": "Para una fachada de hacienda estándar, 4-6 cañones son suficientes. Para un salón de eventos mediano, 8 unidades. Para venues grandes con múltiples zonas, 16 o más. Te asesoramos según las dimensiones de tu espacio." }},
      { "@type": "Question", "name": "¿Se puede cambiar el color durante el evento?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Los city colors se controlan vía DMX512 y pueden cambiar de color en tiempo real — rosa para el vals, dorado para la cena, multicolor para la fiesta. Nuestro operador programa los cambios según los momentos de tu evento." }},
      { "@type": "Question", "name": "¿Funcionan en exteriores?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestros cañones de luz tienen protección IP65 para uso en exteriores. Son ideales para fachadas, jardines, fuentes y espacios al aire libre." }},
      { "@type": "Question", "name": "¿Qué diferencia hay entre city color y uplighting arquitectónico?", "acceptedAnswer": { "@type": "Answer", "text": "El city color usa cañones de alta potencia para cubrir superficies grandes (fachadas completas, escenarios). El uplighting arquitectónico usa reflectores más pequeños para iluminar puntos específicos (columnas, árboles, arcos). Lo ideal es combinar ambos." }},
      { "@type": "Question", "name": "¿Se puede combinar el city color con otros servicios?", "acceptedAnswer": { "@type": "Answer", "text": "Sí — es lo más recomendable. La fachada bañada de color es solo el primer nivel. Agrega uplighting en columnas, cascadas LED dentro del salón y sky tracker para una producción completa." }}
    ]
  }
]);

const serviciosRelacionados = [
  { title: "Iluminación Arquitectónica", image: "/img/iluminacion-arquitectonica/iluminacion-arquitectonica-arcos-coloniales-luz-violeta-fachada-300w.avif", alt: "Uplighting en arcos coloniales", description: "City color para las fachadas grandes + uplighting para los detalles. Cobertura total del venue.", link: "/servicios/iluminacion-arquitectonica/" },
  { title: "Sky Tracker", image: "/img/sky-tracker/renta-skytracker-cielo-nocturno-potente-300w.avif", alt: "Sky tracker al cielo", description: "Fachadas bañadas de color + haces de luz al cielo. La producción nocturna más impresionante.", link: "/servicios/sky-tracker/" },
  { title: "Cascadas LED", image: "/img/cascadas-led/cascadas-led-novios-mesa-romantica-boda-300w.avif", alt: "Cascadas LED para mesa de novios", description: "Color en las paredes exteriores + cascadas brillantes dentro del salón. Adentro y afuera, transformado.", link: "/servicios/cascadas-led/" },
  { title: "Cabezas Móviles", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante-300w.avif", alt: "Cabezas móviles con beams", description: "City color para el ambiente + cabezas móviles para el show. La combinación que usan en conciertos.", link: "/servicios/cabezas-moviles/" },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Iluminación", href: "/servicios/iluminacion/" },
    { label: "City Color" }
  ]} />
</Fragment>

    <Hero
      title="Renta de City Color para Eventos en CDMX"
      subtitle="Cañones de luz LED RGBW que bañan de color fachadas, salones y escenarios. Control DMX. Desde $4,000 + IVA."
      introParagraph1='El city color es un cañón de luz LED que baña superficies grandes con color uniforme. No es un foco que ilumina un punto — es un wash de 180W a 360W que cubre 10 a 30 metros cuadrados por unidad. Con 4 cañones cubres la fachada frontal de una hacienda. Con 8, fachada más jardín. Con 16, la hacienda completa. Operamos <strong>Elation SixPar</strong>, <strong>Chauvet Colorado</strong> y <strong>Martin Rush</strong> con certificación IP65 para exteriores.'
      introParagraph2='La diferencia con el uplighting arquitectónico es la escala. El uplighting usa reflectores chicos para puntos específicos: una columna, un árbol, un arco. El city color baña paredes enteras, fachadas de 15 metros de ancho, escenarios completos. Los dos se complementan y se controlan por el mismo operador vía DMX512 — cambia colores en tiempo real según el momento del evento. Rosa para el vals, dorado para la cena, multicolor cuando se arma la fiesta.'
    />

    <CtaBar
      headline="¿Qué quieres bañar de color?"
      items={[
        { label: "Fachadas de Hacienda", href: "#paquetes", icon: "iluminacion" },
        { label: "Toda la iluminación", href: "/servicios/iluminacion/", icon: "iluminacion" },
        { label: "Bodas", href: "/eventos/bodas/", icon: "iluminacion" },
        { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
      ]}
    />

    <!-- Galería -->
    <section class="services-section">
      <div class="container">
        <SectionHeader
          title="Fachadas, salones y escenarios bañados de color"
          subtitle="Cada cañón cubre hasta 30m² de superficie con luz potente y uniforme."
          paragraph1="Con 4 cañones distribuidos a lo largo de la fachada, el color se ve uniforme sin manchas ni puntos muertos. Si los cañones están demasiado juntos, se superponen y generan un centro más brillante que los bordes. La distribución correcta depende del ancho de la fachada y del ángulo de apertura de cada cañón."
          paragraph2="En haciendas con cantera, el color se absorbe diferente que en paredes lisas. La cantera tiene textura y la luz resalta cada relieve. El resultado es más dramático que en un muro plano — pero requiere más cañones porque la textura absorbe más luz."
        />
        <Gallery4x4 images={[
          { src: "/img/city-color/city-color-fachada-hacienda-boda.avif", alt: "Fachada de hacienda bañada de color para boda" },
          { src: "/img/city-color/iluminacion-ceremonia-boda-hacienda.avif", alt: "Ceremonia de boda con iluminación city color en hacienda" },
          { src: "/img/city-color/iluminacion-salon-boda-rosa.avif", alt: "Salón de boda iluminado en rosa con city color" },
          { src: "/img/city-color/renta-city-color-boda-romantica.avif", alt: "City color romántico para boda" },
          { src: "/img/city-color/iluminacion-fachada-colonial-ambar.avif", alt: "Fachada colonial iluminada en ámbar" },
          { src: "/img/city-color/renta-city-color-xv-anos-rosa.avif", alt: "City color rosa para XV años" },
          { src: "/img/city-color/iluminacion-fiesta-corporativa-azul.avif", alt: "Fiesta corporativa iluminada en azul" },
          { src: "/img/city-color/renta-city-color-haciendas.avif", alt: "City color en hacienda para evento nocturno" },
          { src: "/img/city-color/iluminacion-rooftop-vista-nocturna.avif", alt: "Rooftop iluminado con city color vista nocturna" },
          { src: "/img/city-color/renta-city-color-primer-baile.avif", alt: "Primer baile con iluminación city color" },
          { src: "/img/city-color/iluminacion-fiesta-xv-magenta.avif", alt: "Fiesta de XV años con iluminación magenta" },
          { src: "/img/city-color/luces-boda-hacienda-mexicana.avif", alt: "Luces de color en hacienda mexicana para boda" },
          { src: "/img/city-color/renta-city-color-evento-nocturno.avif", alt: "Evento nocturno con cañones de color" },
          { src: "/img/city-color/iluminacion-profesional-jardines-eventos.avif", alt: "Iluminación profesional de jardines para eventos" },
          { src: "/img/city-color/renta-city-color-terraza-ciudad.avif", alt: "Terraza urbana iluminada con city color" },
          { src: "/img/city-color/luces-salon-quinceanos-morado.avif", alt: "Salón de quinceaños iluminado en morado" },
        ]} />
      </div>
    </section>

    <!-- Paquetes -->
    <section class="services-section services-alt" id="paquetes">
      <div class="container">
        <SectionHeader
          title="Paquetes de City Color"
          subtitle="4 opciones según la superficie a iluminar. Operador DMX incluido."
          paragraph1="Cada paquete incluye los cañones LED RGBW, tripies o soportes de piso, cableado DMX, operador técnico y desmontaje. El operador programa cambios de color para cada momento del evento — ceremonia, cena, fiesta, brindis."
          paragraph2="¿Tu venue necesita una configuración especial? Armamos propuestas a la medida. Cotiza por WhatsApp con fotos de tu espacio."
        />
        <PricingCards packages={[
          {
            name: "Básico — 4 Cañones",
            price: "$4,000",
            priceNote: "+ IVA",
            description: "Baño de color para una fachada frontal o un lateral del salón. El punto de partida para transformar tu venue.",
            features: [
              { text: "4 cañones LED RGBW de 180W", included: true },
              { text: "Cobertura hasta 80m² de superficie", included: true },
              { text: "Control DMX con operador", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Ideal para: fachada, un lateral del salón", included: true },
              { text: "Cambios de color programados", included: true },
              { text: "Múltiples zonas de color", included: false },
              { text: "IP65 para exteriores", included: true },
            ],
            ctaLabel: "Cotizar 4 cañones",
            ctaHref: "/servicios/city-color/paquete-4-canones/",
          },
          {
            name: "Estándar — 8 Cañones",
            price: "$7,000",
            priceNote: "+ IVA",
            badge: "Más popular",
            highlight: true,
            description: "Fachada completa + interior del salón. El más pedido para bodas en haciendas — transforma dentro y fuera.",
            features: [
              { text: "8 cañones LED RGBW de 180-360W", included: true },
              { text: "Cobertura hasta 200m² de superficie", included: true },
              { text: "2 zonas de color independientes", included: true },
              { text: "Operador DMX profesional", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Ideal para: bodas, haciendas, salones", included: true },
              { text: "Cambios sincronizados con momentos", included: true },
              { text: "IP65 para exteriores", included: true },
            ],
            ctaLabel: "Cotizar 8 cañones",
            ctaHref: "/servicios/city-color/paquete-8-canones/",
          },
          {
            name: "Premium — 16 Cañones",
            price: "$12,000",
            priceNote: "+ IVA",
            description: "Hacienda completa: fachada, jardín, salón, fuentes. Múltiples zonas con colores independientes.",
            features: [
              { text: "16 cañones LED RGBW de alta potencia", included: true },
              { text: "4+ zonas de color independientes", included: true },
              { text: "Fachada + jardín + salón + detalles", included: true },
              { text: "Operador DMX + asistente", included: true },
              { text: "Transporte + montaje + desmontaje", included: true },
              { text: "Diseño de color personalizado", included: true },
              { text: "Visita previa al venue", included: true },
              { text: "Ideal para: haciendas completas, fincas", included: true },
            ],
            ctaLabel: "Cotizar premium",
            ctaHref: "/servicios/city-color/paquete-16-canones/",
          },
          {
            name: "Producción — 24+ Cañones",
            price: "$18,000",
            priceNote: "+ IVA",
            description: "Producción completa para festivales, conciertos y eventos de gran escala. Escenarios, fachadas y estructuras.",
            features: [
              { text: "24+ cañones LED de alta potencia", included: true },
              { text: "Coreografía de color programada", included: true },
              { text: "Sincronización con audio/video", included: true },
              { text: "Equipo completo de operadores", included: true },
              { text: "Logística y generadores incluidos", included: true },
              { text: "Múltiples escenarios y zonas", included: true },
              { text: "Visita técnica previa", included: true },
              { text: "Ideal para: festivales, conciertos, TV", included: true },
            ],
            ctaLabel: "Cotizar producción",
            ctaHref: "/servicios/city-color/paquete-produccion/",
          },
        ]} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <SectionHeader
          title="Preguntas sobre City Color"
          subtitle="Todo lo que necesitas saber sobre los cañones de luz."
          paragraph1="Si tienes otra duda, escríbenos por WhatsApp y te asesoramos en minutos."
          paragraph2="Cada venue es diferente — te recomendamos la cantidad exacta de cañones según tu espacio."
        />
      </div>
      <FaqSection items={[
        { question: "¿Cuántos cañones necesito?", answer: "Para una fachada frontal de 10-15 metros: 4-6 cañones. Para fachada + jardín: 8-12. Para una hacienda completa con múltiples fachadas, jardines y fuentes: 16+. La cantidad depende del ancho de las superficies. Mándanos fotos del venue y te decimos el número exacto." },
        { question: "¿Se pueden cambiar los colores durante el evento?", answer: "Sí. El operador los controla vía DMX512 en tiempo real. Programa cambios para cada momento: rosa suave en el vals, dorado en la cena, multicolor en la fiesta. Los cambios pueden ser graduales (fade de 10 segundos) o instantáneos según el efecto que quieras." },
        { question: "¿Funcionan bajo lluvia?", answer: "Sí. Tienen certificación IP65 — resistentes a lluvia, humedad y polvo. Son equipo diseñado para exteriores. Hemos montado en bodas donde llovió toda la noche y los cañones siguieron operando sin problema." },
        { question: "¿Cuál es la diferencia con el uplighting?", answer: "Escala. El city color baña superficies grandes: fachadas de 15 metros, escenarios completos. El uplighting ilumina puntos específicos: una columna, un árbol. Se complementan bien — city color para las fachadas y uplighting para los detalles. Los controla el mismo operador." },
        { question: "¿Consumen mucha corriente?", answer: "No. Cada cañón LED consume 180W a 360W. Un paquete de 8 cañones consume en total lo que un horno de microondas. En venues con instalación eléctrica normal no hay problema. Para 24+ cañones o venues sin corriente, llevamos generador." },
        { question: "¿Se ve bien en paredes de color?", answer: "Depende del color de la pared. En paredes claras o blancas, el color del cañón se proyecta limpio. En paredes pintadas de color, el resultado es una mezcla. Pared roja + cañón azul = morado. Pared blanca + cañón azul = azul nítido. Para haciendas de cantera (beige/gris), funciona bien con casi cualquier color." },
      ]} />
    </section>

    <!-- Servicios relacionados -->
    <section class="services-section services-alt">
      <div class="container">
        <SectionHeader
          title="City color afuera + cascadas LED adentro"
          subtitle="La fachada bañada de color y el salón con backdrop brillante."
          paragraph1="La combinación más completa para haciendas: city color bañando la fachada de un color, uplighting en columnas y árboles del jardín, y adentro cascadas LED detrás de la mesa de novios. Los invitados ven color desde que llegan al estacionamiento hasta que se sientan a cenar."
          paragraph2="Con sky tracker se le suma un haz al cielo que marca el venue desde kilómetros. Es lo que usan los antros para que los veas desde la carretera — en una hacienda el efecto es más llamativo porque no hay otros haces compitiendo."
        />
        <div class="services-grid">
          {serviciosRelacionados.map((s) => (
            <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>¿Listo para bañar tu evento de color?</h2>
          <p>Mándanos fotos de tu venue por WhatsApp. Te decimos cuántos cañones necesitas, qué colores recomendamos y el precio exacto.</p>
          <div class="cta-buttons">
            <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
            <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
