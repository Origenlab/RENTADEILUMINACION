const title = "Renta de Iluminación en Azcapotzalco | Bodas y XV Años | REDEIL";
const description = "Renta de iluminación para bodas y XV años en Azcapotzalco. Guirnaldas, luces y sonido. Especialización en salones tradicionales. 350+ eventos/año. Cotiza: 55 3068 2988";
const canonical = "https://rentadeiluminacion.com/zonas/azcapotzalco/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Iluminación en Azcapotzalco",
    "serviceType": "Iluminación para Eventos",
    "areaServed": {
      "@type": "City",
      "name": "Azcapotzalco",
      "addressRegion": "CDMX"
    },
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "addressCountry": "MX"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "10:00",
          "closes": "14:00"
        }
      ]
    },
    "serviceArea": [
      {
        "@type": "Place",
        "name": "Azcapotzalco",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.4831, "longitude": -99.1444}
      },
      {
        "@type": "Place",
        "name": "Álvaro Obregón",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.3960, "longitude": -99.1997}
      },
      {
        "@type": "Place",
        "name": "Gustavo A. Madero",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.4850, "longitude": -99.0750}
      }
    ],
    "description": "Renta de iluminación profesional para bodas, XV años y eventos en Azcapotzalco. Especialización en salones tradicionales, bodas masivas y eventos corporativos. Transporte e instalación incluidos.",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuál es la cobertura de REDEIL en Azcapotzalco?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cubrimos todo Azcapotzalco, norte de CDMX y zonas aledañas. Salones, patios, jardines y espacios industriales adaptados. Transporte incluido en toda la zona."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto cuesta iluminar una boda en Azcapotzalco?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Una boda básica con guirnaldas arranca desde $6,500. XV años con iluminación completa $12,000+. Bodas masivas con múltiples servicios, $20,000+. Cotiza con detalles de tu evento."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuál es el tiempo de instalación en salones de Azcapotzalco?",
