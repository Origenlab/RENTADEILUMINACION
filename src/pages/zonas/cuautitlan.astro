const canonical = "https://rentadeiluminacion.com/zonas/cuautitlan/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Iluminación en Cuautitlán Izcalli",
    "serviceType": "Iluminación para Eventos",
    "areaServed": {
      "@type": "City",
      "name": "Cuautitlán Izcalli",
      "addressRegion": "Estado de México"
    },
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "addressCountry": "MX"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "10:00",
          "closes": "14:00"
        }
      ]
    },
    "serviceArea": [
      {
        "@type": "Place",
        "name": "Cuautitlán Izcalli",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.6477, "longitude": -99.2117}
      },
      {
        "@type": "Place",
        "name": "Centro Cuautitlán",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.6725, "longitude": -99.1775}
      },
      {
        "@type": "Place",
        "name": "Arboledas",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.6390, "longitude": -99.2250}
      }
    ],
    "description": "Renta de iluminación profesional para XV años, bodas y fiestas familiares en Cuautitlán Izcalli, Centro Cuautitlán, Arboledas y Los Reyes Izcalli. Especialización en salones y jardines de zona metropolitana norte. Transporte e instalación incluidos.",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuál es la cobertura de REDEIL en Cuautitlán Izcalli?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cubrimos todo Cuautitlán Izcalli, Centro Cuautitlán, Arboledas, Los Reyes Izcalli y alrededores. Salones, jardines, terrazas. Transporte incluido en toda la zona."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto cuesta iluminar unos XV años en Cuautitlán Izcalli?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Unos XV años básicos con guirnaldas arrancan desde $5,500. Paquetes completos con luces neón, bocinas y DJ lighting, $15,000+. Cotiza por WhatsApp con detalles de tu evento."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuál es el tiempo de instalación?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nuestro equipo en Cuautitlán Izcalli tarda 2-3 horas en montar un evento estándar. Llegamos 4 horas antes, con tiempo de sobra."
