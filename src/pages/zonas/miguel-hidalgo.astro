        }
      },
      {
        "@type": "Question",
        "name": "¿Cuál es el tiempo de instalación?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nuestro equipo en Miguel Hidalgo tarda 2-3 horas. Llegamos 4-5 horas antes para coordinación y ajustes detallados."
        }
