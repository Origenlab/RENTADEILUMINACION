        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "10:00",
          "closes": "14:00"
        }
      ]
    },
    "serviceArea": [
      {
        "@type": "Place",
        "name": "Miguel Hidalgo",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.4000, "longitude": -99.1864}
      },
      {
        "@type": "Place",
        "name": "Lomas",
