---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Iluminación en Magdalena Contreras | Bodas Íntimas | REDEIL";
const description = "Renta de iluminación para bodas íntimas en Magdalena Contreras. Jardines con vista, áreas boscosas. Especialización en eventos elegantes. 350+ eventos/año. Cotiza: 55 3068 2988";
const canonical = "https://rentadeiluminacion.com/zonas/magdalena-contreras/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Iluminación en Magdalena Contreras",
    "serviceType": "Iluminación para Eventos",
    "areaServed": {
      "@type": "City",
      "name": "Magdalena Contreras",
      "addressRegion": "CDMX"
    },
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "addressCountry": "MX"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "10:00",
          "closes": "14:00"
        }
      ]
    },
    "serviceArea": [
      {
        "@type": "Place",
        "name": "Magdalena Contreras",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.2957, "longitude": -99.2254}
      },
      {
        "@type": "Place",
        "name": "Cuajimalpa",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.3576, "longitude": -99.2890}
      },
      {
        "@type": "Place",
        "name": "Álvaro Obregón",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.3960, "longitude": -99.1997}
      }
    ],
    "description": "Renta de iluminación profesional para bodas íntimas en Magdalena Contreras. Especialización en jardines con vista, áreas boscosas y eventos elegantes. Transporte e instalación incluidos.",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuál es la cobertura de REDEIL en Magdalena Contreras?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cubrimos todo Magdalena Contreras, zonas boscosas, jardines privados y haciendas. Transporte incluido en toda la zona sur-poniente."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué tipo de eventos son más comunes en Magdalena Contreras?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bodas íntimas, ceremonias al aire libre, eventos elegantes. Los jardines con vista de Magdalena Contreras son perfectos para iluminación sutil pero impactante."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo adaptan la iluminación a jardines con vista?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Trabajamos con uplighting sutil, guirnaldas que no compitan con la vista natural, proyecciones sutiles. La iluminación resalta, no oculta."
        }
      },
      {
        "@type": "Question",
        "name": "¿Es complicado montar en áreas boscosas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Nuestro equipo tiene experiencia montando en terrenos irregulares, arboles, pendientes. Sabemos cómo adaptar instalaciones sin dañar naturaleza."
        }
      },
      {
        "@type": "Question",
