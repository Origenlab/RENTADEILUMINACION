---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Iluminación en Huixquilucan | Bodas Premium e Interlomas | REDEIL";
const description = "Renta de iluminación para bodas y eventos premium en Huixquilucan, Interlomas, La Herradura y Bosque Real. Guirnaldas, luces y sonido. Cotiza: 55 3068 2988";
const canonical = "https://rentadeiluminacion.com/zonas/huixquilucan/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Iluminación en Huixquilucan",
    "serviceType": "Iluminación para Eventos",
    "areaServed": {
      "@type": "City",
      "name": "Huixquilucan",
      "addressRegion": "Estado de México"
    },
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "addressCountry": "MX"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "10:00",
          "closes": "14:00"
        }
      ]
    },
    "serviceArea": [
      {
        "@type": "Place",
        "name": "Huixquilucan",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.3625, "longitude": -99.3481}
      },
      {
        "@type": "Place",
        "name": "Interlomas",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.3945, "longitude": -99.2876}
      },
      {
        "@type": "Place",
        "name": "La Herradura",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.3890, "longitude": -99.2654}
      }
    ],
    "description": "Renta de iluminación profesional para bodas, eventos premium y celebraciones en Huixquilucan, Interlomas, La Herradura y Bosque Real. Especialización en residencias y salones de alto nivel. Transporte e instalación incluidos.",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuál es la cobertura de REDEIL en Huixquilucan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cubrimos todo Huixquilucan, Interlomas, La Herradura, Bosque Real y alrededores. Residencias privadas, salones de eventos, jardines exclusivos. Transporte incluido en toda la zona."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto cuesta iluminar una boda en Huixquilucan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Una boda básica con guirnaldas arranca desde $7,500. Bodas premium completas con múltiples servicios, $25,000+. Cotiza por WhatsApp con detalles de tu evento."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuál es el tiempo de instalación?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nuestro equipo en Huixquilucan tarda 2-3 horas en montar un evento estándar. Llegamos 4 horas antes, con tiempo de sobra."
        }
      },
      {
        "@type": "Question",
        "name": "¿Pueden montar iluminación en residencias privadas de Bosque Real?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí. Tenemos amplia experiencia en residencias privadas de Bosque Real, Interlomas y La Herradura. Conocemos los protocolos de acceso de cada fraccionamiento y coordinamos con seguridad."
        }
      }
    ]
  }
]);

const serviciosRelacionados = [
  {
    title: "Guirnaldas de Focos Edison",
    image: "/img/guirnaldas/guirnaldas-edison-hacienda-boda.avif",
    alt: "Guirnaldas Edison iluminando hacienda para boda",
    description: "Focos LED o vintage, cableado IP65, resistentes a lluvia. La base del ambiente en cualquier boda en Huixquilucan.",
    link: "/servicios/guirnaldas/"
  },
  {
    title: "Luces Neon Personalizadas",
    image: "/img/luces-neon/luces-neon-nombres-boda.avif",
    alt: "Luces neon personalizadas para boda",
    description: "Nombres de los novios, iniciales, frases. Luces neón de colores ámbar, rosa, azul, blanco. Perfecto para bodas premium.",
    link: "/servicios/luces-neon/"
  },
  {
    title: "Cabezas Móviles — Sky Tracker",
    image: "/img/cabezas-moviles/cabezas-moviles-boda.avif",
    alt: "Cabezas móviles iluminando pista de baile",
    description: "Proyecciones animadas, colores sincronizados, efectos especiales. El efecto de escenario profesional para bodas de alto nivel.",
    link: "/servicios/cabezas-moviles/"
  },
  {
    title: "Bocinas y DJ Lighting",
    image: "/img/bocinas/bocinas-sistema-profesional.avif",
    alt: "Sistema de sonido profesional para evento",
    description: "Sonido profesional + luces que reaccionan a la música. Sistema completo de sonido e iluminación.",
    link: "/servicios/bocinas-djs/"
  }
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[
      { label: "Inicio", href: "/" },
      { label: "Zonas de Cobertura", href: "/zonas-de-cobertura/" },
      { label: "Huixquilucan" }
    ]} />
  </Fragment>

  <Hero
    title="Renta de Iluminación en Huixquilucan"
    subtitle="Bodas y eventos premium en Interlomas, La Herradura y Bosque Real. Más de 150 eventos iluminados en la zona. Transporte e instalación incluidos."
    whatsappText="Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20evento%20en%20Huixquilucan"
    introParagraph1='Huixquilucan es sinónimo de exclusividad. Residencias en Bosque Real, jardines privados en La Herradura, salones premium en Interlomas — los eventos aquí exigen iluminación a la altura. <strong>REDEIL lleva más de 20 años iluminando eventos en Huixquilucan</strong>. Bodas en jardines con vista panorámica, recepciones en residencias de Bosque Real, celebraciones en los mejores salones de Interlomas. Conocemos cada fraccionamiento, cada salón, cada jardín exclusivo. 150+ eventos al año en la zona. Es experiencia + equipo premium + conocimiento del terreno.'
    introParagraph2='Somos los que montamos las guirnaldas en los jardines de las residencias más exclusivas. Los que iluminan bodas de revista en La Herradura. Los que transforman terrazas de Interlomas en escenarios de ensueño. ¿Venues frecuentes? Salones en Interlomas, residencias en Bosque Real, jardines en La Herradura, terrazas panorámicas en zona residencial. Cada espacio requiere estrategia diferente. El equipo llega 4 horas antes. Monta en 2-3 horas. Todo probado antes de que lleguen los invitados. Precio transparente: sin cargos ocultos.'
  />

  <!-- Stats -->
  <section class="stats-section-enhanced">
    <div class="container">
      <div class="stats-grid-enhanced">
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">20+</span>
          <span class="stat-label-enhanced">Años en Huixquilucan</span>
        </div>
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">150+</span>
          <span class="stat-label-enhanced">Eventos/Año</span>
        </div>
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">2h</span>
          <span class="stat-label-enhanced">Instalación Rápida</span>
        </div>
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">100%</span>
          <span class="stat-label-enhanced">Cobertura Zona</span>
        </div>
      </div>
    </div>
  </section>


  <!-- Por qué nosotros en Huixquilucan -->
  <section class="services-section">
    <div class="container">
      <SectionHeader
        title="Por qué Nosotros en Huixquilucan"
        subtitle="4 razones por las que REDEIL es el proveedor de iluminación premium en Huixquilucan."
        paragraph1="Los eventos en Huixquilucan exigen un nivel superior. Residencias con jardines amplios, techos altos, acabados de lujo. La iluminación tiene que estar a la altura — y eso es exactamente lo que hacemos. Guirnaldas perfectamente distribuidas, uplighting en tonos cálidos, neón con los nombres de los novios."
        paragraph2="Conocemos los protocolos de acceso de cada fraccionamiento. Coordinamos con seguridad, administración y personal de las residencias. Cero complicaciones logísticas para ti."
      />
      <div class="features-grid-4">
        <div class="feature-card">
          <h3>Nivel Premium</h3>
          <p>Iluminación de alta gama para eventos que exigen excelencia. Equipo profesional, acabados impecables, atención al detalle.</p>
        </div>
        <div class="feature-card">
          <h3>Instalación en 2 Horas</h3>
          <p>Logística propia, equipo entrenado. Montaje discreto y eficiente en residencias privadas y salones exclusivos.</p>
        </div>
        <div class="feature-card">
          <h3>Experiencia en Residencias</h3>
          <p>Bosque Real, La Herradura, Interlomas. Conocemos los protocolos de acceso y los espacios de cada fraccionamiento.</p>
        </div>
        <div class="feature-card">
          <h3>Bodas de Ensueño</h3>
          <p>Guirnaldas + uplighting + neón + cabezas móviles. Transformamos cualquier jardín o terraza en un escenario de revista.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios Principales -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Servicios Principales"
        subtitle="Las 4 soluciones de iluminación más solicitadas en Huixquilucan."
        paragraph1="Cada servicio se adapta a tu evento. Si necesitas combinar varios servicios, el precio baja porque compartimos traslado y operador."
        paragraph2="Cotiza por WhatsApp con fotos de tu venue. Respuesta en minutos."
      />
      <div class="services-grid">
        {serviciosRelacionados.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre Iluminación en Huixquilucan"
        subtitle="Lo que todos preguntan antes de cotizar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respuesta en minutos."
        paragraph2="Cada espacio es diferente — por eso hacemos propuestas a la medida."
      />
    </div>
    <FaqSection items={[
      {
        question: "¿Cuál es la cobertura de REDEIL en Huixquilucan?",
        answer: "Cubrimos todo Huixquilucan, Interlomas, La Herradura, Bosque Real y alrededores. Residencias privadas, salones de eventos, jardines exclusivos. Transporte incluido en toda la zona."
      },
      {
        question: "¿Cuánto cuesta iluminar una boda en Huixquilucan?",
        answer: "Una boda básica con guirnaldas arranca desde $7,500. Bodas premium completas con múltiples servicios, $25,000+. Cotiza por WhatsApp con detalles de tu evento."
      },
      {
        question: "¿Cuál es el tiempo de instalación?",
        answer: "Nuestro equipo en Huixquilucan tarda 2-3 horas en montar un evento estándar. Llegamos 4 horas antes, con tiempo de sobra."
      },
      {
        question: "¿Pueden montar iluminación en residencias privadas de Bosque Real?",
        answer: "Sí. Tenemos amplia experiencia en residencias privadas de Bosque Real, Interlomas y La Herradura. Conocemos los protocolos de acceso de cada fraccionamiento y coordinamos con seguridad previamente."
      },
      {
        question: "¿Manejan iluminación para bodas al aire libre en jardines?",
        answer: "Es nuestra especialidad en Huixquilucan. Jardines amplios con guirnaldas Edison cruzadas, uplighting en árboles, neón personalizado. Todo IP65, resistente a lluvia y humedad."
      },
      {
        question: "¿Ofrecen paquetes para bodas completas?",
        answer: "Sí. Guirnaldas + luces neón + cabezas móviles + bocinas. Paquetes integrados con descuento por combinar servicios. Mándanos fotos de tu venue y te hacemos propuesta personalizada."
      },
      {
        question: "¿Qué incluye el servicio de transporte e instalación?",
        answer: "Todo. Traslado de equipo, montaje profesional, pruebas, operación durante el evento, desmontaje al finalizar. Coordinación con seguridad del fraccionamiento incluida. Cero cargos ocultos."
      },
      {
        question: "¿Con cuánta anticipación debo reservar?",
        answer: "Idealmente 4-6 semanas. Huixquilucan es zona de bodas premium y los fines de semana se llenan rápido, especialmente en temporada alta (octubre-enero, mayo-junio)."
      }
    ]} />
  </section>

  <!-- CTA Final -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para iluminar tu evento en Huixquilucan?</h2>
        <p>Mándanos fotos de tu venue por WhatsApp y te cotizamos en minutos. Transporte, instalación y montaje incluidos.</p>
        <div class="cta-buttons">
          <a href="https://wa.me/525530682988?text=Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20evento%20en%20Huixquilucan" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
