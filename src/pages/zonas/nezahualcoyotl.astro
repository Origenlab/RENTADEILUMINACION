    "@type": "Service",
    "name": "Renta de Iluminación en Nezahualcóyotl",
    "serviceType": "Iluminación para Eventos",
    "areaServed": {
      "@type": "City",
      "name": "Nezahualcóyotl",
      "addressRegion": "Estado de México"
    },
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
