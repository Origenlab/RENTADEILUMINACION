const serviciosRelacionados = [
  {
    title: "Guirnaldas de Focos Edison",
    image: "/img/guirnaldas/guirnaldas-edison-hacienda-boda.avif",
    alt: "Guirnaldas Edison iluminando hacienda para boda",
    description: "Focos LED o vintage, cableado IP65, resistentes a lluvia. La base del ambiente en cualquier boda.",
    link: "/servicios/guirnaldas/"
  },
  {
    title: "Luces Neon Personalizadas",
    image: "/img/luces-neon/luces-neon-nombres-boda.avif",
    alt: "Luces neon personalizadas para boda",
    description: "Nombres de los novios, iniciales, frases. Luces neón de colores ámbar, rosa, azul, blanco. Perfecto para XV años.",
    link: "/servicios/luces-neon/"
  },
  {
    title: "Cabezas Móviles — Sky Tracker",
    image: "/img/cabezas-moviles/cabezas-moviles-boda.avif",
    alt: "Cabezas móviles iluminando pista de baile",
    description: "Proyecciones animadas, colores sincronizados, efectos especiales. El efecto de escenario profesional.",
    link: "/servicios/cabezas-moviles/"
  },
  {
    title: "Bocinas y DJ Lighting",
    image: "/img/bocinas/bocinas-sistema-profesional.avif",
    alt: "Sistema de sonido profesional para evento",
    description: "Sonido profesional + luces que reaccionan a la música. Sistema completo de sonido e iluminación.",
    link: "/servicios/bocinas-djs/"
  }
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[
      { label: "Inicio", href: "/" },
      { label: "Zonas de Cobertura", href: "/zonas-de-cobertura/" },
      { label: "Nezahualcóyotl" }
    ]} />
  </Fragment>

  <Hero
    title="Renta de Iluminación en Nezahualcóyotl"
    subtitle="XV años, bodas y eventos amplios en Ciudad Neza. Salones de escala, eventos masivos. Transporte e instalación incluidos."
    whatsappText="Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20evento%20en%20Nezahualcoyotl"
    introParagraph1='Nezahualcóyotl es Ciudad Neza — eventos de escala, XV años legendarios, bodas masivas que requieren logística profesional. <strong>REDEIL lleva 30 años iluminando eventos en Nezahualcóyotl</strong>. Sabemos cómo coordinar logística en eventos de 200+ invitados, cómo iluminar salones amplios con impacto. Luces que funcionan en espacios grandes, en cualquier tipo de instalación. 340+ eventos al año en Neza.'
    introParagraph2='Los XV años de Nezahualcóyotl son XV años de presencia — 150+ invitados, familias extendidas, eventos que requieren iluminación de categoría. Guirnaldas en techo alto, luces neón personalizadas, uplighting coordinado, DJ lighting sincronizado. Bodas amplias, despedidas de soltero masivas — equipo que lleva 30 años en la zona. Llegamos 4 horas antes, montamos en 2-3 horas, se adapta a cambios. Precio transparente: no cobramos cargos ocultos.'
  />

  <!-- Stats -->
  <section class="stats-section-enhanced">
    <div class="container">
      <div class="stats-grid-enhanced">
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">30+</span>
          <span class="stat-label-enhanced">Años en Nezahualcóyotl</span>
        </div>
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">340+</span>
          <span class="stat-label-enhanced">Eventos/Año</span>
        </div>
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">2h</span>
          <span class="stat-label-enhanced">Instalación Rápida</span>
        </div>
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">100%</span>
          <span class="stat-label-enhanced">Cobertura Zona</span>
        </div>
      </div>
    </div>
  </section>


  <!-- Por qué nosotros en Nezahualcóyotl -->
  <section class="services-section">
    <div class="container">
      <SectionHeader
        title="Por qué Nosotros en Nezahualcóyotl"
        subtitle="4 razones por las que REDEIL es el proveedor de iluminación en Nezahualcóyotl."
        paragraph1="El 75% de nuestros eventos en Neza son XV años masivos. Sabemos exactamente qué iluminación transforma un salón en fiesta legendaria. Guirnaldas en techo alto, luces neón visibles a distancia, uplighting en colores coordinados. Cada detalle cuenta en eventos de escala."
        paragraph2="Logística propia, equipo para eventos grandes. Colocamos guirnaldas en techos altos, coordinamos sistemas amplios, trabajamos sin drama. Eso te deja tranquilo — tu evento funciona como está planeado."
      />
      <div class="features-grid-4">
        <div class="feature-card">
          <h3>XV Años Legendarios</h3>
          <p>75% de nuestros eventos son XV años de escala. Sabemos la logística de eventos grandes.</p>
        </div>
        <div class="feature-card">
          <h3>Logística Amplia</h3>
          <p>Equipo para eventos de 200+ invitados. Montaje en espacios grandes, coordinación profesional.</p>
        </div>
        <div class="feature-card">
          <h3>Salones Conocidos</h3>
          <p>30 años en Nezahualcóyotl. Conocemos los principales salones de Ciudad Neza.</p>
        </div>
        <div class="feature-card">
          <h3>Escalabilidad Garantizada</h3>
          <p>Iluminación que funciona en cualquier tamaño de espacio. Sistema flexible, profesional.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios Principales -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Servicios Principales"
        subtitle="Las 4 soluciones de iluminación más solicitadas en Nezahualcóyotl."
        paragraph1="Cada servicio se adapta a tu evento. Si necesitas combinar varios servicios, el precio baja porque compartimos traslado y operador."
        paragraph2="Cotiza por WhatsApp con fotos de tu venue. Respuesta en minutos."
      />
      <div class="services-grid">
        {serviciosRelacionados.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre Iluminación en Nezahualcóyotl"
        subtitle="Lo que todos preguntan antes de cotizar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respuesta en minutos."
        paragraph2="Cada espacio es diferente — por eso hacemos propuestas a la medida."
      />
    </div>
    <FaqSection items={[
      {
        question: "¿Cuál es la cobertura de REDEIL en Nezahualcóyotl?",
        answer: "Cubrimos Nezahualcóyotl, Ciudad Neza y alrededores. Salones, patios, espacios de zona oriente Edomex. Transporte incluido."
      },
      {
        question: "¿Cuánto cuesta iluminar una boda en Nezahualcóyotl?",
        answer: "Una boda básica con guirnaldas arranca desde $6,500. Bodas amplias con múltiples servicios, $15,000+. Cotiza por WhatsApp."
      },
      {
        question: "¿Cuál es el tiempo de instalación?",
        answer: "Nuestro equipo en Nezahualcóyotl tarda 2-3 horas. Llegamos 4 horas antes, con tiempo de sobra para preparación."
      },
      {
        question: "¿Conocen los salones de Nezahualcóyotl?",
        answer: "Sí. Conocemos los principales salones de Ciudad Neza. Experiencia en eventos de 200+ invitados con logística completa."
      },
      {
        question: "¿Cómo funcionan las guirnaldas en techos altos?",
        answer: "Especialización en techos altos. Sistemas de cableado seguro, instalación profesional, efectos visibles a distancia."
      },
      {
        question: "¿Puedo solicitar iluminación específica para mi XV años?",
        answer: "Sí. Personalización total. Mándanos foto del salón y te hacemos propuesta en 24 horas."
      },
      {
        question: "¿Qué incluye el servicio de transporte e instalación?",
        answer: "Todo. Traslado de equipo, montaje profesional, pruebas, operación durante el evento, desmontaje. Cero cargos ocultos."
      },
      {
        question: "¿Con cuánta anticipación debo reservar?",
        answer: "Idealmente 2-3 semanas. Neza en temporada alta (mayo-julio, noviembre-enero) se llena rápido. Entre antes reserves, mejor."
      }
    ]} />
  </section>

  <!-- CTA Final -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para iluminar tu evento en Nezahualcóyotl?</h2>
        <p>Mándanos fotos de tu venue por WhatsApp y te cotizamos en minutos. Transporte, instalación y montaje incluidos.</p>
        <div class="cta-buttons">
          <a href="https://wa.me/525530682988?text=Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20evento%20en%20Nezahualcoyotl" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
