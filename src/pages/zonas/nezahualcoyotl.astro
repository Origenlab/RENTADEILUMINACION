      "telephone": "+525530682988",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "addressCountry": "MX"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "10:00",
          "closes": "14:00"
        }
      ]
    },
    "serviceArea": [
      {
        "@type": "Place",
        "name": "Nezahualcóyotl",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.4014, "longitude": -98.9979}
      },
      {
        "@type": "Place",
        "name": "Ciudad Neza",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.4014, "longitude": -98.9979}
      },
      {
        "@type": "Place",
        "name": "Área Metropolitana",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.4014, "longitude": -98.9979}
      }
    ],
    "description": "Renta de iluminación profesional en Nezahualcóyotl, Edomex. Especialización en salones amplios, XV años y bodas masivas. Transporte e instalación incluidos.",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuál es la cobertura de REDEIL en Nezahualcóyotl?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cubrimos Nezahualcóyotl, Ciudad Neza y alrededores. Salones amplios, patios, espacios de zona oriente Edomex. Transporte incluido."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto cuesta iluminar una boda en Nezahualcóyotl?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Una boda básica con guirnaldas arranca desde $6,500. Bodas amplias con múltiples servicios, $15,000+. Cotiza por WhatsApp."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuál es el tiempo de instalación?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nuestro equipo en Nezahualcóyotl tarda 2-3 horas. Llegamos 4 horas antes, con tiempo de sobra para preparación."
        }
      },
      {
        "@type": "Question",
        "name": "¿Conocen los salones de Nezahualcóyotl?",
