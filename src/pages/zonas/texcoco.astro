---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery4x4 from '../../components/Gallery4x4.astro';
import FaqSection from '../../components/FaqSection.astro';

const title = "Renta de Iluminación en Texcoco | Bodas Rústicas y Haciendas | REDEIL";
const description = "Renta de iluminación para bodas rústicas en haciendas y jardines de Texcoco. Guirnaldas, luces y sonido. Instalación en 2h. 150+ eventos/año. Cotiza: 55 3068 2988";
const canonical = "https://rentadeiluminacion.com/zonas/texcoco/";

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Iluminación en Texcoco",
    "serviceType": "Iluminación para Eventos",
    "areaServed": {
      "@type": "City",
      "name": "Texcoco",
      "addressRegion": "Estado de México"
    },
    "provider": {
      "@type": "LocalBusiness",
      "name": "REDEIL",
      "url": "https://rentadeiluminacion.com",
      "telephone": "+525530682988",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "addressCountry": "MX"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "10:00",
          "closes": "14:00"
        }
      ]
    },
    "serviceArea": [
      {
        "@type": "Place",
        "name": "Texcoco",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.5097, "longitude": -98.8825}
      },
      {
        "@type": "Place",
        "name": "San Miguel Chapultepec",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.5150, "longitude": -98.8900}
      },
      {
        "@type": "Place",
        "name": "Molino de Flores",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.4870, "longitude": -98.8490}
      }
    ],
    "description": "Renta de iluminación profesional para bodas rústicas, XV años y eventos en Texcoco, San Miguel Chapultepec, Molino de Flores y zona universitaria UACh. Especialización en haciendas y jardines campestres. Transporte e instalación incluidos.",
    "priceRange": "$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuál es la cobertura de REDEIL en Texcoco?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cubrimos todo Texcoco, San Miguel Chapultepec, Molino de Flores, zona universitaria UACh y alrededores. Haciendas, jardines campestres, salones. Transporte incluido en toda la zona."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto cuesta iluminar una boda rústica en Texcoco?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Una boda rústica con guirnaldas arranca desde $6,000. Bodas completas en hacienda con múltiples servicios, $16,000+. Cotiza por WhatsApp con detalles de tu evento."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuál es el tiempo de instalación?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nuestro equipo en Texcoco tarda 2-3 horas en montar un evento estándar. Llegamos 4 horas antes, con tiempo de sobra para haciendas y jardines grandes."
        }
      },
      {
        "@type": "Question",
        "name": "¿Iluminan la Ex Hacienda Molino de Flores?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí. La Ex Hacienda Molino de Flores es uno de nuestros venues favoritos. Conocemos cada rincón, cada arco, cada patio. Sabemos exactamente dónde colocar guirnaldas para lograr el efecto rústico perfecto."
        }
      }
    ]
  }
]);

const serviciosRelacionados = [
  {
    title: "Guirnaldas de Focos Edison",
    image: "/img/guirnaldas/guirnaldas-edison-hacienda-boda.avif",
    alt: "Guirnaldas Edison iluminando hacienda rústica para boda",
    description: "Focos LED o vintage, cableado IP65, resistentes a lluvia. El complemento perfecto para bodas rústicas en haciendas de Texcoco.",
    link: "/servicios/guirnaldas/"
  },
  {
    title: "Luces Neon Personalizadas",
    image: "/img/luces-neon/luces-neon-nombres-boda.avif",
    alt: "Luces neon personalizadas para boda rústica",
    description: "Nombres de los novios, iniciales, frases. Luces neón que contrastan perfecto con la arquitectura colonial de las haciendas.",
    link: "/servicios/luces-neon/"
  },
  {
    title: "Cabezas Móviles — Sky Tracker",
    image: "/img/cabezas-moviles/cabezas-moviles-boda.avif",
    alt: "Cabezas móviles iluminando pista de baile",
    description: "Proyecciones animadas, colores sincronizados, efectos especiales. El efecto de escenario profesional.",
    link: "/servicios/cabezas-moviles/"
  },
  {
    title: "Bocinas y DJ Lighting",
    image: "/img/bocinas/bocinas-sistema-profesional.avif",
    alt: "Sistema de sonido profesional para evento",
    description: "Sonido profesional + luces que reaccionan a la música. Sistema completo de sonido e iluminación.",
    link: "/servicios/bocinas-djs/"
  }
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[
      { label: "Inicio", href: "/" },
      { label: "Zonas de Cobertura", href: "/zonas-de-cobertura/" },
      { label: "Texcoco" }
    ]} />
  </Fragment>

  <Hero
    title="Renta de Iluminación en Texcoco"
    subtitle="Especialización en bodas rústicas en haciendas y jardines campestres. Más de 150 eventos iluminados en la zona. Transporte e instalación incluidos."
    whatsappText="Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20evento%20en%20Texcoco"
    introParagraph1='Texcoco es el destino de bodas rústicas por excelencia en el oriente del Estado de México. Haciendas coloniales con arcos de piedra, jardines campestres con vistas a la sierra, ex haciendas reconvertidas en venues de ensueño — los espacios que merecen iluminación profesional. <strong>REDEIL lleva más de 15 años iluminando eventos en Texcoco</strong>. Bodas en la Ex Hacienda Molino de Flores, recepciones en jardines de San Miguel Chapultepec, fiestas en salones camino a Texcoco, eventos en zona universitaria UACh. Conocemos cada venue, cada hacienda, cada jardín. 150+ eventos al año en la zona. No es suerte — es conocimiento del terreno + equipo propio + experiencia.'
    introParagraph2='Somos los que montamos las guirnaldas sobre los arcos de piedra de las haciendas. Los que iluminan la primera danza en el jardín campestre. Los que proyectan el monograma de los novios sobre los muros coloniales. ¿Cuáles son los venues que más montamos? Ex Hacienda Molino de Flores, jardines en zona rural, salones camino a Texcoco, espacios cerca de la UACh. Cada uno requiere estrategia diferente. El equipo llega 4 horas antes. Monta en 2-3 horas. Todo probado antes de que lleguen los invitados. Precio transparente: no cobramos cargos ocultos.'
  />

  <!-- Stats -->
  <section class="stats-section-enhanced">
    <div class="container">
      <div class="stats-grid-enhanced">
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">15+</span>
          <span class="stat-label-enhanced">Años en Texcoco</span>
        </div>
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">150+</span>
          <span class="stat-label-enhanced">Eventos/Año</span>
        </div>
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">2h</span>
          <span class="stat-label-enhanced">Instalación Rápida</span>
        </div>
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">100%</span>
          <span class="stat-label-enhanced">Cobertura Zona</span>
        </div>
      </div>
    </div>
  </section>


  <!-- Por qué nosotros en Texcoco -->
  <section class="services-section">
    <div class="container">
      <SectionHeader
        title="Por qué Nosotros en Texcoco"
        subtitle="4 razones por las que REDEIL es el proveedor de iluminación en Texcoco."
        paragraph1="Más del 70% de nuestros montajes en Texcoco son bodas rústicas en haciendas y jardines campestres. Sabemos qué iluminación potencia la arquitectura colonial y el ambiente natural. Guirnaldas entre arcos de piedra, gobo con monograma en muros coloniales, uplighting que resalta la vegetación. Cada detalle cuenta."
        paragraph2="Logística propia con ruta directa desde CDMX. Colocamos guirnaldas, uplighting, efectos especiales en tiempo récord. Eso te deja tranquilo — no hay estrés de última hora. Haciendas, jardines rurales, salones campestres. Sabemos dónde van los postes, cómo distribuir guirnaldas sin dañar estructuras históricas."
      />
      <div class="features-grid-4">
        <div class="feature-card">
          <h3>Especialización en Bodas Rústicas</h3>
          <p>Más del 70% de nuestros montajes son bodas rústicas. Sabemos cómo la iluminación potencia haciendas y jardines campestres.</p>
        </div>
        <div class="feature-card">
          <h3>Instalación en 2 Horas</h3>
          <p>Logística propia, equipo entrenado. Montaje ágil que te deja tranquilo. No hay estrés de última hora.</p>
        </div>
        <div class="feature-card">
          <h3>Conocimiento de Haciendas</h3>
          <p>Conocemos cada hacienda, cada arco de piedra, cada jardín campestre. Sabemos cómo iluminar sin dañar arquitectura histórica.</p>
        </div>
        <div class="feature-card">
          <h3>Ambiente Campestre Completo</h3>
          <p>Guirnaldas cálidas + uplighting + luces neón. Creamos la atmósfera rústica perfecta que complementa el entorno natural de Texcoco.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios Principales -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Servicios Principales"
        subtitle="Las 4 soluciones de iluminación más solicitadas en Texcoco."
        paragraph1="Cada servicio se adapta a tu evento. Si necesitas combinar varios servicios, el precio baja porque compartimos traslado y operador."
        paragraph2="Cotiza por WhatsApp con fotos de tu venue. Respuesta en minutos."
      />
      <div class="services-grid">
        {serviciosRelacionados.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre Iluminación en Texcoco"
        subtitle="Lo que todos preguntan antes de cotizar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respuesta en minutos."
        paragraph2="Cada espacio es diferente — por eso hacemos propuestas a la medida."
      />
    </div>
    <FaqSection items={[
      {
        question: "¿Cuál es la cobertura de REDEIL en Texcoco?",
        answer: "Cubrimos todo Texcoco, San Miguel Chapultepec, Molino de Flores, zona universitaria UACh y alrededores. Haciendas, jardines campestres, salones. Transporte incluido en toda la zona."
      },
      {
        question: "¿Cuánto cuesta iluminar una boda rústica en Texcoco?",
        answer: "Una boda rústica con guirnaldas arranca desde $6,000. Bodas completas en hacienda con múltiples servicios, $16,000+. Cotiza por WhatsApp con detalles de tu evento."
      },
      {
        question: "¿Cuál es el tiempo de instalación?",
        answer: "Nuestro equipo en Texcoco tarda 2-3 horas en montar un evento estándar. Llegamos 4 horas antes, con tiempo de sobra para haciendas y jardines grandes."
      },
      {
        question: "¿Iluminan la Ex Hacienda Molino de Flores?",
        answer: "Sí. La Ex Hacienda Molino de Flores es uno de nuestros venues favoritos. Conocemos cada rincón, cada arco, cada patio. Sabemos exactamente dónde colocar guirnaldas para lograr el efecto rústico perfecto."
      },
      {
        question: "¿Cómo funcionan las guirnaldas en jardines al aire libre?",
        answer: "IP65 certificado. Lluvia directa, humedad, cambios de temperatura. Todo resistido. Nuestras guirnaldas están diseñadas para funcionar en los jardines campestres de Texcoco, incluso en temporada de lluvias."
      },
      {
        question: "¿Pueden iluminar eventos en la zona universitaria UACh?",
        answer: "Sí. Cubrimos la zona universitaria de Chapingo y alrededores. Salones, jardines, espacios al aire libre. Tenemos experiencia en eventos académicos, graduaciones y celebraciones en la zona."
      },
      {
        question: "¿Qué incluye el servicio de transporte e instalación?",
        answer: "Todo. Traslado de equipo desde CDMX por la autopista México-Texcoco, montaje profesional, pruebas, operación durante el evento, desmontaje al finalizar. Cero cargos ocultos."
      },
      {
        question: "¿Con cuánta anticipación debo reservar?",
        answer: "Idealmente 3-4 semanas. Texcoco en temporada de bodas (octubre-diciembre, marzo-mayo) se llena rápido. Las haciendas más populares requieren reserva anticipada. Entre antes reserves, mejor."
      }
    ]} />
  </section>

  <!-- CTA Final -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para iluminar tu evento en Texcoco?</h2>
        <p>Mándanos fotos de tu hacienda o jardín por WhatsApp y te cotizamos en minutos. Transporte, instalación y montaje incluidos.</p>
        <div class="cta-buttons">
          <a href="https://wa.me/525530682988?text=Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20evento%20en%20Texcoco" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
