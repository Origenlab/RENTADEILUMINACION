          "closes": "14:00"
        }
      ]
    },
    "serviceArea": [
      {
        "@type": "Place",
        "name": "Álvaro Obregón",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.3762, "longitude": -99.2083}
      },
      {
        "@type": "Place",
        "name": "Santa Fe",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.3578, "longitude": -99.2683}
      },
