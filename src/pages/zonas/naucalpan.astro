    link: "/servicios/bocinas-djs/"
  }
];
---

<BaseLayout title={title} description={description} canonical={canonical} schemaMarkup={schemaMarkup}>

  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[
      { label: "Inicio", href: "/" },
      { label: "Zonas de Cobertura", href: "/zonas-de-cobertura/" },
      { label: "Naucalpan" }
    ]} />
  </Fragment>

  <Hero
    title="Renta de Iluminación en Naucalpan"
    subtitle="Especialización en bodas premium y eventos corporativos elegantes. Más de 350 eventos iluminados en la zona. Cobertura Edomex poniente."
    whatsappText="Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20boda%20en%20Naucalpan"
    introParagraph1='Naucalpan es la zona de bodas premium del poniente del Estado de México. Salones corporativos, country clubs privados, haciendas elegantes. <strong>REDEIL lleva 30 años iluminando eventos en Naucalpan y Edomex</strong>. Aquí no usamos iluminación de espectáculo — usamos iluminación de elegancia. Guirnaldas sutiles, uplighting discreto, efectos dinámicos que complementan sin dominar. 350+ eventos al año en la zona poniente.'
    introParagraph2='Somos los que entendemos bodas premium. Los que saben adaptar iluminación a espacios corporativos modular y restrictivos. Los que crean ambientes elegantes sin exceso. Equipo entrenado en eventos de alto nivel. Montaje discreto, profesional, impecable. Logística especializada en Naucalpan: permisos con country clubs, coordinación previa, equipo que respeta espacios premium. Precio transparente: no cobramos cargos ocultos.'
  />

  <!-- Stats -->
  <section class="stats-section-enhanced">
    <div class="container">
      <div class="stats-grid-enhanced">
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">30+</span>
          <span class="stat-label-enhanced">Años en Edomex</span>
        </div>
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">350+</span>
          <span class="stat-label-enhanced">Eventos/Año</span>
        </div>
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">100%</span>
          <span class="stat-label-enhanced">Espacios Corporativos</span>
        </div>
        <div class="stat-card-enhanced">
          <span class="stat-number-enhanced">100%</span>
          <span class="stat-label-enhanced">Cobertura Zona</span>
        </div>
      </div>
    </div>
  </section>

  <CtaBar
    headline="¿Para qué tipo de evento necesitas iluminación?"
    items={[
      { label: "Bodas Premium", href: "/eventos/bodas/", icon: "iluminacion" },
      { label: "Corporativos", href: "/eventos/corporativos/", icon: "iluminacion" },
      { label: "Country Clubs", href: "/eventos/bodas/", icon: "iluminacion" },
      { label: "Cotiza Ahora", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <!-- Por qué nosotros en Naucalpan -->
  <section class="services-section">
    <div class="container">
      <SectionHeader
        title="Por qué Nosotros en Naucalpan"
        subtitle="4 razones por las que REDEIL es el proveedor de iluminación para bodas premium en Naucalpan."
        paragraph1="Naucalpan es zona de bodas premium y elegantes. Aquí la iluminación complementa, no domina. Guirnaldas sutiles, uplighting discreto, efectos que realzan sin exceso. Sabemos crear ambientes sofisticados."
        paragraph2="Experiencia en salones corporativos y country clubs. Naucalpan tiene espacios restrictivos, modulares, con reglas de instalación. Nuestro equipo entiende eso. Permisos, coordinación previa, instalación impecable."
      />
      <div class="features-grid-4">
        <div class="feature-card">
          <h3>Especialización en Bodas Premium</h3>
          <p>Espacios corporativos, country clubs, haciendas elegantes. Iluminación que complementa elegancia.</p>
        </div>
        <div class="feature-card">
          <h3>Experiencia en Salones Corporativos</h3>
          <p>Naucalpan tiene salones premium. Sabemos adaptar iluminación a espacios modulares y restrictivos.</p>
        </div>
        <div class="feature-card">
          <h3>Iluminación Sofisticada</h3>
          <p>Guirnaldas sutiles, uplighting discreto, efectos elegantes. Sin exceso, sin ruido visual.</p>
        </div>
        <div class="feature-card">
          <h3>Logística Premium en Edomex</h3>
          <p>Permisos con country clubs, coordinación con gerencias, equipo que respeta espacios de alto nivel.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios Principales -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Servicios Principales"
        subtitle="Las 4 soluciones de iluminación para bodas premium en Naucalpan."
        paragraph1="Cada servicio adaptado a elegancia. Combinaciones generan paquetes más económicos porque compartimos equipo."
        paragraph2="Cotiza por WhatsApp con fotos de tu salón. Respuesta en minutos."
      />
      <div class="services-grid">
        {serviciosRelacionados.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre Iluminación en Naucalpan"
        subtitle="Lo que todos preguntan antes de cotizar."
        paragraph1="Si tienes otra duda, escríbenos por WhatsApp. Respuesta en minutos."
        paragraph2="Cada evento es diferente — por eso hacemos propuestas personalizadas."
      />
    </div>
    <FaqSection items={[
      {
        question: "¿Cuál es la cobertura de REDEIL en Naucalpan?",
        answer: "Cubrimos Naucalpan, Huixquilucan, Interlomas y toda la zona poniente del Estado de México. Salones corporativos, country clubs, haciendas privadas."
      },
      {
        question: "¿Qué tipo de eventos son más comunes en Naucalpan?",
        answer: "Bodas premium, eventos corporativos elegantes, celebraciones de alto nivel. Naucalpan es zona residencial premium del Edomex."
      },
      {
        question: "¿Cuánto cuesta iluminar una boda premium en Naucalpan?",
        answer: "Bodas premium en salones corporativos arrancan desde $15,000. Bodas de lujo con múltiples servicios, $25,000+."
      },
      {
        question: "¿Tienen experiencia en salones corporativos?",
        answer: "Sí. Naucalpan tiene salones corporativos premium. Sabemos adaptar iluminación a espacios elegantes, modular, con restricciones."
      },
      {
        question: "¿Cómo adaptan la iluminación a espacios corporativos?",
        answer: "Iluminación discreta pero elegante. Respetamos estética del lugar, sintonizamos con decoración existente, creamos ambientes sofisticados."
      },
      {
        question: "¿Cubren eventos en country clubs de Naucalpan?",
        answer: "Sí. Conocemos los country clubs y clubes privados de Naucalpan. Permisos, coordinación previa, instalación que respeta el lugar."
      },
      {
        question: "¿Qué incluye el servicio de transporte e instalación?",
        answer: "Todo. Traslado a Naucalpan, montaje profesional, pruebas, operación, desmontaje. Coordinación con gerencias y permisos. Cero cargos ocultos."
      },
      {
        question: "¿Con cuánta anticipación debo reservar?",
        answer: "Idealmente 4-6 semanas. Naucalpan es zona de bodas premium — los salones corporativos se reservan con tiempo."
      }
    ]} />
  </section>

  <!-- CTA Final -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Listo para iluminar tu boda en Naucalpan?</h2>
        <p>Mándanos fotos de tu salón por WhatsApp y te cotizamos en minutos. Transporte, instalación y montaje incluidos.</p>
        <div class="cta-buttons">
          <a href="https://wa.me/525530682988?text=Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20boda%20en%20Naucalpan" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
