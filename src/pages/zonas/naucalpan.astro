const serviciosRelacionados = [
  {
    title: "Guirnaldas Elegantes",
    image: "/img/guirnaldas/guirnaldas-edison-hacienda-boda.avif",
    alt: "Guirnaldas Edison en salón corporativo elegante",
    description: "Focos LED vintage o modernos. Adaptadas a estética corporativa. Iluminación sutil pero impactante.",
    link: "/servicios/guirnaldas/"
  },
  {
    title: "Uplighting Profesional",
    image: "/img/cabezas-moviles/cabezas-moviles-boda.avif",
    alt: "Uplighting profesional en salón",
    description: "Iluminación de bajo perfil que resalta arquitectura. Perfecta para espacios corporativos y elegantes.",
    link: "/servicios/sky-tracker/"
  },
  {
    title: "Sky Tracker Subtle",
    image: "/img/luces-neon/luces-neon-nombres-boda.avif",
    alt: "Sky tracker con proyecciones sutiles",
