      {
        "@type": "Place",
        "name": "Huixquilucan",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.3903, "longitude": -99.2670}
      },
      {
        "@type": "Place",
        "name": "Interlomas",
        "geo": {"@type": "GeoCoordinates", "latitude": 19.3938, "longitude": -99.2750}
      }
    ],
