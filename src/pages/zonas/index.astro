---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const title = "Zonas de Cobertura REDEIL | CDMX y Estado de México";
const description = "REDEIL cubre todas las alcaldías de CDMX y municipios Edomex. 30 años iluminando eventos en la zona metropolitana. Cobertura completa: bodas, XV años, corporativos.";
const canonical = "https://rentadeiluminacion.com/zonas/";

const schemaMarkup = JSON.stringify({
