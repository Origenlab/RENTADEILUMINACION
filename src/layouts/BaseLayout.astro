---
interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  schemaMarkup?: string;
}

// CDN (ExactDN). La reescritura /img/ → CDN/img/ ocurre en post-build
// (scripts/rewrite-cdn.mjs). Aquí sólo se usa para defaults absolutos
// como ogImage, donde el rewrite post-build no aplica.
const CDN_URL = 'https://ek8wn5x6rqg.exactdn.com';

const {
  title,
  description,
  canonical,
  ogImage = `${CDN_URL}/img/og/og-image-redeil.avif`,
  ogTitle,
  ogDescription,
  schemaMarkup,
} = Astro.props;

const finalOgTitle = ogTitle || title;
const finalOgDescription = ogDescription || description;

// BreadcrumbList schema — auto-generated from canonical URL
const siteUrl = 'https://rentadeiluminacion.com';
const urlPath = new URL(canonical).pathname;
const pathSegments = urlPath.split('/').filter(Boolean);

const slugNames: Record<string, string> = {
  'servicios': 'Servicios',
  'eventos': 'Eventos',
  'nosotros': 'Nosotros',
  'contacto': 'Contacto',
  'blog': 'Blog',
  'aviso-privacidad': 'Aviso de Privacidad',
  'zonas-de-cobertura': 'Zonas de Cobertura',
  'cabezas-moviles': 'Cabezas Móviles',
  'guirnaldas': 'Guirnaldas',
  'luces-neon': 'Luces Neón',
  'luces-led': 'Luces LED',
  'sky-tracker': 'Sky Tracker',
  'bola-disco': 'Bola de Disco',
  'city-color': 'City Color',
  'city-light': 'City Light',
  'gobos': 'Gobos',
  'cascadas-led': 'Cascadas LED',
  'maquina-humo': 'Máquina de Humo',
  'humo-bajo': 'Humo Bajo',
  'confeti': 'Confeti',
  'confeti-papelitos': 'Confeti Papelitos',
  'burbujas': 'Burbujas',
  'bocinas': 'Bocinas',
  'bocinas-bodas': 'Bocinas para Bodas',
  'bocinas-xv': 'Bocinas para XV Años',
  'bocinas-fiestas': 'Bocinas para Fiestas',
  'bocinas-conferencias': 'Bocinas para Conferencias',
  'bocinas-djs': 'DJ y Bocinas',
  'dj': 'DJ',
  'pantalla-inflable': 'Pantalla Inflable',
  'iluminacion-arquitectonica': 'Iluminación Arquitectónica',
  'luz-negra': 'Luz Negra',
  'seguidor': 'Seguidor',
  'podiums': 'Podiums',
  'bodas': 'Bodas',
  'xv-anos': 'XV Años',
  'co2': 'CO2',
  'sparklers': 'Sparklers',
  'robot-led': 'Robot LED',
  'microfonos': 'Micrófonos',
  'pantallas-led': 'Pantallas LED',
  'plantas-de-luz': 'Plantas de Luz',
  'iluminacion': 'Iluminación',
  'sonido': 'Sonido',
  'efectos-especiales': 'Efectos Especiales',
  'paquete-50-metros': 'Paquete 50 Metros',
  'paquete-100-metros': 'Paquete 100 Metros',
  'paquete-200-metros': 'Paquete 200 Metros',
  'paquete-500-metros': 'Paquete 500 Metros',
  'paquete-uv-basico': 'Paquete UV Básico',
  'paquete-neon-premium': 'Paquete Neón Premium',
  'paquete-glow-party': 'Paquete Glow Party',
  'paquete-produccion-neon': 'Paquete Producción Neón',
};

let breadcrumbSchema: string | null = null;
if (pathSegments.length > 0) {
  const items: Array<Record<string, unknown>> = [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl + "/" }
  ];
  let currentPath = '';
  pathSegments.forEach((seg, i) => {
    currentPath += '/' + seg;
    const isLast = i === pathSegments.length - 1;
    const name = slugNames[seg] || seg.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
    const entry: Record<string, unknown> = {
      "@type": "ListItem",
      "position": i + 2,
      "name": name,
    };
    if (!isLast) {
      entry["item"] = siteUrl + currentPath + "/";
    }
    items.push(entry);
  });
  breadcrumbSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": items
  });
}

import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!DOCTYPE html>
<html lang="es-MX">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Critical CSS Inline (LCP optimization) — valores idénticos a style.css para evitar FOUC -->
  <style>
    :root {
      /* Colores — deben coincidir exactamente con style.css */
      --color-primary: #ff5722;
      --color-primary-dark: #e64a19;
      --color-primary-light: #ff8a65;
      --color-secondary: #1a1a2e;
      --color-white: #ffffff;
      --color-gray-800: #343a40;
      /* Fuentes */
      --font-primary: 'Montserrat', system-ui, -apple-system, sans-serif;
      --font-secondary: 'Open Sans', system-ui, -apple-system, sans-serif;
      /* Header */
      --header-height: 76px;
      --hdr-height: 76px;
      --hdr-max: 1400px;
      --hdr-accent: #ff5722;
      --hdr-text: #1a1a2e;
      --hdr-text-hover: #ff5722;
      --topbar-height: 36px;
    }
    html { scroll-behavior: smooth; }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Open Sans', system-ui, -apple-system, sans-serif; color: #343a40; background: #ffffff; }
    main { display: block; }
    /* Header base crítico — evita flash */
    .hdr {
      background: #ffffff;
      height: 76px;
      border-bottom: 1px solid rgba(0,0,0,0.07);
    }
  </style>

  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content="REDEIL">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonical}>

  <meta property="og:type" content="website">
  <meta property="og:url" content={canonical}>
  <meta property="og:title" content={finalOgTitle}>
  <meta property="og:description" content={finalOgDescription}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:locale" content="es_MX">
  <meta property="og:site_name" content="REDEIL - Renta de Iluminación">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={finalOgTitle}>
  <meta name="twitter:description" content={finalOgDescription}>
  <meta name="twitter:image" content={ogImage}>

  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">
  <meta name="theme-color" content="#1a1a2e">

  <!-- Preconnect al CDN de imágenes (ExactDN) — ahorra DNS + TLS antes del primer <img> -->
  <link rel="preconnect" href="https://ek8wn5x6rqg.exactdn.com" crossorigin>
  <link rel="dns-prefetch" href="https://ek8wn5x6rqg.exactdn.com">

  <!-- Critical Font Preloads for LCP -->
  <link rel="preload" href="/fonts/montserrat-700.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/montserrat-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/open-sans-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/fonts.css">
  <link rel="stylesheet" href="/css/style.css">

  <style is:global>
    /* TruConversion Microsurvey - Tema REDEIL */
    #ti-poke-ct #ti-poke-co { background-color: #1a1a2e !important; }
    #ti-poke-ct .opener { background-color: #1a1a2e !important; }
    #ti-poke-ct .header { background-color: #0f0f1a !important; color: #ffffff !important; }
    #ti-poke-ct .separator { border-color: #0a0a12 !important; }
    #ti-poke-ct .separator .inner { border-color: #2a2a40 !important; }
    #ti-poke-ct .body li { color: #ffffff !important; background-color: #1f1f36 !important; }
    #ti-poke-ct .body li label.ti-poke-radio { color: #ffffff !important; }
    #ti-poke-ct .body ul li:hover,
    #ti-poke-ct .body ul li.active { background-color: #ff5722 !important; }
    #ti-poke-ct .footer .arrow { border-left-color: #1a1a2e !important; }
    #ti-poke-ct .footer .cta-link,
    #ti-poke-ct .footer .cta-link-m { background-color: #ff5722 !important; color: #ffffff !important; }
    #ti-poke-ct .footer .cta-link:hover,
    #ti-poke-ct .footer .cta-link-m:hover { background-color: #e64a19 !important; }
    #ti-poke-ct .body .main-txt.thanku .tick { background-color: #0f0f1a !important; border-color: #ff5722 !important; }
    /* Ocultar logo de TruConversion */
    #ti-poke-brand { display: none !important; }
  </style>

  {schemaMarkup && <script type="application/ld+json" set:html={schemaMarkup} />}
  {breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}

  <!-- Measure TopBar height dynamically for hero padding -->
  <script is:inline>
    (function(){
      function setTopbarHeight(){
        var tb = document.querySelector('.topbar');
        var h = tb ? tb.offsetHeight : 36;
        document.documentElement.style.setProperty('--topbar-height', h + 'px');
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setTopbarHeight);
      } else {
        setTopbarHeight();
      }
      window.addEventListener('resize', setTopbarHeight, {passive:true});
    })();
  </script>

  <!-- ExactDN CDN — la reescritura /img/ → CDN se hace en post-build
       (scripts/rewrite-cdn.mjs). Ya no hay rewrite en runtime: evitaba
       el doble request (origin + CDN) que destruía LCP. -->

  <!-- TruConversion -->
  <script is:inline>
    var _tip = _tip || [];
    (function(d,s,id){
      var js, tjs = d.getElementsByTagName(s)[0];
      if(d.getElementById(id)) { return; }
      js = d.createElement(s); js.id = id;
      js.async = true;
      js.src = d.location.protocol + '//app.truconversion.com/ti-js/62671/e4e92.js';
      tjs.parentNode.insertBefore(js, tjs);
    }(document, 'script', 'ti-js'));
  </script>
</head>
<body>
  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

  <TopBar />
  <div class="hdr-stack">
    <Header />
    <slot name="breadcrumbs" />
  </div>

  <main id="main-content">
    <slot />
  </main>

  <Footer />

  <!-- Botón flotante de WhatsApp — contacto directo -->
  <a
    href="https://wa.me/525530682988?text=Hola%20REDEIL%2C%20quiero%20cotizar%20iluminaci%C3%B3n%20para%20mi%20evento."
    class="wa-float"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Cotizar por WhatsApp"
  >
    <span class="wa-float__pulse" aria-hidden="true"></span>
    <svg class="wa-float__icon" viewBox="0 0 24 24" width="34" height="34" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.582 0 11.941-5.359 11.944-11.893a11.821 11.821 0 00-3.418-8.451z"/>
    </svg>
  </a>
  <style>
    .wa-float {
      position: fixed;
      right: 20px;
      bottom: 20px;
      z-index: 9999;
      width: 60px;
      height: 60px;
      border-radius: 50%;
      background: #25D366;
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .wa-float:hover,
    .wa-float:focus-visible {
      transform: scale(1.08);
      box-shadow: 0 6px 22px rgba(0, 0, 0, 0.32);
      color: #ffffff;
    }
    .wa-float__icon { position: relative; z-index: 1; }
    .wa-float__pulse {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      background: #25D366;
      animation: wa-pulse 2s ease-out infinite;
    }
    @keyframes wa-pulse {
      0% { transform: scale(1); opacity: 0.55; }
      70% { transform: scale(1.7); opacity: 0; }
      100% { transform: scale(1.7); opacity: 0; }
    }
    @media (max-width: 480px) {
      .wa-float { right: 16px; bottom: 16px; width: 54px; height: 54px; }
      .wa-float__icon { width: 30px; height: 30px; }
    }
    @media (prefers-reduced-motion: reduce) {
      .wa-float__pulse { animation: none; }
    }
  </style>

  <!-- TruConversion Microsurvey — Traducción al español -->
  <script>
    (function() {
      function translateWidget() {
        document.querySelectorAll('#ti-poke-ct h5').forEach(function(h5) {
          if (h5.textContent!.trim() === 'What did you come to the site to do?') {
            h5.textContent = '¿Qué te trajo por aquí hoy?';
          }
        });
        document.querySelectorAll('#ti-poke-ct .cta-link, #ti-poke-ct .cta-link-m').forEach(function(btn) {
          var t = btn.textContent!.trim();
          if (t === 'Send' || t === 'SEND') btn.textContent = 'Enviar';
        });
        document.querySelectorAll('#ti-poke-ct .thanku').forEach(function(el) {
          if (el.textContent!.includes('Thank you!'))
            el.textContent = el.textContent!.replace('Thank you!', '¡Gracias por tu respuesta!');
        });
      }
      function startObserver() {
        var widget = document.getElementById('ti-poke-ct');
        if (widget) {
          translateWidget();
          new MutationObserver(translateWidget).observe(widget, { childList: true, subtree: true });
        } else {
          setTimeout(startObserver, 500);
        }
      }
      document.readyState === 'loading'
        ? document.addEventListener('DOMContentLoaded', startObserver)
        : startObserver();
    })();
  </script>
  <!-- Contacto directo por WhatsApp (cualquier botón con data-open-chat) -->
  <script is:inline>
  (function() {
    var WA_PHONE = '525530682988';
    var WA_DEFAULT = 'Hola REDEIL, quiero cotizar iluminación para mi evento.';
    window.openWhatsApp = function(text) {
      var msg = (text && text.trim()) ? text : WA_DEFAULT;
      window.open('https://wa.me/' + WA_PHONE + '?text=' + encodeURIComponent(msg), '_blank', 'noopener');
    };
    // Delegación global: cualquier elemento con data-open-chat abre WhatsApp.
    // Soporta mensaje personalizado vía atributo data-wa-text.
    document.addEventListener('click', function(e) {
      var el = e.target.closest('[data-open-chat]');
      if (el) {
        e.preventDefault();
        window.openWhatsApp(el.getAttribute('data-wa-text'));
      }
    });
  })();
  </script>
</body>
</html>
