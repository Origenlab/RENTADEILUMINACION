---
interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  schemaMarkup?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://rentadeiluminacion.com/img/og/og-image-redeil.avif',
  ogTitle,
  ogDescription,
  schemaMarkup,
} = Astro.props;

const finalOgTitle = ogTitle || title;
const finalOgDescription = ogDescription || description;

// BreadcrumbList schema — auto-generated from canonical URL
const siteUrl = 'https://rentadeiluminacion.com';
const urlPath = new URL(canonical).pathname;
const pathSegments = urlPath.split('/').filter(Boolean);

const slugNames: Record<string, string> = {
  'servicios': 'Servicios',
  'eventos': 'Eventos',
  'nosotros': 'Nosotros',
  'contacto': 'Contacto',
  'blog': 'Blog',
  'aviso-privacidad': 'Aviso de Privacidad',
  'zonas-de-cobertura': 'Zonas de Cobertura',
  'cabezas-moviles': 'Cabezas Móviles',
  'guirnaldas': 'Guirnaldas',
  'luces-neon': 'Luces Neón',
  'luces-led': 'Luces LED',
  'sky-tracker': 'Sky Tracker',
  'bola-disco': 'Bola de Disco',
  'city-color': 'City Color',
  'city-light': 'City Light',
  'gobos': 'Gobos',
  'cascadas-led': 'Cascadas LED',
  'maquina-humo': 'Máquina de Humo',
  'humo-bajo': 'Humo Bajo',
  'confeti': 'Confeti',
  'confeti-papelitos': 'Confeti Papelitos',
  'burbujas': 'Burbujas',
  'bocinas': 'Bocinas',
  'bocinas-bodas': 'Bocinas para Bodas',
  'bocinas-xv': 'Bocinas para XV Años',
  'bocinas-fiestas': 'Bocinas para Fiestas',
  'bocinas-conferencias': 'Bocinas para Conferencias',
  'bocinas-djs': 'DJ y Bocinas',
  'dj': 'DJ',
  'pantalla-inflable': 'Pantalla Inflable',
  'iluminacion-arquitectonica': 'Iluminación Arquitectónica',
  'luz-negra': 'Luz Negra',
  'seguidor': 'Seguidor',
  'podiums': 'Podiums',
  'bodas': 'Bodas',
  'xv-anos': 'XV Años',
  'co2': 'CO2',
  'sparklers': 'Sparklers',
  'robot-led': 'Robot LED',
  'microfonos': 'Micrófonos',
  'pantallas-led': 'Pantallas LED',
  'plantas-de-luz': 'Plantas de Luz',
  'iluminacion': 'Iluminación',
  'sonido': 'Sonido',
  'efectos-especiales': 'Efectos Especiales',
  'paquete-50-metros': 'Paquete 50 Metros',
  'paquete-100-metros': 'Paquete 100 Metros',
  'paquete-200-metros': 'Paquete 200 Metros',
  'paquete-500-metros': 'Paquete 500 Metros',
  'paquete-uv-basico': 'Paquete UV Básico',
  'paquete-neon-premium': 'Paquete Neón Premium',
  'paquete-glow-party': 'Paquete Glow Party',
  'paquete-produccion-neon': 'Paquete Producción Neón',
};

let breadcrumbSchema: string | null = null;
if (pathSegments.length > 0) {
  const items: Array<Record<string, unknown>> = [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl + "/" }
  ];
  let currentPath = '';
  pathSegments.forEach((seg, i) => {
    currentPath += '/' + seg;
    const isLast = i === pathSegments.length - 1;
    const name = slugNames[seg] || seg.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
    const entry: Record<string, unknown> = {
      "@type": "ListItem",
      "position": i + 2,
      "name": name,
    };
    if (!isLast) {
      entry["item"] = siteUrl + currentPath + "/";
    }
    items.push(entry);
  });
  breadcrumbSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": items
  });
}

import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!DOCTYPE html>
<html lang="es-MX">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content="REDEIL">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonical}>

  <meta property="og:type" content="website">
  <meta property="og:url" content={canonical}>
  <meta property="og:title" content={finalOgTitle}>
  <meta property="og:description" content={finalOgDescription}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:locale" content="es_MX">
  <meta property="og:site_name" content="REDEIL - Renta de Iluminación">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={finalOgTitle}>
  <meta name="twitter:description" content={finalOgDescription}>
  <meta name="twitter:image" content={ogImage}>

  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">
  <meta name="theme-color" content="#1a1a2e">

  <link rel="preload" href="/fonts/montserrat-700.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/montserrat-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/open-sans-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/fonts.css">
  <link rel="stylesheet" href="/css/style.css">

  <style is:global>
    /* TruConversion Microsurvey - Tema REDEIL */
    #ti-poke-ct #ti-poke-co { background-color: #1a1a2e !important; }
    #ti-poke-ct .opener { background-color: #1a1a2e !important; }
    #ti-poke-ct .header { background-color: #0f0f1a !important; color: #ffffff !important; }
    #ti-poke-ct .separator { border-color: #0a0a12 !important; }
    #ti-poke-ct .separator .inner { border-color: #2a2a40 !important; }
    #ti-poke-ct .body li { color: #ffffff !important; background-color: #1f1f36 !important; }
    #ti-poke-ct .body li label.ti-poke-radio { color: #ffffff !important; }
    #ti-poke-ct .body ul li:hover,
    #ti-poke-ct .body ul li.active { background-color: #ff5722 !important; }
    #ti-poke-ct .footer .arrow { border-left-color: #1a1a2e !important; }
    #ti-poke-ct .footer .cta-link,
    #ti-poke-ct .footer .cta-link-m { background-color: #ff5722 !important; color: #ffffff !important; }
    #ti-poke-ct .footer .cta-link:hover,
    #ti-poke-ct .footer .cta-link-m:hover { background-color: #e64a19 !important; }
    #ti-poke-ct .body .main-txt.thanku .tick { background-color: #0f0f1a !important; border-color: #ff5722 !important; }
    /* Ocultar logo de TruConversion */
    #ti-poke-brand { display: none !important; }
  </style>

  {schemaMarkup && <script type="application/ld+json" set:html={schemaMarkup} />}
  {breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}

  <!-- Measure TopBar height dynamically for hero padding -->
  <script is:inline>
    (function(){
      function setTopbarHeight(){
        var tb = document.querySelector('.topbar');
        var h = tb ? tb.offsetHeight : 36;
        document.documentElement.style.setProperty('--topbar-height', h + 'px');
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setTopbarHeight);
      } else {
        setTopbarHeight();
      }
      window.addEventListener('resize', setTopbarHeight, {passive:true});
    })();
  </script>

  <!-- ExactDN CDN — rewrite image paths to CDN in production -->
  <script is:inline>
    (function(){
      var cdn = 'https://ek8wn5x6rqg.exactdn.com';
      if (window.location.hostname === 'localhost') return;
      document.addEventListener('DOMContentLoaded', function(){
        var imgs = document.querySelectorAll('img[src^="/img/"]');
        for (var i = 0; i < imgs.length; i++) {
          imgs[i].src = cdn + imgs[i].getAttribute('src');
          if (imgs[i].srcset) {
            imgs[i].srcset = imgs[i].srcset.replace(/(\/img\/)/g, cdn + '/img/');
          }
        }
        // Also rewrite CSS background-images with /img/ paths
        var els = document.querySelectorAll('[style*="/img/"]');
        for (var j = 0; j < els.length; j++) {
          els[j].style.cssText = els[j].style.cssText.replace(/(\/img\/)/g, cdn + '/img/');
        }
      });
    })();
  </script>

  <!-- TruConversion -->
  <script is:inline>
    var _tip = _tip || [];
    (function(d,s,id){
      var js, tjs = d.getElementsByTagName(s)[0];
      if(d.getElementById(id)) { return; }
      js = d.createElement(s); js.id = id;
      js.async = true;
      js.src = d.location.protocol + '//app.truconversion.com/ti-js/62671/e4e92.js';
      tjs.parentNode.insertBefore(js, tjs);
    }(document, 'script', 'ti-js'));
  </script>
</head>
<body>
  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

  <TopBar />
  <div class="hdr-stack">
    <Header />
    <slot name="breadcrumbs" />
  </div>

  <main id="main-content">
    <slot />
  </main>

  <Footer />

  <!-- Sticky CTA Mobile — solo visible en mobile -->
  <div class="sticky-cta-mobile">
    <a href="https://wa.me/525530682988?text=Hola,%20quiero%20cotizar%20iluminaci%C3%B3n%20para%20mi%20evento" class="sticky-cta__wa" target="_blank" rel="noopener noreferrer">
      <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      WhatsApp
    </a>
    <a href="/contacto/" class="sticky-cta__cotizar">
      Cotizar Gratis
    </a>
  </div>

  <!-- TruConversion Microsurvey — Traducción al español -->
  <script>
    (function() {
      function translateWidget() {
        document.querySelectorAll('#ti-poke-ct h5').forEach(function(h5) {
          if (h5.textContent!.trim() === 'What did you come to the site to do?') {
            h5.textContent = '¿Qué te trajo por aquí hoy?';
          }
        });
        document.querySelectorAll('#ti-poke-ct .cta-link, #ti-poke-ct .cta-link-m').forEach(function(btn) {
          var t = btn.textContent!.trim();
          if (t === 'Send' || t === 'SEND') btn.textContent = 'Enviar';
        });
        document.querySelectorAll('#ti-poke-ct .thanku').forEach(function(el) {
          if (el.textContent!.includes('Thank you!'))
            el.textContent = el.textContent!.replace('Thank you!', '¡Gracias por tu respuesta!');
        });
      }
      function startObserver() {
        var widget = document.getElementById('ti-poke-ct');
        if (widget) {
          translateWidget();
          new MutationObserver(translateWidget).observe(widget, { childList: true, subtree: true });
        } else {
          setTimeout(startObserver, 500);
        }
      }
      document.readyState === 'loading'
        ? document.addEventListener('DOMContentLoaded', startObserver)
        : startObserver();
    })();
  </script>
</body>
</html>
