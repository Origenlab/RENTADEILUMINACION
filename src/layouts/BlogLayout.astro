    { title: "Iluminación para el Primer Vals", description: "Follow Spot, Gobo y efectos para el momento más fotogénico.", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", imageAlt: "Iluminación primer vals", category: "Bodas", slug: "iluminacion-primer-vals-boda" },
    { title: "¿Cuánto Cuesta la Iluminación para Boda en CDMX?", description: "Precios reales y rangos por paquete.", image: "/img/guirnaldas/renta-guirnaldas-boda-hacienda-mexicana-guirnaldas-18-400w.avif", imageAlt: "Iluminación boda hacienda", category: "Bodas", slug: "cuanto-cuesta-iluminacion-boda-cdmx" },
  ],
  "XV Años": [
    { title: "Tendencias de Iluminación para XV Años 2025", description: "Neón, LED, efectos especiales y todo lo que está de moda.", image: "/img/luces-neon/renta-luces-neon-fiesta-pista-baile-colores-800w.avif", imageAlt: "Luces neón XV años", category: "XV Años", slug: "iluminacion-xv-anos-tendencias" },
    { title: "Efectos Especiales para Entrada de XV Años", description: "CO2, bengalas y sky tracker para la entrada más impactante.", image: "/img/cascadas-led/cascadas-led-backdrop-boda-espectacular-800w.avif", imageAlt: "Efectos especiales XV", category: "XV Años", slug: "entrada-xv-anos-efectos-especiales" },
    { title: "Iluminación para XV Años en Iztapalapa", description: "Equipos y efectos para salones y jardines.", image: "/img/xv-anos/iluminacion-xv-anos-vals-seguidor.avif", imageAlt: "XV años Iztapalapa", category: "Zonas", slug: "iluminacion-xv-anos-iztapalapa" },
  ],
  "Iluminación": [
    { title: "Iluminación Profesional para Eventos Corporativos Polanco", description: "Qué iluminación usar en eventos corporativos.", image: "/img/directorio/directorio-tienda-iluminacion-01.avif", imageAlt: "Iluminación corporativa Polanco", category: "Iluminación", slug: "iluminacion-profesional-eventos-corporativos-polanco-cdmx" },
    { title: "Cabezas Móviles Chauvet, Robe y ADJ: Guía de Compra CDMX", description: "Comparativa técnica de las mejores cabezas móviles.", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante.avif", imageAlt: "Cabezas móviles CDMX", category: "Iluminación", slug: "cabezas-moviles-chauvet-robe-adj-cdmx-guia-compra" },
    { title: "Strips LED RGB para Decoración de Eventos CDMX", description: "Cómo usar strips LED en bodas y eventos.", image: "/img/directorio/directorio-almacen-luces-01.avif", imageAlt: "Strips LED eventos", category: "Iluminación", slug: "strips-led-rgb-decoracion-eventos-cdmx" },
  ],
  "Guirnaldas": [
    { title: "¿Cuántos Metros de Guirnaldas Necesito?", description: "Calculadora práctica por tipo de espacio e invitados.", image: "/img/guirnaldas/guirnaldas-edison-hacienda-boda.avif", imageAlt: "Guirnaldas boda jardín", category: "Guirnaldas", slug: "cuantos-metros-guirnaldas-necesito" },
    { title: "Guirnaldas: Jardín vs Salón — Diferencias Clave", description: "No todas funcionan igual. Lo que debes saber.", image: "/img/guirnaldas/guirnaldas-exterior-jardin-boda.avif", imageAlt: "Guirnaldas hacienda", category: "Guirnaldas", slug: "guirnaldas-boda-jardin-vs-salon" },
    { title: "Focos Edison vs LED para Guirnaldas: ¿Cuál Elegir?", description: "Temperatura, consumo y estética. Comparativa honesta.", image: "/img/guirnaldas/guirnaldas-focos-edison-eventos.avif", imageAlt: "Guirnaldas Edison vintage", category: "Guirnaldas", slug: "diferencia-guirnaldas-edison-led" },
  ],
  "Sonido": [
    { title: "Audio para Boda: Lo Que Nadie Te Dice", description: "Los 3 momentos de audio y errores que arruinan eventos.", image: "/img/bocinas-bodas/renta-bocinas-boda-banda-cantante-mezcladora-jbl-800w.avif", imageAlt: "Audio profesional boda", category: "Sonido", slug: "audio-profesional-boda-que-necesitas-saber" },
