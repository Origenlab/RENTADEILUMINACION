---
/**
 * BlogLayout — REDEIL
 * ────────────────────
 * Layout de 2 columnas para artículos del blog.
 * Col izquierda: artículo completo | Col derecha: BlogSidebar sticky
 * Hereda de BaseLayout. Sin animaciones. CSS limpio y scoped.
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Hero from '../components/Hero.astro';
import CtaBar from '../components/CtaBar.astro';
import BlogSidebar from '../components/BlogSidebar.astro';
import BlogCard from '../components/BlogCard.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  image: string;
  imageAlt: string;
  category: string;
  schemaMarkup?: string;
}

const {
  title,
  description,
  canonical,
  image,
  imageAlt,
  category,
  schemaMarkup,
} = Astro.props;

// Popular articles for sidebar (hand-picked)
const popularArticles = [
  { title: "¿Cuánto Cuesta la Iluminación para una Boda en CDMX?", slug: "cuanto-cuesta-iluminacion-boda-cdmx", category: "Bodas", img: "/img/guirnaldas/renta-guirnaldas-boda-hacienda-mexicana-guirnaldas-18-400w.avif" },
  { title: "¿Cuántos Metros de Guirnaldas Necesito para mi Boda?", slug: "cuantos-metros-guirnaldas-necesito", category: "Guirnaldas", img: "/img/guirnaldas/guirnaldas-edison-hacienda-boda.avif" },
  { title: "Tipos de Iluminación para Eventos: Guía Completa", slug: "tipos-iluminacion-para-eventos", category: "Guía", img: "/img/city-color/city-color-fachada-hacienda-boda-800w.avif" },
  { title: "Bengalas Frías en Interiores: ¿Son Seguras?", slug: "bengalas-frias-seguras-interiores", category: "Efectos", img: "/img/cascadas-led/cascadas-led-backdrop-boda-espectacular-800w.avif" },
  { title: "¿Cuánto Cuesta un DJ para Boda en CDMX?", slug: "cuanto-cuesta-dj-para-boda-cdmx", category: "Sonido", img: "/img/bocinas-djs/dj-para-bodas-mezclando-musica-evento-800w.avif" },
];

// Mapa de empresas del directorio por categoría
const directorioMap: Record<string, Array<{nombre: string; slug: string; categoria: string; zona: string; rating: number}>> = {
  "Audio": [
    { nombre: "Audio Mundo Salvador 30", slug: "audio-mundo-salvador", categoria: "audio", zona: "Centro Histórico, CDMX", rating: 4.1 },
    { nombre: "Audiomexican", slug: "audiomexican", categoria: "audio", zona: "Gustavo A. Madero, CDMX", rating: 5.0 },
    { nombre: "Audiosystem Shop", slug: "audiosystem-shop", categoria: "audio", zona: "Iztapalapa, CDMX", rating: 4.8 },
