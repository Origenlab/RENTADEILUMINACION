    { nombre: "Forest Ingeniería de Audio", slug: "forest-ingenieria-audio", categoria: "audio", zona: "CDMX", rating: 4.3 },
  ],
  "Iluminación": [
    { nombre: "Brillante Iluminación", slug: "brillante-iluminacion", categoria: "iluminacion", zona: "CDMX", rating: 4.6 },
    { nombre: "Grupo Lighting", slug: "grupo-lighting", categoria: "iluminacion", zona: "CDMX", rating: 4.4 },
    { nombre: "Top Show Iluminación", slug: "top-show-iluminacion", categoria: "iluminacion", zona: "CDMX", rating: 4.7 },
    { nombre: "Outled México", slug: "outled-mexico", categoria: "iluminacion", zona: "CDMX", rating: 4.2 },
    { nombre: "LED Colors", slug: "led-colors", categoria: "iluminacion", zona: "CDMX", rating: 4.5 },
  ],
  "DJ": [
    { nombre: "DJ Shop", slug: "dj-shop", categoria: "dj", zona: "CDMX", rating: 4.3 },
    { nombre: "Chilango eShop", slug: "chilango-eshop", categoria: "dj", zona: "CDMX", rating: 4.6 },
    { nombre: "Music Club CDMX", slug: "music-club-cdmx", categoria: "audio", zona: "CDMX", rating: 4.4 },
    { nombre: "Topmusic CDMX", slug: "topmusic-cdmx", categoria: "audio", zona: "CDMX", rating: 4.5 },
  ],
  "Efectos": [
    { nombre: "Laser LED", slug: "laser-led", categoria: "efectos", zona: "CDMX", rating: 4.7 },
    { nombre: "Top Show Iluminación", slug: "top-show-iluminacion", categoria: "iluminacion", zona: "CDMX", rating: 4.7 },
    { nombre: "Grupo Lighting", slug: "grupo-lighting", categoria: "iluminacion", zona: "CDMX", rating: 4.4 },
  ],
  "Sonido": [
    { nombre: "Audio Mundo Salvador 30", slug: "audio-mundo-salvador", categoria: "audio", zona: "Centro Histórico, CDMX", rating: 4.1 },
    { nombre: "Representaciones de Audio", slug: "representaciones-de-audio", categoria: "audio", zona: "CDMX", rating: 4.3 },
    { nombre: "Esquema Musical", slug: "esquema-musical", categoria: "audio", zona: "CDMX", rating: 4.5 },
    { nombre: "Hi-Tech Audio", slug: "hi-tech-audio", categoria: "audio", zona: "CDMX", rating: 4.5 },
  ],
};

const defaultDirectorio = [
  { nombre: "Audio Mundo Salvador 30", slug: "audio-mundo-salvador", categoria: "audio", zona: "Centro Histórico, CDMX", rating: 4.1 },
  { nombre: "Brillante Iluminación", slug: "brillante-iluminacion", categoria: "iluminacion", zona: "CDMX", rating: 4.6 },
  { nombre: "Laser LED", slug: "laser-led", categoria: "efectos", zona: "CDMX", rating: 4.7 },
  { nombre: "DJ Shop", slug: "dj-shop", categoria: "dj", zona: "CDMX", rating: 4.3 },
];

const directorioEmpresas = directorioMap[category] || defaultDirectorio;

// Related articles by category
const relatedByCategory: Record<string, Array<{title: string; description: string; image: string; imageAlt: string; category: string; slug: string}>> = {
