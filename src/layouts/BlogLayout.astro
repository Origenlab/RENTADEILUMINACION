    { title: "Guía de Efectos que Combinan Perfecto", description: "CO2, confeti y bengalas frías para máximo impacto.", image: "/img/galeria/confeti-03.avif", imageAlt: "Efectos especiales evento", category: "Efectos", slug: "efectos-especiales-que-combinan" },
    { title: "Máquina de Burbujas para Bodas y Fiestas", description: "El efecto más fotogénico y cuándo usarlo.", image: "/img/burbujas/burbujas-efecto-especial-fotografia-video.avif", imageAlt: "Máquina de burbujas", category: "Efectos", slug: "maquina-burbujas-bodas-fiestas-cdmx" },
  ],
};

// Default related articles if category not found
const defaultRelated = [
  { title: "Tipos de Iluminación para Eventos: Guía Completa", description: "Wash, spot, efectos, arquitectónica. Todo lo que debes conocer.", image: "/img/city-color/city-color-fachada-hacienda-boda-800w.avif", imageAlt: "Tipos de iluminación", category: "Guía", slug: "tipos-iluminacion-para-eventos" },
  { title: "¿Cuánto Cuesta la Iluminación para una Boda?", description: "Precios reales, rangos por paquete y qué incluye cada opción.", image: "/img/guirnaldas/renta-guirnaldas-boda-hacienda-mexicana-guirnaldas-18-400w.avif", imageAlt: "Iluminación boda", category: "Bodas", slug: "cuanto-cuesta-iluminacion-boda-cdmx" },
  { title: "Cabezas Móviles vs Par LED: ¿Cuál Necesita Tu Evento?", description: "Comparativa técnica para elegir el equipo correcto.", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante-600w.avif", imageAlt: "Cabezas móviles vs par led", category: "Equipos", slug: "cabezas-moviles-vs-par-led" },
];

const relatedArticles = relatedByCategory[category] || defaultRelated;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={image}
  schemaMarkup={schemaMarkup}
>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[
      { label: "Inicio", href: "/" },
      { label: "Blog", href: "/blog/" },
      { label: title.length > 45 ? title.substring(0, 45) + "…" : title }
    ]} />
  </Fragment>

  <!-- Hero — 2 columnas igual que todo el sitio -->
  <Hero
    title={title}
    subtitle={description}
    introParagraph1={`<strong>${category}</strong> · Escrito por el equipo técnico de <strong>REDEIL</strong> con más de 30 años de experiencia en iluminación profesional para eventos en la Ciudad de México y Estado de México. Cada artículo está basado en proyectos reales.`}
    introParagraph2={`En este blog compartimos conocimiento práctico sobre cómo elegir la iluminación correcta para cada tipo de evento — bodas, XV años, galas corporativas y fiestas privadas. Todo lo que aprendemos en campo, lo documentamos para ti.`}
  />

  <!-- CtaBar — barra de acceso rápido -->

  <!-- Contenido del artículo: 2 columnas (artículo + sidebar) -->
  <section class="blog-article-section">
    <div class="container blog-article-layout">

      <!-- Artículo principal -->
      <article class="blog-article">

        <!-- Imagen destacada -->
        <div class="blog-article__hero-img">
          <img
            src={image}
            alt={imageAlt}
            loading="eager"
            width="1200"
            height="630"
          />
        </div>

        <!-- Contenido del artículo (slot) -->
        <div class="blog-content">
          <slot />
        </div>

        <!-- CTA al final del artículo -->
        <div class="blog-article__cta">
          <div class="blog-article__cta-inner">
            <h3>¿Te quedaron dudas sobre tu evento?</h3>
            <p>Escríbenos por WhatsApp con la fecha y el venue. Te asesoramos gratis y te cotizamos en minutos.</p>
            <div class="blog-article__cta-btns">
              <button type="button" data-open-chat class="btn btn-whatsapp btn-lg">
                Cotizar ahora
              </button>
              <a href="/servicios/" class="btn btn-primary btn-lg">Ver todos los servicios</a>
            </div>
          </div>
        </div>

      </article>

      <!-- Sidebar -->
      <div class="blog-article-sidebar">
        <BlogSidebar popularArticles={popularArticles} directorioEmpresas={directorioEmpresas} />
      </div>

    </div>
  </section>

  <!-- Artículos relacionados -->
  <section class="blog-related services-alt">
    <div class="container">
      <div class="blog-related__header">
        <h2 class="blog-related__title">Artículos Relacionados</h2>
        <p class="blog-related__sub">Más guías y consejos del equipo técnico de REDEIL</p>
      </div>
      <div class="blog-related__grid">
        {relatedArticles.map((art) => (
          <BlogCard
            title={art.title}
            description={art.description}
            image={art.image}
            imageAlt={art.imageAlt}
            category={art.category}
            slug={art.slug}
          />
        ))}
      </div>
      <div class="blog-related__link">
        <a href="/blog/" class="btn btn-outline btn-lg">Ver todos los artículos →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
