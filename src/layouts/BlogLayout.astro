    { title: "Audio Profesional en Neza: Guía Completa", description: "Dónde encontrar audio profesional en Nezahualcóyotl.", image: "/img/directorio/directorio-sistema-sonido-01.avif", imageAlt: "Audio Nezahualcóyotl", category: "Audio", slug: "audio-profesional-nezahualcoyotl-guia-completa" },
    { title: "Cómo Elegir Micrófono Inalámbrico para Eventos CDMX", description: "Guía técnica para seleccionar el micrófono correcto.", image: "/img/directorio/directorio-tienda-audio-01.avif", imageAlt: "Micrófonos inalámbricos", category: "Audio", slug: "como-elegir-microfono-inalambrico-eventos-cdmx" },
    { title: "Sistemas Line Array para Eventos de Gran Escala CDMX", description: "Cuándo y por qué usar line array en tu evento.", image: "/img/bocinas/renta-bocinas-line-array-concierto.avif", imageAlt: "Line array eventos CDMX", category: "Audio", slug: "sistemas-linea-array-eventos-gran-escala-cdmx" },
  ],
  "Bodas": [
