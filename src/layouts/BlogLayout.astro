---
/**
 * BlogLayout — REDEIL
 * ────────────────────
 * Layout de 2 columnas para artículos del blog.
 * Col izquierda: artículo completo | Col derecha: BlogSidebar sticky
 * Hereda de BaseLayout. Sin animaciones. CSS limpio y scoped.
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Hero from '../components/Hero.astro';
import CtaBar from '../components/CtaBar.astro';
import BlogSidebar from '../components/BlogSidebar.astro';
import BlogCard from '../components/BlogCard.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  image: string;
  imageAlt: string;
  category: string;
  schemaMarkup?: string;
}

const {
  title,
  description,
  canonical,
  image,
  imageAlt,
  category,
  schemaMarkup,
} = Astro.props;

// Popular articles for sidebar (hand-picked)
const popularArticles = [
  { title: "¿Cuánto Cuesta la Iluminación para una Boda en CDMX?", slug: "cuanto-cuesta-iluminacion-boda-cdmx", category: "Bodas", img: "/img/guirnaldas/renta-guirnaldas-boda-hacienda-mexicana-guirnaldas-18-400w.avif" },
  { title: "¿Cuántos Metros de Guirnaldas Necesito para mi Boda?", slug: "cuantos-metros-guirnaldas-necesito", category: "Guirnaldas", img: "/img/guirnaldas/renta-guirnaldas-boda-jardin-encino-cdmx-600w.avif" },
  { title: "Tipos de Iluminación para Eventos: Guía Completa", slug: "tipos-iluminacion-para-eventos", category: "Guía", img: "/img/city-color/renta-iluminacion-led-par-color-wash-eventos-600w.avif" },
  { title: "Bengalas Frías en Interiores: ¿Son Seguras?", slug: "bengalas-frias-seguras-interiores", category: "Efectos", img: "/img/cascadas-led/renta-cascadas-led-eventos-cdmx-600w.avif" },
  { title: "¿Cuánto Cuesta un DJ para Boda en CDMX?", slug: "cuanto-cuesta-dj-para-boda-cdmx", category: "Sonido", img: "/img/bocinas-djs/dj-para-bodas-mezclando-musica-evento-800w.avif" },
];

// Related articles by category
const relatedByCategory: Record<string, Array<{title: string; description: string; image: string; imageAlt: string; category: string; slug: string}>> = {
  "Bodas": [
    { title: "Checklist de Iluminación para Boda", description: "La lista que usan los wedding planners para no olvidar nada.", image: "/img/guirnaldas/renta-guirnaldas-boda-jardin-encino-cdmx-600w.avif", imageAlt: "Guirnaldas para boda", category: "Bodas", slug: "checklist-iluminacion-boda" },
    { title: "Iluminación para el Primer Vals", description: "Follow Spot, Gobo y efectos para el momento más fotogénico.", image: "/img/seguidor/renta-luz-seguidor-boda-primer-baile-hmi-1200w-300w.avif", imageAlt: "Iluminación primer vals", category: "Bodas", slug: "iluminacion-primer-vals-boda" },
    { title: "¿Cuánto Cuesta la Iluminación para Boda en CDMX?", description: "Precios reales y rangos por paquete.", image: "/img/guirnaldas/renta-guirnaldas-boda-hacienda-mexicana-guirnaldas-18-400w.avif", imageAlt: "Iluminación boda hacienda", category: "Bodas", slug: "cuanto-cuesta-iluminacion-boda-cdmx" },
  ],
  "XV Años": [
    { title: "Tendencias de Iluminación para XV Años 2025", description: "Neón, LED, efectos especiales y todo lo que está de moda.", image: "/img/luces-neon/renta-luces-neon-fiesta-pista-baile-colores-800w.avif", imageAlt: "Luces neón XV años", category: "XV Años", slug: "iluminacion-xv-anos-tendencias" },
    { title: "Efectos Especiales para Entrada de XV Años", description: "CO2, bengalas y sky tracker para la entrada más impactante.", image: "/img/cascadas-led/renta-cascadas-led-eventos-cdmx-600w.avif", imageAlt: "Efectos especiales XV", category: "XV Años", slug: "entrada-xv-anos-efectos-especiales" },
    { title: "Iluminación para XV Años en Iztapalapa", description: "Equipos y efectos para salones y jardines.", image: "/img/xv-anos/iluminacion-xv-anos-vals-seguidor.avif", imageAlt: "XV años Iztapalapa", category: "Zonas", slug: "iluminacion-xv-anos-iztapalapa" },
  ],
  "Guirnaldas": [
    { title: "¿Cuántos Metros de Guirnaldas Necesito?", description: "Calculadora práctica por tipo de espacio e invitados.", image: "/img/guirnaldas/renta-guirnaldas-boda-jardin-encino-cdmx-600w.avif", imageAlt: "Guirnaldas boda jardín", category: "Guirnaldas", slug: "cuantos-metros-guirnaldas-necesito" },
    { title: "Guirnaldas: Jardín vs Salón — Diferencias Clave", description: "No todas funcionan igual. Lo que debes saber.", image: "/img/guirnaldas/renta-guirnaldas-boda-finca-hacienda-600w.avif", imageAlt: "Guirnaldas hacienda", category: "Guirnaldas", slug: "guirnaldas-boda-jardin-vs-salon" },
    { title: "Focos Edison vs LED para Guirnaldas: ¿Cuál Elegir?", description: "Temperatura, consumo y estética. Comparativa honesta.", image: "/img/guirnaldas/renta-guirnaldas-foco-edison-vintage-bodas-600w.avif", imageAlt: "Guirnaldas Edison vintage", category: "Guirnaldas", slug: "diferencia-guirnaldas-edison-led" },
  ],
  "Sonido": [
    { title: "Audio para Boda: Lo Que Nadie Te Dice", description: "Los 3 momentos de audio y errores que arruinan eventos.", image: "/img/bocinas-bodas/renta-bocinas-boda-banda-cantante-mezcladora-jbl-800w.avif", imageAlt: "Audio profesional boda", category: "Sonido", slug: "audio-profesional-boda-que-necesitas-saber" },
    { title: "¿Cuánto Cuesta un DJ para Boda en CDMX?", description: "Precios reales de DJ: desde $4,500 hasta $22,000.", image: "/img/bocinas-djs/dj-para-bodas-mezclando-musica-evento-800w.avif", imageAlt: "DJ para bodas CDMX", category: "Sonido", slug: "cuanto-cuesta-dj-para-boda-cdmx" },
    { title: "Audio para Conferencias en CDMX", description: "Por qué el sonido mata tu presentación.", image: "/img/bocinas-conferencias/alquiler-bocinas-para-conferencias-y-seminarios-800w.avif", imageAlt: "Audio conferencias", category: "Sonido", slug: "audio-profesional-conferencias-cdmx" },
  ],
  "Efectos": [
    { title: "Bengalas Frías en Interiores: ¿Son Seguras?", description: "Mitos y verdades sobre los sparklers en salones.", image: "/img/cascadas-led/renta-cascadas-led-eventos-cdmx-600w.avif", imageAlt: "Bengalas frías interiores", category: "Efectos", slug: "bengalas-frias-seguras-interiores" },
    { title: "Guía de Efectos que Combinan Perfecto", description: "CO2, confeti y bengalas frías para máximo impacto.", image: "/img/galeria/confeti-03.avif", imageAlt: "Efectos especiales evento", category: "Efectos", slug: "efectos-especiales-que-combinan" },
    { title: "Máquina de Burbujas para Bodas y Fiestas", description: "El efecto más fotogénico y cuándo usarlo.", image: "/img/burbujas/burbujas-efecto-especial-fotografia-video.avif", imageAlt: "Máquina de burbujas", category: "Efectos", slug: "maquina-burbujas-bodas-fiestas-cdmx" },
  ],
};

// Default related articles if category not found
const defaultRelated = [
  { title: "Tipos de Iluminación para Eventos: Guía Completa", description: "Wash, spot, efectos, arquitectónica. Todo lo que debes conocer.", image: "/img/city-color/renta-iluminacion-led-par-color-wash-eventos-600w.avif", imageAlt: "Tipos de iluminación", category: "Guía", slug: "tipos-iluminacion-para-eventos" },
  { title: "¿Cuánto Cuesta la Iluminación para una Boda?", description: "Precios reales, rangos por paquete y qué incluye cada opción.", image: "/img/guirnaldas/renta-guirnaldas-boda-hacienda-mexicana-guirnaldas-18-400w.avif", imageAlt: "Iluminación boda", category: "Bodas", slug: "cuanto-cuesta-iluminacion-boda-cdmx" },
  { title: "Cabezas Móviles vs Par LED: ¿Cuál Necesita Tu Evento?", description: "Comparativa técnica para elegir el equipo correcto.", image: "/img/cabezas-moviles/renta-cabezas-moviles-beam-wash-eventos-cdmx-600w.avif", imageAlt: "Cabezas móviles vs par led", category: "Equipos", slug: "cabezas-moviles-vs-par-led" },
];

const relatedArticles = relatedByCategory[category] || defaultRelated;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={image}
  schemaMarkup={schemaMarkup}
>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[
      { label: "Inicio", href: "/" },
      { label: "Blog", href: "/blog/" },
      { label: title.length > 45 ? title.substring(0, 45) + "…" : title }
    ]} />
  </Fragment>

  <!-- Hero — 2 columnas igual que todo el sitio -->
  <Hero
    title={title}
    subtitle={description}
    introParagraph1={`<strong>${category}</strong> · Escrito por el equipo técnico de <strong>REDEIL</strong> con más de 30 años de experiencia en iluminación profesional para eventos en la Ciudad de México y Estado de México. Cada artículo está basado en proyectos reales.`}
    introParagraph2={`En este blog compartimos conocimiento práctico sobre cómo elegir la iluminación correcta para cada tipo de evento — bodas, XV años, galas corporativas y fiestas privadas. Todo lo que aprendemos en campo, lo documentamos para ti.`}
  />

  <!-- CtaBar — barra de acceso rápido -->
  <CtaBar
    headline="Explora nuestros servicios"
    items={[
      { label: "Iluminación", href: "/servicios/iluminacion/", icon: "iluminacion" },
      { label: "Sonido y DJ", href: "/servicios/sonido/", icon: "sonido" },
      { label: "Efectos Especiales", href: "/servicios/efectos-especiales/", icon: "efectos" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <!-- Contenido del artículo: 2 columnas (artículo + sidebar) -->
  <section class="blog-article-section">
    <div class="container blog-article-layout">

      <!-- Artículo principal -->
      <article class="blog-article">

        <!-- Imagen destacada -->
        <div class="blog-article__hero-img">
          <img
            src={image}
            alt={imageAlt}
            loading="eager"
            width="1200"
            height="630"
          />
        </div>

        <!-- Contenido del artículo (slot) -->
        <div class="blog-content">
          <slot />
        </div>

        <!-- CTA al final del artículo -->
        <div class="blog-article__cta">
          <div class="blog-article__cta-inner">
            <h3>¿Te quedaron dudas sobre tu evento?</h3>
            <p>Escríbenos por WhatsApp con la fecha y el venue. Te asesoramos gratis y te cotizamos en minutos.</p>
            <div class="blog-article__cta-btns">
              <a href={`https://wa.me/5215530682988?text=${encodeURIComponent(`Hola REDEIL, leí el artículo "${title}" y quiero cotizar iluminación para mi evento.`)}`}
                 target="_blank" rel="noopener noreferrer"
                 class="btn btn-whatsapp btn-lg">
                Cotizar por WhatsApp
              </a>
              <a href="/contacto/" class="btn btn-primary btn-lg">Ver todos los servicios</a>
            </div>
          </div>
        </div>

      </article>

      <!-- Sidebar -->
      <div class="blog-article-sidebar">
        <BlogSidebar popularArticles={popularArticles} />
      </div>

    </div>
  </section>

  <!-- Artículos relacionados -->
  <section class="blog-related services-alt">
    <div class="container">
      <div class="blog-related__header">
        <h2 class="blog-related__title">Artículos Relacionados</h2>
        <p class="blog-related__sub">Más guías y consejos del equipo técnico de REDEIL</p>
      </div>
      <div class="blog-related__grid">
        {relatedArticles.map((art) => (
          <BlogCard
            title={art.title}
            description={art.description}
            image={art.image}
            imageAlt={art.imageAlt}
            category={art.category}
            slug={art.slug}
          />
        ))}
      </div>
      <div class="blog-related__link">
        <a href="/blog/" class="btn btn-outline btn-lg">Ver todos los artículos →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ──────────────────────────────────────────
   LAYOUT DE 2 COLUMNAS
   ────────────────────────────────────────── */
.blog-article-section {
  background: #f8f9fa;
  padding: 3rem 0 4rem;
}

.blog-article-layout {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 3rem;
  align-items: start;
}

/* ──────────────────────────────────────────
   ARTÍCULO
   ────────────────────────────────────────── */
.blog-article {
  background: #fff;
  border-radius: 12px;
  border: 1px solid #e9ecef;
  overflow: hidden;
}

.blog-article__hero-img {
  width: 100%;
  aspect-ratio: 16 / 7;
  overflow: hidden;
}

.blog-article__hero-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ──────────────────────────────────────────
   TIPOGRAFÍA DEL CONTENIDO
   ────────────────────────────────────────── */
.blog-content {
  padding: 2.5rem 2.5rem 2rem;
}

.blog-content :global(h2) {
  font-family: var(--font-primary, 'Montserrat', sans-serif);
  font-size: clamp(1.3rem, 2.5vw, 1.75rem);
  font-weight: 700;
  color: var(--color-secondary, #1C2B4A);
  margin: 2.5rem 0 1rem;
  line-height: 1.25;
  padding-left: 1rem;
  border-left: 4px solid var(--color-primary, #ff5722);
}

.blog-content :global(h2:first-child) {
  margin-top: 0;
}

.blog-content :global(h3) {
  font-family: var(--font-primary, 'Montserrat', sans-serif);
  font-size: clamp(1.05rem, 2vw, 1.3rem);
  font-weight: 700;
  color: var(--color-secondary, #1C2B4A);
  margin: 2rem 0 0.75rem;
  line-height: 1.3;
}

.blog-content :global(p) {
  font-family: var(--font-body, 'Open Sans', sans-serif);
  font-size: 1.0625rem;
  line-height: 1.8;
  color: #343a40;
  margin: 0 0 1.4rem;
}

.blog-content :global(strong) {
  font-weight: 700;
  color: var(--color-secondary, #1C2B4A);
}

.blog-content :global(em) {
  font-style: italic;
}

.blog-content :global(ul),
.blog-content :global(ol) {
  font-family: var(--font-body, 'Open Sans', sans-serif);
  font-size: 1.0625rem;
  line-height: 1.8;
  color: #343a40;
  margin: 0 0 1.4rem 0;
  padding-left: 0;
  list-style: none;
}

.blog-content :global(ul li),
.blog-content :global(ol li) {
  padding-left: 1.75rem;
  position: relative;
  margin-bottom: 0.5rem;
}

.blog-content :global(ul li::before) {
  content: '';
  position: absolute;
  left: 0.25rem;
  top: 0.65rem;
  width: 7px;
  height: 7px;
  background: var(--color-primary, #ff5722);
  border-radius: 50%;
}

.blog-content :global(ol) {
  counter-reset: ol-counter;
}

.blog-content :global(ol li) {
  counter-increment: ol-counter;
}

.blog-content :global(ol li::before) {
  content: counter(ol-counter) ".";
  position: absolute;
  left: 0;
  font-weight: 700;
  color: var(--color-primary, #ff5722);
  font-size: 0.875rem;
}

.blog-content :global(a) {
  color: var(--color-primary, #ff5722);
  text-decoration: none;
}

.blog-content :global(a:hover) {
  text-decoration: underline;
}

.blog-content :global(blockquote) {
  border-left: 4px solid var(--color-primary, #ff5722);
  background: rgba(255, 87, 34, 0.05);
  margin: 1.5rem 0;
  padding: 1.25rem 1.5rem;
  border-radius: 0 8px 8px 0;
}

.blog-content :global(blockquote p) {
  margin: 0;
  color: var(--color-secondary, #1C2B4A);
  font-weight: 600;
  font-style: italic;
  font-size: 1.0625rem;
}

.blog-content :global(img) {
  width: 100%;
  height: auto;
  border-radius: 8px;
  margin: 1.5rem 0;
  display: block;
}

.blog-content :global(figure) {
  margin: 1.5rem 0;
}

.blog-content :global(figcaption) {
  font-size: 0.8125rem;
  color: #6c757d;
  text-align: center;
  margin-top: 0.5rem;
  font-style: italic;
}

/* ── Tablas responsive (sin inline styles) ── */
.blog-content :global(.table-wrap) {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  margin: 1.5rem 0;
  border-radius: 8px;
  border: 1px solid #e9ecef;
}

.blog-content :global(table) {
  width: 100%;
  border-collapse: collapse;
  min-width: 480px;
  font-size: 0.9375rem;
}

.blog-content :global(th) {
  background: var(--color-secondary, #1C2B4A);
  color: #fff;
  padding: 0.75rem 1rem;
  text-align: left;
  font-family: var(--font-primary, 'Montserrat', sans-serif);
  font-size: 0.875rem;
  font-weight: 700;
  white-space: nowrap;
}

.blog-content :global(th:first-child) {
  border-radius: 0;
}

.blog-content :global(td) {
  padding: 0.7rem 1rem;
  border-bottom: 1px solid #e9ecef;
  color: #343a40;
  vertical-align: top;
}

.blog-content :global(tr:last-child td) {
  border-bottom: none;
}

.blog-content :global(tr:nth-child(even) td) {
  background: #f8f9fa;
}

/* ──────────────────────────────────────────
   CTA DENTRO DEL ARTÍCULO
   ────────────────────────────────────────── */
.blog-article__cta {
  border-top: 1px solid #e9ecef;
  background: #f8f9fa;
  padding: 2.5rem;
}

.blog-article__cta-inner {
  max-width: 640px;
}

.blog-article__cta h3 {
  font-family: var(--font-primary, 'Montserrat', sans-serif);
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-secondary, #1C2B4A);
  margin: 0 0 0.5rem;
}

.blog-article__cta p {
  font-size: 0.9375rem;
  color: #6c757d;
  line-height: 1.6;
  margin: 0 0 1.5rem;
}

.blog-article__cta-btns {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

/* ──────────────────────────────────────────
   SIDEBAR
   ────────────────────────────────────────── */
.blog-article-sidebar {
  position: sticky;
  top: calc(36px + 70px + 1.5rem);
}

/* ──────────────────────────────────────────
   ARTÍCULOS RELACIONADOS
   ────────────────────────────────────────── */
.blog-related {
  padding: 3.5rem 0;
}

.blog-related__header {
  margin-bottom: 2rem;
}

.blog-related__title {
  font-family: var(--font-primary, 'Montserrat', sans-serif);
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 700;
  color: var(--color-secondary, #1C2B4A);
  margin: 0 0 0.5rem;
}

.blog-related__sub {
  font-size: 0.9375rem;
  color: #6c757d;
  margin: 0;
}

.blog-related__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.75rem;
  margin-bottom: 2rem;
}

.blog-related__link {
  text-align: center;
}

/* ──────────────────────────────────────────
   RESPONSIVE
   ────────────────────────────────────────── */
@media (max-width: 1200px) {
  .blog-article-layout {
    grid-template-columns: 1fr 280px;
    gap: 2rem;
  }
}

@media (max-width: 1024px) {
  .blog-article-layout {
    grid-template-columns: 1fr 260px;
    gap: 1.5rem;
  }

  .blog-content {
    padding: 2rem 2rem 1.75rem;
  }

  .blog-article__cta {
    padding: 2rem;
  }
}

@media (max-width: 900px) {
  .blog-article-layout {
    grid-template-columns: 1fr;
  }

  .blog-article-sidebar {
    position: static;
    order: 2;
  }

  .blog-related__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 640px) {
  .blog-article-section {
    padding: 1.5rem 0 2.5rem;
  }

  .blog-content {
    padding: 1.5rem 1.25rem;
  }

  .blog-article__cta {
    padding: 1.5rem 1.25rem;
  }

  .blog-article__cta-btns {
    flex-direction: column;
  }

  .blog-related__grid {
    grid-template-columns: 1fr;
  }

  .blog-related {
    padding: 2.5rem 0;
  }
}
</style>
