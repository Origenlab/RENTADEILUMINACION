---
/**
 * BlogLayout — REDEIL
 * ────────────────────
 * Usa SOLO los componentes existentes del sitio:
 * BaseLayout, Hero, CtaBar, ContentWithSidebar, SectionHeader, ServiceCard
 *
 * Estructura idéntica a páginas de servicio:
 * Hero → CtaBar → ContentWithSidebar (artículo + sidebar) → Servicios relacionados → CTA Final
 *
 * Sin componentes custom. Sin CSS de layout custom.
 * Solo CSS para tipografía del contenido markdown.
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Hero from '../components/Hero.astro';
import CtaBar from '../components/CtaBar.astro';
import ContentWithSidebar from '../components/ContentWithSidebar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceCard from '../components/ServiceCard.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  image: string;
  imageAlt: string;
  category: string;
  schemaMarkup?: string;
}

const {
  title,
  description,
  canonical,
  image,
  imageAlt,
  category,
  schemaMarkup,
} = Astro.props;

const serviciosRelacionados = [
  { title: "Guirnaldas Edison", image: "/img/guirnaldas/renta-guirnaldas-edison-terraza-recepcion-02-300w.avif", alt: "Guirnaldas Edison para bodas", description: "Focos Edison con luz cálida vintage para jardines, terrazas y haciendas. Las más pedidas para bodas.", link: "/servicios/guirnaldas/" },
  { title: "Cascadas LED", image: "/img/cascadas-led/cascadas-led-novios-mesa-romantica-boda-300w.avif", alt: "Cascadas LED para mesa de novios", description: "Cortinas de luces LED como backdrop para la mesa de novios. Efecto brillante y fotogénico.", link: "/servicios/cascadas-led/" },
  { title: "Cabezas Móviles", image: "/img/cabezas-moviles/renta-cabezas-moviles-boda-beams-blancos-elegante-300w.avif", alt: "Show de luces para eventos", description: "Show de luces robóticas Beam, Spot y Wash con control DMX. El efecto de concierto en tu evento.", link: "/servicios/cabezas-moviles/" },
  { title: "Humo Bajo", image: "/img/humo-bajo/efecto-nubes-piso-boda-jardin-400w.avif", alt: "Humo bajo para vals de boda", description: "Niebla baja que crea nubes en el piso para el vals. El efecto más emotivo para bodas y XV años.", link: "/servicios/humo-bajo/" },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={image}
  schemaMarkup={schemaMarkup}
>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[
      { label: "Inicio", href: "/" },
      { label: "Blog", href: "/blog/" },
      { label: title.length > 45 ? title.substring(0, 45) + "…" : title }
    ]} />
  </Fragment>

  <!-- Hero — mismas 2 columnas que todo el sitio -->
  <Hero
    title={title}
    subtitle={description}
    introParagraph1={`<strong>${category}</strong> · Escrito por el equipo técnico de <strong>REDEIL</strong> con más de 30 años de experiencia en iluminación profesional para eventos en la Ciudad de México y Estado de México. Cada artículo está basado en proyectos reales y asesoría directa a nuestros clientes.`}
    introParagraph2={`En este blog compartimos conocimiento práctico sobre cómo elegir la iluminación correcta para cada tipo de evento — bodas en hacienda, XV años temáticos, galas corporativas y fiestas privadas. Todo lo que aprendemos en campo, lo documentamos aquí para ti.`}
  />

  <!-- CtaBar — misma barra naranja -->
  <CtaBar
    headline="Explora nuestros servicios"
    items={[
      { label: "Iluminación", href: "/servicios/iluminacion/", icon: "iluminacion" },
      { label: "Sonido y DJ", href: "/servicios/sonido/", icon: "sonido" },
      { label: "Efectos Especiales", href: "/servicios/efectos-especiales/", icon: "efectos" },
      { label: "Cotiza Gratis", href: "/contacto/", icon: "cotizar" },
    ]}
  />

  <!-- Contenido del artículo con sidebar — ContentWithSidebar existente -->
  <section class="services-section">
    <ContentWithSidebar
      sidebarTitle="Cotiza tu Evento"
      features={[
        { text: "30 años de experiencia" },
        { text: "Equipo profesional certificado" },
        { text: "Instalación incluida" },
        { text: "CDMX y Estado de México" },
        { text: "Sin costos ocultos" },
        { text: "Asesoría gratuita por WhatsApp" },
      ]}
      waMessage={`Hola REDEIL, leí el artículo "${title}" y quiero cotizar iluminación para mi evento.`}
      packages={[
        { label: "Iluminación", price: "", href: "/servicios/iluminacion/" },
        { label: "Sonido y DJ", price: "", href: "/servicios/sonido/" },
        { label: "Efectos Especiales", price: "", href: "/servicios/efectos-especiales/" },
        { label: "Ver todos", price: "", href: "/servicios/" },
      ]}
    >
      <!-- Imagen destacada del artículo -->
      <div class="container">
        <img
          src={image}
          alt={imageAlt}
          style="width:100%; height:auto; border-radius:8px; margin-bottom:2rem;"
          loading="eager"
          width="1200"
          height="630"
        />
      </div>

      <!-- Contenido markdown renderizado -->
      <div class="container blog-content">
        <slot />
      </div>
    </ContentWithSidebar>
  </section>

  <!-- Servicios relacionados — SectionHeader + ServiceCard como en todo el sitio -->
  <section class="services-section services-alt">
    <div class="container">
      <SectionHeader
        title="Servicios Relacionados"
        subtitle="Conoce nuestros servicios más solicitados para eventos."
        paragraph1="Cada servicio incluye transporte, instalación profesional, operación durante el evento y desmontaje. Cotiza sin compromiso por WhatsApp."
        paragraph2="Combinamos servicios con precio especial. Cuéntanos tu evento y te armamos la propuesta perfecta."
      />
      <div class="services-grid">
        {serviciosRelacionados.map((s) => (
          <ServiceCard title={s.title} image={s.image} alt={s.alt} description={s.description} link={s.link} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final — mismo estilo naranja de todo el sitio -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>¿Te quedaron dudas sobre tu evento?</h2>
        <p>Escríbenos por WhatsApp con la fecha y el venue. Te asesoramos gratis y te cotizamos en minutos.</p>
        <div class="cta-buttons">
          <a href="/contacto/" class="btn btn-whatsapp btn-lg">Cotiza por WhatsApp</a>
          <a href="tel:+525530682988" class="btn btn-primary btn-lg">Llámanos — 55 3068 2988</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* Tipografía para contenido markdown dentro del artículo */
.blog-content :global(h2) {
  font-family: var(--font-primary, 'Montserrat', sans-serif);
  font-size: clamp(1.4rem, 2.5vw, 1.9rem);
  font-weight: 700;
  color: var(--color-secondary, #1C2B4A);
  margin: 2.5rem 0 1rem;
  line-height: 1.25;
}
.blog-content :global(h3) {
  font-family: var(--font-primary, 'Montserrat', sans-serif);
  font-size: clamp(1.1rem, 2vw, 1.4rem);
  font-weight: 700;
  color: var(--color-secondary, #1C2B4A);
  margin: 2rem 0 0.75rem;
}
.blog-content :global(p) {
  font-family: var(--font-body, 'Open Sans', sans-serif);
  font-size: 1.0625rem;
  line-height: 1.8;
  color: var(--color-gray-800, #343a40);
  margin: 0 0 1.4rem;
}
.blog-content :global(strong) {
  font-weight: 700;
  color: var(--color-secondary, #1C2B4A);
}
.blog-content :global(ul),
.blog-content :global(ol) {
  margin: 0 0 1.4rem 1.5rem;
  padding: 0;
  font-family: var(--font-body, 'Open Sans', sans-serif);
  font-size: 1.0625rem;
  line-height: 1.8;
  color: var(--color-gray-800, #343a40);
}
.blog-content :global(li) {
  margin-bottom: 0.5rem;
}
.blog-content :global(a) {
  color: var(--color-primary, #E05800);
  text-decoration: underline;
}
.blog-content :global(blockquote) {
  border-left: 4px solid var(--color-primary, #E05800);
  background: rgba(224,88,0,0.05);
  margin: 1.5rem 0;
  padding: 1rem 1.5rem;
  border-radius: 0 8px 8px 0;
}
.blog-content :global(blockquote p) {
  margin: 0;
  color: var(--color-secondary, #1C2B4A);
  font-weight: 600;
  font-style: italic;
}
.blog-content :global(img) {
  width: 100%;
  height: auto;
  border-radius: 8px;
  margin: 1.5rem 0;
  display: block;
}
.blog-content :global(table) {
  width: 100%;
  border-collapse: collapse;
  margin: 1.5rem 0;
  font-size: 0.9375rem;
}
.blog-content :global(th) {
  background: var(--color-secondary, #1C2B4A);
  color: #fff;
  padding: 0.75rem 1rem;
  text-align: left;
  font-family: var(--font-primary, 'Montserrat', sans-serif);
  font-size: 0.875rem;
}
.blog-content :global(td) {
  padding: 0.65rem 1rem;
  border-bottom: 1px solid var(--color-gray-200, #e9ecef);
}
.blog-content :global(tr:nth-child(even) td) {
  background: var(--color-gray-50, #f8f9fa);
}
</style>
