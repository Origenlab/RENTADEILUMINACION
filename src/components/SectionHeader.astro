---
/**
 * SectionHeader Component — OrigenLab Standard
 * ─────────────────────────────────────────────
 * Título de sección en 2 columnas.
 *   Col 1: Subtitle (eyebrow) → Heading → Divider
 *   Col 2: Dos párrafos descriptivos
 * Respeta jerarquía SEO: H1 solo en Hero, secciones usan H2+
 * Sin animaciones. Código limpio.
 */
interface Props {
  tag?: 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
  title: string;
  subtitle?: string;
  paragraph1: string;
  paragraph2: string;
  dark?: boolean;
}

const {
  tag = 'h2',
  title,
  subtitle,
  paragraph1,
  paragraph2,
  dark = false,
} = Astro.props;

const Tag = tag;
---

<div class:list={['sh', { 'sh--dark': dark }]}>
  <div class="container sh__grid">
    <div class="sh__col1">
      {subtitle && <p class="sh__eyebrow">{subtitle}</p>}
      <Tag class="sh__title">{title}</Tag>
      <div class="sh__divider" aria-hidden="true"></div>
    </div>
    <div class="sh__col2">
      <p class="sh__text">{paragraph1}</p>
      <p class="sh__text">{paragraph2}</p>
    </div>
  </div>
</div>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
