---
interface Post {
  title: string;
  href: string;
  excerpt: string;
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<section class="related-blog">
  <div class="container">
    <h2 class="related-blog__title">Artículos Relacionados</h2>
    <div class="related-blog__grid">
      {posts.map((post) => (
        <a href={post.href} class="related-blog__card">
          <h3 class="related-blog__card-title">{post.title}</h3>
          <p class="related-blog__card-excerpt">{post.excerpt}</p>
          <span class="related-blog__card-link">Leer más →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
