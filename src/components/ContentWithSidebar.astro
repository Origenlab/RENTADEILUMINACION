---
/**
 * ContentWithSidebar — OrigenLab Standard (REDEIL)
 * ────────────────────────────────────────────────
 * 2 columnas: contenido principal (slot) + sidebar sticky
 * Sidebar: datos clave del servicio + CTA WhatsApp
 * Sin animaciones. Código limpio.
 */
interface Feature {
  text: string;
}

interface RelatedPackage {
  label: string;
  price: string;
  href: string;
  active?: boolean;
}

interface Props {
  sidebarTitle?: string;
  price?: string;
  priceNote?: string;
  features?: Feature[];
  packages?: RelatedPackage[];
  whatsapp?: string;
  waMessage?: string;
  phone?: string;
}

const {
  sidebarTitle = "Datos del servicio",
  price,
  priceNote,
  features = [],
  packages = [],
  whatsapp = "5530682988",
  waMessage = "Hola REDEIL, quiero cotizar para mi evento.",
  phone = "55 3068 2988",
} = Astro.props;

const waHref = `https://wa.me/${whatsapp}?text=${encodeURIComponent(waMessage)}`;
---

<div class="cws container">
  <div class="cws__content">
    <slot />
  </div>

  <aside class="cws__sidebar">
    <div class="cws__card">
      <h3 class="cws__card-title">{sidebarTitle}</h3>

      {price && (
        <div class="cws__price">
          <span class="cws__price-label">Desde</span>
          <span class="cws__price-value">{price}</span>
          {priceNote && <span class="cws__price-note">{priceNote}</span>}
        </div>
      )}

      {features.length > 0 && (
        <ul class="cws__features">
          {features.map((f) => (
            <li>{f.text}</li>
          ))}
        </ul>
      )}

      <div class="cws__ctas">
        <button type="button" data-open-chat class="cws__btn cws__btn--wa">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Cotizar ahora
        </button>
        <a href={`tel:+52${whatsapp}`} class="cws__btn cws__btn--tel">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          {phone}
        </a>
      </div>

      {packages.length > 0 && (
        <div class="cws__packages">
          <span class="cws__packages-title">Otros paquetes</span>
          {packages.map((pkg) => (
            <a href={pkg.href} class:list={['cws__pkg', { 'cws__pkg--active': pkg.active }]}>
              <span class="cws__pkg-label">{pkg.label}</span>
              <span class="cws__pkg-price">{pkg.price}</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </aside>
</div>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
