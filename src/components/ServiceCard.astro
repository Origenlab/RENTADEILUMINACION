---
/**
 * ServiceCard — REDEIL Editorial
 * ────────────────────────────────────────
 * Diseño alineado con el Hero: tipografía tight,
 * barra editorial naranja, sin animaciones en card/imagen.
 * Solo el botón tiene transición de color.
 */
interface Props {
  title: string;
  description: string;
  image: string;
  alt?: string;
  link: string;
  btnLabel?: string;
  eyebrow?: string;
}

const {
  title,
  description,
  image,
  alt = title,
  link,
  btnLabel,
  eyebrow = "Servicio REDEIL",
} = Astro.props;

const finalBtnLabel = btnLabel || title;
---

<article class="sc">
  <a href={link} class="sc__img-link" aria-label={title}>
    <div class="sc__img">
      <img src={image} alt={alt} loading="lazy" width="480" height="600" />
    </div>
  </a>

  <div class="sc__body">
    <div class="sc__eyebrow" aria-hidden="true">
      <span class="sc__dot"></span>
      <span>{eyebrow}</span>
    </div>

    <div class="sc__bar" aria-hidden="true"></div>

    <h3 class="sc__title">
      <a href={link} class="sc__title-link">{title}</a>
    </h3>

    <p class="sc__desc">{description}</p>

    <a href={link} class="sc__btn">
      {finalBtnLabel}
      <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none">
        <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</article>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
