---
/**
 * Gallery4x4 — OrigenLab Standard (REDEIL)
 * Grid 4×4 de imágenes. CSS 100% scoped.
 */
interface GalleryImage {
  src: string;
  alt: string;
}

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;
---

<div class="g4">
  {images.map((img) => (
    <div class="g4__item">
      <img src={img.src} alt={img.alt} width="400" height="300" loading="lazy" />
    </div>
  ))}
</div>

<style>
  .g4 {
    display: grid !important;
    grid-template-columns: repeat(4, 1fr) !important;
    gap: 0.75rem !important;
  }

  .g4__item {
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: #f0f0f0;
  }

  .g4__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 1024px) {
    .g4 {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }

  @media (max-width: 640px) {
    .g4 {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 0.5rem !important;
    }
  }
</style>
