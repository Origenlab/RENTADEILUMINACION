---
/**
 * Gallery4x4 — OrigenLab Standard (REDEIL)
 * Grid 4×4 de imágenes. CSS 100% scoped.
 */
interface GalleryImage {
  src: string;
  alt: string;
}

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;
---

<div class="g4">
  {images.map((img) => (
    <div class="g4__item">
      <img src={img.src} alt={img.alt} width="400" height="300" loading="lazy" />
    </div>
  ))}
</div>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
