---
/**
 * DirectoryCard — Origenlab Standard (REDEIL Directorio)
 * ───────────────────────────────────────────────────────
 * Card para empresas del directorio de proveedores.
 * Muestra nombre, rating, categoría, zona, teléfono y botón.
 * Sin animaciones. CSS scoped.
 */

interface Props {
  nombre: string;
  categoria: string;
  zona: string;
  alcaldia_municipio: string;
  telefono?: string;
  rating?: number;
  resenas?: number;
  slug: string;
}

const {
  nombre,
  categoria,
  zona,
  alcaldia_municipio,
  telefono,
  rating,
  resenas,
  slug,
} = Astro.props;

const categoriaLabel: Record<string, string> = {
  audio: 'Audio',
  iluminacion: 'Iluminación',
  'audio-video': 'Audio & Video',
  dj: 'DJ',
  efectos: 'Efectos',
};

const zonaLabel: Record<string, string> = {
  cdmx: 'CDMX',
  'estado-de-mexico': 'Edomex',
};

const categoriaBadgeClass: Record<string, string> = {
  audio: 'badge--audio',
  iluminacion: 'badge--iluminacion',
  'audio-video': 'badge--av',
  dj: 'badge--dj',
  efectos: 'badge--efectos',
};

const stars = rating ? Math.round(rating) : 0;
const fullStars = Math.floor(rating ?? 0);
const hasHalf = (rating ?? 0) - fullStars >= 0.5;
---

<article class="dc">
  <div class="dc__header">
    <span class={`dc__badge ${categoriaBadgeClass[categoria] ?? ''}`}>
      {categoriaLabel[categoria] ?? categoria}
    </span>
    <span class="dc__zona">{zonaLabel[zona] ?? zona}</span>
  </div>

  <h3 class="dc__name">{nombre}</h3>

  {alcaldia_municipio && (
    <p class="dc__location">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      {alcaldia_municipio}
    </p>
  )}

  {rating !== undefined && (
    <div class="dc__rating">
      <span class="dc__stars" aria-label={`${rating} estrellas`}>
        {Array.from({ length: 5 }, (_, i) => (
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            aria-hidden="true"
            class={i < fullStars ? 'star star--full' : (i === fullStars && hasHalf ? 'star star--half' : 'star star--empty')}
          >
            <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" fill="currentColor" stroke="currentColor" stroke-width="1"/>
          </svg>
        ))}
      </span>
      <span class="dc__rating-val">{rating.toFixed(1)}</span>
      {resenas !== undefined && (
        <span class="dc__resenas">({resenas.toLocaleString('es-MX')} reseñas)</span>
      )}
    </div>
  )}

  {telefono && (
    <a href={`tel:${telefono.replace(/\s/g, '')}`} class="dc__phone">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.13 12.72 19.79 19.79 0 012.06 4.11 2 2 0 014 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      {telefono}
    </a>
  )}

  <a href={`/directorio/${slug}/`} class="dc__btn">Ver detalles →</a>
</article>

<style>
  .dc {
    background: #fff;
    border: 1px solid var(--c-border, #E7E0D8);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .dc__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .dc__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.625rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .badge--audio     { background: #EEF2FF; color: #3730A3; }
  .badge--iluminacion { background: #FEF9C3; color: #854D0E; }
  .badge--av        { background: #F0FDF4; color: #166534; }
  .badge--dj        { background: #FDF4FF; color: #7E22CE; }
  .badge--efectos   { background: #FFF7ED; color: #9A3412; }

  .dc__zona {
    font-size: 0.75rem;
    color: var(--c-text-muted, #78716C);
    background: var(--c-bg-alt, #F7F4F0);
    padding: 0.2rem 0.5rem;
    border-radius: 20px;
  }

  .dc__name {
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--c-text, #1C1917);
    margin: 0;
    line-height: 1.3;
  }

  .dc__location {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--c-text-muted, #78716C);
    margin: 0;
  }

  .dc__location svg {
    flex-shrink: 0;
    color: var(--c-primary, #2C5530);
  }

  .dc__rating {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .dc__stars {
    display: flex;
    gap: 1px;
  }

  .star--full   { color: #F59E0B; }
  .star--half   { color: #F59E0B; opacity: 0.6; }
  .star--empty  { color: #D1D5DB; }

  .dc__rating-val {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--c-text, #1C1917);
  }

  .dc__resenas {
    font-size: 0.8125rem;
    color: var(--c-text-muted, #78716C);
  }

  .dc__phone {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--c-primary, #2C5530);
    text-decoration: none;
    font-weight: 600;
  }

  .dc__phone:hover {
    text-decoration: underline;
  }

  .dc__btn {
    display: block;
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--color-primary, #2C5530);
    color: #fff;
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    border-radius: 8px;
    margin-top: auto;
  }

  .dc__btn:hover {
    background: var(--color-primary-dark, #1E3D22);
  }

  @media (max-width: 480px) {
    .dc {
      padding: 1.25rem;
    }
    .dc__name {
      font-size: 1rem;
    }
  }
</style>
