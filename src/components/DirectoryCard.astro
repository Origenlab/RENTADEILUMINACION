---
/**
 * DirectoryCard — Origenlab Standard (REDEIL Directorio)
 * ───────────────────────────────────────────────────────
 * Card para empresas del directorio con imagen, rating, categoría.
 * Diseño consistente con ServiceCard. Sin animaciones. CSS scoped.
 */

interface Props {
  nombre: string;
  categoria: string;
  zona: string;
  alcaldia_municipio: string;
  telefono?: string;
  rating?: number;
  resenas?: number;
  slug: string;
}

const {
  nombre,
  categoria,
  zona,
  alcaldia_municipio,
  telefono,
  rating,
  resenas,
  slug,
} = Astro.props;

const categoriaLabel: Record<string, string> = {
  audio: 'Audio Profesional',
  iluminacion: 'Iluminación',
  'audio-video': 'Audio & Video',
  dj: 'Equipo DJ',
  efectos: 'Efectos',
};

const zonaLabel: Record<string, string> = {
  cdmx: 'CDMX',
  'estado-de-mexico': 'Edomex',
};

// Generated images per category (ImageFX / Imagen 4)
const categoriaImg: Record<string, string> = {
  audio: '/img/directorio/directorio-tienda-audio-01.avif',
  iluminacion: '/img/directorio/directorio-tienda-iluminacion-01.avif',
  'audio-video': '/img/directorio/directorio-audio-video-01.avif',
  dj: '/img/directorio/directorio-equipo-dj-01.avif',
  efectos: '/img/directorio/directorio-efectos-especiales-01.avif',
};

const image = categoriaImg[categoria] || categoriaImg.audio;
const fullStars = Math.floor(rating ?? 0);
const hasHalf = (rating ?? 0) - fullStars >= 0.3;
---

<article class="dc">
  <a href={`/directorio/${slug}/`} class="dc__img-link">
    <div class="dc__img">
      <img src={image} alt={`${nombre} — ${categoriaLabel[categoria] || categoria}`} loading="lazy" width="400" height="225" />
      <span class="dc__cat">{categoriaLabel[categoria] || categoria}</span>
      <span class="dc__zona">{zonaLabel[zona] || zona}</span>
    </div>
  </a>
  <div class="dc__body">
    <h3 class="dc__title">
      <a href={`/directorio/${slug}/`}>{nombre}</a>
    </h3>
    {rating && (
      <div class="dc__rating">
        <span class="dc__stars">
          {Array.from({length: 5}, (_, i) => (
            <svg class={`dc__star ${i < fullStars ? 'dc__star--full' : (i === fullStars && hasHalf) ? 'dc__star--half' : ''}`} width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </span>
        <span class="dc__rating-text">{rating} ({resenas} reseñas)</span>
      </div>
    )}
    <p class="dc__location">📍 {alcaldia_municipio}, {zonaLabel[zona] || zona}</p>
    {telefono && (
      <p class="dc__phone">
        <a href={`tel:+52${telefono.replace(/\s/g, '')}`}>📞 {telefono}</a>
      </p>
    )}
    <a href={`/directorio/${slug}/`} class="dc__btn">Ver detalles →</a>
  </div>
</article>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
