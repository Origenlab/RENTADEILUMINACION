---
/**
 * Breadcrumbs Component — REDEIL
 * Fondo oscuro contrastante con acento naranja.
 */
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const schemaItems = items.map((item, index) => ({
  "@type": "ListItem",
  "position": index + 1,
  "name": item.label,
  ...(item.href ? { "item": `https://rentadeiluminacion.com${item.href}` } : {})
}));

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": schemaItems
});
---

<nav class="crumbs" aria-label="Breadcrumb">
  <div class="crumbs__inner">
    <ol class="crumbs__list">
      {items.map((item, index) => (
        <li class="crumbs__item">
          {index === 0 && (
            <svg class="crumbs__home-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
              <polyline points="9 21 9 12 15 12 15 21"/>
            </svg>
          )}
          {item.href && index < items.length - 1 ? (
            <a href={item.href} class="crumbs__link">{item.label}</a>
          ) : (
            <span class="crumbs__current" aria-current="page">{item.label}</span>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>

<script type="application/ld+json" set:html={breadcrumbSchema} />

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
