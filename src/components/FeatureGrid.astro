---
/**
 * FeatureGrid — OrigenLab Standard (REDEIL)
 * Grid de features con ícono, título y descripción.
 * CSS 100% scoped.
 */
interface Feature {
  title: string;
  description: string;
}

interface Props {
  features: Feature[];
  columns?: 2 | 3;
}

const { features, columns = 3 } = Astro.props;
---

<div class="fg" style={`--fg-cols: ${columns}`}>
  {features.map((f) => (
    <div class="fg__item">
      <span class="fg__icon">✓</span>
      <div>
        <h4 class="fg__title">{f.title}</h4>
        <p class="fg__desc">{f.description}</p>
      </div>
    </div>
  ))}
</div>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
