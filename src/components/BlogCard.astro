---
/**
 * BlogCard — REDEIL
 * Card para el listado de artículos del blog.
 * Sin fechas. Sin animaciones.
 */
interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  category: string;
  slug: string;
}

const { title, description, image, imageAlt, category, slug } = Astro.props;
---

<article class="bc">
  <a href={`/blog/${slug}/`} class="bc__img-link">
    <div class="bc__img">
      <img src={image} alt={imageAlt} loading="lazy" width="600" height="338" />
      <span class="bc__cat">{category}</span>
    </div>
  </a>
  <div class="bc__body">
    <h2 class="bc__title">
      <a href={`/blog/${slug}/`}>{title}</a>
    </h2>
    <p class="bc__desc">{description}</p>
    <a href={`/blog/${slug}/`} class="bc__link">
      Leer artículo <span aria-hidden="true">→</span>
    </a>
  </div>
</article>

<style>
  .bc {
    background: #fff;
    border: 1px solid var(--color-gray-200, #e9ecef);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .bc__img-link {
    display: block;
    position: relative;
  }

  .bc__img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
  }

  .bc__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .bc__cat {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--color-primary, #E05800);
    color: #fff;
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }

  .bc__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .bc__title {
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-secondary, #1C2B4A);
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .bc__title a {
    text-decoration: none;
    color: inherit;
  }

  .bc__title a:hover {
    color: var(--color-primary, #E05800);
  }

  .bc__desc {
    font-size: 0.9rem;
    color: var(--color-gray-600, #6c757d);
    line-height: 1.7;
    flex: 1;
    margin: 0 0 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bc__link {
    font-family: var(--font-primary, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary, #E05800);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .bc__link:hover {
    color: #c44d00;
  }
</style>
