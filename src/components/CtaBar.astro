---
/**
 * CtaBar Component — REDEIL
 * Barra de navegación compacta debajo del Hero.
 */
interface CtaItem {
  label: string;
  href: string;
  icon?: string;
  description?: string;
}

interface Props {
  headline?: string;
  items: CtaItem[];
}

const { items } = Astro.props;

const descriptions: Record<string, string> = {
  iluminacion: "Guirnaldas · Cabezas móviles · Gobos · Sky trackers",
  sonido: "Sistemas JBL · QSC · DJ profesional · Micrófonos Shure",
  efectos: "Humo bajo · Confeti · Bengalas frías · Efectos de escenario",
  cotizar: "Respuesta en menos de 15 min por WhatsApp",
};
---

<section class="ctabar" aria-label="Categorías de servicio">
  <div class="ctabar__grid">
    {items.map((item) => {
      const isCta = item.icon === 'cotizar';
      const desc = item.description ?? (item.icon ? descriptions[item.icon] : '');

      return (
        <a
          href={item.href}
          class={`ctabar__card${isCta ? ' ctabar__card--cta' : ''}`}
          aria-label={item.label}
        >
          <div class="ctabar__text">
            <span class="ctabar__label">{item.label}</span>
            <span class="ctabar__desc">{desc}</span>
          </div>
          <svg class="ctabar__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
          <span class="ctabar__line" aria-hidden="true"></span>
        </a>
      );
    })}
  </div>
</section>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
