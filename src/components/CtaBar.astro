---
/**
 * CtaBar Component — OrigenLab Standard
 * ─────────────────────────────────────
 * Barra de navegación por categorías debajo del Hero.
 * Objetivo: guiar al usuario a explorar antes de contactar.
 * Sin animaciones. Código limpio.
 */
interface CtaItem {
  label: string;
  href: string;
  icon?: string;
}

interface Props {
  headline?: string;
  items: CtaItem[];
}

const {
  headline = "¿Qué tipo de evento estás planeando?",
  items,
} = Astro.props;

const icons: Record<string, string> = {
  iluminacion: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6M10 22h4M12 2a7 7 0 00-4 12.7V17h8v-2.3A7 7 0 0012 2z"/></svg>',
  sonido: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>',
  efectos: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>',
  cotizar: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>',
};
---

<section class="ctabar" aria-label="Tipos de evento">
  <div class="container">
    <p class="ctabar__headline">{headline}</p>
    <div class="ctabar__grid">
      {items.map((item) => (
        <a href={item.href} class="ctabar__item">
          {item.icon && icons[item.icon] && (
            <span class="ctabar__icon" set:html={icons[item.icon]} />
          )}
          <span class="ctabar__label">{item.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ctabar {
    background: #1a1a2e;
    padding: 2rem 0;
  }

  .ctabar__headline {
    text-align: center;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 1.25rem;
    letter-spacing: 0.01em;
  }

  .ctabar__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .ctabar__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-md, 12px);
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 600;
    text-align: center;
    transition: background 0.2s var(--ease, ease), border-color 0.2s var(--ease, ease);
  }

  .ctabar__item:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .ctabar__icon {
    display: flex;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .ctabar__label {
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .ctabar__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 400px) {
    .ctabar__grid {
      grid-template-columns: 1fr;
    }

    .ctabar__item {
      padding: 0.75rem 1rem;
    }
  }
</style>
