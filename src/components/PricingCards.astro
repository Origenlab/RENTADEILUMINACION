---
/**
 * PricingCards — OrigenLab Standard (REDEIL)
 * ──────────────────────────────────────────
 * Grid de paquetes/pricing con highlight en el recomendado.
 * CSS 100% scoped. Sin animaciones.
 */
interface Feature {
  text: string;
  included: boolean;
}

interface Package {
  name: string;
  badge?: string;
  highlight?: boolean;
  price: string;
  priceNote?: string;
  description: string;
  features: Feature[];
  ctaLabel?: string;
  ctaHref: string;
}

interface Props {
  packages: Package[];
}

const { packages } = Astro.props;
---

<div class="pk__grid">
  {packages.map((pkg) => (
    <div class:list={['pk__card', { 'pk__card--highlight': pkg.highlight }]}>
      {pkg.badge && <span class="pk__badge">{pkg.badge}</span>}
      <h3 class="pk__name">{pkg.name}</h3>
      <div class="pk__price">
        <span class="pk__price-value">{pkg.price}</span>
        {pkg.priceNote && <span class="pk__price-note">{pkg.priceNote}</span>}
      </div>
      <p class="pk__desc">{pkg.description}</p>
      <ul class="pk__features">
        {pkg.features.map((f) => (
          <li class:list={[{ 'pk__feat--no': !f.included }]}>
            <span class="pk__feat-icon">{f.included ? '✓' : '—'}</span>
            {f.text}
          </li>
        ))}
      </ul>
      <button type="button" data-open-chat class:list={['pk__cta', { 'pk__cta--highlight': pkg.highlight }]}>
        {pkg.ctaLabel || 'Cotizar este paquete'}
      </button>
    </div>
  ))}
</div>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
