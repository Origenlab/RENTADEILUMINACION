---
import NavRapida from './NavRapida.astro';

interface Props {
  title: string;
  subtitle: string;
  cotizarHref?: string;
  whatsappText?: string;
  introParagraph1: string;
  introParagraph2: string;
  extraClass?: string;
  badge?: string;
  stats?: { value: string; label: string }[];
  hideCtas?: boolean;
}

const {
  title,
  subtitle,
  cotizarHref = "/contacto/",
  whatsappText = "Hola,%20quiero%20cotizar%20iluminacion%20para%20mi%20evento",
  introParagraph1,
  introParagraph2,
  extraClass = "",
  badge,
  stats,
  hideCtas = false,
} = Astro.props;

const defaultStats = [
  { value: "+500", label: "Eventos realizados" },
  { value: "10+", label: "Años de experiencia" },
  { value: "CDMX", label: "Y zona metropolitana" },
];

const displayStats = stats ?? defaultStats;
---

<section class={`hero hero-two-columns ${extraClass}`} aria-labelledby="hero-title">

  <!-- Fondo con gradiente sutil -->
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__bg-glow"></div>
  </div>

  <div class="container">
    <div class="hero__grid">

      <!-- COLUMNA IZQUIERDA -->
      <div class="hero__left">

        <!-- Overline -->
        <div class="hero__overline" aria-hidden="true">
          <span class="hero__overline-dot"></span>
          <span>Iluminación &amp; Sonido Profesional · CDMX</span>
        </div>

        <!-- H1 con acento -->
        <h1 id="hero-title" class="hero__h1">
          {title.includes("Iluminación") ? (
            <>
              <span class="hero__h1-top">Renta de</span>
              <span class="hero__h1-accent">Iluminación</span>
              <span class="hero__h1-bottom">y Sonido para Eventos en CDMX</span>
            </>
          ) : (
            title
          )}
        </h1>

        <!-- Subtítulo -->
        <p class="hero__subtitle">{subtitle}</p>


        <!-- Stats -->
        <div class="hero__stats">
          {displayStats.map((s) => (
            <div class="hero__stat">
              <span class="hero__stat-value">{s.value}</span>
              <span class="hero__stat-label">{s.label}</span>
            </div>
          ))}
        </div>

      </div>

      <!-- COLUMNA DERECHA -->
      <div class="hero__right">
        <div class="hero__editorial">
          <div class="hero__editorial-bar" aria-hidden="true"></div>
          <p class="hero__para hero__para--lead" set:html={introParagraph1} />
          <p class="hero__para" set:html={introParagraph2} />

          <!-- Marca de confianza -->
          <div class="hero__brands" aria-label="Marcas de equipo profesional">
            <span class="hero__brands-label">Equipo profesional</span>
            <div class="hero__brands-list">
              {["Martin", "Chauvet", "JBL", "QSC", "Shure"].map((b) => (
                <span class="hero__brand-tag">{b}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
<NavRapida />

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
