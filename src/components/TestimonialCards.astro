---
/**
 * TestimonialCards — REDEIL v2
 * Cards de reseñas estilo empresa: avatar, company badge, estrellas, texto, rol.
 * Schema Review en cada card. CSS 100% scoped.
 */
interface Testimonial {
  name: string;
  text: string;
  rating: number;
  event?: string;
  avatar?: string;
  company?: string;
  companyUrl?: string;
  role?: string;
  date?: string;
}

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
---

<div class="tc__grid">
  {testimonials.map((t) => (
    <article class="tc__card" itemscope itemtype="https://schema.org/Review">
      <!-- Quote decorativa -->
      <span class="tc__quote-icon" aria-hidden="true">"</span>

      <!-- Texto primero — visual más limpio -->
      <p class="tc__text" itemprop="reviewBody">{t.text}</p>

      <!-- Estrellas -->
      <div class="tc__stars" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
        <meta itemprop="ratingValue" content={String(t.rating)} />
        <meta itemprop="bestRating" content="5" />
        {Array.from({ length: t.rating }).map(() => (
          <span class="tc__star" aria-hidden="true">★</span>
        ))}
      </div>

      <!-- Divider -->
      <hr class="tc__divider" />

      <!-- Footer: avatar + info -->
      <div class="tc__footer">
        <div class="tc__avatar-wrap">
          {t.avatar ? (
            <img src={t.avatar} alt={`Foto de ${t.name}`} class="tc__avatar" width="44" height="44" loading="lazy" />
          ) : (
            <div class="tc__avatar-initials">{t.name.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}</div>
          )}
        </div>
        <div class="tc__meta">
          <span class="tc__name" itemprop="author">{t.name}</span>
          {t.role && <span class="tc__role">{t.role}</span>}
          {t.company && (
            <span class="tc__company">
              <svg class="tc__company-icon" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                <rect x="1" y="3" width="8" height="6" rx="1" stroke="currentColor" stroke-width="1.2"/>
                <path d="M3 3V2a2 2 0 014 0v1" stroke="currentColor" stroke-width="1.2"/>
              </svg>
              {t.companyUrl ? (
                <a href={t.companyUrl} target="_blank" rel="noopener noreferrer" class="tc__company-link">{t.company}</a>
              ) : (
                t.company
              )}
            </span>
          )}
        </div>
        {t.event && (
          <span class="tc__badge">{t.event}</span>
        )}
      </div>

    </article>
  ))}
</div>

<!-- Estilos en /css/style.css (global) — evita FOUC en dev mode -->
