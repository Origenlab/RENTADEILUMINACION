---
/**
 * Footer — REDEIL Premium v3
 * Basado en el sistema de diseño: --color-primary #1a1a2e · --color-accent #ff5722
 * Diseño de agencia de alta gama: trust strip · nav completa · bottom bar sólido.
 */
const year = new Date().getFullYear();
---

<footer class="ft">

  <!-- ═══ TRUST STRIP ═══ -->
